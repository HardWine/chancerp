stock Iter_Func@Bits(start, Bit:data[], size = sizeof (data))
{
	
	new
		cur,
		i = ((_:++start)>>>(5));
	if (i == size)
	{
		return -1;
	}

	if ((cur = _:(data[i] & ~((Bit:(1<<((_:start)&cellbits-1))) - Bit:1))))
	{
		

		return Cell_GetLowestBit(cur) + (i << (5));
	}
	while (++i != size)
	{
		if ((cur = _:data[i]))
		{
			return Cell_GetLowestBit(cur) + (i << (5));
		}
	}
	return -1;
}

