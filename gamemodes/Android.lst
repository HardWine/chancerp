public OnPlayerEnterVehicle(playerid, vehicleid, ispassenger)
{	
	SetPVarInt(playerid, "enter_vehicleid", vehicleid);

	if(ispassenger == 0) {
		if(GetVehicleDriver(vehicleid) != (0xFFFF)) {
			ClearPlayerAnimation(playerid);
			return 0;
		}
	}
	return 1;
}

public OnPlayerExitVehicle(playerid, vehicleid)
{
	if(GetVehicleModel(vehicleid) == 448) SetPVarInt(playerid, "pizza_ss", gettime() + 15);
	return 1;
}

public OnPlayerStateChange(playerid, newstate, oldstate)
{
	if(!ac_1{playerid} && newstate == (1) && oldstate == (0)) return dc_kickfix__Kick(playerid); 

	CallLocalFunction("Salon_OnPlayerStateChange", "iii", playerid, newstate, oldstate);
	for(new  f=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( f=Iterator@Player [_: f])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);)
	{
		if(spectating[f] == playerid)
		{
			if(!IsPlayerConnected(spectating[f])) pc_cmd_reoff(playerid,"\0");

			UpdateSpectatingStatus(f, playerid);
		}
	}
	new vehicleid = GetPlayerVehicleID(playerid);
	new modelid = GetVehicleModel(vehicleid);
	if(newstate == (1) && oldstate == (2))
	{

		new return_value = CallLocalFunction("Vehicle_OnPlayerExitVehicle", "ii", playerid, gonecar[playerid]);
		if(return_value == 0) {
			gonecar[playerid] = (0xFFFF);
		}
		if(Platform[playerid] == 1) {
			hide_speedo(playerid);
		}
	}
	if(newstate == (2)) {

		if(GetPlayerVehicleSeat(playerid) == 0) {
			if(IsABMX(GetVehicleModel(vehicleid)) == 0) {
				if(get_radar(playerid)) {
					turnon_detector(playerid);
				}
				if(IsAPlane(GetVehicleModel(GetPlayerVehicleID(playerid))) && GetPVarInt(playerid, "mobile") == 0) {
					SendClientMessage(playerid, -1, """{6de64e}""×ňîáű çŕâĺńňč äâčăŕňĺëü ââĺäčňĺ ęîěŕíäó: ""{FFFFFF}""/en");
				} else {
					SendClientMessage(playerid, -1, """{6de64e}""×ňîáű çŕâĺńňč äâčăŕňĺëü íŕćěčňĺ ęëŕâčřó ""{FFFFFF}""'2'""{6de64e}"" čëč ââĺäčňĺ ęîěŕíäó: ""{FFFFFF}""/en");
					if(PlayerInfo[playerid][pSpeedLimit] == 0) SendClientMessage(playerid, -1, """{6de64e}""Čńďîëüçóéňĺ äë˙ âęëţ÷ĺíč˙ îăđŕíč÷čňĺë˙ ńęîđîńňč ęîěŕíäó: ""{FFFFFF}""/sl [ęě/÷]");
					if(PlayerInfo[playerid][pSpeedLimit] != 0) SendClientMessage(playerid, -1, """{6de64e}""×ňîáű íŕńňđîčňü îăđŕíč÷čňĺëü ńęîđîńňč čńďîëüçóéňĺ ęîěŕíäó: ""{FFFFFF}""/sl [ęě/÷] (/sl 0 - äë˙ âűęëţ÷ĺíč˙ ëčěčňŕ ńęîđîńňč)");
				}
			} else {
				new engine, lights, alarm, doors, bonnet, boot, objective;
				GetVehicleParamsEx(vehicleid, engine, lights, alarm, doors, bonnet, boot, objective);
				SetVehicleParamsEx(vehicleid, 1, 0, alarm, 0, bonnet, boot, objective);
			}
		}

		if(Platform[playerid] == 1) {
			show_speedo(playerid, modelid);
			format(big_string, sizeof(big_string),"%s",GetVehicleText(modelid));
			PlayerTextDrawSetString(playerid,speedo_TD[playerid][3], big_string);
		}
		hide_logo(playerid);
		Timer_Speed[playerid] = KillTimer(Timer_Speed[playerid]);
		Timer_Speed[playerid] = SetTimerEx("UpdateSpeed",500,false,"d",playerid);
		if(IsAirVehicle(vehicleid) == 1) {
				if(PlayerInfo[playerid][pLicenseAir] == 0 && GetPVarInt(playerid,"GetLicAir") != 1)
					{
						SendClientMessage(playerid, -1, """{ff353c}""Ó Âŕń íĺň ëčöĺíçčč ďčëîňŕ");
						SendClientMessage(playerid, -1, """{ff353c}""Ďîëó÷čňü ëčöĺíçčţ ěîćíî â Ŕâňîřęîëĺ Ńŕí-Ôčĺđđî");
						RemovePlayerFromVehicle(playerid);
						return 1;
					}
		}

		if(gonecar[playerid] != (0xFFFF)) {
			if(gonecar[playerid] != vehicleid) return RemovePlayerFromVehicle(playerid);
		}

		new
			return_value = CallLocalFunction("Vehicle_OnPlayerEnterVehicle", "ii", playerid, vehicleid);

		if(return_value == 0) {
			RemovePlayerFromVehicle(playerid);
			return 1;
		} else if(return_value == 1) {
			gonecar[playerid] = vehicleid;
		}

		CallLocalFunction("OnPlayerEnteredVehicle", "ii", playerid, vehicleid);

		if(return_value != 5) {
			if(PlayerInfo[playerid][pLicense] == 0) {
				if(modelid != 481 && modelid != 510 && modelid != 509 && modelid != 462) {
					SendClientMessage(playerid, -1, """{ff353c}""Ó Âŕń íĺň âîäčňĺëüńęčő ďđŕâ");
					SendClientMessage(playerid, -1, """{ff353c}""Ďîëó÷čňü ëčöĺíçčţ ěîćíî â Ŕâňîřęîëĺ Ńŕí-Ôčĺđđî");
					RemovePlayerFromVehicle(playerid);
					return 1;
				}
			}
		}

		if(vehicleid >= Ambulance[0] && vehicleid <= Ambulance[14])
		{
			if(GetPVarInt(playerid, "Paramedic") != 1) return RemovePlayerFromVehicle(playerid);
		}
		if(vehicleid >= HARVEST_CAR[0] && vehicleid <= HARVEST_CAR[2])
		{
			if(gone[playerid] != -1) return RemovePlayerFromVehicle(playerid);
			if(GetPVarInt(playerid, "tempjob") != 1) return RemovePlayerFromVehicle(playerid);
			if(PlayerInfo[playerid][pFarmSkill] < 200) return RemovePlayerFromVehicle(playerid),SendClientMessage(playerid, -1, """{ff353c}""Äîńňóďíî ń 200 íŕâűęŕ ôĺđěĺđŕ");
			if(vehicleid == HARVEST_CAR[0] && Harvest[0] < 200) return SetVehicleToRespawn(vehicleid),SendClientMessage(playerid, -1, """{ff353c}""Ôóđăîí íĺ çŕăđóćĺí äî ęîíöŕ");
			if(vehicleid == HARVEST_CAR[1] && Harvest[1] < 200) return SetVehicleToRespawn(vehicleid),SendClientMessage(playerid, -1, """{ff353c}""Ôóđăîí íĺ çŕăđóćĺí äî ęîíöŕ");
			if(vehicleid == HARVEST_CAR[2] && Harvest[2] < 200) return SetVehicleToRespawn(vehicleid),SendClientMessage(playerid, -1, """{ff353c}""Ôóđăîí íĺ çŕăđóćĺí äî ęîíöŕ");
			UnloadFarm[playerid] = 1;
			Route2[playerid] = -1;
			RouteTrash[playerid] = -1;
			RouteLSPD[playerid] = -1;
			RouteFarm[playerid] = -1;
			Route3[playerid] = -1;
			ArmyMission[playerid] = -1;
			Route[playerid] = -1;
			RouteLic[playerid] = -1;
			RouteLicAir[playerid] = -1;
			RouteAir[playerid] = -1;
			RouteAir2[playerid] = -1;
			SetPlayerRaceCheckpoint(playerid, 1, 2178.9387, -1660.8270, 14.9413, 2178.9387, -1660.8270, 14.9413, 4); 
			SendClientMessage(playerid, -1, """{6de64e}""Âű îňďđŕâčëčńü íŕ ďđîäŕćó ęóńňîâ. Äîńňŕâüňĺ ăđóç");
			return 1;
		}
		if(TCar[playerid] != 0)
		{
			if(GetVehicleModel(vehicleid) == TCar[playerid])
			{
				if(ThefStatus[playerid] == 2) return SendClientMessage(playerid, -1, """{4eb9e6}""Äîńňŕâüňĺ ŕâňîěîáčëü â óęŕçŕííîĺ íŕ ęŕđňĺ ěĺńňî");
				ThefStatus[playerid] = 2;
				SendClientMessage(playerid, -1, """{4eb9e6}""Äîńňŕâüňĺ ŕâňîěîáčëü â óęŕçŕííîĺ íŕ ęŕđňĺ ěĺńňî");
				AddNewSteelCar(vehicleid);
				if(Player__SteelCar[playerid] != (-1)) {
					DestroyDynamicCP(Player__SteelCar[playerid]);
				}
				new rand = random((3));
				Player__SteelCar[playerid] = CreateDynamicCP(steel_car_coord[rand][0], steel_car_coord[rand][1], steel_car_coord[rand][2], 8.00, -1, -1, playerid, 8000.000, .priority = 1);

				GangZoneDestroy(TheftZone[playerid]);
				PlayerInfo[playerid][pWanted] += 1200;
				SetPlayerWanted(playerid, PlayerInfo[playerid][pWanted]);

				new model = GetVehicleModel(TCar[playerid]);
				format(small_string, sizeof(small_string), "~r~%s theft %s",PlayerInfo[playerid][pName], GetVehicleText(model));
				SendPoliceGameText(small_string);
				return 1;
			}
		}
		if(caridhouse[playerid] != (0xFFFF)) {
			if(vehicleid == caridhouse[playerid]) {
				if(modelid != 481 && modelid != 510 && modelid != 509) {
				if(PlayerInfo[playerid][pSelectedSlot] == 1) {
					format(small_string, sizeof(small_string), """{4eb9e6}""Ďđîáĺă âŕřĺăî ňđŕíńďîđňŕ: {FFFFFF}%dęě.", PlayerInfo[playerid][pMileage]/1000);
					SendClientMessage(playerid, -1, small_string);
				}
				else {
					format(small_string, sizeof(small_string), """{4eb9e6}""Ďđîáĺă âŕřĺăî ňđŕíńďîđňŕ: {FFFFFF}%dęě.", PlayerInfo[playerid][pMileage2]/1000);
					SendClientMessage(playerid, -1, small_string);					
				}
				}
				return 1;
			}
		}
		if(IsABike(vehicleid)) {
			for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i=Iterator@Player [_: i])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);) {
				if(caridhouse[i] == (0xFFFF)) {
					continue;
				}
				if(vehicleid == caridhouse[i]) {
					if(i != playerid) {
						format(small_string, sizeof(small_string), """{ff353c}""Âëŕäĺëĺö âĺëî/ěîňî-ňđŕíńďîđňŕ: %s. Ó Âŕń íĺň ęëţ÷ĺé", PlayerInfo[i][pName]);
						SendClientMessage(playerid, -1, small_string);		
						RemovePlayerFromVehicle(playerid);
					}
				}
			}
		}
	}
	return 0;
}

stock PlayerSpeed(playerid)
{
        if(playerid != (0xFFFF))
        {
                new Float:Pos[3],Float:PS;
                GetPlayerVelocity(playerid, Pos[0], Pos[1], Pos[2]);
                PS = floatsqroot(Pos[0]*Pos[0] + Pos[1]*Pos[1] + Pos[2]*Pos[2])*200;
                return floatround(PS,floatround_round);
        }
        return 0;
} 

