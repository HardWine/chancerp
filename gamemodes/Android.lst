		SendClientMessage(playerid, -1, !"5 óđîâĺíü: /auninvite /cc /skin /unban /gzcolor /whois");
	}
	return 1;
}
forward pc_cmd_getban(playerid, params[]); public pc_cmd_getban(playerid, params[])
{
	if(Player__AdminLevel{playerid} < 4) {
		return false;
	}

	new
		target_name[24 + 1];

	if(sscanf(params, "s[24]", target_name)) {
		SendClientMessage(playerid, -1, !"Čńďîëüçóéňĺ: /getban [Íčę čăđîęŕ]");
		return false;
	}

	new
		target_accID = Player__GetPlayerAccID(target_name);

	if(target_accID == (-1)) {
		format(small_string, sizeof(small_string), "Óęŕçŕííűé Âŕěč ŕęęŕóíň ""{FFAF00}""%s""{FFFFFF}"" íĺ ńóůĺńňâóĺň", target_name);
		SendClientMessage(playerid, -1, small_string);
		return false;
	}

	mysql_format(database, big_string, sizeof(big_string),
		"SELECT IFNULL(p.Name, '-') as UnBannedName, b.Reason, b.BanTime, b.UnBanTime FROM player_banned AS b LEFT OUTER JOIN players AS p ON p.ID = b.AdminID WHERE PlayerID = %i ORDER BY b.ID DESC LIMIT 15",
		target_accID
	);
	mysql_query(database, big_string, true);

	new
		rows = cache_get_row_count();

	if(rows == 0) {
		format(small_string, sizeof(small_string), "Óęŕçŕííűé Âŕěč ŕęęŕóíň ""{FFAF00}""%s""{FFFFFF}"" íĺ čěĺĺë áëîęčđîâîę", target_name);
		SendClientMessage(playerid, -1, small_string);
		return false;
	} else {
		new
			bantime[20 + 1],
			unbantime[20 + 1],
			unbanadmin[24 + 1],
			reason[48 + 1];

		if(Platform[playerid] != 0) {
			huge_string = !"Äŕňŕ áëîęčđîâęč\tÄŕňŕ đŕçáëîęčđîâęč\tĎđč÷číŕ\tĐŕçáëîęčđîâŕí\n";
		} else {
		   huge_string = !"""{4eb9e6}""Äŕňŕ áëîęčđîâęč\tÄŕňŕ đŕçáëîęčđîâęč\tĎđč÷číŕ\tĐŕçáëîęčđîâŕí\n\n""{FFFFFF}""";
		}
		for(new i = 0; i < rows; i++) {
			cache_get_field_content(i, "BanTime", bantime);
			cache_get_field_content(i, "UnBanTime", unbantime);
			cache_get_field_content(i, "Reason", reason);
			cache_get_field_content(i, "UnBannedName", unbanadmin);

			format(big_string, sizeof(big_string),
				"%s\t%s\t%s\t%s\n",
					bantime,
					unbantime,
					reason,
					unbanadmin
			);
			strcat(huge_string, big_string);
		}


		if(Platform[playerid] != 0) {
			format(small_string, sizeof(small_string), """{4eb9e6}""Číôîđěŕöč˙ î áëîęčđîâęŕő %s", target_name);
			SPD(playerid, DIALOG_INFO, 5, small_string, huge_string, "Çŕęđűňü", "");
		} else {
			format(small_string, sizeof(small_string), "Číôîđěŕöč˙ î áëîęčđîâęŕő %s", target_name);
			SPD(playerid, DIALOG_INFO, 0, small_string, huge_string, "Çŕęđűňü", "Çŕęđűňü");
		}
	}

	return true;
}

