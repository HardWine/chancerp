forward dre_pay_debt_part(playerid, response, listitem, inputtext[]); public dre_pay_debt_part(playerid, response, listitem, inputtext[]) {

	if(!response) {
		return Dialog_Show(playerid, #pay_debt);	
	}

	new debt = strval(inputtext);
	if(debt > PlayerInfo[playerid][pDebt] || debt < 1) return 1;
	if(CheckCash(playerid, debt) == false) return 1;
	RemovePlayerEXP(playerid, debt, "Îďëŕňŕ ÷ŕńňč řňđŕôîâ çŕ ńęîđîńňü");
	PlayerInfo[playerid][pDebt] -= debt;
	SetPlayerInt(playerid, "Debt", PlayerInfo[playerid][pDebt]);
	SendClientMessage(playerid, -1, """{6de64e}""Âű îďëŕňčëč ÷ŕńňü ńâîčő řňđŕôîâ");
	Dialog_Show(playerid, #pay_debt);
	return 1;
}

