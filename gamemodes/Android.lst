public OnJITCompile()
{
	state _ALS : _ALS_go;
	state _script_init_fix_state : false;


	if (YSI_g_sCodeJITing)
		return 0;
	
	YSI_g_sCodeJITing = true;
	ScriptInit_CallOnCodeInit(true);
	new ret = ScriptInit_OnJITCompile();
	if (ret)
		YSI_g_sCodeJITed = true;
	else
		Debug_Print0("\7*** YSI Warning: JIT disabled");
	
	return ret;
}

