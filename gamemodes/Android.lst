stock Porter_OnPlayerEnterDynamicCP(playerid, checkpointid) {
	if(IsPlayerInAnyVehicle(playerid)) {
		return 0;
	}

	if(checkpointid == point_porter)
	{
		if(GetPVarInt(playerid,"DropBox") > gettime()) { 
			GameTextForPlayer(playerid, "~r~WAIT...", 7250, 5);	
			return 1; 
		}


		TogglePlayerDynamicCP(playerid, point_porter, false);
		deliver_goods(playerid);
		Streamer_Update(playerid, (2));
		if(GetPVarInt(playerid, "Worker") == 0) {
		SetPVarInt(playerid,"Worker", 1);
		SendClientMessage(playerid, -1, """{FFAF00}""Âű âç˙ëč ăđóç, äîńňŕâüňĺ ĺăî â óęŕçŕííîĺ ěĺńňî");
		}



    	SetPlayerSpecialAction(playerid, 25);
    	weight[playerid] = RandomEx(1, 10);

    	format(pointer_string, sizeof(pointer_string), "%d ~g~KG", weight[playerid]);
		GameTextForPlayer(playerid, pointer_string, 2000, 5);


		SetPVarInt(playerid,"TakenBox",gettime() + 3);

		SetPlayerAttachedObject(playerid, 0, 1271, 17, -0.030999, 0.492000, 0.000000, 0.000000, 0.000000, 0.000000, 0.503000, 0.569000, 1.000000);

		switch(random(5)){
			case 0: {		
			switch(random(5)){		
				case 0: format(pointer_string, 100, "- %s[%d]: Ôóő, óňîěčëń˙ ˙", PlayerInfo[playerid][pName], playerid);
				case 1: format(pointer_string, 100, "- %s[%d]: Ň˙ćĺëűé, ńóęŕ...", PlayerInfo[playerid][pName], playerid);
				case 2: format(pointer_string, 100, "- %s[%d]: Ňŕě ÷ňî, ęčđďč÷č", PlayerInfo[playerid][pName], playerid);
				case 3: format(pointer_string, 100, "- %s[%d]: Őóő, ďîňŕůčëč", PlayerInfo[playerid][pName], playerid);
				case 4: format(pointer_string, 100, "- %s[%d]: Ň˙ćĺëűé ňđóä", PlayerInfo[playerid][pName], playerid);
			}
			ProxDetector(playerid, (20.00), 0xE6E6E6E6, pointer_string);
			}
			case 1: return 1;
			case 2: return 1;
			case 3: return 1;
			case 4: return 1;
		}
		return 1;						
    }
    if(checkpointid >= unload_porter[0] && checkpointid <= unload_porter[3]) {
		for(new i = 0; i < sizeof(unload_porter); i++) {
			TogglePlayerDynamicCP(playerid, unload_porter[i], false);
		}
		get_goods(playerid);
		Streamer_Update(playerid, (2));
		ClearPlayerAnim(playerid);
		SetPlayerSpecialAction(playerid, 0);
		if(GetPVarInt(playerid,"TakenBox") > gettime()) {
			dc_kickfix__Kick(playerid); 
			return 1;
		}

		if(GetPVarInt(playerid, "Worker") == 1) {
			SetPVarInt(playerid,"Worker", 2);
			SendClientMessage(playerid, -1, """{6de64e}""Âű äîńňŕâčëč ăđóç. Äë˙ ďîëó÷ĺíč˙ çŕđďëŕňű - ďĺđĺîäĺíüňĺńü");
		}			

		AddPlayerAchievement(playerid, E_HEAVY_LOAD);	
		UpdatePlayerProgressQuest(playerid, E_GARBAGE_LOADER);
		value_boxes[playerid]++;

		if (value_boxes[playerid] % 15 == 0) {
			format(pointer_string, sizeof(pointer_string), """{4eb9e6}""Âű ďîëó÷čëč ďđĺěčţ â đŕçěĺđĺ: {FFFFFF}%d EXP", 50);
			SendClientMessage(playerid, -1, pointer_string);

			total_porter_payday[playerid] += 50;
		}

		new sum = weight[playerid]*1;


		total_porter_payday[playerid] += sum;

		format(pointer_string, sizeof(pointer_string), "~g~+%d EXP~n~~b~TOTAL: ~w~%d", sum, total_porter_payday[playerid]);
		GameTextForPlayer(playerid, pointer_string, 5000, 5);			

        if(IsPlayerAttachedObjectSlotUsed(playerid, 0) == 1) {
            RemovePlayerAttachedObject(playerid, 0);
        }

        switch(random(5)){
			case 0: {		
				switch(random(3)){		
					case 0: format(pointer_string, 100, "%s âűňĺđ(ëŕ) ďîň ńî ëáŕ", PlayerInfo[playerid][pName]);
					case 1: format(pointer_string, 100, "%s ň˙ćĺëî âçäîőíóë(ŕ)", PlayerInfo[playerid][pName]);
					case 2: format(pointer_string, 100, "%s îňäűřŕëń˙", PlayerInfo[playerid][pName]);
				}
				ProxDetector(playerid, (20.00), 0xDD90FFFF, pointer_string);
			}
		}
		return 1;
	}
	return 0;
}

stock get_goods(playerid) {
	TogglePlayerDynamicCP(playerid, point_porter, true);
}

stock deliver_goods(playerid) {
	return TogglePlayerDynamicCP(playerid, unload_porter[random(4)], true);
}

stock ClearPlayerAnim(playerid) {
	ApplyAnimation(playerid, !"ped", !"facsurp", 4.0, 1, 0, 0, 1, 1, 1);
	ApplyAnimation(playerid, !"ped", !"facsurp", 4.0, 1, 0, 0, 1, 1, 1);
	SetPlayerSpecialAction(playerid, 0);
	return true;
}

stock BoxFail(playerid) {
	if(GetPVarInt(playerid,"DropBox") > gettime())	{ return false; }
	SetPlayerSpecialAction(playerid, 0);
	SendClientMessage(playerid, -1, """{ff353c}""Âű óđîíčëč ˙ůčę");
	TogglePlayerDynamicCP(playerid, point_porter, false);
	get_goods(playerid);
	Streamer_Update(playerid, (2));
	if(IsPlayerAttachedObjectSlotUsed(playerid, 0) == 1) {
		RemovePlayerAttachedObject(playerid, 0);
	}
	ClearAnimations(playerid);
	ApplyAnimation(playerid,"PED","IDLE_tired",4.1,0,1,1,0,1);

	SetPVarInt(playerid,"DropBox",gettime() + 2);
	SetPVarInt(playerid,"DroppedBox",gettime() + 8);

	switch(random(5)){
		case 0: {		
		switch(random(4)){		
			case 0: format(pointer_string, 100, "- %s[%d]: Ĺáňŕ, ďđ˙ě íŕ íîăó", PlayerInfo[playerid][pName], playerid);
			case 1: format(pointer_string, 100, "- %s[%d]: Ŕő, ÷ňî ćĺ ňŕę ň˙ćĺëî", PlayerInfo[playerid][pName], playerid);
			case 2: format(pointer_string, 100, "- %s[%d]: Ňŕě ęčđďč÷č?", PlayerInfo[playerid][pName], playerid);
			case 3: format(pointer_string, 100, "- %s[%d]: Ńóęŕ!", PlayerInfo[playerid][pName], playerid);
		}
		ProxDetector(playerid, (20.00), 0xE6E6E6E6, pointer_string);
		}
		case 1: return 1;
		case 2: return 1;
		case 3: return 1;
		case 4: return 1;
	}	
	return 1;
}


