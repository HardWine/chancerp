public OnPlayerKeyStateChange(playerid, newkeys, oldkeys)
{
	Porter_OnPlayerKeyStateChange(playerid, newkeys, oldkeys);
	Safe_OnPlayerKeyStateChange(playerid, newkeys, oldkeys);

	if(newkeys & (1024)) {
		if(Player__AdminLevel{playerid} > 0 && GetPlayerState(playerid) == (9)) {
			if(GetPVarInt(playerid, "tdesc") != 1) {
        		SetPVarInt(playerid, "tdesc", 1);
        		return SelectTextDraw(playerid, 0x2A3439FF);
        	} else {
        		DeletePVar(playerid, "tdesc");
        		return CancelSelectTextDraw(playerid);
        	}
		}
	}

	if(newkeys & (512))
	{
		if(IsAPlane(GetVehicleModel(GetPlayerVehicleID(playerid))) && GetPVarInt(playerid, "mobile") == 0) {
			return SendClientMessage(playerid, -1, """{6de64e}""×ňîáű çŕâĺńňč äâčăŕňĺëü ââĺäčňĺ ęîěŕíäó: ""{FFFFFF}""/en");
		}
		engine_car(playerid);
	}

	if(newkeys & (4))
	{
		lamp_car(playerid);
	}


















































	return 1;
}

