publics: LoadProperty()
{
	new rows = cache_get_row_count();
	new time = GetTickCount(), text[190], klass[20];
	if(rows >= 1857) printf("Кол-во домов в базе больше максимального");
	else if(!rows) printf("Домов в базе не найдено");
	else
	{
		TOTALHOUSE = rows;
		for(new he = 1; he <= rows; he++)
		{
			HouseInfo[he][hID] = cache_get_field_content_int(he-1,"ID");
			HouseInfo[he][hEntrancex] = cache_get_field_content_float(he-1,"Entrancex");
			HouseInfo[he][hEntrancey] = cache_get_field_content_float(he-1,"Entrancey");
			HouseInfo[he][hEntrancez] = cache_get_field_content_float(he-1,"Entrancez");

			HouseInfo[he][hCarx] = cache_get_field_content_float(he-1,"Carx");
			HouseInfo[he][hCary] = cache_get_field_content_float(he-1,"Cary");
			HouseInfo[he][hCarz] = cache_get_field_content_float(he-1,"Carz");
			HouseInfo[he][hCarc] = cache_get_field_content_float(he-1,"Carc");

			cache_get_field_content(he-1,"Owner",HouseInfo[he][hOwner]);
			HouseInfo[he][hPrice] = cache_get_field_content_int(he-1,"Price");
			HouseInfo[he][hOwned] = cache_get_field_content_int(he-1,"Owned");
			HouseInfo[he][hDoor] = cache_get_field_content_int(he-1,"Door");
			HouseInfo[he][hTakings] = cache_get_field_content_int(he-1,"Takings");
			HouseInfo[he][hClass] = cache_get_field_content_int(he-1,"Class");

			switch(HouseInfo[he][hClass])
			{
			case 0:
			{
			klass = "Эконом";
			HouseInfo[he][hInt] = 2;
			HouseInfo[he][hExitx] = 1691.0641;
			HouseInfo[he][hExity] = -2665.7048;
			HouseInfo[he][hExitz] = 13.5869;
			}
			case 1:
			{
			klass = "Доступный";
			HouseInfo[he][hInt] = 3;
			HouseInfo[he][hExitx] = 1691.0641;
			HouseInfo[he][hExity] = -2665.7048;
			HouseInfo[he][hExitz] = 13.5869;
			}
			case 2:
			{
			klass = "Средний";
			HouseInfo[he][hInt] = 4;
			HouseInfo[he][hExitx] = 2108.8228;
			HouseInfo[he][hExity] = -2403.1648;
			HouseInfo[he][hExitz] = 13.5847;
			}
			case 3:
			{
			klass = "Элитный";
			HouseInfo[he][hInt] = 5;
			HouseInfo[he][hExitx] = 1826.4791;
			HouseInfo[he][hExity] = -2676.6099;
			HouseInfo[he][hExitz] = 13.6351;
			}
			case 4:
			{
			klass = "Премиум";
			HouseInfo[he][hInt] = 6;
			HouseInfo[he][hExitx] = 1826.4791;
			HouseInfo[he][hExity] = -2676.6099;
			HouseInfo[he][hExitz] = 13.6351;
			}
			case 5:
			{
			klass = "Люкс";
			HouseInfo[he][hInt] = 7;
			HouseInfo[he][hExitx] = 1877.5209;
			HouseInfo[he][hExity] = -2673.4766;
			HouseInfo[he][hExitz] = 13.6030;
			}
			}

			if(HouseInfo[he][hOwned] == 0)
			{
				format(text, sizeof(text),"Дом №%d {11FF00}(свободен){FFFFFF}\nКласс: {1C82E8}%s{FFFFFF}\nЦена: {1C82E8}$%d{FFFFFF}", he, klass, HouseInfo[he][hPrice]);
				HouseInfo[he][hPickup] = CreateDynamicPickup(1273, 23, HouseInfo[he][hEntrancex], HouseInfo[he][hEntrancey], HouseInfo[he][hEntrancez],-1);
				HouseInfo[he][hIcon] = CreateDynamicMapIcon(HouseInfo[he][hEntrancex], HouseInfo[he][hEntrancey], HouseInfo[he][hEntrancez], 31, -1, 0, 0, -1, 100.0);
			}
			if(HouseInfo[he][hOwned] == 1)
			{
				format(text, sizeof(text),"Дом №%d {FF6347}(куплен){FFFFFF}\nВладелец: {7CFC00}%s{FFFFFF}\nКласс: {7CFC00}%s{FFFFFF}{FFFFFF}", he, HouseInfo[he][hOwner],klass);
				HouseInfo[he][hPickup] = CreateDynamicPickup(1272, 23, HouseInfo[he][hEntrancex], HouseInfo[he][hEntrancey], HouseInfo[he][hEntrancez],-1);
				HouseInfo[he][hIcon] = CreateDynamicMapIcon(HouseInfo[he][hEntrancex], HouseInfo[he][hEntrancey], HouseInfo[he][hEntrancez], 32, -1, 0, -1, -1, 100.0);
			}
			HouseInfo[he][hText] = CreateDynamic3DTextLabel(text, -1, HouseInfo[he][hEntrancex], HouseInfo[he][hEntrancey], HouseInfo[he][hEntrancez]+1, 3.0);
		}
		printf("============================================");
		printf("Загружено: %d домов за %d м.с", TOTALHOUSE, GetTickCount() - time);
	}
	return true;
}
stock BuyHouse(he)
{
	new text[170], klass[20];
	switch(HouseInfo[he][hClass])
	{
		case 0: klass = "Эконом";
		case 1: klass = "Доступный";
		case 2: klass = "Средний";
		case 3: klass = "Элитный";
		case 4: klass = "Премиум";
		case 5: klass = "Люкс";
	}
	if(HouseInfo[he][hOwned] == 0)
	{
		format(text, sizeof(text),"Дом №%d {11FF00}(свободен){FFFFFF}\nКласс: {1C82E8}%s{FFFFFF}\nЦена: {1C82E8}$%d{FFFFFF}", he, klass, HouseInfo[he][hPrice]);
		if(IsValidDynamicMapIcon(HouseInfo[he][hIcon])) {
			DestroyDynamicMapIcon(HouseInfo[he][hIcon]);
		}
		Streamer_SetIntData(STREAMER_TYPE_PICKUP, HouseInfo[he][hPickup], E_STREAMER_MODEL_ID, 1273);
		HouseInfo[he][hIcon] = CreateDynamicMapIcon(HouseInfo[he][hEntrancex], HouseInfo[he][hEntrancey], HouseInfo[he][hEntrancez], 31, -1, 0, 0, -1, 100.0);
	}
	if(HouseInfo[he][hOwned] == 1)
	{
		if(IsValidDynamicMapIcon(HouseInfo[he][hIcon])) {
			DestroyDynamicMapIcon(HouseInfo[he][hIcon]);
		}
		Streamer_SetIntData(STREAMER_TYPE_PICKUP, HouseInfo[he][hPickup], E_STREAMER_MODEL_ID, 1272);
		format(text, sizeof(text),"Дом №%d {FF6347}(куплен){FFFFFF}\nВладелец: {7CFC00}%s{FFFFFF}\nКласс: {7CFC00}%s{FFFFFF}", he, HouseInfo[he][hOwner],klass);
		HouseInfo[he][hIcon] = CreateDynamicMapIcon(HouseInfo[he][hEntrancex], HouseInfo[he][hEntrancey], HouseInfo[he][hEntrancez], 32, -1, 0, -1, -1, 100.0);
	}
	UpdateDynamic3DTextLabelText(HouseInfo[he][hText], -1, text);
	return true;
}
stock GetPlayerHouseID(playerid)
{
	new house = 0;
	for(new i = 1; i <= TOTALHOUSE;i++)
	{
		if(HouseInfo[i][hOwned] == 0) {
			continue;
		}
		if(!strcmp(HouseInfo[i][hOwner],PlayerInfo[playerid][pName],true)) {
			house = i;
			SetPVarInt(playerid, "PlayerHouse", i);
		}
	}
	return house;
}
stock GetPlayerHouse(playerid)
{
	new house = 0;
	for(new i = 1; i <= TOTALHOUSE;i++)
	{
		if(HouseInfo[i][hOwned] == 0) {
			continue;
		}
		if(!strcmp(HouseInfo[i][hOwner],PlayerInfo[playerid][pName],true)) {
			house ++;
			SetPVarInt(playerid, "PlayerHouse", i);
		}
	}
	return house;
}
stock LoadCarPlayerId(playerid)
{
	if(GetPlayerHouse(playerid) == 0 && Player.Hotel[playerid] == INVALID_HOTEL_ID) return true;
	if(IsValidVehicle(caridhouse[playerid]))
	{
		DestroyVehicle(caridhouse[playerid]);
		caridhouse[playerid] = INVALID_VEHICLE_ID;
	}
	new 
		fuel = 40;
	if(PlayerInfo[playerid][pSelectedSlot] == 1) {
		PlayerCar[playerid] = PlayerInfo[playerid][pCar];
		CarColor[playerid] = PlayerInfo[playerid][pCarCol];
		CarColor2[playerid] = PlayerInfo[playerid][pCarCol2];	
		fuel = PlayerInfo[playerid][pFuel1];	 													
	}
	if(PlayerInfo[playerid][pSelectedSlot] == 2) {
		PlayerCar[playerid] = PlayerInfo[playerid][pCar2];
		CarColor[playerid] = PlayerInfo[playerid][pCar2Col];
		CarColor2[playerid] = PlayerInfo[playerid][pCar2Col2];
		fuel = PlayerInfo[playerid][pFuel2];
	}
	if(PlayerCar[playerid] == -1) return 1;

	new engine, lights, alarm, doors, bonnet, boot, objective;

	if(Player.Hotel[playerid] != INVALID_HOTEL_ID) {
		new
			value = active_car_slot_spawn;

		active_car_slot_spawn++;
		if(active_car_slot_spawn >= MAX_HOTEL_CAR) {
			active_car_slot_spawn = 0;
		}

		caridhouse[playerid] = INVALID_VEHICLE_ID;
		caridhouse[playerid] = CreateVehicle(PlayerCar[playerid],
			HolelCar[value][0], HolelCar[value][1], HolelCar[value][2], HolelCar[value][3],
			CarColor[playerid], CarColor2[playerid],
			86400
		);
		AttachSiren(playerid, caridhouse[playerid]);
		PutPlayerInVehicle(playerid, caridhouse[playerid], 0);
		SetVehicleZAngle(caridhouse[playerid], HolelCar[value][3]);
		if(IsABMX(GetVehicleModel(caridhouse[playerid])) == 1) return 1;
		GetVehicleParamsEx(caridhouse[playerid], engine, lights, alarm, doors, bonnet, boot, objective);	
		SetVehicleParamsEx(caridhouse[playerid], 0, 0, alarm, 0, bonnet, boot, objective);
		callcmd::lock(playerid, "");
	} else {
		new he = GetPVarInt(playerid, "PlayerHouse");
		caridhouse[playerid] = INVALID_VEHICLE_ID;
		caridhouse[playerid] = CreateVehicle(PlayerCar[playerid], HouseInfo[he][hCarx], HouseInfo[he][hCary], HouseInfo[he][hCarz], HouseInfo[he][hCarc], CarColor[playerid], CarColor2[playerid], 86400);
		AttachSiren(playerid, caridhouse[playerid]);
		SetVehicleFuel(caridhouse[playerid], fuel);
		if(IsABMX(GetVehicleModel(caridhouse[playerid])) == 1) return 1;
		GetVehicleParamsEx(caridhouse[playerid], engine, lights, alarm, doors, bonnet, boot, objective);	
		SetVehicleParamsEx(caridhouse[playerid], 0, 0, alarm, 1, bonnet, boot, objective);
	}
	if(IsABMX(GetVehicleModel(caridhouse[playerid])) == 1) return 1;
	format(small_string, sizeof(small_string), "%d", playerid);
	SetVehicleNumberPlate(caridhouse[playerid], small_string);
	wear_elements(playerid);
	return 1;
}

forward BuyApartment(playerid);
public BuyApartment(playerid)
{
	/*if(test_server == true) {
		return 1;
	}*/
	new h = GetPVarInt(playerid, "HouseID");
	if(IsPlayerInRangeOfPoint(playerid, 2, HouseInfo[h][hEntrancex], HouseInfo[h][hEntrancey], HouseInfo[h][hEntrancez]))
	{
		if(HouseInfo[h][hOwned] != 0) return 1;
		if(CheckCash(playerid, HouseInfo[h][hPrice]) == false) return 1;
		RemovePlayerEXP(playerid, HouseInfo[h][hPrice], "Покупка дома %i", h);
		if(GetPlayerHouse(playerid) > 0) return SendClientMessage(playerid, -1, ""COLOR_RED"У вас уже есть дом!");
		HouseInfo[h][hOwned] = 1;
		HouseInfo[h][hTakings] = 3;
		strmid(HouseInfo[h][hOwner], PlayerInfo[playerid][pName], 0, strlen(PlayerInfo[playerid][pName]), 255);
		SetPlayerPos(playerid,HouseInfo[h][hExitx],HouseInfo[h][hExity]+3,HouseInfo[h][hExitz]);
		SetPlayerVirtualWorld(playerid, GetPlayerAccountID(playerid));
		SetPlayerInterior(playerid,HouseInfo[h][hInt]);
		PlayerPlaySound(playerid, 1058, 0.0, 0.0, 10.0);
		//if(PlayerInfo[playerid][pCar] == 0) PlayerInfo[playerid][pCar] = 509, SetPlayerInt(playerid, "Car", PlayerInfo[playerid][pCar]);
		new MySQL[110];
		mysql_format(database, MySQL, sizeof(MySQL), "UPDATE `apartment` SET Owner = '%e', Owned = 1, Takings = 3 WHERE ID = '%d' LIMIT 1",PlayerInfo[playerid][pName],h);
		mysql_pquery(database, MySQL, "", "");
		LoadCarPlayerId(playerid);
		Streamer_SetIntData(STREAMER_TYPE_PICKUP, HouseInfo[h][hPickup], 23, 1272);
		BuyHouse(h);
		SetPVarInt(playerid, "PlayerHouse", h);
		DeletePVar(playerid,"HouseID");
		SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы купили дом!");
		SendClientMessage(playerid, -1, ""COLOR_GREEN"Государство оплатит Ваше проживание ближайшие три дня");
		SendClientMessage(playerid, -1, ""COLOR_GREEN"После этого придется оплатить квартплату в банке или дом будет отобран");
		SendClientMessage(playerid, -1, "(( Открыть или закрыть двери дома можно командой: /homelock ))");
		GameTextForPlayer(playerid, "~g~Welcome home!", 9000, 0);
		return 1;
	}
	DeletePVar(playerid,"HouseID");
	return 1;
}
forward SellApartment(playerid);
public SellApartment(playerid)
{
	if(GetPlayerHouse(playerid) > 0) {
		new house = GetPVarInt(playerid, "PlayerHouse");
		HouseInfo[house][hTakings] = 0;
		HouseInfo[house][hOwned] = 0;
		if(IsValidVehicle(caridhouse[playerid])) {
		DestroyVehicle(caridhouse[playerid]);
		caridhouse[playerid] = INVALID_VEHICLE_ID;
		}
		strmid(HouseInfo[house][hOwner], "The State", 0, strlen("The State"), 255);
		new num;
		num = HouseInfo[house][hPrice]/3;

		format(small_string, sizeof(small_string), ""COLOR_GREEN"Ваш дом успешно продан за {FFFFFF}%d EXP", num);
		SendClientMessage(playerid, -1, small_string);
		AddPlayerEXP(playerid, num, "Продажа дома %i", house);
		BuyHouse(house);
		new MySQL[256];
		mysql_format(database, MySQL, sizeof(MySQL), "UPDATE `apartment` SET Owner = 'The State', Owned = 0 WHERE ID = '%d' LIMIT 1",house);
		mysql_pquery(database, MySQL, "", "");
		GetPlayerHouse(playerid);
		UpdateSpawnInfo(playerid);
	}
	return 1;
}
forward GBackSkin(playerid);
public GBackSkin(playerid)
{
	new
		Fraction: fractionid = GetPlayerFraction(playerid),
		returnid;

	if(fractionid == FRACTION_NONE) {
		SetPlayerColor(playerid, CIVIL_COLOR);
		returnid = 26;

		if(PlayerInfo[playerid][pSex] != 0) {
			returnid = 193;
		}
	}
	if(PlayerInfo[playerid][pSkin] > 0) {
		returnid =  PlayerInfo[playerid][pSkin];
	}
	new
		player_rank = PlayerInfo[playerid][pRank],
		player_sex = PlayerInfo[playerid][pSex];

	if(GetPlayerJobDayStatus(playerid) == true)
	{
		switch(fractionid) {
			case FRACTION_LSPD: {
