CMD:wanted(playerid, params[]) {
	new
		Fraction:fractionid = GetPlayerFraction(playerid);

	if(fractionid == FRACTION_FBI || fractionid == FRACTION_LSPD) {
		if(GetPlayerJobDayStatus(playerid) == false)
		{
			return SendClientMessage(playerid, -1, MSG_START_JOB_DAY);
		}

		small_string[0] = EOS;
		big_string[0] = EOS;
		big_string = "ID\tНикнейм\tУровень розыска\n";
		new 
			iter_count = 0;

		foreach(new i: PlayerWanted) {
			format(small_string, sizeof(small_string), "%i\t"COLOR_GREEN"%s"COLOR_WHITE"\t%i звезд\n", i, PlayerInfo[i][pName], GetPlayerWantedLevel(i));
			strcat(big_string, small_string);
			iter_count += 1;
		}

		if(iter_count == 0) {
			return SendClientMessage(playerid, -1, ""COLOR_ORANGE"В данный момент, в штате нет преступников");
		}

		format(small_string, sizeof(small_string), ""COLOR_BLUE"Список преступников: "COLOR_ORANGE"Всего %i чел.", iter_count);
		return ShowPlayerDialog(playerid, DIALOG_INFO, DIALOG_STYLE_TABLIST_HEADERS, small_string, big_string, "Закрыть", "");	
	} else {
		return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Вам недоступна данная команда.");
	}
}

CMD:setfuel(playerid, params[]) {
	if(GetPlayerAdminLevel(playerid) < 2) {
		return false;
	}

	new 
		vehiclied, 
		fuel;

	if(sscanf(params, "dd", vehiclied, fuel)) 
	{
		if(IsPlayerInAnyVehicle(playerid))
		{
			vehiclied = GetPlayerVehicleID(playerid);
			if(SetVehicleFuel(vehiclied, 50)) {
				return SendClientMessage(playerid, -1, ""COLOR_WHITE"Автомобиль "COLOR_GREEN"заправлен.");
			}
		}
		else
		{
			return SendClientMessage(playerid, -1, "Используйте: /setfuel [ID Машины] [Кол-во литров]");
		}
	}
	
	if(fuel > MAX_REFILL && fuel < 5) {
		return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Неверное значения литров");
	}
	if(SetVehicleFuel(vehiclied, fuel)) {
		return SendClientMessage(playerid, -1, ""COLOR_WHITE"Автомобиль "COLOR_GREEN"заправлен.");
	}
	return false;
}

CMD:setfuelall(playerid, params[]) {
	if(GetPlayerAdminLevel(playerid) < 2) {
		return false;
	}

	new 
		vehiclied, 
		fuel;

	if(sscanf(params, "d", vehiclied, fuel)) 
	{
		return SendClientMessage(playerid, -1, "Используйте: /setfuelall [Кол-во литров]");
	}
	
	if(fuel > MAX_REFILL && fuel < 5) {
		return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Неверное значения литров");
	}
	foreach(new i: VehicleInfo)
	{
		AddVehicleFuel(i, fuel);
	}
	return SendClientMessage(playerid, -1, ""COLOR_WHITE"Все автомобили "COLOR_GREEN"заправлены.");
}

CMD:setvh(playerid, params[]) {
	if(GetPlayerAdminLevel(playerid) < 2) {
		return false;
	}

	new 
		vehiclied;

	if(sscanf(params, "d", vehiclied))
	{
		if(IsPlayerInAnyVehicle(playerid))
		{
			vehiclied = GetPlayerVehicleID(playerid);
			SetVehicleHealth(vehiclied, 1000.00);
			RepairVehicle(vehiclied);
			return SendClientMessage(playerid, -1, ""COLOR_WHITE"Автомобиль "COLOR_GREEN"отремонинтирован.");
		}
		else
		{
			return SendClientMessage(playerid, -1, "Используйте: /setvh [ID Машины]");
		}
	} 
	SetVehicleHealth(vehiclied, 1000.00);
	RepairVehicle(vehiclied);
	SendClientMessage(playerid, -1, ""COLOR_WHITE"Автомобиль "COLOR_GREEN"отремонинтирован.");
	return false;
}


CMD:fuel_consumption(playerid, params[]) {
	if(GetPlayerAdminLevel(playerid) < 2) {
		return false;
	}

	new 
		value;

	if(sscanf(params, "d", value)) return SendClientMessage(playerid, -1, "Используйте: /fuel_consumption [Расход топлива]");

	fuel_consumption = value;
	return SendClientMessage(playerid, -1, ""COLOR_GREEN"Расход топлива обновлен");
}


#define MAX_ALL_BANS_LIST 				(30)

new 
	PlayerPageAllBans[MAX_PLAYERS];

