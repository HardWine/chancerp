    huge_string = !"Íčęíĺéě (ID)\tĐŕíă\tŃňŕňóń AFK\tĐŕáî÷čé äĺíü\n";
    for(new  i =(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i =Iterator@Player [_: i ])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);) { 
        if(!PlayerLogged{i}|| GetPlayerFraction(i) != fractionid) continue; 
        if(pl_afk_time[i] > 10) {
            format(small_string, sizeof(small_string), """{6de64e}""%s(%i)\t(%i) %s\t""{FFAF00}""Â AFK (%s)\t%s\n", PlayerInfo[i][pName], i, PlayerInfo[i][pRank], gFractionRankName_RU[_:fractionid-1][PlayerInfo[i][pRank]], Convert(pl_afk_time[i]), (GetPlayerJobDayStatus(i) == true) ? ("""{6de64e}""Íŕ÷ŕň") : ("""{FFAF00}""Îęîí÷ĺí")); 
        	strcat(huge_string, small_string);
        } 
        else { 
            format(small_string, sizeof(small_string), """{6de64e}""%s(%i)\t(%i) %s\t""{6de64e}""Íĺ â AFK\t%s\n", PlayerInfo[i][pName], i, PlayerInfo[i][pRank], gFractionRankName_RU[_:fractionid-1][PlayerInfo[i][pRank]], (GetPlayerJobDayStatus(i) == true) ? ("""{6de64e}""Íŕ÷ŕň") : ("""{FFAF00}""Îęîí÷ĺí")); 
       		strcat(huge_string, small_string);
        } 
        full++; 
    }  
	format(small_string,sizeof(small_string),"""{4eb9e6}""Îíëŕéí ôđŕęöčč: ""{FFAF00}""%i ÷ĺëîâĺę\n",full);
	SPD(playerid, dKickMessage, 5, small_string, huge_string, "Çŕęđűňü", ""); 
  	return 1; 
}  

forward pc_cmd_uninvite(playerid, params[]); public pc_cmd_uninvite(playerid, params[]) {
	new fractionid = GetPlayerFractionInt(playerid);
	new crutch = LeaderPlayerFraction(playerid);
	if(Fraction[crutch][E_FRACTION_LEADER_ID] == (-1)) {

		if(PlayerInfo[playerid][pRank] < 10) return SendClientMessage(playerid, -1, """{ff353c}""Äîńňóďíî ňîëüęî ďîńëĺ äîńňčćĺíč˙ 10 đŕíăŕ");
		if(GetPlayerJobDayStatus(playerid) == false)
		{
			return SendClientMessage(playerid, -1, """{FFFFFF}""Íĺîáőîäčěî íŕ÷ŕňü đŕáî÷čé äĺíü íŕ ""{6de64e}""áŕçĺ îđăŕíčçŕöčč");
		}
		if(uninviteFraction[_:fractionid-1] == -1) {
			if(sscanf(params,"ds[32]", params[0],params[1])) return SendClientMessage(playerid, -1, !"Čńďîëüçóéňĺ: /uninvite [id čăđîęŕ] [ďđč÷číŕ]");
			if(uninvitePlayerID[_:fractionid-1] != (0xFFFF)) {
	            SendClientMessage(playerid, -1, """{ff353c}""Ăîëîńîâŕíčĺ íŕ óâîëüíĺíčĺ óćĺ çŕďóůĺíî!");
	            return SendClientMessage(playerid, -1, """{e67b4e}""Ââĺäčňĺ {FFFFFF}'/uninvite +',""{e67b4e}"" ÷ňîáű ďđîăîëîńîâŕňü 'çŕ' č {FFFFFF}'/uninvite -'""{e67b4e}"", ÷ňîáű ďđîăîëîńîâŕňü 'ďđîňčâ'");
	        }
	        if((0xFFFF) == params[0] || PlayerLogged{params[0]} == false) return SendClientMessage(playerid, -1, """{ff353c}""Čăđîę íĺ íŕéäĺí!");
	        if(playerid == params[0]) return SendClientMessage(playerid, -1, """{ff353c}""Âű íĺ ěîćĺňĺ ďđčěĺíčňü ýňî íŕ ńĺá˙!");
	        if(fractionid != GetPlayerFractionInt(params[0])) return SendClientMessage(playerid, -1, """{ff353c}""Čăđîę íĺ ńîńňîčň â âŕřĺé ôđŕęöčč");
	      	uninviteFraction[_:fractionid-1] = 1;
	        uninvitePlayerID[_:fractionid-1] = params[0];
	        SetPVarInt(uninvitePlayerID[_:fractionid-1], "AgreeVotesCount", 1);
	        DeletePVar(uninvitePlayerID[_:fractionid-1], "DisagreeVotesCount");
	        SetPVarString(uninvitePlayerID[_:fractionid-1], "VoteReason", params[1]);
	        for(new i = GetPlayerPoolSize(); i != -1; --i) DeletePVar(i, "HasVoted");
	        new string[256];
	        format(string, sizeof string, """{e67b4e}""%s {FFFFFF}%s""{e67b4e}"" íŕ÷ŕë ăîëîńîâŕíčĺ çŕ óâîëüíĺíčĺ {FFFFFF}%s""{e67b4e}"". Ďđč÷číŕ: {FFFFFF}%s",
	        	 gFractionRankName_RU[_:fractionid-1][PlayerInfo[playerid][pRank]], PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName], params[1]);
	        SendLeadMessage(Fraction:fractionid, params[0], string);
			SendLeadMessage(Fraction:fractionid, params[0], """{e67b4e}""Ââĺäčňĺ {FFFFFF}'/uninvite +',""{e67b4e}"" ÷ňîáű ďđîăîëîńîâŕňü 'çŕ' č {FFFFFF}'/uninvite -'""{e67b4e}"", ÷ňîáű ďđîăîëîńîâŕňü 'ďđîňčâ'");
	        new t = _:fractionid-1;
	       	uninviteTimer[t] = SetTimerEx("VoteTimer", 60 * 1000, 0, "d", t);
	        SetPVarInt(playerid, "HasVoted", 1);
	        SetPVarString(params[0], "name_origin", PlayerInfo[playerid][pName]);
		}
		else {
		if(sscanf(params,"s[4]", params[0])) return SendClientMessage(playerid, -1, !"Čńďîëüçóéňĺ: /uninvite [+/-]");
		if(!strcmp(params[0], "+", true)) {
	        if(uninviteFraction[_:fractionid-1] == -1) return SendClientMessage(playerid, -1, """{ff353c}""Ăîëîńîâŕíčĺ íŕ óâîëüíĺíčĺ íĺ çŕďóůĺíî!");
	        if(playerid == uninvitePlayerID[_:fractionid-1]) return SendClientMessage(playerid, -1, """{ff353c}""Âű íĺ ěîćĺňĺ ăîëîńîâŕňü çŕ ńŕěîăî ńĺá˙!");
	        if(GetPVarInt(playerid, "HasVoted")) return SendClientMessage(playerid, -1, """{ff353c}""Âű óćĺ ďđîăîëîńîâŕëč!");
	        SetPVarInt(uninvitePlayerID[_:fractionid-1], "AgreeVotesCount", GetPVarInt(uninvitePlayerID[_:fractionid-1], "AgreeVotesCount") + 1);
	        new gName[24], string[145];
	        GetPlayerName(uninvitePlayerID[_:fractionid-1], gName, sizeof gName);
	        format(string, sizeof string, """{6de64e}""Âű ďđîăîëîńîâŕëč {FFFFFF}'çŕ'""{6de64e}"" óâîëüíĺíčĺ čăđîęŕ{FFFFFF} %s[%d]""{6de64e}"" (%d 'çŕ' č %d 'ďđîňčâ')", gName, uninvitePlayerID[_:fractionid-1], GetPVarInt(uninvitePlayerID[_:fractionid-1], "AgreeVotesCount"), GetPVarInt(uninvitePlayerID[_:fractionid-1], "DisagreeVotesCount"));
	        SendClientMessage(playerid, -1, string);
	        SetPVarInt(playerid, "HasVoted", 1);
	    	} else if(!strcmp(params[0], "-", true)) {
	        if(uninviteFraction[_:fractionid-1] == -1) return SendClientMessage(playerid, -1, """{ff353c}""Ăîëîńîâŕíčĺ íŕ óâîëüíĺíčĺ íĺ çŕďóůĺíî!");
	        if(playerid == uninvitePlayerID[_:fractionid-1]) return SendClientMessage(playerid, -1, """{ff353c}""Âű íĺ ěîćĺňĺ ăîëîńîâŕňü çŕ ńŕěîăî ńĺá˙!");
	        if(GetPVarInt(playerid, "HasVoted")) return SendClientMessage(playerid, -1, """{ff353c}""Âű óćĺ ďđîăîëîńîâŕëč!");
	        SetPVarInt(uninvitePlayerID[_:fractionid-1], "DisagreeVotesCount", GetPVarInt(uninvitePlayerID[_:fractionid-1], "DisagreeVotesCount") + 1);
	        new gName[24], string[145];
	        GetPlayerName(uninvitePlayerID[_:fractionid-1], gName, sizeof gName);
	        format(string, sizeof string, """{6de64e}""Âű ďđîăîëîńîâŕëč {FFFFFF}'ďđîňčâ'""{6de64e}"" óâîëüíĺíč˙ čăđîęŕ{FFFFFF} %s[%d]""{6de64e}"" (%d 'çŕ' č %d 'ďđîňčâ')", gName, uninvitePlayerID[_:fractionid-1], GetPVarInt(uninvitePlayerID[_:fractionid-1], "AgreeVotesCount"), GetPVarInt(uninvitePlayerID[_:fractionid-1], "DisagreeVotesCount"));
	        SendClientMessage(playerid, -1, string);
	        SetPVarInt(playerid, "HasVoted", 1);
	    }
		}
	}
	else {
		if(PlayerInfo[playerid][pRank] < 9) return SendClientMessage(playerid, -1, """{ff353c}""Äîńňóďíî ňîëüęî ďîńëĺ äîńňčćĺíč˙ 9 đŕíăŕ");

		if(sscanf(params,"ds[32]", params[0],params[1])) return SendClientMessage(playerid, -1, !"Čńďîëüçóéňĺ: /uninvite [id čăđîęŕ] [ďđč÷číŕ]");
		if(GetPlayerJobDayStatus(playerid) == false)
		{
			return SendClientMessage(playerid, -1, """{FFFFFF}""Íĺîáőîäčěî íŕ÷ŕňü đŕáî÷čé äĺíü íŕ ""{6de64e}""áŕçĺ îđăŕíčçŕöčč");
		}
		if(PlayerInfo[playerid][pRank] < PlayerInfo[params[0]][pRank]) return 1;
		if(params[0] == playerid) return 1;
		if(GetPlayerFraction(params[0]) != GetPlayerFraction(playerid)) return 1;		

		SetPlayerArmour(params[0], 0);
	 	RM_ResetPlayerWeapons(params[0]);
	 	RemovePlayerFraction(params[0], true);

		if(GetPVarInt(playerid, "onair_master")) {
			DeletePVar(playerid, "onair_master");
			onair = 0;
			SendFamilyMessage(FRACTION_NEWS, -1, """{FFAF00}""Âĺäóůčé ďđĺđâŕë ďđ˙ěîé ýôčđ (áűë óâîëĺí)");
		}

     	format(big_string, sizeof(big_string),
        "{FFFFFF}Âű áűëč óâîëĺíű ďî đĺřĺíčţ %s.\n\n""{ff353c}""Ďđč÷číŕ: {FFFFFF}%s\n""{ff353c}""Âŕř đŕíă: {FFFFFF}%d\n\nĹńëč âű ń÷čňŕĺňĺ ÷ňî áűëč íŕđóřĺíű ďđŕâčëŕ,\nńäĺëŕéňĺ ńęđčířîň äŕííîăî äčŕëîăŕ č đŕçěĺńňčňĺ\nćŕëîáó íŕ ôîđóěĺ ďđîĺęňŕ: talk.chancerp.ru",
        PlayerInfo[playerid][pName],
        params[1],
        PlayerInfo[params[0]][pRank]);
        SPD(params[0], dKickMessage, 0, "Číôîđěŕöč˙", big_string, "Çŕęđűňü", "");
        new string[156];
        format(string, sizeof(string), """{ff353c}""%s áűë óâîëĺí ďî đĺřĺíčţ %s. Ďđč÷číŕ: %s", 
        	PlayerInfo[params[0]][pName], PlayerInfo[playerid][pName], params[1]);
        SendFamilyMessage(GetPlayerFraction(playerid), -1, string);

	 	PlayerInfo[params[0]][pStatus] = 0;
	 	SetPlayerInt(params[0], "Status", PlayerInfo[params[0]][pStatus]);
	 	PlayerInfo[params[0]][pRank] = 0;
	 	SetPlayerInt(params[0], "Rank", PlayerInfo[params[0]][pRank]);

	 	CBackSkin(params[0]);
	}
    return 1;
}  
stock SendLeadMessage(Fraction:family, id = (0xFFFF), string[])
{
	for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i=Iterator@Player [_: i])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);)
	{
		if(GetPlayerFraction(i) == family && PlayerInfo[i][pRank] == 10 && i != id)
	    {
			SendClientMessage(i, -1, string);
		}
	}
}
forward VoteTimer(fractionid);
public VoteTimer(fractionid)
{
    new
        AverageVotesCount = GetPVarInt(uninvitePlayerID[fractionid], "AgreeVotesCount") + GetPVarInt(uninvitePlayerID[fractionid], "DisagreeVotesCount"),
        PositiveVotesPercent = (GetPVarInt(uninvitePlayerID[fractionid], "AgreeVotesCount") / AverageVotesCount) * 100,
        string[145];
    if(PositiveVotesPercent >= 55.0 && GetPVarInt(uninvitePlayerID[fractionid], "AgreeVotesCount") >= 3)
    {
        new reason[128],
        	origin[24+1];
        GetPVarString(uninvitePlayerID[fractionid], "VoteReason", reason, sizeof reason);
        GetPVarString(uninvitePlayerID[fractionid], "name_origin", origin, sizeof origin);

        format(big_string, sizeof(big_string),
        "{FFFFFF}Âű áűëč óâîëĺíű ďî đĺřĺíčţ đóęîâîäńňâŕ ôđŕęöčč.\n\n""{ff353c}""Číčöčŕňîđ: {FFFFFF}%s\n""{ff353c}""Ďđč÷číŕ: {FFFFFF}%s\n""{ff353c}""Âŕř đŕíă: {FFFFFF}%d (%d)\n\nĹńëč âű íĺ ńîăëŕńíű ń ďđč÷číîé óâîëüíĺíč˙,\nńäĺëŕéňĺ ńęđčířîň äŕííîăî äčŕëîăŕ č đŕçěĺńňčňĺ\nćŕëîáó íŕ ôîđóěĺ ďđîĺęňŕ: talk.chancerp.ru",
        origin,
        reason,
        PlayerInfo[uninvitePlayerID[fractionid]][pRank],
        PlayerInfo[uninvitePlayerID[fractionid]][pStatus]);
        SPD(uninvitePlayerID[fractionid], dKickMessage, 0, "Číôîđěŕöč˙", big_string, "Çŕęđűňü", "");
        format(string, sizeof(string), """{e67b4e}""Čăđîę {FFFFFF}%s[%d]""{e67b4e}"" áűë óâîëĺí ďî đĺřĺíčţ đóęîâîäńňâŕ ôđŕęöčč. Ďđč÷číŕ: {FFFFFF}%s", 
        	PlayerInfo[uninvitePlayerID[fractionid]][pName], uninvitePlayerID[fractionid], reason);

        SendFamilyMessage(GetPlayerFraction(uninvitePlayerID[fractionid]), -1, string);
	 	SetPlayerColor(uninvitePlayerID[fractionid], 0xFFFFFFFF);
	 	SetPlayerArmour(uninvitePlayerID[fractionid], 0);
	 	RM_ResetPlayerWeapons(uninvitePlayerID[fractionid]);
	 	RemovePlayerFraction(uninvitePlayerID[fractionid], true);

	 	PlayerInfo[uninvitePlayerID[fractionid]][pStatus] = 0;
	 	SetPlayerInt(uninvitePlayerID[fractionid], "Status", PlayerInfo[uninvitePlayerID[fractionid]][pStatus]);
	 	PlayerInfo[uninvitePlayerID[fractionid]][pRank] = 0;
	 	SetPlayerInt(uninvitePlayerID[fractionid], "Rank", PlayerInfo[uninvitePlayerID[fractionid]][pRank]);

	 	CBackSkin(uninvitePlayerID[fractionid]);
        uninviteFraction[fractionid] = -1;
   		uninvitePlayerID[fractionid] = (0xFFFF);
    }
    else
    {
        format(string, sizeof string, """{e67b4e}""Čăđîę {FFFFFF}%s[%d]""{e67b4e}"" íĺ áűë óâîëĺí. Íĺ íŕáđŕëîńü äîńňŕňî÷íîĺ ęîëč÷ĺńňâî ăîëîńîâ", PlayerInfo[uninvitePlayerID[fractionid]][pName],
         uninvitePlayerID[fractionid]);
        SendLeadMessage(GetPlayerFraction(uninvitePlayerID[fractionid]), uninvitePlayerID[fractionid], string);
        uninviteFraction[fractionid] = -1;
   		uninvitePlayerID[fractionid] = (0xFFFF);
    }
    return 1;
}  
forward StopInvitation();
public StopInvitation() {
	KillTimer(uninviteTimerEnd);
	gov_Status = 0;
	INVITATION_ARMY = 0;
	SendClientMessageToAll(-1, gov_string_6);
	return 1;
}

forward InviteAlert();
public InviteAlert() {
	new alert = GetSVarInt("alert_inv");
	alert++;
	SetSVarInt("alert_inv", alert);

	new inviter = 0;
	for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i=Iterator@Player [_: i])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);) { 
		if(IsPlayerInDynamicArea(i, army_area)) {
			if(PlayerInfo[i][pRank] >= 9 && GetPlayerFraction(i) == FRACTION_ARMY)

			inviter += 1;
		}
	}
	if(inviter == 0) {
		return StopInvitation();
	}

	switch(alert) {
		case 0..4: {
			SendClientMessageToAll(-1, gov_string_1);
			SendClientMessageToAll(-1, gov_string_2);
			SendClientMessageToAll(-1, gov_string_3);
			SendClientMessageToAll(-1, gov_string_4);
			if(GetSVarInt("alert_inv") == 4) return 1;
			SetTimer("InviteAlert", 600000, false);
		}
		default: return 1;
	}

	return 1;
}
forward pc_cmd_su(playerid, params[]); public pc_cmd_su(playerid, params[]) {
	if(GetPlayerFraction(playerid) != FRACTION_LSPD && GetPlayerFraction(playerid) != FRACTION_FBI) return 1;
	if(PlayerInfo[playerid][pRank] < 5) return SendClientMessage(playerid, -1, """{ff353c}""Âűäŕ÷ŕ đîçűńęŕ äîńňóďíŕ ń 5 đŕíăŕ");

	new crutch = GetPlayerFractionInt(playerid);
	crutch--;

	if(Fraction[crutch][E_FRACTION_LEADER_ID] == (-1)) return 1;
	if(GetPlayerFraction(playerid) != FRACTION_LSPD && GetPlayerFraction(playerid) != FRACTION_FBI) return 1;
	if(GetPlayerJobDayStatus(playerid) == false)
	{
		return SendClientMessage(playerid, -1, """{FFFFFF}""Íĺîáőîäčěî íŕ÷ŕňü đŕáî÷čé äĺíü íŕ ""{6de64e}""áŕçĺ îđăŕíčçŕöčč");
	}
	if(PlayerInfo[playerid][pRank] < 5) return SendClientMessage(playerid, -1, """{ff353c}""Âűäŕ÷ŕ đîçűńęŕ äîńňóďíŕ ń 5 đŕíăŕ");

	if(sscanf(params,"ds[32]", params[0],params[1])) return SendClientMessage(playerid, -1, !"Čńďîëüçóéňĺ: /su [id čăđîęŕ] [ďđč÷číŕ]");

	new level = PlayerInfo[params[0]][pWanted];

	if(level > 10800) return SendClientMessage(playerid, -1, """{ff353c}""Čăđîę óćĺ čěĺĺň ěŕęńčěŕëüíűé óđîâĺíü đîçűńęŕ");

	if(7201 <= level <= 10800) SetPlayerWantedLevel(params[0], 6); PlayerInfo[params[0]][pWanted] = 10801;
	if(5401 <= level <= 7200) SetPlayerWantedLevel(params[0], 5); PlayerInfo[params[0]][pWanted] = 7201;
	if(3601 <= level <= 5400) SetPlayerWantedLevel(params[0], 4); PlayerInfo[params[0]][pWanted] = 5401;
	if(301 <= level <= 3600) SetPlayerWantedLevel(params[0], 3); PlayerInfo[params[0]][pWanted] = 3601;
	if(0 < level <= 300) SetPlayerWantedLevel(params[0], 2); PlayerInfo[params[0]][pWanted] = 1800;
	if(level <= 0) SetPlayerWantedLevel(params[0], 1); PlayerInfo[params[0]][pWanted] = 900;

	SetPlayerInt(playerid, "Wanted", PlayerInfo[playerid][pWanted]);
	if(GetPlayerFraction(playerid) == FRACTION_LSPD) {
		format(small_string, sizeof small_string, """{ff353c}""Ďîëčöĺéńęčé %s ďîâűńčë đîçűńę %s (%d [+1]). Ďđč÷číŕ: %s", PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName], PlayerInfo[params[0]][pWanted], params[1]);
		SendPoliceAlert(-1, small_string);

		format(small_string, sizeof small_string, """{ff353c}""Ďîëčöĺéńęčé %s ďîâűńčë Âŕě óđîâĺíü đîçűńęŕ (%d [+1]). Ďđč÷číŕ: %s", PlayerInfo[playerid][pName], PlayerInfo[params[0]][pWanted], params[1]);
		SendClientMessage(params[0], -1, small_string);
	}
	if(GetPlayerFraction(playerid) == FRACTION_FBI) {
		format(small_string, sizeof small_string, """{ff353c}""Ŕăĺíň %s ďîâűńčë đîçűńę %s (%d [+1]). Ďđč÷číŕ: %s", PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName], PlayerInfo[params[0]][pWanted], params[1]);
		SendFBIAlert(-1, small_string);

		format(small_string, sizeof small_string, """{ff353c}""Ŕăĺíň %s ďîâűńčë Âŕě óđîâĺíü đîçűńęŕ (%d [+1]). Ďđč÷číŕ: %s", PlayerInfo[playerid][pName], PlayerInfo[params[0]][pWanted], params[1]);
		SendClientMessage(params[0], -1, small_string);
	}

	return 1;	
}
forward pc_cmd_radio(playerid, params[]); public pc_cmd_radio(playerid, params[]) {
	if(GetPlayerFraction(playerid) != FRACTION_LSPD) return 1;
	if(PlayerInfo[playerid][pRank] < 3) return 1;
	if(GetPVarInt(playerid, "GT_LSPD") == 0) {
		SetPVarInt(playerid, "GT_LSPD", 1); 
		GameTextForPlayer(playerid, "~g~LSPD Channel", 2500, 4);
	}

	if(GetPVarInt(playerid, "GT_LSPD") == 1) SetPVarInt(playerid, "GT_LSPD", 0); GameTextForPlayer(playerid, "~r~Radio Off", 2500, 4);
	return 1;
}
forward pc_cmd_auninvite(playerid, params[]); public pc_cmd_auninvite(playerid, params[]) {
	if(sscanf(params,"ds[32]", params[0],params[1])) return SendClientMessage(playerid, -1, !"Čńďîëüçóéňĺ: /auninvite [id čăđîęŕ] [ďđč÷číŕ]");
	if(Player__Leader[params[0]] != -1) return 1;
	if(GetPlayerFraction(params[0]) == FRACTION_NONE) return 1;
	if(Player__AdminLevel{playerid} < 5) return 1;

	SetPlayerArmour(params[0], 0);
 	RM_ResetPlayerWeapons(params[0]);
 	RemovePlayerFraction(params[0], true);

 	format(big_string, sizeof(big_string),
