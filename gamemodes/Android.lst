forward dcr_DIALOG_SELL_AVIA(playerid); public dcr_DIALOG_SELL_AVIA(playerid) {
	new 
		time = PlayerSellAviaTime[playerid];		

	new 
		model = PlayerAviationModel[playerid],
		cash = 0;

	switch(model) {
