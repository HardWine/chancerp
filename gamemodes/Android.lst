forward dre_DIALOG_JOB_COLLECTORS(playerid, response, listitem, inputtext[]); public dre_DIALOG_JOB_COLLECTORS(playerid, response, listitem, inputtext[]) {
	if(!response) {
		return 0;
	} else {
		if(PlayerJobCollectors[playerid] == false) {
			PlayerJobCollectors[playerid] = true;
			SendClientMessage(playerid, -1, """{FFFFFF}""Âű íŕ÷ŕëč đŕáîňó číęŕcńŕňîđŕ. Îňďđŕâë˙éňĺńü ę ńňî˙íęĺ, č ń˙äüňĺ â ""{6de64e}""áđîíčđîâŕííűé ôóđăîí");
			return true;
		} else {
			PlayerJobCollectors[playerid] = false;

			PlayerCollectorsLoadedMoney[playerid] = 0;
			if(PlayerCollectorsLoadingTimer[playerid] != (-1)) {
				KillTimer(PlayerCollectorsLoadingTimer[playerid]);
			}
			PlayerCollectorsLoadingTimer[playerid] = (-1);

			if(PlayerCollectorsUnloadingTimer[playerid] != (-1)) {
				KillTimer(PlayerCollectorsUnloadingTimer[playerid]);
			}
			PlayerCollectorsUnloadingTimer[playerid] = (-1);

			if(PlayerCollectorsCheckVehicle[playerid] != (-1)) {
				KillTimer(PlayerCollectorsCheckVehicle[playerid]);
			}
			PlayerCollectorsCheckVehicle[playerid] = (-1);

			if(PlayerCollectorsLoadingCP[playerid] != (0)) {
				DestroyDynamicCP(PlayerCollectorsLoadingCP[playerid]);
			}
			PlayerCollectorsLoadingCP[playerid] = (0);

			if(PlayerCollectorsUnloadingCP[playerid] != (0)) {
				DestroyDynamicCP(PlayerCollectorsUnloadingCP[playerid]);
			}
			PlayerCollectorsUnloadingCP[playerid] = (0);

			for(new i = 0; i < sizeof(td_cash[]); i++) {
				PlayerTextDrawHide(playerid, td_cash[playerid][i]);
			}

			SendClientMessage(playerid, -1, """{FFFFFF}""Âű çŕâĺđřčëč đŕáîňó ""{6de64e}""číęŕńńŕňîđŕ");
			return true;
		}
	}
