CMD:carjack(playerid, params[]) {
	new
		Fraction:fractionid = GetPlayerFraction(playerid);

	if(fractionid < FRACTION_RUSSIAN_MAFIA && fractionid > FRACTION_LSPD) {
		if(GetPlayerJobDayStatus(playerid) == false)
		{
			return SendClientMessage(playerid, -1, MSG_START_JOB_DAY);
		}

		new nearid = GetNearestVehicle(playerid);
		if(PlayerInfo[playerid][pScrew] == 0) return SendClientMessage(playerid, -1, ""COLOR_RED"У Вас нет отвертки");
		if(nearid == 1) return SendClientMessage(playerid, -1, ""COLOR_RED"Подойдите ближе к автомобилю");
		if(IsVehicleOccupied(nearid) != -1) return SendClientMessage(playerid, -1, ""COLOR_RED"Автомобиль должен быть без водителя");
		new nearmodel = GetVehicleModel(nearid);
		if(nearmodel == TCar[playerid]) {
			PlayerInfo[playerid][pScrew] = 0;
			SetPlayerInt(playerid, "Screw", PlayerInfo[playerid][pScrew]);

			new engine, lights, alarm, doors, bonnet, boot, objective;
			GetVehicleParamsEx(nearid, engine, lights, alarm, doors, bonnet, boot, objective);
			SetVehicleParamsEx(nearid, engine, lights, alarm, 0, bonnet, boot, objective);
			SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы вскрыли замок автомобиля");
			format(small_string, sizeof(small_string), "%s взломал(а) центральный замок автомобиля %s", PlayerInfo[playerid][pName], GetVehicleText(nearmodel));
			ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_PURPLE, small_string);
		}
		else SendClientMessage(playerid, -1, ""COLOR_RED"У Вас нет заказа на эту модель");
	}
	return 1;
}
