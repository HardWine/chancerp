stock rob(playerid) {
	if(GetPVarInt(playerid, "bz_rob")) {
		new door = GetPVarInt(playerid, "bz_rob");
		DeletePVar(playerid, "bz_rob");

		SetPlayerPos(playerid,
		EnterCoords[door][ent_X],
		EnterCoords[door][ent_Y],
		EnterCoords[door][ent_Z]+0.5);

		SetPlayerFacingAngle(playerid, EnterCoords[door][ent_A]);
		SetCameraBehindPlayer(playerid);
		SetPlayerVirtualWorld(playerid, DOOR_VW_ADDENDUM+door);
		SetPlayerInterior(playerid, Properties[door][IID]);

		if(GetPVarInt(playerid, "mate") != -1) {
			new mateid = GetPVarInt(playerid, "mate");
			SetPlayerPos(mateid,
			EnterCoords[door][ent_X],
			EnterCoords[door][ent_Y],
			EnterCoords[door][ent_Z]);
			SetPlayerFacingAngle(mateid, EnterCoords[door][ent_A]);
			SetCameraBehindPlayer(mateid);
			SetPlayerVirtualWorld(mateid, DOOR_VW_ADDENDUM+door);		
			SetPlayerInterior(mateid, Properties[door][IID]);
		}
		callcmd::rob(playerid);
	}
	return 1;
}