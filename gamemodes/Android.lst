forward dre_selectcolor(playerid, response, listitem, inputtext[]); public dre_selectcolor(playerid, response, listitem, inputtext[]) {
	if(!response) return 1;
	switch(listitem) {
		case 0: {
			if(PlayerInfo[playerid][pColor] == 0) SendClientMessage(playerid, -1, !"""{F3FF02}""Öâĺň óńňŕíîâëĺí");
			PlayerInfo[playerid][pColor] = 0;
			SetPlayerInt(playerid, "Color", PlayerInfo[playerid][pColor]);
			update_logo_textdraw_color(playerid);
			update_spec_textdraw_color(playerid);
			SetPVarInt(playerid,"AntiFloodTD",gettime() + 10);
		}
		case 1: {
			if(PlayerInfo[playerid][pColor] == 1) SendClientMessage(playerid, -1, !"""{F3FF02}""Öâĺň óńňŕíîâëĺí");
			PlayerInfo[playerid][pColor] = 1;
			SetPlayerInt(playerid, "Color", PlayerInfo[playerid][pColor]);
			update_logo_textdraw_color(playerid);
			update_spec_textdraw_color(playerid);
			SetPVarInt(playerid,"AntiFloodTD",gettime() + 10);
		}
		case 2: {
			if(PlayerInfo[playerid][pColor] == 2) SendClientMessage(playerid, -1, !"""{F3FF02}""Öâĺň óńňŕíîâëĺí");
			PlayerInfo[playerid][pColor] = 2;
			SetPlayerInt(playerid, "Color", PlayerInfo[playerid][pColor]);
			update_logo_textdraw_color(playerid);
			update_spec_textdraw_color(playerid);
			SetPVarInt(playerid,"AntiFloodTD",gettime() + 10);
		}
		case 3: {
			if(PlayerInfo[playerid][pColor] == 3) SendClientMessage(playerid, -1, !"""{F3FF02}""Öâĺň óńňŕíîâëĺí");
			PlayerInfo[playerid][pColor] = 3;
			SetPlayerInt(playerid, "Color", PlayerInfo[playerid][pColor]);
			update_logo_textdraw_color(playerid);
			update_spec_textdraw_color(playerid);
			SetPVarInt(playerid,"AntiFloodTD",gettime() + 10);
		}
	}

	if(PlayerInfo[playerid][pColorSelected] == 0) {
		PlayerInfo[playerid][pColorSelected] = 1;
		SetPlayerInt(playerid, "ColorSelected", PlayerInfo[playerid][pColorSelected]);
	}

	if(GetPVarInt(playerid, "mobile")) RM_ShowPlayerDialog(playerid, dKickMessage, 0, """{FFAF00}""Číôîđěŕöč˙", """{FFFFFF}""Íŕńňî˙ňĺëüíî đĺęîěĺíäóĺě â íŕńňđîéęŕő ăđŕôčęč ""{FFAF00}""îňęëţ÷čňü ňĺíč""{FFFFFF}"" - DYNAMIC SHADOWS\nČ óńňŕíîâčňü ""{FFAF00}""ŕíăëčéńęčé ˙çűę""{FFFFFF}"" äë˙ ďđŕâčëüíîé č ńňŕáčëüíîé đŕáîňű čăđű!", "ÎĘ", "");
	return 1;
}

