public OnPlayerKeyStateChange(playerid, newkeys, oldkeys) 
{ 
	Porter_OnPlayerKeyStateChange(playerid, newkeys, oldkeys);

    if(newkeys & (8192)) 
    { 
        if(spectating[playerid] != -1 && GetPlayerState(playerid) == (9)) 
        { 
            if(spectating[playerid] <= 0) spectating[playerid] = GetPlayerPoolSize(); 
            else spectating[playerid]--; 
            if(spectating[playerid] == (0xFFFF)) {
            	spectating[playerid] = GetPlayerPoolSize();
            }
            return UpdateSpectatingStatus(playerid, spectating[playerid]); 
        } 
    } 

    if(newkeys & (16384)) 
    { 
        if(spectating[playerid] != -1 && GetPlayerState(playerid) == (9)) 
        { 
            if(spectating[playerid] >= GetPlayerPoolSize()) spectating[playerid] = 0; 
            else spectating[playerid]++; 
            if(spectating[playerid] == (0xFFFF)) {
            	spectating[playerid] = GetPlayerPoolSize();
            }
            return UpdateSpectatingStatus(playerid, spectating[playerid]); 
        } 
    } 
    return 1; 



}  

