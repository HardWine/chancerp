DialogCreate:BecomeMateAgreement(playerid) {
		new mate = GetPVarInt(playerid, "mate_inv");

		format(small_string, sizeof small_string, ""COLOR_GREEN"%s"COLOR_WHITE" приглашает вас в команду. Вы согласны?", 
		PlayerInfo[mate][pName]
		);

		Dialog_Open(playerid, Dialog:BecomeMateAgreement, DIALOG_STYLE_MSGBOX,
	        "Приглашение",
	        small_string,
	        "Да", "Нет");
}

DialogResponse:BecomeMateAgreement(playerid, response, listitem, inputtext[]) {
	new mate = GetPVarInt(playerid, "mate_inv");
	if(!response) {
		
		SetPVarInt(playerid, "mate", -1);
		SetPVarInt(mate, "mate", -1);
		DeletePVar(playerid, "mate_inv");
		DeletePVar(playerid, "mate_inv");
		SendClientMessage(playerid, -1, ""COLOR_ORANGE"Вы отклонили приглашение");
		SendClientMessage(mate, -1, ""COLOR_ORANGE"Ваше приглашение отклонили");
		return 0;
	} else {
		SetPVarInt(playerid, "mate", mate);
		SetPVarInt(mate, "mate", playerid);
		SendClientMessage(playerid, -1, ""COLOR_BLUE"Вы приняли приглашение");
		SendClientMessage(mate, -1, ""COLOR_GREEN"Ваше приглашение приняли");
	}
	return 1;
}


CMD:mate(playerid, params[0]) {
	if(IsAGov(playerid)) return 1;
	if(GetPVarInt(playerid, "mate") != -1) {
		format(small_string, sizeof(small_string), ""COLOR_BLUE"Команда: "COLOR_WHITE"%s[%d], %s[%d]", PlayerInfo[playerid][pName], playerid, PlayerInfo[params[0]][pName], params[0]);
		SendClientMessage(playerid, -1, "Чтобы покинуть команду, используйте: /leave");
		return 1;
	}
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, -1, "Используйте: /mate [id игрока]");
	if(IsAGov(params[0])) return 1;
	if(params[0] == playerid) return 1;
	if(GetPVarInt(params[0], "mate") != -1) return SendClientMessage(playerid, -1, ""COLOR_RED"Игрок уже в команде или рассматривает другое приглашение");
	if(GetDistanceBetweenPlayerz(playerid, params[0], 8.00) != 1) return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Вы слишком далеко от указанного игрока");
	SetPVarInt(playerid, "mate_inv", params[0]);
	SetPVarInt(params[0], "mate_inv", playerid);
	Dialog_Show(params[0], Dialog:BecomeMateAgreement);
	SendClientMessage(playerid, -1, ""COLOR_BLUE"Приглашение в команду отправлено");
	return 1;
}

CMD:leave(playerid) {

	if(GetPVarInt(playerid, "robbing_now") == 1) return 1;

	new mate = GetPVarInt(playerid, "mate");

	if(mate != -1) {
		if(GetPVarInt(mate, "mate") == playerid) {
			SetPVarInt(mate,  "mate", -1);
			SendClientMessage(playerid, -1, ""COLOR_ORANGE"Ваша команда расформирована");
			SendClientMessage(mate, -1, ""COLOR_RED"Ваш партнер покинул команду");
		}
		SetPVarInt(playerid, "mate", -1);
	} else {
		return SendClientMessage(playerid, -1, ""COLOR_RED"Вы не в команде!");
	}
	return 1;
}

CMD:rob(playerid) {

	if(IsAGov(playerid)) return 1;
	new player_world = GetPlayerVirtualWorld(playerid),
		menuid = player_world-DOOR_VW_ADDENDUM,	
		mate = GetPVarInt(playerid, "mate"),
		RobberyTime;

	if(player_world >= 100 && player_world <= 198) {

		if(BusinessInfo[menuid][ID] != -1) {
			//SendClientMessage(playerid, -1, "Вы в бизе");
		} else {
			//SendClientMessage(playerid, -1, "Вы не в бизе");	
			return 1;
		}


		if(BusinessInfo[menuid][Rob] > 0) return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Бизнес был недавно ограблен");
		if(mate != -1) {		
			if(GetDistanceBetweenPlayerz(playerid, mate, 15.00) == 1) {
				RobberyTime = 55000+Random(0,30000);
				if(GetPVarInt(mate, "Hidden") != 1) {
					PlayerInfo[mate][pWanted] += 900;
					SetPlayerWanted(mate, PlayerInfo[mate][pWanted]);
				}	
			} else {
				SendClientMessage(playerid, -1, "Ваш партнер слишком далеко!");
				SendClientMessage(playerid, -1, "Хотите провести ограбление в одиночку? Оставьте партнера (/leave)");
				return 1;
			}
		} else {
			RobberyTime = 80000+Random(0,25000);
		}

		if(GetPVarInt(playerid, "Hidden") != 1) {
			PlayerInfo[playerid][pWanted] += 900;
			SetPlayerWanted(playerid, PlayerInfo[playerid][pWanted]);
		}		

		RobTimer[playerid] = KillTimer(RobTimer[playerid]);
		RobTimer[playerid] = SetTimerEx("StartRobbery", RobberyTime, 0, "iii", menuid, playerid);

		format(small_string, sizeof(small_string), ""COLOR_BLUE"Вы начали ограбление "COLOR_WHITE"%s!", Properties[menuid][IName]);

		SendClientMessage(playerid, -1, small_string);
		SendClientMessage(mate, -1, small_string);

		SendClientMessage(playerid, -1, ""COLOR_RED"Покинув здание вы провалите ограбление");
		SendClientMessage(mate, -1, ""COLOR_RED"Покинув здание вы провалите ограбление");

		new normaltime = RobberyTime/1000;
		BusinessInfo[menuid][Rob] = 300+normaltime;

		SetPVarInt(playerid, "MinusTime", normaltime);
		SetPVarInt(mate, "MinusTime", normaltime);

		SetPVarInt(playerid, "robbing_now", 1);
		SetPVarInt(mate, "robbing_now", 1);

		new armed = 0,
			a_factor,
			chance_succeed;

		if(GetPlayerWeapon(playerid) >= 22 && GetPlayerWeapon(playerid) <= 32) armed += 1;
		if(mate != -1) {
			if(GetPlayerWeapon(mate) >= 22 && GetPlayerWeapon(mate) <= 32) armed += 1;
		}

		if(armed == 1) chance_succeed = 1;
		if(armed == 2) chance_succeed = 2;

		chance_succeed = RandomEx(0,a_factor);

		if(armed == 0) chance_succeed = 0;

		if(chance_succeed == 0) {
			new Float:dist;
			new bz = menuid;
			bz = bz+1;
			foreach(new i: Player) {
				if(IsACop(i)) {
					dist = GetPlayerDistanceFromPoint(i, Pickup[bz][ent_X], Pickup[bz][ent_Y], Pickup[bz][ent_Z]);
					format(small_string, sizeof(small_string), ""COLOR_RED"Поступил сигнал тревожной кнопки из "COLOR_WHITE"%s [ID: %d] (%.2fм.)", Properties[bz][IName], bz, dist);
					SendClientMessage(i, -1, small_string);
					SendClientMessage(i, -1, ""COLOR_RED"Чтобы поставить метку на карте введите: {FFFFFF}/gb [ID бизнеса]");
				}
			}
		}
	}
	//InterpolateCameraPos(playerid, RobberyCam[menuid][E_FROM_X], RobberyCam[menuid][E_FROM_Y], RobberyCam[menuid][E_FROM_Z], RobberyCam[menuid][E_FROM_TO_X], RobberyCam[menuid][E_FROM_TO_Y], RobberyCam[menuid][E_FROM_TO_Z], 60000);
	//InterpolateCameraLookAt(playerid, RobberyCam[menuid][E_LOOK_FROM_X], RobberyCam[menuid][E_LOOK_FROM_Y], RobberyCam[menuid][E_LOOK_FROM_Z], RobberyCam[menuid][E_LOOK_TO_X], RobberyCam[menuid][E_LOOK_TO_Y], RobberyCam[menuid][E_LOOK_TO_Z], 60000);

	//SetPlayerVirtualWorld(playerid, 0);
	//SetPlayerInterior(playerid, 0);
	return 1;
}

CMD:gb(playerid, params[]) {
	//if(!IsAGov(playerid)) return 1;
	if(sscanf(params,"d",params[0])) return SendClientMessage(playerid, -1, ""COLOR_RED"Используйте: /gb [ID бизнеса]");
	if(params[0] < 0 || params[0] > 103) return 1;
	
	new menuid = params[0];
	menuid = menuid-1;

	SetPVarInt(playerid, "gb", 1);

	SendClientMessage(playerid, -1, ""COLOR_RED"Бизнес отмечен красным маркером на карте");

	SetPlayerRaceCheckpoint(playerid, 1, Pickup[menuid][ent_X], Pickup[menuid][ent_Y], Pickup[menuid][ent_Z], Pickup[menuid][ent_X], Pickup[menuid][ent_Y], Pickup[menuid][ent_Z], 5);
	return 1;
}

forward StartRobbery(menuid, playerid);
public StartRobbery(menuid, playerid) {
	RobTimer[playerid] = KillTimer(RobTimer[playerid]);

	DeletePVar(playerid, "robbing_now");

	if(BusinessInfo[menuid][Income] <= 0) {
		SendClientMessage(playerid, -1, ""COLOR_RED"В кассе не оказалось денег!");
		SendClientMessage(playerid, -1, ""COLOR_RED"Со злости вы разбили витрины и ранили продавца");
		SendClientMessage(playerid, -1, ""COLOR_RED"Продавец отдал все наличные которые были при нём");
	}
	
	new mate = GetPVarInt(playerid, "mate");
	new jackpot = 0;

	new income_month = Properties[menuid][ICost]/30;
	new income_hourly = income_month/24;
	new income_shave = income_hourly/2;	

	if(income_hourly > 150) income_hourly = 150+RandomEx(0,9);

	format(small_string, sizeof(small_string), ""COLOR_GREEN"Бизнес ограблен. Прибыль: "COLOR_WHITE"%d EXP", income_hourly/2);

	if(PlayerInfo[playerid][pJailed] == 0) {
		AddPlayerEXP(playerid, (income_hourly/2), "Ограбление бизнеса");
		jackpot += 1;
		SendClientMessage(playerid, -1, small_string);
		DecreaseKarma(playerid);
	}
	if(mate != -1) {
		if(PlayerInfo[mate][pJailed] == 0) {
			AddPlayerEXP(mate, (income_hourly/2), "Ограбление бизнеса");
			jackpot += 1;
			SendClientMessage(mate, -1, small_string);
			DecreaseKarma(mate);
		}
	}

	if(jackpot != 0 && BusinessInfo[menuid][Income] > 0) {
		printf("[bizz_debug] [bid:%d] ОГРАБИЛИ нахуй было: %d", menuid, BusinessInfo[menuid][Income]);
		if(jackpot == 1) BusinessInfo[menuid][Income] -= income_shave;
		if(jackpot == 2) BusinessInfo[menuid][Income] -= income_hourly;
		SetBusinessInt("Income", BusinessInfo[menuid][Income], menuid);	
		printf("[bizz_debug] [bid:%d] ОГРАБИЛИ нахуй стало: %d", menuid, BusinessInfo[menuid][Income]);
	}
	return 1;
}

