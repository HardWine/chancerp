stock Cell_PrecomputeMaskPermutation(m)
{

	new
		mk = ~m << 1,
		mp,
		mv,
		masks[5];

	for (new i = 0; i != 5; ++i)
	{

		mp = mk ^ (mk <<  1),
		mp = mp ^ (mp <<  2),
		mp = mp ^ (mp <<  4),
		mp = mp ^ (mp <<  8),
		mp = mp ^ (mp << 16),

		masks[i] = mv = mp & m,

		m = m ^ mv | (mv >>> (1 << i)),
		mk = mk & ~mp;
	}
	return masks;
}

