	PlayerInfo[playerid][pFightMaster] = cache_get_field_content_int(0, "FightMaster");

	PlayerFarming[playerid] = cache_get_field_content_int(0, "Farming");
	PlayerFirstClassPilot[playerid] = cache_get_field_content_int(0, "FirstClassPilot");
	PlayerHeavyLoad[playerid] = cache_get_field_content_int(0, "HeavyLoad");
