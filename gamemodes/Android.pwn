			format(small_string, sizeof(small_string), ""COLOR_GREEN"Вы приобрели {FFFFFF}%d"COLOR_GREEN" грамм наркотиков за {FFFFFF}%d EXP"COLOR_GREEN". Использовать: {FFFFFF}/drugs", drugAmount, drugAmount*DRUG_SELL_PRICE);
			SendClientMessage(playerid, -1, small_string);
