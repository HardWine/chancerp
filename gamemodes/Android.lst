	            SendClientMessage(playerid, 0xEB4949FF, "[AC] " "Âű áűëč ęčęíóňű ďî ďîäîçđĺíčţ â ÷čňĺđńňâĺ! (code #1 > OnFoot: Fly / Surf / Slapper)");
	            format(small_string, sizeof(small_string), "[A] %s(%i) áűë ęčęíóň. (code #1 > OnFoot: Fly / Surf / Slapper)", PlayerInfo[playerid][pName], playerid);
