CMD:ahelp(playerid, params[]) {
	new
		admin_level = GetPlayerAdminLevel(playerid);

	if(admin_level == 0) {
		return 0;
	}

	if(admin_level >= 1) {
		SendClientMessage(playerid, -1, !""COLOR_GREEN"Доступные команды:");
		SendClientMessage(playerid, -1, !"1 уровень: /a /pm /thx /admins /sh /re /reoff /abar /g /ac_off");
	}
	if(admin_level >= 2) {
		SendClientMessage(playerid, -1, !"2 уровень: /mute /unmute /respawn /togphone /ping /setvh /setfuel");
	}
	if(admin_level >= 3) {
		SendClientMessage(playerid, -1, !"3 уровень: /kick /jail /unjail /tp /weapon /org /hp");
	}
	if(admin_level >= 4) {
		SendClientMessage(playerid, -1, !"4 уровень: /msg /prize /gethere /ban /offjail /offmute /sethp /getban");
	}
	if(admin_level >= 5) {
		SendClientMessage(playerid, -1, !"5 уровень: /spawncars /sban /offban /skick /car /delcar (all)");
		SendClientMessage(playerid, -1, !"5 уровень: /auninvite /cc /skin /unban /gzcolor /whois");
	}
	return 1;
}
CMD:getban(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) < 4) {
		return false;
	}

	new
		target_name[MAX_PLAYER_NAME + 1];

	if(sscanf(params, "s[24]", target_name)) {
		SendClientMessage(playerid, -1, !"Используйте: /getban [Ник игрока]");
		return false;
	}

	new
		target_accID = Player.GetPlayerAccID(target_name);

	if(target_accID == INVALID_ACCOUNT_ID) {
		format(small_string, sizeof(small_string), "Указанный Вами аккаунт "COLOR_ORANGE"%s"COLOR_WHITE" не существует", target_name);
		SendClientMessage(playerid, -1, small_string);
		return false;
	}

	mysql_format(database, big_string, sizeof(big_string),
		"SELECT IFNULL(p.Name, '-') as UnBannedName, b.Reason, b.BanTime, b.UnBanTime FROM player_banned AS b LEFT OUTER JOIN players AS p ON p.ID = b.AdminID WHERE PlayerID = %i ORDER BY b.ID DESC LIMIT 15",
		target_accID
	);
	mysql_query(database, big_string, true);

	new
		rows = cache_get_row_count();

	if(rows == 0) {
		format(small_string, sizeof(small_string), "Указанный Вами аккаунт "COLOR_ORANGE"%s"COLOR_WHITE" не имеел блокировок", target_name);
		SendClientMessage(playerid, -1, small_string);
		return false;
	} else {
		new
			bantime[20 + 1],
			unbantime[20 + 1],
			unbanadmin[MAX_PLAYER_NAME + 1],
			reason[48 + 1];

		if(Platform[playerid] != 0) {
			huge_string = !"Дата блокировки\tДата разблокировки\tПричина\tРазблокирован\n";
		} else {
		   huge_string = !""COLOR_BLUE"Дата блокировки\tДата разблокировки\tПричина\tРазблокирован\n\n"COLOR_WHITE"";
		}
		for(new i = 0; i < rows; i++) {
			cache_get_field_content(i, "BanTime", bantime);
			cache_get_field_content(i, "UnBanTime", unbantime);
			cache_get_field_content(i, "Reason", reason);
			cache_get_field_content(i, "UnBannedName", unbanadmin);

			format(big_string, sizeof(big_string),
				"%s\t%s\t%s\t%s\n",
					bantime,
					unbantime,
					reason,
					unbanadmin
			);
			strcat(huge_string, big_string);
		}


		if(Platform[playerid] != 0) {
			format(small_string, sizeof(small_string), ""COLOR_BLUE"Информация о блокировках %s", target_name);
			SPD(playerid, DIALOG_INFO, DIALOG_STYLE_TABLIST_HEADERS, small_string, huge_string, "Закрыть", "");
		} else {
			format(small_string, sizeof(small_string), "Информация о блокировках %s", target_name);
			SPD(playerid, DIALOG_INFO, DIALOG_STYLE_MSGBOX, small_string, huge_string, "Закрыть", "Закрыть");
		}
	}

	return true;
}

CMD:unban(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) < 5) {
		return false;
	}

	new
		target_name[MAX_PLAYER_NAME + 1],
		reason[48 + 1];

	if(sscanf(params, "s[24]s[48]", target_name, reason)) {
		SendClientMessage(playerid, -1, !"Используйте: /unban [Ник игрока] [Причина]");
		return false;
	}

	new
		target_accID = Player.GetPlayerAccID(target_name);

	if(target_accID == INVALID_ACCOUNT_ID) {
		format(small_string, sizeof(small_string), "Указанный Вами аккаунт "COLOR_ORANGE"%s"COLOR_WHITE" не существует", target_name);
		SendClientMessage(playerid, -1, small_string);
		return false;
	}
	if(BanPlayer.IsAccBanned(target_accID) == -1) {
		format(small_string, sizeof(small_string), "Указанный Вами аккаунт "COLOR_ORANGE"%s"COLOR_WHITE" не заблокирован, либо уже вышел срок блокировки", target_name);
		SendClientMessage(playerid, -1, small_string);
		return false;
	}

	format(small_string, sizeof(small_string), ""COLOR_RED"[A] Администратор %s(%i) разблокировал игрока %s. Причина: %s", PlayerInfo[playerid][pName], playerid, target_name, reason);
	SendAdminMessage(-1, small_string);

	BanPlayer.UnBanPlayer(target_accID, GetPlayerAccountID(playerid), reason);
	return true;
}
CMD:id(playerid, params[])
{
	if(!(1 <= strlen(params) <= MAX_PLAYER_NAME-4))
	{
		return SendClientMessage(playerid, -1, "Используйте: /id [часть имени игрока]");
	}

	SendClientMessage(playerid, -1, "Результаты поиска:");
	
	new message[12+11+MAX_PLAYER_NAME],
		bool:isfound = false;
	for(new i; i < MAX_PLAYERS; i++)
	{
		if(GetPlayerName(i, message, MAX_PLAYER_NAME))
		{
			if(strfind(message, params, true) != -1)
			{
				isfound = true;
				format(small_string, sizeof(small_string), "ID: %d | Имя: %s", i, message);
				SendClientMessage(playerid, -1, small_string);
			}
		}
	}
	if(isfound == false)
	{
		SendClientMessage(playerid, -1, "Поиск не дал результатов!");
	}
	return 1;
}  

CMD:ping(playerid,params[])
{
	if(GetPlayerAdminLevel(playerid) < 2) {
		return 0;
	}

	new
		targetid;

	if(sscanf(params, "u", targetid)) {
		SendClientMessage(playerid, -1, "Используйте: /ping [Ник/Часть ника]");
		return 0;
	}

	if(!IsPlayerConnected(targetid))
		return SendClientMessage(playerid, -1, "Игрока нет в сети!");

	format(small_string, sizeof(small_string), "Пинг игрока %s(%d) - %i", PlayerInfo[targetid][pName], targetid, GetPlayerPing(targetid));
	SendClientMessage(playerid, -1, small_string);
	return true;
}

CMD:reoff(playerid,params[])
{
	if(GetPlayerAdminLevel(playerid) < 1) return true;
	
	StopSpectate(playerid);
	return 1;
}
CMD:respawn(playerid,params[])
{
	if(GetPlayerAdminLevel(playerid) < 1) {
		return true;
	}
	if(GetPlayerState(playerid) == PLAYER_STATE_SPECTATING) {
		return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Выйдите из слежки.");
	}

	SpawnPlayer(playerid);
	return 1;
}
CMD:kick(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) < 3) return true;
	new giveplayerid, result[128];
	if(sscanf(params, "ds[64]", giveplayerid, result)) return SendClientMessage(playerid, -1, !"Используйте: /kick [id игрока] [причина]");
	if(giveplayerid == INVALID_PLAYER_ID) return 1;
	if(GetPlayerAdminLevel(giveplayerid) > 5) return true;
	format(small_string, sizeof(small_string), ""COLOR_RED"Администратор %s отключил %s от сервера. Причина: %s", PlayerInfo[playerid][pName], PlayerInfo[giveplayerid][pName], result);
	SendJudgeMessageToAll(small_string, giveplayerid);
	Admin.UpCountKick(GetPlayerAccountID(playerid));

 	admstat[5]++;
	upd_admstat();	

	return Kick(giveplayerid);
}
CMD:skick(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) < 5) return true;
	new giveplayerid, result[128];
	if(sscanf(params, "ds[64]", giveplayerid, result)) return SendClientMessage(playerid, -1, !"Используйте: /skick [id игрока] [причина]");
	if(giveplayerid == INVALID_PLAYER_ID) return 1;
	if(GetPlayerAdminLevel(giveplayerid) > 5) return true;
	format(small_string, sizeof(small_string), "[A]"COLOR_RED"Администратор %s тихо отключил %s от сервера. Причина: %s", PlayerInfo[playerid][pName], PlayerInfo[giveplayerid][pName], result);
	SendAdminMessage(-1, small_string);
	Admin.UpCountKick(GetPlayerAccountID(playerid));

 	admstat[5]++;
	upd_admstat();	


	return Kick(giveplayerid);
}
CMD:ban(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) < 4) return true;
	new giveplayerid, result[MAX_ADMIN_REASON];
	new days;
	if(sscanf(params, "rI(2038)S(Нарушение правил сервера)[47]", giveplayerid, days, result)) return SendClientMessage(playerid, -1, "Используйте: /ban [id игрока] [кол-во дней] [причина]");
	// if(giveplayerid == INVALID_PLAYER_ID) return 1;
	// if(GetPlayerAdminLevel(giveplayerid) > 5) return true;
	if(days < 2 && days != 2038) {
		return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Количество дней должно быть в диапозоне от 2 до 30");
	}
	if(days > 30 && days != 2038) {
		return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Количество дней должно быть в диапозоне от 2 до 30");
	}
	if(days == 2038) {

		static string[144];
		mysql_format(database,
			string, sizeof(string),
			"INSERT INTO "TABLE_BANIP" (`IP`) VALUES ('%s')",
				ipsget[giveplayerid]
		);
		mysql_pquery(database, string);

		days = 365*19;
		format(small_string, sizeof(small_string), ""COLOR_RED"Администратор %s заблокировал игрока %s. Причина: %s", PlayerInfo[playerid][pName], PlayerInfo[giveplayerid][pName], result);
	} else {
		format(small_string, sizeof(small_string), ""COLOR_RED"Администратор %s заблокировал игрока %s на %i дней. Причина: %s", PlayerInfo[playerid][pName], PlayerInfo[giveplayerid][pName], days, result);
	}

	SendJudgeMessageToAll(small_string, giveplayerid);

 	RemovePlayerFraction(giveplayerid, true);

 	PlayerInfo[giveplayerid][pStatus] = 0;
 	SetPlayerInt(giveplayerid, "Status", PlayerInfo[giveplayerid][pStatus]);
 	PlayerInfo[giveplayerid][pRank] = 0;
 	SetPlayerInt(giveplayerid, "Rank", PlayerInfo[giveplayerid][pRank]);	

	BanPlayer.BanPlayer(GetPlayerAccountID(giveplayerid), GetPlayerAccountID(playerid), result, days);
	Admin.UpCountBan(GetPlayerAccountID(playerid));

	admstat[2]++;
	upd_admstat();

	return true;
}

CMD:abar(playerid, params[])
{

	if(GetPlayerAdminLevel(playerid) == 0) return true;
	SetPlayerPos(playerid, 2144.7192,2436.8203,10.8231);
	SetPlayerFacingAngle(playerid, 280);
	SetPlayerInterior(playerid, 1);
	SetPlayerVirtualWorld(playerid, 400);
	return 1;
}
CMD:sethp(playerid, params[])
{
	if(4 > GetPlayerAdminLevel(playerid))
		return 1;

	new
		targetid,
		amount;

	if(sscanf(params, "uI(100)", targetid, amount)) return SendClientMessage(playerid, -1, "Используйте: /sethp [id игрока] [значение]");
	if(!(0 <= amount <= 100)) return SendClientMessage(playerid, -1, "Количество здоровья от 0 до 100");

	SetPlayerHealth(targetid, amount);
	if(IsPlayerInAnyVehicle(playerid)) SetVehicleHealth(GetPlayerVehicleID(playerid), 1000.0);	

	static const
		fmt_str0[] = ""COLOR_RED"Администратор %s установил игроку %s здоровье: %d";

	new
		str[sizeof(fmt_str0) - 2 + MAX_PLAYER_NAME - 2 + 4 - 2 + MAX_PLAYER_NAME - 2 + 4 - 2 + 11];


	format(str, sizeof(str), fmt_str0, PlayerInfo[playerid][pName], PlayerInfo[targetid][pName], amount);
	SendAdminMessage(-1, str);
	return 1;
}
CMD:hp(playerid, params[])
{
	if(3 > GetPlayerAdminLevel(playerid))
		return 1;

	SetPlayerHealth(playerid, 100);
	if(IsPlayerInAnyVehicle(playerid)) SetVehicleHealth(GetPlayerVehicleID(playerid), 1000.0);

	static const
		fmt_str0[] = ""COLOR_ORANGE"[A] Администратор %s восстановил себе здоровье";

	new
		str[sizeof(fmt_str0) - 2 + MAX_PLAYER_NAME - 2 + 4 - 2 + MAX_PLAYER_NAME - 2 + 4 - 2 + 11];


	format(str, sizeof(str), fmt_str0, PlayerInfo[playerid][pName]);
	SendAdminMessage(-1, str);
	return 1;
}
CMD:sban(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) < 5) return true;
	new giveplayerid, result[MAX_ADMIN_REASON];
	new days;
	if(sscanf(params, "rI(2038)S(Нарушение правил сервера)[47]", giveplayerid, days, result)) return SendClientMessage(playerid, -1, "Используйте: /sban [id игрока] [кол-во дней] [причина]");
	if(giveplayerid == INVALID_PLAYER_ID) return 1;
	if(GetPlayerAdminLevel(giveplayerid) > 5) return true;
	if(days < 2 && days != 2038) {
		return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Количество дней должно быть в диапозоне от 2 до 30");
	}
	if(days > 30 && days != 2038) {
		return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Количество дней должно быть в диапозоне от 2 до 30");
	}
	//format(small_string, sizeof(small_string), ""COLOR_RED"[S-BAN] Администратор %s заблокировал %s на %i дней. Причина: %s", PlayerInfo[playerid][pName], PlayerInfo[giveplayerid][pName], days, result);
	if(days == 2038) {

		static string[144];
		mysql_format(database,
			string, sizeof(string),
			"INSERT INTO "TABLE_BANIP" (`IP`) VALUES ('%s')",
				ipsget[giveplayerid]
		);
		mysql_pquery(database, string);

		days = 365*19;
		format(small_string, sizeof(small_string), "[S-BAN] "COLOR_RED"Администратор %s заблокировал игрока %s. Причина: %s", PlayerInfo[playerid][pName], PlayerInfo[giveplayerid][pName], result);
	} else {
		format(small_string, sizeof(small_string), "[S-BAN] "COLOR_RED"Администратор %s заблокировал игрока %s на %i дней. Причина: %s", PlayerInfo[playerid][pName], PlayerInfo[giveplayerid][pName], days, result);
	}


	SendAdminMessage(-1, small_string);

 	RemovePlayerFraction(giveplayerid, true);

 	PlayerInfo[giveplayerid][pStatus] = 0;
 	SetPlayerInt(giveplayerid, "Status", PlayerInfo[giveplayerid][pStatus]);
 	PlayerInfo[giveplayerid][pRank] = 0;
 	SetPlayerInt(giveplayerid, "Rank", PlayerInfo[giveplayerid][pRank]);	

 	admstat[2]++;
	upd_admstat();	

	BanPlayer.BanPlayer(GetPlayerAccountID(giveplayerid), GetPlayerAccountID(playerid), result, days);
	Admin.UpCountBan(GetPlayerAccountID(playerid));
	return true;
}
CMD:jail(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) < 3) return true;
	if(sscanf(params,"rI(30)S(Нарушение правил сервера)[128]", params[0],params[1],params[2])) return SendClientMessage(playerid, -1, !"Используйте: /jail [id игрока] [минуты] [причина]");
	if(params[0] == INVALID_PLAYER_ID) return 1;
	if(params[1] > 360) return SendClientMessage(playerid, -1, !""COLOR_ORANGE"Максимальное время тюрьмы - 180 минут");
	if(GetPlayerAdminLevel(params[0]) > 0) return true;
	format(small_string, sizeof(small_string), ""COLOR_RED"Администратор %s посадил в тюрьму %s на %d минут. Причина: %s", PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName], params[1], params[2]);
	SendJudgeMessageToAll(small_string, params[0]);
	RemovePlayerFromVehicle(params[0]);
	ResetPlayerWeapons(params[0]);
	PlayerInfo[params[0]][pJailed] = 2;
	PlayerInfo[params[0]][pJailTime] = params[1] * 60;
	SetPlayerInt(params[0], "Jailed", PlayerInfo[params[0]][pJailed]);
	SetPlayerInt(params[0], "JailTime", PlayerInfo[params[0]][pJailTime]);
	Admin.UpCountJail(GetPlayerAccountID(playerid));


 	admstat[4]++;
	upd_admstat();	

	return true;
}
CMD:unjail(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) < 3) return true;
	if(sscanf(params,"d", params[0])) return SendClientMessage(playerid, -1, !"Используйте: /unjail [id игрока]");
	if(PlayerInfo[params[0]][pJailed] == 0) return 1;
	if(params[0] == INVALID_PLAYER_ID) return 1;
	format(small_string, sizeof(small_string), ""COLOR_RED"Администратор %s выпустил из тюрьмы %s", PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName]);
	if(GetPlayerAdminLevel(params[0]) == 0) SendClientMessageToAll(-1, small_string);
	PlayerInfo[params[0]][pJailed] = 0;
	PlayerInfo[params[0]][pJailTime] = 0;
	SetPlayerInt(params[0], "Jailed", PlayerInfo[params[0]][pJailed]);
	SetPlayerInt(params[0], "JailTime", PlayerInfo[params[0]][pJailTime]);
	SpawnPlayer(params[0]);
	return true;
}
CMD:mute(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) == 0) return true;
	if(sscanf(params,"dI(30)S(Нарушение правил сервера)[128]", params[0],params[1],params[2])) return SendClientMessage(playerid, -1, "Используйте: /mute [id игрока] [минуты] [причина]");
	if(params[0] == INVALID_PLAYER_ID) return 1;
	if(params[1] > 200) return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Максимальный бан чата - 30 минут");
	if(GetPlayerAdminLevel(params[0]) > 0) return true;

	format(small_string, sizeof(small_string), ""COLOR_RED"Администратор %s заблокировал чат игроку %s на %d минут. Причина: %s", PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName], params[1], params[2]);
	SendJudgeMessageToAll(small_string, params[0]);
	PlayerInfo[params[0]][pMuted] = 1;
	PlayerInfo[params[0]][pMuteTime] = params[1] * 60;
	SetPlayerInt(params[0], "Muted", PlayerInfo[params[0]][pMuted]);
	SetPlayerInt(params[0], "MuteTime", PlayerInfo[params[0]][pMuteTime]);
	Admin.UpCountMute(GetPlayerAccountID(playerid));


 	admstat[3]++;
	upd_admstat();	

	return true;
}
CMD:unmute(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) < 2) return true;
	if(sscanf(params,"d", params[0])) return SendClientMessage(playerid, -1, "Используйте: /unmute [id игрока]");
	if(PlayerInfo[params[0]][pMuted] < 1) return 1;
	if(params[0] == INVALID_PLAYER_ID) return 1;
	format(small_string, sizeof(small_string), ""COLOR_RED"Администратор %s разблокировал чат игроку %s", PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName]);
	SendJudgeMessageToAll(small_string, params[0]);
	PlayerInfo[params[0]][pMuted] = 0;
	PlayerInfo[params[0]][pMuteTime] = 0;
	SetPlayerInt(params[0], "Muted", PlayerInfo[params[0]][pMuted]);
	SetPlayerInt(params[0], "MuteTime", PlayerInfo[params[0]][pMuteTime]);
	return true;
}
CMD:me(playerid, params[])
{
	if(PlayerInfo[playerid][pMuted] == 1) return SendClientMessage(playerid, -1, ""COLOR_RED"У вас бан чата");
	if(sscanf(params, "s[128]",params[0])) return	SendClientMessage(playerid, -1, "Используйте: /me [действие]");
	format(small_string, sizeof(small_string), "%s %s", PlayerInfo[playerid][pName], params[0]);
	ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_PURPLE, small_string);
	SetPlayerChatBubble(playerid,params[0],C_PURPLE,30.0,10000);
	if(GetPVarInt(playerid,"Ach_RP") > gettime()) { return 1; }
	SetPVarInt(playerid,"Ach_RP",gettime() + 60);		
	AddPlayerAchievement(playerid, E_RP_OUR_ALL);
	return true;
}


CMD:s(playerid, params[])
{
	if(PlayerInfo[playerid][pMuted] == 1) return SendClientMessage(playerid, -1, ""COLOR_RED"У вас бан чата");
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, -1, "Используйте: /s [текст]");
	format(small_string, sizeof(small_string), "- %s[%d] крикнул: %s!!", PlayerInfo[playerid][pName], playerid, params[0]);
	ProxDetector(playerid, MAX_DISTANCE_VISIBLE * 2, -1, small_string);
	if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT && GetPVarInt(playerid, "MinusTime") == 0) {
		ApplyAnimation(playerid,"ON_LOOKERS","shout_in",9000.999,0,0,0,0,0,1);
	}
	SetPlayerChatBubble(playerid,params[0],0xF5DEB3AA,60.0,10000);
	return true;
}
