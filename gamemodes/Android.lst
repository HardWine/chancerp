	for(new i = 0; i < sizeof(YachtBuy); i++) {
		if(YachtBuy[i][E_VEHICLE_ID] != (0xFFFF) && IsValidVehicle(YachtBuy[i][E_VEHICLE_ID])) {
			SetVehicleParamsForPlayerEx(YachtBuy[i][E_VEHICLE_ID], playerid, 0, 1);
