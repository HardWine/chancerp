forward pc_cmd_changecar(playerid, params[]); public pc_cmd_changecar(playerid, params[]) {

	if(GetPVarInt(playerid,"deal_created") > gettime()) return SendClientMessage(playerid, -1, """{ff353c}""Ďîäîćäčňĺ íĺěíîăî");
	SetPVarInt(playerid,"deal_created",gettime()+30);
	if(!IsValidVehicle(caridhouse[playerid])) return 1;

	if(sscanf(params, "ii", params[0], params[1])) return SendClientMessage(playerid, -1, !"Čńďîëüçóéňĺ: /changecar [id čăđîęŕ] [äîďëŕňŕ ďîęóďŕňĺë˙]");
	if(PlayerLogged{params[0]} == false || !IsPlayerConnected(params[0])) return 0;
	if(GetDistanceBetweenPlayerz(playerid, params[0], 10.00) != 1) return SendClientMessage(playerid, -1, """{ff353c}""Âű ńëčřęîě äŕëĺęî îň óęŕçŕííîăî čăđîęŕ");

	new price = 0;

	if(PlayerInfo[playerid][pTransferControl] == 2)
		return SendClientMessage(playerid, -1, """{ff353c}""Äîńňčăíóň ëčěčň ńäĺëîę ďî ňđŕíńďîđňó íŕ ńĺăîäí˙");
	if(PlayerInfo[params[0]][pTransferControl] == 2)
		return SendClientMessage(playerid, -1, """{ff353c}""Čăđîęîě äîńňčăíóň ëčěčň ńäĺëîę ďî ňđŕíńďîđňó íŕ ńĺăîäí˙");

	if(PlayerInfo[playerid][pDebt] > 1000) return SendClientMessage(playerid, -1, """{ff353c}""Âŕřč řňđŕôű ďđĺâűřŕţň ""{FFFFFF}""1000 EXP""{ff353c}"", âű íĺ ěîćĺňĺ ńîâĺđřŕňü ńäĺëęč");
	if(PlayerInfo[params[0]][pDebt] > 1000) return SendClientMessage(playerid, -1, """{ff353c}""Řňđŕôű óęŕçŕííîăî čăđîęŕ ďđĺâűřŕţň ""{FFFFFF}""1000 EXP""{ff353c}"", âű íĺ ěîćĺňĺ çŕęëţ÷čňü ń íčě ńäĺëęó");


	if(PlayerInfo[playerid][pSelectedSlot] == 1) {
		if(PlayerInfo[playerid][pCarRoulet1] == 1) {
			SendClientMessage(playerid, -1, """{ff353c}""Âŕř ňđŕíńďîđň áűë âűéăđŕí â đóëĺňęĺ");
			return 1;
		}
		if(PlayerInfo[params[0]][pCarRoulet1] == 1) {
			SendClientMessage(playerid, -1, """{ff353c}""Ňđŕíńďîđň čăđîęŕ âűéăđŕí â đóëĺňęĺ");
			return 1;
		}
	    for(new i = 0; i < 87; i++) {
	        if(AutoSalee[i][AS_ModelID] == PlayerInfo[playerid][pCar]) {
	            price = AutoSalee[i][AS_Score];
	        }
	    }
	} else {
		if(PlayerInfo[playerid][pCarRoulet2] == 1) {
			SendClientMessage(playerid, -1, """{ff353c}""Âŕř ňđŕíńďîđň áűë âűéăđŕí â đóëĺňęĺ");
			return 1;
		}
		if(PlayerInfo[params[0]][pCarRoulet2] == 1) {
			SendClientMessage(playerid, -1, """{ff353c}""Ňđŕíńďîđň čăđîęŕ âűéăđŕí â đóëĺňęĺ");
			return 1;
		}
	    for(new i = 0; i < 87; i++) {
	        if(AutoSalee[i][AS_ModelID] == PlayerInfo[playerid][pCar2]) {
	            price = AutoSalee[i][AS_Score]*2;
	        }
	    }
	}

    if(price == 0) return SendClientMessage(playerid, -1, !"Äŕííîĺ ňđŕíńďîđňíîĺ ńđĺäńňâî čńęëţ÷čňĺëüíî. Îáěĺí íĺâîçěîćĺí");
	if(params[1] <= 0) return SendClientMessage(playerid, -1, """{ff353c}""Íĺęîđđĺęňíŕ˙ öĺíŕ");
	if(params[1] > price) return SendClientMessage(playerid, -1, """{ff353c}""Äîďëŕňŕ äîëćíŕ áűňü íĺ âűřĺ äâîéíîé đűíî÷íîé ńňîčěîńňč ňđŕíńďîđňŕ");
	if(params[0] == playerid || params[0] == (0xFFFF)) return SendClientMessage(playerid, -1, "Íĺâĺđíűé ID");
	if(caridhouse[params[0]] == (0xFFFF)) return SendClientMessage(playerid, -1, "Ó čăđîęŕ íĺň äîěŕ äë˙ ďŕđęîâęč ňđŕíńďîđňŕ");

	SetPVarInt(playerid, "buyer_house", params[0]);
	SetPVarInt(playerid, "price_house", params[1]);


	if(PlayerInfo[params[0]][pSelectedSlot] == 1 && PlayerInfo[playerid][pSelectedSlot] == 1) {
	format(big_string, sizeof big_string, 
		"{FFFFFF}Âű ďđĺäëîćčëč îáěĺí ňđŕíńďîđňŕ %s\n""{ff353c}""Âű îňäŕĺňĺ: {FFFFFF}%s (%dęě.)\n""{6de64e}""Âű ďîëó÷ŕĺňĺ: {FFFFFF}%s (%dęě.), %d EXP\n\n""{FFAF00}""×ňîáű ďîäňâĺđäčňü ńäĺëęó íŕćěčňĺ - Äŕëĺĺ", 
		PlayerInfo[params[0]][pName], 
		GetVehicleText(PlayerInfo[playerid][pCar]), 
		PlayerInfo[playerid][pMileage]/1000,
		GetVehicleText(PlayerInfo[params[0]][pCar]), 
		PlayerInfo[params[0]][pMileage]/1000,
		params[1]);
	}
	if(PlayerInfo[params[0]][pSelectedSlot] == 1 && PlayerInfo[playerid][pSelectedSlot] == 2) {
	format(big_string, sizeof big_string, 
		"{FFFFFF}Âű ďđĺäëîćčëč îáěĺí ňđŕíńďîđňŕ %s\n""{ff353c}""Âű îňäŕĺňĺ: {FFFFFF}%s (%dęě.)\n""{6de64e}""Âű ďîëó÷ŕĺňĺ: {FFFFFF}%s (%dęě.), %d EXP\n\n""{FFAF00}""×ňîáű ďîäňâĺđäčňü ńäĺëęó íŕćěčňĺ - Äŕëĺĺ", 
		PlayerInfo[params[0]][pName], 
		GetVehicleText(PlayerInfo[playerid][pCar2]), 
		PlayerInfo[playerid][pMileage2]/1000,
		GetVehicleText(PlayerInfo[params[0]][pCar]), 
		PlayerInfo[params[0]][pMileage]/1000,
		params[1]);
	}
	if(PlayerInfo[params[0]][pSelectedSlot] == 2 && PlayerInfo[playerid][pSelectedSlot] == 1) {
	format(big_string, sizeof big_string, 
		"{FFFFFF}Âű ďđĺäëîćčëč îáěĺí ňđŕíńďîđňŕ %s\n""{ff353c}""Âű îňäŕĺňĺ: {FFFFFF}%s (%dęě.)\n""{6de64e}""Âű ďîëó÷ŕĺňĺ: {FFFFFF}%s (%dęě.), %d EXP\n\n""{FFAF00}""×ňîáű ďîäňâĺđäčňü ńäĺëęó íŕćěčňĺ - Äŕëĺĺ", 
