public OnVehicleSpawn(vehicleid)
{
	for(new i = 0; i < sizeof(VehicleInfo); i++) {
		if(VehicleInfo[i][VI_Owner] == VO_FRACTION_TRIADA && vehicleid == VehicleInfo[i][VI_VehicleID] && GetVehicleModel(VehicleInfo[i][VI_VehicleID]) != 487) {
			SetVehicleVirtualWorld(VehicleInfo[i][VI_VehicleID], 50000);
		}
	}	

	new engine, lights, alarm, doors, bonnet, boot, objective;
	GetVehicleParamsEx(vehicleid, engine, lights, alarm, doors, bonnet, boot, objective);
	SetVehicleParamsEx(vehicleid, 0, 0, alarm, 0, bonnet, boot, objective);
	if(IsABMX(GetVehicleModel(vehicleid)) == 1) return SetVehicleParamsEx(vehicleid, 1, 0, alarm, 0, bonnet, boot, objective);

	for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i=Iterator@Player [_: i])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);)
	{
		if(caridhouse[i] == vehicleid) {
			if(IsARadarDetectable(GetVehicleModel(vehicleid))) {

				SetVehicleParamsEx(caridhouse[i], 0, 0, alarm, 1, bonnet, boot, objective);
				return wear_elements(i);
			}
		}
	}
	return 1;
}

public OnVehicleDeath(vehicleid, killerid)
{
	for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i=Iterator@Player [_: i])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);)
	{
		if(caridhouse[i] == vehicleid) {
			if(Player__Hotel[i] != (-1)) {
				FUEL_DestroyVehicle(caridhouse[i]);
				caridhouse[i] = (0xFFFF);
			}
		}
	}
	return 1;
}

forward OffJails(playerid, name[]);
public OffJails(playerid, name[])
{
		new rows = cache_get_row_count();
		if(!rows) return SendClientMessage(playerid, -1, """{ff353c}""Ŕęęŕóíň íĺ íŕéäĺí"); 
		new temp_int, admin_int;
		temp_int = cache_get_field_content_int(0, "isOnline");
		admin_int = cache_get_field_content_int(0, "Admin");
		if(temp_int == 1) {
			return SendClientMessage(playerid, -1, """{ff353c}""Čăđîę íŕőîäčňń˙ â ńĺňč");
		}
		if(admin_int > 0) {
			return 1;
		}
		new string[256],reason[32]; 
		GetPVarString(playerid,"OffJailReason",reason,sizeof(reason)); 
		format(string,sizeof(string),"UPDATE ""players"" SET `Jailed` = '2', `JailTime` = `JailTime` + '%d' WHERE `Name` = '%s'",GetPVarInt(playerid,"OffJailDay")*60, name); 
		mysql_tquery(database, string, "", ""); 

		format(small_string, sizeof(small_string), """{ff353c}""[Offline] Ŕäěčíčńňđŕňîđ %s ďîńŕäčë %s â ňţđüěó íŕ %d ěčí. Ďđč÷číŕ: %s",  PlayerInfo[playerid][pName],name, GetPVarInt(playerid,"OffJailDay"),reason);
		SendAdminMessage(-1, small_string);

		DeletePVar(playerid,"OffJailReason"); 
		DeletePVar(playerid,"OffMJailDay");
		Admin__UpCountJail(PlayerInfo[playerid][pID]);
		return 1;
}
