new park_triad = 0;

forward dre_GetCarTriad(playerid, response, listitem, inputtext[]); public dre_GetCarTriad(playerid, response, listitem, inputtext[]) {
	if(!response) {
		return 1;
	} else {

	new strval_inputtext,
		model_get;	

	if(Platform[playerid] == 0) {
		strval_inputtext = strval(inputtext);	
		if(strval_inputtext < 1 || strval_inputtext > 3) return Dialog_Show(playerid, #GetCarTriad);
		strval_inputtext--;

	} else {
		strval_inputtext = listitem;
	}

	switch(strval_inputtext) {
		case 0: model_get = 562;
		case 1: model_get = 405;
		case 2:	model_get = 409;
		default: return 1;
	}

	new got_car = 0;

	for(new i = 0; i < sizeof(VehicleInfo); i++) {
		if(VehicleInfo[i][VI_Owner] == VO_FRACTION_TRIADA && VehicleInfo[i][VI_ModelID] == model_get) {
			if(GetVehicleVirtualWorld(VehicleInfo[i][VI_VehicleID]) == 50000) {
				if(park_triad == 0) {
					park_triad = 1;
					SetVehiclePos(VehicleInfo[i][VI_VehicleID], -2109.3584,725.6940,69.2865);
					SetVehicleVirtualWorld(VehicleInfo[i][VI_VehicleID], 0);


					got_car = 1;
					SetPVarInt(playerid,"car_triad",gettime() + 60);
					RM_PutPlayerInVehicle(playerid, VehicleInfo[i][VI_VehicleID], 0);
					SetVehicleZAngle(VehicleInfo[i][VI_VehicleID], 360);
					break;	
				} else {
					SetVehiclePos(VehicleInfo[i][VI_VehicleID], -2103.3105,725.6035,69.3048);
					SetVehicleVirtualWorld(VehicleInfo[i][VI_VehicleID], 0);


					park_triad = 0;
					got_car = 1;
					SetPVarInt(playerid,"car_triad",gettime() + 60);	
					RM_PutPlayerInVehicle(playerid, VehicleInfo[i][VI_VehicleID], 0);
					SetVehicleZAngle(VehicleInfo[i][VI_VehicleID], 360);
					break;
				}
			}
		}
	}	
	if(got_car == 0) {
		Dialog_Show(playerid, #GetCarTriad);
		SendClientMessage(playerid, -1, """{ff353c}""Âńĺ ŕâňîěîáčëč äŕííîé ěîäĺëč óćĺ čńďîëüçóţňń˙");
	}
	}
	return 1;
}

