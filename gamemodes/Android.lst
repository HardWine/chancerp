ReturnUser(text[])
{
	new pos = 0;
	while (text[pos] < 0x21) 
	{
		if (text[pos] == 0) return (0xFFFF); 
		pos++;
	}
	new userid = (0xFFFF);
	if (IsNumeric(text[pos])) 
	{

		userid = strval(text[pos]);
		if (userid >=0 && userid < 126)
		{
			if(!IsPlayerConnected(userid))
			{
				userid = (0xFFFF);
			}
			else
			{
				return userid; 
			}
		}
	}

	new len = MDialog_strlen(text[pos]);
	new count = 0;
	new name[24];
	for (new i = 0; i < 126; i++)
	{
		if (IsPlayerConnected(i))
		{
			GetPlayerName(i, name, sizeof (name));
			if (strcmp(name, text[pos], true, len) == 0) 
			{
				if (len == MDialog_strlen(name)) 
				{
					return i; 



				}
				else 
				{
					count++;
					userid = i;
				}
			}
		}
	}
	if (count != 1)
	{
		userid = (0xFFFF);
	}
	return userid; 
}
IsNumeric(const string[])
{
	for (new i = 0, j = MDialog_strlen(string); i < j; i++)
	{
		if (string[i] > '9' || string[i] < '0') return 0;
	}
	return 1;
}   






GetGangName(fnumbwer)
{
	new string[40];
	switch(fnumbwer)
	{
		case 3: format(string,sizeof(string), "Ballas Gang");
		case 4: format(string,sizeof(string), "Vagos Gang");
		case 2: format(string,sizeof(string), "Grove Street");
		case 6: format(string,sizeof(string), "Aztecas");
		case 5: format(string,sizeof(string), "Rifa Gang");
		case 7: format(string,sizeof(string), "Russian Mafia");
		case 8: format(string,sizeof(string), "Triads Mafia");
		case 9: format(string,sizeof(string), "Da Nang Boys");

	}
	return string;
}

public ScriptInit_OnGameModeExit() <_ALS : _ALS_go>
{
	for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i=Iterator@Player [_: i])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);) {
		SSCANF_OnPlayerDisconnect(i, 255);
	}
	DestroyAllDynamicPickups();
	DestroyAllDynamicCPs();
	DestroyAllDynamicObjects();
	DestroyAllDynamicMapIcons();
	DestroyAllDynamic3DTextLabels();
	DestroyAllDynamicAreas();
	mysql_close(database);
	return 1;
}

forward CheckBannedIp(playerid);
public CheckBannedIp(playerid) {
	new rows = cache_get_row_count();
	if(rows)
	{
		SendClientMessage(playerid, -1, """{ff353c}""Âŕř IP Ŕäđĺń çŕáëîęčđîâŕí. Ďîďđîáóéňĺ çŕéňč â čăđó ďîçćĺ");

		dc_kickfix__Kick(playerid);
	} else {

		SetPVarInt(playerid, "OnPlayerRequestClassFix", 1);
		requestt[playerid] = KillTimer(requestt[playerid]);
		requestt[playerid] = SetTimerEx("SetPlayerCameraPosForReqClass", GetPlayerPing(playerid) + 500, 0, "i", playerid);
	}
}


public SSCANF_OnPlayerConnect(playerid)
{
	AD_OnPlayerConnect(playerid);

	PlayerInfo[playerid] = NULL_PlayerInfo;
	PlayerLogged{playerid} = false;
	RemObject(playerid);
	GetPlayerIp(playerid, ipsget[playerid], (19 + 1));

	Client[playerid] = 0;
	gpci(playerid, Client[playerid], 45);

	new sendername[24+1];
	GetPlayerName(playerid, sendername, sizeof(sendername));

	if(!strcmp(Client[playerid], """33544A514C4A433257504B36434947475545454B""")) {	
		SetPVarInt(playerid, "mobile", 1);

		if(IsRpNickname(sendername) == 0) {
			SetPVarInt(playerid, "mobile_client", 1);
			SendClientMessage(playerid, -1, """{FFAF00}""×ňîáű ęŕćäűé đŕç íĺ ââîäčňü íčę, óęŕćčňĺ ĺăî â ""{FFFFFF}""settings.ini");
			SendClientMessage(playerid, -1, """{FFAF00}""Â ďŕďęĺ ""{FFFFFF}""'andoid/data/com.rockstargames.gtasa/files/SAMP'");
			RM_ShowPlayerDialog(playerid, dName, 1, "Äîáđî ďîćŕëîâŕňü!", "Ââĺäčňĺ âŕř íčę (Čńďîëüçóéňĺ ôîđěŕň: Čě˙_Ôŕěčëč˙)", "Äŕëĺĺ", "");
		} 
		else 
		{
			LoadAccounts(playerid);
		}
	} 
	else 
	{
		LoadAccounts(playerid);
	}
	OnPlayerConnect_textdraw(playerid);

	TogglePlayerSpectating(playerid, true);

	new query_string[144];
	mysql_format(database, query_string, sizeof(query_string), "SELECT * FROM ""banned_ip"" WHERE `IP` = '%s'", ipsget[playerid]);
	mysql_tquery(database, query_string, "CheckBannedIp","i", playerid);	

	ac_1{playerid} = false; 

	SetPlayerVirtualWorld(playerid, playerid+333);

	gettime(hour, minute, seconds);

	PlayerTimerID[playerid] = KillTimer(PlayerTimerID[playerid]);
	PlayerTimerID[playerid] = SetTimerEx("PlayerUpdate", 1000, false, "d", playerid);

	secure[playerid] = 0;
	SetPVarInt(playerid, "mate", -1);

	cabClient[playerid] = (0xFFFF);
	gonecar[playerid] = (0xFFFF);
	Dealer_OnPlayerConnect(playerid);
	Porter_OnPlayerConnect(playerid);
	CallLocalFunction("Fraction_OnPlayerConnect", "i", playerid);
	CallLocalFunction("Gps_OnPlayerConnect", "i", playerid);
	CallLocalFunction("Army_OnPlayerConnect", "i", playerid);

	SetPVarInt(playerid, "SellingCar", -1);
	SetPVarInt(playerid, "CarOffer", -1);

	pPickup_Status{playerid} = false;  

	DamageTaken[playerid] = 0;

	PlayerInfo[playerid][slot_2_gun] = 0;
	PlayerInfo[playerid][slot_2_ammo] = 0;
	PlayerInfo[playerid][slot_3_gun] = 0;
	PlayerInfo[playerid][slot_3_ammo] = 0;
	PlayerInfo[playerid][slot_4_gun] = 0;
	PlayerInfo[playerid][slot_4_ammo] = 0;
	PlayerInfo[playerid][slot_5_gun] = 0;
	PlayerInfo[playerid][slot_5_ammo] = 0;
	PlayerInfo[playerid][slot_8_gun] = 0;
	PlayerInfo[playerid][slot_8_ammo] = 0;	

	Player__MafiaCP[playerid] = (-1);
	Player__SteelCar[playerid] = (-1);
	Player__FarmCP[playerid] = (-1);
	Player__PatrolCP[playerid] = (-1);
	Streamer_Update(playerid, (2));
	GangZoneShowForPlayer(playerid,gangzone,0xFF7F0066); 

	carry[playerid] = -1;
	gone[playerid] = -1;
	PlayerCar[playerid] = -1;
	CarColor[playerid] = -1;
	CarColor2[playerid] = -1;
	player_Patrol[playerid] = -1;
	ReturnTimerID[playerid] = KillTimer(ReturnTimerID[playerid]); 
	caridhouse[playerid] = (0xFFFF);
	spectating[playerid] = (0xFFFF);
	Platform[playerid] = -1;
	for(new i = 0; i < 20; i++) {
		SendClientMessage(playerid, -1, """{ff353c}""");
	}
	SendClientMessage(playerid, -1, """{4eb9e6}""Äîáđî ďîćŕëîâŕňü íŕ ďĺđâűé ęđîńńďëŕňôîđěĺííűé ďđîĺęň â ""{FFFFFF}""San Andreas Multiplayer");
	SendClientMessage(playerid, -1, """{4eb9e6}""Ďîńĺňčňĺ íŕřĺ ńîîáůĺńňâî Âęîíňŕęňĺ: ""{FFFFFF}""vk.com/ChanceRp");
	format(small_string,
		sizeof(small_string),
		"""{4eb9e6}""Ňĺęóůčé îíëŕéí íŕ Chance RolePlay: ""{FFFFFF}""%d čăđîęîâ",
		(_:F@i:(Iter_Single@Player )));
	SendClientMessage(playerid, -1, small_string);

	printf("%s", Client[playerid]);

	for(new i = 0; i < sizeof(update_gpci); i++)
	{
		if(strcmp(Client[playerid], update_gpci[i], false) == 0)
		{
			RM_ShowPlayerDialog(playerid, DIALOG_INFO, 0, 
				"""{4eb9e6}""Îáíîâëĺíčĺ ęëčĺíňŕ",
#line 2854
				"""{FFFFFF}""Âűřëî îáíîâëĺíčĺ! Ěű đŕáîňŕĺě ÷ňîáű âŕřŕ čăđŕ áűëŕ ďđč˙ňíĺĺ\nÍĺîáőîäčěî îáíîâčňü ęëčĺíň. Óçíŕéňĺ ęŕę, â íŕřĺé ăđóďďĺ:\n""{6de64e}""vk.com/chancerp", 
				"Çŕęđűňü", ""
			);	
			return dc_kickfix__Kick(playerid);
		}
	}

	if(Platform[playerid] == -1) {
		Platform[playerid] = 1;
	}

	printf("Name: %s | Platform: %d | IP: %s", sendername, Platform[playerid], ipsget[playerid]);	

	AuthTimeFix[playerid] = KillTimer(AuthTimeFix[playerid]);
	AuthTimeFix[playerid] = SetTimerEx("FixAuth", FIX_AUTH_TIME, 0, "i", playerid);	
	return 1;
}

public SSCANF_OnPlayerDisconnect(playerid, reason)
{
	AD_OnPlayerDisconnect(playerid, reason);

	DeletePlayerCheaterPanel(playerid);

	HidePlayerCheaterPanel(playerid);

	SetPlayerInt(playerid, "isOnline", 0);
	if(IsPlayerNPC(playerid)) {
		(_:F@i:Iter_Remove_InternalC(Iter_Single@Bot ,_:Iterator@Bot,(_:F@f:F@e:sizeof (Iterator@Bot  ))-1,_:F@t:(FALSE?(_:F@D:(Iterator@Bot[0]*( playerid) )):_:( playerid)) ));
		return 1;
	}

	if(GetPVarInt(playerid, "weapon_hack") == 1)
	{
		DelGuns(playerid);
	}
	if(PlayerArea[playerid] == false) {

	GetPlayerWeaponData(playerid, 2, PlayerInfo[playerid][slot_2_gun], PlayerInfo[playerid][slot_2_ammo]);
	GetPlayerWeaponData(playerid, 3, PlayerInfo[playerid][slot_3_gun], PlayerInfo[playerid][slot_3_ammo]);
	GetPlayerWeaponData(playerid, 4, PlayerInfo[playerid][slot_4_gun], PlayerInfo[playerid][slot_4_ammo]);
	GetPlayerWeaponData(playerid, 5, PlayerInfo[playerid][slot_5_gun], PlayerInfo[playerid][slot_5_ammo]);
	GetPlayerWeaponData(playerid, 8, PlayerInfo[playerid][slot_8_gun], PlayerInfo[playerid][slot_8_ammo]);

	SetPlayerInt(playerid, "slot_2_gun", PlayerInfo[playerid][slot_2_gun]);
	SetPlayerInt(playerid, "slot_3_gun", PlayerInfo[playerid][slot_3_gun]);
	SetPlayerInt(playerid, "slot_4_gun", PlayerInfo[playerid][slot_4_gun]);
	SetPlayerInt(playerid, "slot_5_gun", PlayerInfo[playerid][slot_5_gun]);
	SetPlayerInt(playerid, "slot_8_gun", PlayerInfo[playerid][slot_8_gun]);

	SetPlayerInt(playerid, "slot_2_ammo", PlayerInfo[playerid][slot_2_ammo]);
	SetPlayerInt(playerid, "slot_3_ammo", PlayerInfo[playerid][slot_3_ammo]);
	SetPlayerInt(playerid, "slot_4_ammo", PlayerInfo[playerid][slot_4_ammo]);
	SetPlayerInt(playerid, "slot_5_ammo", PlayerInfo[playerid][slot_5_ammo]);
	SetPlayerInt(playerid, "slot_8_ammo", PlayerInfo[playerid][slot_8_ammo]);

	}

	OnArenaDisconnect(playerid);



	if(PlayerInfo[playerid][pSelectedSlot] == 1) {
		if(caridhouse[playerid] != (0xFFFF)) {
			SetPlayerInt(playerid, "Fuel1", GetVehicleFuel(caridhouse[playerid]));
		}	
	} else if(PlayerInfo[playerid][pSelectedSlot] == 2) {
		if(caridhouse[playerid] != (0xFFFF)) {
			SetPlayerInt(playerid, "Fuel2", GetVehicleFuel(caridhouse[playerid]));
		}	
	}
	if(IsValidVehicle(caridhouse[playerid]))
	{
		FUEL_DestroyVehicle(caridhouse[playerid]);
		caridhouse[playerid] = (0xFFFF);
	}

	SetPlayerInt(playerid, "Online", PlayerInfo[playerid][pOnline]);
	onair_offline(playerid);
	stop_detector(playerid);
	OnPlayerDisconnect_textdraw(playerid);

	if(PlayerLogged{playerid} == true)
	{
		CallLocalFunction("OnPlayerGameQuit", "i", playerid);
	}

	if(IsValidDynamicObject(plane[playerid])) DestroyDynamicObject(plane[playerid]);
	new mate = GetPVarInt(playerid, "mate");

	if(mate != -1 && mate != playerid) {
		if(GetPVarInt(mate, "mate") == playerid) {
			SetPVarInt(mate,  "mate", -1);
			SendClientMessage(mate, -1, """{ff353c}""Âŕř ďŕđňíĺđ ďîęčíóë ęîěŕíäó");
		}
		SetPVarInt(playerid, "mate", -1);
	}	

	SetPlayerInt(playerid, "Wanted", PlayerInfo[playerid][pWanted]);














	secure[playerid] = 0;

	gonecar[playerid] = (0xFFFF);

	SetPVarInt(playerid, "SellingCar", -1);
	CancelOffer(playerid);

	if(cabAvailible[playerid] != 1) cabAvailible[playerid] = 1; 
	if(destinationMark[playerid] != (-1)) {
		DestroyDynamicCP(destinationMark[playerid]);
		destinationMark[playerid] = (-1);
	}
	if(cabClient[playerid] != (0xFFFF)) cabClient[playerid] = (0xFFFF);

	CallLocalFunction("Casino_OnPlayerDisconnect", "ii", playerid, reason);
	CallLocalFunction("Gps_OnPlayerDisconnect", "ii", playerid, reason);
	CallLocalFunction("Army_OnPlayerDisconnect", "ii", playerid, reason);
	if(GetPVarInt(playerid,!"OffFrisk") > gettime()) {
		if(GetPVarInt(playerid, "punishf") != 1) {
		DeletePVar(playerid, "OffFrisk"); SetPVarInt(playerid, "punishf", 1);
		if(PlayerInfo[playerid][pJailed] == 0) {
				PlayerInfo[playerid][pJailTime] = 3600;
				PlayerInfo[playerid][pJailed] = 1;
				SetPlayerInt(playerid, "Jailed", PlayerInfo[playerid][pJailed]);
				SetPlayerInt(playerid, "JailTime", PlayerInfo[playerid][pJailTime]);
				PlayerInfo[playerid][pWanted] = 0;
				SetPlayerWanted(playerid, 0);
				SetPlayerInt(playerid, "Wanted", 0);

				PlayerInfo[playerid][pPetard] = 0;
				PlayerInfo[playerid][pGrenade] = 0;
				PlayerInfo[playerid][pDynamite] = 0;
				SetPlayerInt(playerid, "Petard", PlayerInfo[playerid][pPetard]);
				SetPlayerInt(playerid, "Grenade", PlayerInfo[playerid][pGrenade]);
				SetPlayerInt(playerid, "Dynamite", PlayerInfo[playerid][pDynamite]);
				PlayerInfo[playerid][pDrugs] = 0;
				PlayerInfo[playerid][pDrugsSell] = 0;
				PlayerInfo[playerid][pStuff] = 0;
				SetPlayerInt(playerid, "Drugs", PlayerInfo[playerid][pDrugs]);
				SetPlayerInt(playerid, "DrugsSell", PlayerInfo[playerid][pDrugsSell]);
				SetPlayerInt(playerid, "Stuff", PlayerInfo[playerid][pStuff]);
				format(small_string, sizeof(small_string), """{ff353c}""Čăđîę %s âűřĺë ďđč îáűńęĺ č áűë îňďđŕâëĺí â ňţđüěó", PlayerInfo[playerid][pName]);
				SendClientMessageToAll(-1, small_string);
			}
		}
	}
	if(GetPVarInt(playerid,!"OffArrest") > gettime() || GetPVarType(playerid, !"cuffed") == 1) {
		if(GetPVarInt(playerid, "punish") != 1) {
			DeletePVar(playerid, "OffArrest"); SetPVarInt(playerid, "punish", 1);
			if(PlayerInfo[playerid][pJailed] == 0) {
				PlayerInfo[playerid][pJailTime] = PlayerInfo[playerid][pWanted];
				PlayerInfo[playerid][pJailed] = 1;
				SetPlayerInt(playerid, "Jailed", PlayerInfo[playerid][pJailed]);
				SetPlayerInt(playerid, "JailTime", PlayerInfo[playerid][pJailTime]);
				PlayerInfo[playerid][pWanted] = 0;
				SetPlayerWanted(playerid, 0);
				SetPlayerInt(playerid, "Wanted", 0);
				format(small_string, sizeof(small_string), """{ff353c}""Čăđîę %s âűřĺë ďđč ŕđĺńňĺ č áűë îňďđŕâëĺí â ňţđüěó", PlayerInfo[playerid][pName]);
				SendClientMessageToAll(-1, small_string);

			}
		}
	}
	for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i=Iterator@Player [_: i])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);)
	{
		if(GetPlayerState(i) == (9) && spectating[i] == playerid)
		{
			StopSpectate(i);
			GameTextForPlayer(i,"~r~Player Offline", 3800, 3);
		}
	}
	Dealer_OnPlayerDisconnect(playerid, reason);
	Porter_OnPlayerDisconnect(playerid, reason);
	if(Player__PatrolCP[playerid] != (-1)) {
		DestroyDynamicCP(Player__PatrolCP[playerid]);
		Player__PatrolCP[playerid] = (-1);
	}
	if(Player__MafiaCP[playerid] != (-1)) {
		DestroyDynamicCP(Player__MafiaCP[playerid]);
		Player__MafiaCP[playerid] = (-1);
	}
	if(Player__SteelCar[playerid] != (-1)) {
		DestroyDynamicCP(Player__SteelCar[playerid]);
		Player__SteelCar[playerid] = (-1);
	}
	if(Player__FarmCP[playerid] != (-1)) {
		DestroyDynamicCP(Player__FarmCP[playerid]);
		Player__FarmCP[playerid] = (-1);
	}


	PreviewElement[playerid] = KillTimer(PreviewElement[playerid]);
	WelcomeCustoms[playerid] = KillTimer(WelcomeCustoms[playerid]);
	PlaneTimer[playerid] = KillTimer(PlaneTimer[playerid]);
	AuthTimeFix[playerid] = KillTimer(AuthTimeFix[playerid]);
	requestt[playerid] = KillTimer(requestt[playerid]);
	vehfixtimer[playerid] = KillTimer(vehfixtimer[playerid]);
	RobTimer[playerid] = KillTimer(RobTimer[playerid]);
	AzinoTimer[playerid] = KillTimer(AzinoTimer[playerid]);
	DrugTimer[playerid] = KillTimer(DrugTimer[playerid]);
	Timer_Speed[playerid] = KillTimer(Timer_Speed[playerid]);
	taxiPayment[playerid] = KillTimer(taxiPayment[playerid]);
	routetimer[playerid] = KillTimer(routetimer[playerid]);
	PlayerTimerID[playerid] = KillTimer(PlayerTimerID[playerid]);
	ReturnTimerID[playerid] = KillTimer(ReturnTimerID[playerid]);
	CopTimerID[playerid] = KillTimer(CopTimerID[playerid]);
	FriskTimer[playerid] = KillTimer(FriskTimer[playerid]);
	BinTimer[playerid] = KillTimer(BinTimer[playerid]);
	LSPDTimer[playerid] = KillTimer(LSPDTimer[playerid]);
	entrance_timer[playerid] = KillTimer(entrance_timer[playerid]);
	ThefStatus[playerid] = 0;
	TheftZone[playerid] = -1;
	if(TimeTCar[playerid] != 0) {
		TimeTCar[playerid] = 0;
		if(PlayerInfo[playerid][pTheftSkill] != 0) {
		PlayerInfo[playerid][pTheftSkill] -= 1;
		SetPlayerInt(playerid, "TheftSkill", PlayerInfo[playerid][pTheftSkill]);
		}
	}
	TCar[playerid] = 0;
	if(IsValidTimer(LeaveTimer[playerid])) KillTimer(LeaveTimer[playerid]),LeaveTimer[playerid] = -1;
	if(IsValidTimer(LawTimer[playerid])) KillTimer(LawTimer[playerid]),LawTimer[playerid] = -1;
	if(Lawyer == playerid) Lawyer = (0xFFFF);

	if(gone[playerid] != -1) {
		gone[playerid] = -1;
		gonecar[playerid] = (0xFFFF);
	}
	if(player_Patrol[playerid] != -1) {

		if(player_Patrol[playerid] == 0) {
			PATROL_TOWER[0] = 0;
		}
		else if(player_Patrol[playerid] == 1) {
			PATROL_TOWER[1] = 0;
		}
		else if(player_Patrol[playerid] == 2) {
			PATROL_TOWER[2] = 0;
		}
		else if(player_Patrol[playerid] == 3) {
			PATROL_TOWER[3] = 0;
		}
		else if(player_Patrol[playerid] == 4) {
			PATROL_TOWER[4] = 0;
		}
		else if(player_Patrol[playerid] == 5) {
			PATROL_TOWER[5] = 0;
		}
		else if(player_Patrol[playerid] == 6) {
			PATROL_TOWER[6] = 0;
		}
		else if(player_Patrol[playerid] == 7) {
			PATROL_TOWER[7] -= 1;
		}
		else if(player_Patrol[playerid] == 8) {
			PATROL_TOWER[8] -= 1;
		}

		player_Patrol[playerid] = -1;
		PatrolTimer[playerid] = KillTimer(PatrolTimer[playerid]);
		DeletePatrolCP(playerid);
	}

	PlayerInfo[playerid][slot_2_gun] = 0;
	PlayerInfo[playerid][slot_2_ammo] = 0;
	PlayerInfo[playerid][slot_3_gun] = 0;
	PlayerInfo[playerid][slot_3_ammo] = 0;
	PlayerInfo[playerid][slot_4_gun] = 0;
	PlayerInfo[playerid][slot_4_ammo] = 0;
	PlayerInfo[playerid][slot_5_gun] = 0;
	PlayerInfo[playerid][slot_5_ammo] = 0;
	PlayerInfo[playerid][slot_8_gun] = 0;
	PlayerInfo[playerid][slot_8_ammo] = 0;	

	if(carry[playerid] != -1) carry[playerid] = -1;

	SetPlayerWanted(playerid, 0);
	AllAd[GetPVarInt(playerid,"ListAD")][2] = "0";
	return PlayerInfo[playerid] = NULL_PlayerInfo;
}

forward arena_death(playerid);
