@_UpdateGarbage();
@_UpdateGarbage() {
	for(new i = 0; i < sizeof(LocationGarbage); i++) {
		if(LocationGarbage[i][E_LAST_TIME] > 0) {

			if(LocationGarbage[i][E_LAST_TIME] == (30) * 60) {
				UpdateDynamic3DTextLabelText(LocationGarbage[i][E_LABEL], -1, """{4eb9e6}""Ěóńîđíűé áŕę\n""{FFAF00}""(íĺëüç˙ îńěîňđĺňü)");
			}


			LocationGarbage[i][E_LAST_TIME] = LocationGarbage[i][E_LAST_TIME] - 1;


			if(LocationGarbage[i][E_LAST_TIME] == 0) {	
				UpdateDynamic3DTextLabelText(LocationGarbage[i][E_LABEL], -1, """{4eb9e6}""Ěóńîđíűé áŕę\n""{6de64e}""(ěîćíî îńěîňđĺňü)");
			}
		}
	}
}

@_PlayerRobberyGarbage(playerid, garbage_array_id);
@_PlayerRobberyGarbage(playerid, garbage_array_id) {

	new Type_Award = RandomEx(1,3);

	if(Type_Award == 1) {	
		new 
			random_award = random((20) - (3)) + (3);

		format(small_string, sizeof(small_string), """{6de64e}""Ďđč îńěîňđĺ ěóńîđíîăî áŕęŕ âű îáíŕđóćčëč %i EXP", random_award);
		SendClientMessage(playerid, -1, small_string);

		AddPlayerEXP(playerid, random_award, "Ęîďŕíčĺ â ěóńîđíîě áŕęĺ");
	}
	if(Type_Award == 2) {
		SendClientMessage(playerid, -1, """{ff353c}""Ďđč îńěîňđĺ ěóńîđíîăî áŕęŕ âű íĺ íŕřëč íč÷ĺăî ďîëĺçíîăî");
	}
	if(Type_Award == 3) {

		new food_trashy[24];

		switch(RandomEx(0,15)) {
			case 0: strins(food_trashy, "çŕńîőřóţ ęîňëĺňęó", 0);
			case 1: strins(food_trashy, "ďđîňóőřóţ ęđčâĺňęó", 0);
			case 2: strins(food_trashy, "čńďîđ÷ĺííîĺ ˙áëîęî", 0);
			case 3: strins(food_trashy, "çŕňâĺđäĺâřčé áóđăĺđ", 0);
			case 4: strins(food_trashy, "áŕíęó ńîäîâîé", 0);
			case 5: strins(food_trashy, "čńďîđ÷ĺííűé ŕďĺëüńčí ", 0);
			case 6: strins(food_trashy, "ęŕđňîôĺëü ôđč ďîä ďëĺńĺíüţ", 0);
			case 7: strins(food_trashy, "îęđîâŕâëĺííîĺ ńĺđäöĺ ÷čňĺđŕ", 0);
			case 8: strins(food_trashy, "ęóđčííîĺ ˙č÷ęî", 0);
			case 9: strins(food_trashy, "ňóőëűé ňîěŕň", 0);
			case 10: strins(food_trashy, "îńňŕňęč ďčđîăŕ", 0);
			case 11: strins(food_trashy, "ďî÷ĺđíĺâřčé áŕíŕí", 0);
			case 12: strins(food_trashy, "î÷čńňęč îň ěŕíäŕđčíŕ", 0);
			case 13: strins(food_trashy, "áŕíŕíîâóţ ęîćóđó", 0);
			case 14: strins(food_trashy, "íĺáîëüřóţ ęîđîáęó ńîęŕ", 0);
			case 15: strins(food_trashy, "ě˙ńî íĺčçâĺńňíîăî ďđîčńőîćäĺíč˙", 0);
		}		

		format(small_string, sizeof(small_string), """{6de64e}""Ďđč îńěîňđĺ ěóńîđíîăî áŕęŕ âű íŕřëč %s", food_trashy);
		SendClientMessage(playerid, -1, small_string);

		ApplyAnimation(playerid,"FOOD","EAT_BURGER",4.1,0,1,1,1,1,1);
		format(small_string, sizeof(small_string), "ńúĺë(ŕ) %s", PlayerInfo[playerid][pName], food_trashy);
		SetPlayerChatBubble(playerid, small_string, 0xDD90FFFF, 30.0, 5000);
		format(small_string, sizeof(small_string), "%s ńúĺë(ŕ) %s", PlayerInfo[playerid][pName], food_trashy);
		ProxDetector(playerid, (20.00), 0xDD90FFFF, small_string);		

		new feed = RandomEx(1,3);

		if(feed == 1) {
			SendClientMessage(playerid, -1, """{6de64e}""Âű ńëĺăęŕ óňîëčëč ńâîé ăîëîä");

			PlayerInfo[playerid][pHunger] += 6;
			if(PlayerInfo[playerid][pHunger] > 100) PlayerInfo[playerid][pHunger] = 100;	
			SetPlayerInt(playerid, "Hunger", PlayerInfo[playerid][pHunger]);

			GameTextForPlayer(playerid, "~n~~n~~n~~n~~n~~n~~n~~n~~w~+6 Satiety", 2000, 6);

		}
		if(feed == 2) {
			SendClientMessage(playerid, -1, """{FFAF00}""Âű ďîĺëč, íî ýňîăî ˙âíî ěŕëî");

			PlayerInfo[playerid][pHunger] += 3;
			if(PlayerInfo[playerid][pHunger] > 100) PlayerInfo[playerid][pHunger] = 100;	
			SetPlayerInt(playerid, "Hunger", PlayerInfo[playerid][pHunger]);

			GameTextForPlayer(playerid, "~n~~n~~n~~n~~n~~n~~n~~n~~w~+3 Satiety", 2000, 6);

		}
		if(feed == 3) {
			SendClientMessage(playerid, -1, """{ff353c}""Ńúĺäĺííŕ˙ ďčůŕ íĺ ďîřëŕ íŕ ďîëüçó");

			PlayerInfo[playerid][pHunger] -= 10;
			if(PlayerInfo[playerid][pHunger] > 100) PlayerInfo[playerid][pHunger] = 100;	
			SetPlayerInt(playerid, "Hunger", PlayerInfo[playerid][pHunger]);

			GameTextForPlayer(playerid, "~n~~n~~n~~n~~n~~n~~n~~n~~r~-10 Satiety", 2000, 6);

		}				
	}

	ClearAnimations(playerid);
	RM_TogglePlayerControllable(playerid, true);

	PlayerTimerRobbertyGarbage[playerid] = (-1);

	mysql_format(database, small_string, sizeof(small_string), "INSERT INTO `robbery_garbage`(`PlayerID`, `GarbageID`, `Type`, `Time`) VALUES (%i, %i, %i,  CURRENT_TIMESTAMP())", PlayerInfo[playerid][pID], LocationGarbage[garbage_array_id][E_ID], Type_Award);
	mysql_pquery(database, small_string);

	UpdatePlayerProgressQuest(playerid, E_GARBAGE_CAN);
	return 1;
}
