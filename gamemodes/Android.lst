	return 1;
}

stock Porter_OnPlayerKeyStateChange(playerid, newkeys, oldkeys) {
	if(GetPVarInt(playerid, "tempjob") == 3 && porter_state[playerid] == 2) 
	{
		if(GetPVarInt(playerid,"DropBox") > gettime())	{ return false; }
    	if((newkeys & (8) && newkeys & (32))) {
			BoxFail(playerid);
        }
        if((newkeys & (32)) && !(oldkeys & (32))) {
			BoxFail(playerid);
        }
        if(newkeys & (16) || (newkeys & (512) && newkeys & (16))) {
			BoxFail(playerid);
        }
        if(newkeys & (4)) {
			BoxFail(playerid);
        }
    }
    return 1;

}














