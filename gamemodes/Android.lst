forward CheckGame(playerid, iterid, place);
public CheckGame(playerid, iterid, place) {

	printf("[CheckGame] id = %i i = %i, sum = %i", CasinoInfo[iterid][CI_Table_ID], iterid, CasinoInfo[iterid][CI_Table_Sum]);

	new 
		sum = CasinoInfo[iterid][CI_Table_Sum];

	if(CheckCash(playerid, sum) == false) 
		return SendClientMessage(playerid, -1, "У вас недостаточно денег для игры за этим столиком.");

	static string[88 + 11 + 1];
	format(string, sizeof(string), 
		"""{FFAF00}""Вы сделали ставку в ""{FFFFFF}""%i EXP. ""{FFAF00}""Ожидайте начала игры",
		 sum
	);
	SendClientMessage(playerid, -1, string);

	Player__DownEXP(PlayerInfo[playerid][pID], sum, E_PLAYING_AZINO, playerid);
	SetCasinoPlayer(CasinoInfo[iterid][CI_Table_ID], place, playerid);

	if(CasinoInfo[iterid][CI_Player2] != (0xFFFF) && CasinoInfo[iterid][CI_Player1] != (0xFFFF)) {
		SendClientMessage(CasinoInfo[iterid][CI_Player1], -1, """{4eb9e6}""Игра началась!");
		SendClientMessage(CasinoInfo[iterid][CI_Player2], -1, """{4eb9e6}""Игра началась!");

		format(small_string, sizeof(small_string), "%s бросает кости...", PlayerInfo[CasinoInfo[iterid][CI_Player1]][pName]);
		ProxDetector(CasinoInfo[iterid][CI_Player1], (20.00), 0xDD90FFFF, small_string);
		format(small_string, sizeof(small_string), "%s бросает кости...", PlayerInfo[CasinoInfo[iterid][CI_Player2]][pName]);
		ProxDetector(CasinoInfo[iterid][CI_Player2], (20.00), 0xDD90FFFF, small_string);
		SetTimerEx("GameCasino", 6_000, false, "i", iterid);
		TogglePlayerControllable(CasinoInfo[iterid][CI_Player1], false);
		TogglePlayerControllable(CasinoInfo[iterid][CI_Player2], false);
		GameTextForPlayer(CasinoInfo[iterid][CI_Player1], "~g~~h~WAITING FOR RESULT...", 6000, 4);
		GameTextForPlayer(CasinoInfo[iterid][CI_Player2], "~g~~h~WAITING FOR RESULT...", 6000, 4);
	}
	return 1;
}

forward GameCasino(iterid);
public GameCasino(iterid) {
	TogglePlayerControllable(CasinoInfo[iterid][CI_Player1], true);
	TogglePlayerControllable(CasinoInfo[iterid][CI_Player2], true);

	if(CasinoInfo[iterid][CI_Player1] == (0xFFFF)) return 1;
    if(CasinoInfo[iterid][CI_Player2] == (0xFFFF)) return 1;

    new 
    	dice = random(12) + 1,
    	dice1 = random(12) + 1,
    	table_sum = CasinoInfo[iterid][CI_Table_Sum],
    	croupier_cash = (table_sum / 100) * 10;

	AddRowLogCasino(PlayerInfo[CasinoInfo[iterid][CI_Player1]][pID], PlayerInfo[CasinoInfo[iterid][CI_Player2]][pID], table_sum);

	if(dice > dice1) {
		format(small_string, sizeof(small_string), 
			"На костях %d:%d. Победитель: %s", 
				dice, 
				dice1, 
				PlayerInfo[CasinoInfo[iterid][CI_Player1]][pName]
		);
		ProxDetector(CasinoInfo[iterid][CI_Player1], (20.00), 0xDD90FFFF, small_string);

		format(small_string, sizeof(small_string), 
			"""{6de64e}""Вы выиграли{FFFFFF} %i EXP!",
				table_sum - croupier_cash
		);
	    SendClientMessage(CasinoInfo[iterid][CI_Player1], -1, small_string);

	    format(small_string, sizeof(small_string), 
	    	"""{ff353c}""Вы проиграли{FFFFFF} %i EXP",
	    		table_sum
	    );
		SendClientMessage(CasinoInfo[iterid][CI_Player2], -1, small_string);

		format(small_string, sizeof(small_string), 
			"~g~~h~+%i EXP", 
				table_sum - croupier_cash
		);
		GameTextForPlayer(CasinoInfo[iterid][CI_Player1], small_string, 2000, 4);

		format(small_string, sizeof(small_string), 
			"~r~~h~-%i EXP", 
				table_sum
		);
		GameTextForPlayer(CasinoInfo[iterid][CI_Player2], small_string, 2000, 4);

		Player__AddEXP(PlayerInfo[CasinoInfo[iterid][CI_Player1]][pID], (table_sum + table_sum) - croupier_cash, E_WIN_CASINO, CasinoInfo[iterid][CI_Player1]);
		if(CasinoInfo[iterid][CI_CroupierID] != (0xFFFF)) {
			Player__AddEXP(PlayerInfo[CasinoInfo[iterid][CI_CroupierID]][pID], croupier_cash, E_CASION_CROUPIER, CasinoInfo[iterid][CI_CroupierID]);

			format(small_string, sizeof(small_string), 
				"""{FFAF00}""Вы получили чаевые, в размере: {FFFFFF}%i EXP",
					croupier_cash
			);
			SendClientMessage(CasinoInfo[iterid][CI_CroupierID], -1, small_string);
		}
		SetCasinoPlayer(CasinoInfo[iterid][CI_Table_ID], 1, (0xFFFF));
		return SetCasinoPlayer(CasinoInfo[iterid][CI_Table_ID], 2, (0xFFFF));
	}
	if(dice1 > dice)
	{
		format(small_string, sizeof(small_string), 
			"На костях %d:%d. Победитель: %s", 
				dice, 
				dice1, 
				PlayerInfo[CasinoInfo[iterid][CI_Player2]][pName]
		);
		ProxDetector(CasinoInfo[iterid][CI_Player2], (20.00), 0xDD90FFFF, small_string);

		format(small_string, sizeof(small_string), 
			"""{6de64e}""Вы выиграли{FFFFFF} %i EXP!",
				table_sum - croupier_cash
		);
	    SendClientMessage(CasinoInfo[iterid][CI_Player2], -1, small_string);

	    format(small_string, sizeof(small_string), 
	    	"""{ff353c}""Вы проиграли{FFFFFF} %i EXP",
	    		table_sum
	    );
		SendClientMessage(CasinoInfo[iterid][CI_Player1], -1, small_string);

		format(small_string, sizeof(small_string), 
			"~g~~h~+%i EXP", 
				table_sum - croupier_cash
		);
		GameTextForPlayer(CasinoInfo[iterid][CI_Player2], small_string, 2000, 4);

		format(small_string, sizeof(small_string), 
			"~r~~h~-%i EXP", 
				table_sum
		);
		GameTextForPlayer(CasinoInfo[iterid][CI_Player1], small_string, 2000, 4);

		Player__AddEXP(PlayerInfo[CasinoInfo[iterid][CI_Player2]][pID], (table_sum + table_sum) - croupier_cash, E_WIN_CASINO, CasinoInfo[iterid][CI_Player2]);

		if(CasinoInfo[iterid][CI_CroupierID] != (0xFFFF)) {
			Player__AddEXP(PlayerInfo[CasinoInfo[iterid][CI_CroupierID]][pID], croupier_cash, E_CASION_CROUPIER, CasinoInfo[iterid][CI_CroupierID]);

			format(small_string, sizeof(small_string), 
				"""{FFAF00}""Вы получили чаевые, в размере: {FFFFFF}%i EXP",
					croupier_cash
			);
			SendClientMessage(CasinoInfo[iterid][CI_CroupierID], -1, small_string);
		}

		SetCasinoPlayer(CasinoInfo[iterid][CI_Table_ID], 1, (0xFFFF));
		return SetCasinoPlayer(CasinoInfo[iterid][CI_Table_ID], 2, (0xFFFF));
	}
	if(dice1 == dice)
	{
		format(small_string, sizeof(small_string), 
			"На костях %d:%d. Ничья", 
				dice1, 
				dice
		);
		ProxDetector(CasinoInfo[iterid][CI_Player1], (20.00), 0xDD90FFFF, small_string);

	    SendClientMessage(CasinoInfo[iterid][CI_Player1], -1, """{FFAF00}""Ничья");
		SendClientMessage(CasinoInfo[iterid][CI_Player2], -1, """{FFAF00}""Ничья");

		format(small_string, sizeof(small_string), 
			"~g~~h~+%i EXP", 
				table_sum
		);
		GameTextForPlayer(CasinoInfo[iterid][CI_Player1], small_string, 2000, 4);
		GameTextForPlayer(CasinoInfo[iterid][CI_Player2], small_string, 2000, 4);	

		Player__AddEXP(PlayerInfo[CasinoInfo[iterid][CI_Player1]][pID], table_sum, E_LEAVE_RETURN_CASINO_CASH, CasinoInfo[iterid][CI_Player1]);
		Player__AddEXP(PlayerInfo[CasinoInfo[iterid][CI_Player2]][pID], table_sum, E_LEAVE_RETURN_CASINO_CASH, CasinoInfo[iterid][CI_Player2]);

		if(CasinoInfo[iterid][CI_CroupierID] != (0xFFFF)) {
			SendClientMessage(CasinoInfo[iterid][CI_CroupierID], -1, """{FFAF00}""Ничья. Вы ничего не заработали");
		}
		SetCasinoPlayer(CasinoInfo[iterid][CI_Table_ID], 1, (0xFFFF));
		return SetCasinoPlayer(CasinoInfo[iterid][CI_Table_ID], 2, (0xFFFF));
	}
	return 1;
}
