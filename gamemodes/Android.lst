public OnPlayerText(playerid, text[])
{
	if(GetPVarType(playerid, !"tasered") == 1) {
		return 0;
	}
    if(GetPVarInt(playerid, "DialogID"))
    {
        return 0;
    }
	new speach[144];
	if(PlayerInfo[playerid][pMuted] > 0) {
		format(speach, sizeof(speach), """{ff353c}""У Вас бан чата! Осталось: %d минут", PlayerInfo[playerid][pMuteTime] / 60);
		SendClientMessage(playerid, -1, speach);
		return 0;
	} else {
		if(GetPVarInt(playerid,"AntiFloodLocal") > gettime()){ SendClientMessage(playerid, -1, !"""{ff353c}""Пожалуйста не флудите"); return false; }
		SetPVarInt(playerid,"AntiFloodLocal",gettime() + 3);
		format(speach, sizeof(speach), "- %s[%d]: %s", PlayerInfo[playerid][pName],playerid, text);
		SetPlayerChatBubble(playerid, text, 0x6ab1ffaa, 20.0, 10000);
		ProxDetector(playerid, (20.00), 0xE6E6E6E6, speach);
		return 0;
	}
}

public OnPlayerCommandReceived(playerid, cmd[], params[], flags)
{
	if(GetPVarType(playerid, !"cuffed") == 1) {
		ApplyAnimation(playerid, "PED", "cower", 1, 1, 0, 0, 0, 0, 1);
		return 0;
	}
    if(GetPVarInt(playerid, "DialogID"))
    {
        return false;
    }
	if(GetPVarInt(playerid,"AntiFloodCMD") > gettime()) { 
		SendClientMessage(playerid, -1, !"""{ff353c}""Пожалуйста не флудите"); 
		return false; 
	}
	SetPVarInt(playerid,"AntiFloodCMD",gettime() + 2);
	return 1;
}
public OnPlayerClickMap(playerid, Float:fX, Float:fY, Float:fZ)
{
	if(PlayerInfo[playerid][pAdmin] > 1) SetPlayerPosFindZ(playerid, fX, fY, fZ); 
    return 1;
}
forward pc_cmd_capture(playerid,params[]); public pc_cmd_capture(playerid,params[])
{
	for(new i = 1;i<=TOTALGZ;i++) {
		if(PlayerInGangZone(playerid,GZInfo[i][gCoords][0], GZInfo[i][gCoords][1],GZInfo[i][gCoords][2],GZInfo[i][gCoords][3]) && ZoneOnBattle[i] == 0)
		{
				if(GZInfo[i][gid] == 102 || GZInfo[i][gid] == 69 || GZInfo[i][gid] == 55 || GZInfo[i][gid] == 56|| GZInfo[i][gid] == 44 || GZInfo[i][gid] == 45 || GZInfo[i][gid] == 42) {
					return SendClientMessage(playerid,-1,!"""{ff353c}""Война за данную территорию невозможна");	
				} 
				if(ZoneOnBattle[i] == 1) {
					format(small_string, 127,"""{4eb9e6}""Идет война за территорию между %s и %s", GetGangName(GZInfo[i][gNapad]), GetGangName(GZInfo[i][gFrak]));
					SendClientMessage(playerid,-1, small_string);
					return 1;
				}

				format(small_string, 127,"""{4eb9e6}""Территория находится под влиянием: {FFFFFF}%s", GetGangName(GZInfo[i][gFrak]));
				SendClientMessage(playerid,-1, small_string);
				new 
				Fraction:fractionid = GetPlayerFraction(playerid);

			    if(fractionid < FRACTION_RUSSIAN_MAFIA && fractionid > FRACTION_LSPD) {
			    format(small_string,sizeof(small_string),"startcapture - %d",startcapture);
				SendClientMessage(playerid, -1, small_string);
				if(startcapture > 0) return SendClientMessage(playerid,-1,!"""{FFAF00}""В этом часу уже была война за территорию");
				new gonline[2];
		  		new 
		  			Fraction:target_fractionid;
		  		for(new  b=_:_Y_ITER_C1:_Y_ITER_C2:sizeof  Player@YSII_Ag-1;_:( b=_:_Y_ITER_C0: Player@YSII_Ag[ b])!=_:_Y_ITER_C1:_Y_ITER_C2:sizeof  Player@YSII_Ag-1;)
				{
					target_fractionid = GetPlayerFraction(b);
					if(_:target_fractionid == _:fractionid) gonline[0]++;
					if(_:target_fractionid == _:GZInfo[i][gFrak]) gonline[1]++;
				}
				if(Warehouse[_:fractionid] < 25) return SendClientMessage(playerid, -1, """{ff353c}""На складе вашей банды недостаточно материалов. Необходимо: 25");
				if(PlayerInfo[playerid][pKarma] > -100) return SendClientMessage(playerid, -1, !"""{ff353c}""Необходимо -100 законопослушности");
				if(gonline[0] < 5) return SendClientMessage(playerid, -1, !"""{ff353c}""В вашей банде недостаточно людей для нападения. Необходимо: 5");
				if(gonline[1] < 5) return SendClientMessage(playerid, -1, !"""{ff353c}""У данной банды недостаточно людей в сети. Необходимо: 5");
				Warehouse[_:fractionid] -= 25;
				if(GangInfo[_:fractionid][capture] == 1) return SendClientMessage(playerid, -1, !"""{FFAF00}""Ваша банда уже учавствует в захвате зоны");
				if(GangInfo[GZInfo[i][gFrak]][capture] == 1) return SendClientMessage(playerid, -1, !"""{FFAF00}""Банда, на которую вы хотите напасть уже учавствует в захвате зоны!");
				if(_:GZInfo[i][gFrak] == _:fractionid) return SendClientMessage(playerid, -1, !"""{FFAF00}""Вы не можете захватывать зону вашей банды");
				if(IsCapture == 1) return SendClientMessage(playerid, -1, !"""{ff353c}""Уже происходит захват зоны. Дождитесь окончания!");
				IsCapture = 1;
				ZoneCapture = i;
				new zahvatka[128];
				new zahvat[128];
				GZInfo[i][gNapad] = _:fractionid;
				format(zahvatka, 127,"""{4eb9e6}""На вашу территорию напала банда {FFFFFF}%s", GetGangName(GZInfo[i][gNapad]));
				SendFamilyMessage(Fraction:GZInfo[i][gFrak],-1,zahvatka);
				SendFamilyMessage(Fraction:GZInfo[i][gFrak], -1, """{4eb9e6}""Эта зона будет мигать на карте 10 минут");
	            SendFamilyMessage(Fraction:GZInfo[i][gFrak], -1, """{4eb9e6}""Территория достанется стороне которая сделает больше убийств");
				format(small_string, sizeof(small_string), """{4eb9e6}""Если ваших людей будет меньше в квадрате, территория перейдет к {FFFFFF}%s", GZInfo[i][gNapad]);
