static stock DoLevenshteinDistance(const a[], lenA, const b[], lenB)
{

	new

		matrix[(32) + 1] = {0, 1, ...};



	for (new i = 0; i != lenB; ++i)
	{

		new
			prev = matrix[0];
		matrix[0] = i + 1;
		for (new j = 0; j != lenA; ++j)
		{
			new
				distance = min(
					matrix[j + 1] + 1     ,                          min(
					matrix[j] + 1         ,                         
					prev + _:(b[i] != a[j])                          )
				);
			prev = matrix[j + 1];
			matrix[j + 1] = distance;
		}
	}
	return matrix[lenA];
}









stock LevenshteinDistance(const a[], const b[])
{
	if (!strcmp(a, b))
	{

		return 0;
	}

	new
		lenA = strlen(a),
		lenB = strlen(b);
	if (!lenA)
		return lenB;
	if (!lenB)
		return lenA;
	if (lenA > lenB)
	{
		if (lenB > (32))
		{
			Debug_Print0("\7\7\7*** YSI Error: " #"`LevenshteinDistance` can currenly only handle strings up to `MAX_LEVENSHTEIN_STRING` characters (%d).", (32));
			return 1;
		}
		return DoLevenshteinDistance(b, lenB, a, lenA);
	}
	else
	{
		if (lenA > (32))
		{
			Debug_Print0("\7\7\7*** YSI Error: " #"`LevenshteinDistance` can currently only handle strings up to `MAX_LEVENSHTEIN_STRING` characters (%d).", (32));
			return 1;
		}
		return DoLevenshteinDistance(a, lenA, b, lenB);
	}
}








