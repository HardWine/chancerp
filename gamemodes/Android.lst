forward OffJails(playerid, name[]);
public OffJails(playerid, name[])
{
		new rows = cache_get_row_count();
        if(!rows) return SendClientMessage(playerid,-1,!"""{ff353c}""Игрок не найден в базе данных"); 
        new temp_int, admin_int;
		temp_int = cache_get_field_content_int(0, "isOnline");
		admin_int = cache_get_field_content_int(0, "Admin");
		if(temp_int == 1) {
			return SendClientMessage(playerid, -1, !"""{ff353c}""Игрок под данным именем в игре");
		}
		if(admin_int > 0) {
			return 1;
		}
    	new string[256],reason[32]; 
    	GetPVarString(playerid,"OffJailReason",reason,sizeof(reason)); 
    	format(string,sizeof(string),"UPDATE ""players"" SET `Jailed` = '2', `JailTime` = '%d' WHERE `Name` = '%s'",GetPVarInt(playerid,"OffJailDay")*60, name); 
        mysql_tquery(database, string, "", ""); 
        format(string,sizeof(string),"""{ff353c}""[Offline] Администратор %s посадил %s в тюрьму на %d мин. Причина: %s",PlayerInfo[playerid][pName],name, GetPVarInt(playerid,"OffJailDay"),reason); 
        SendAdminMessage(-1, string); 
        DeletePVar(playerid,"OffJailReason"); 
        DeletePVar(playerid,"OffMJailDay");
        return 1;
}
