forward dcr_DIALOG_CLICK_MAP(playerid); public dcr_DIALOG_CLICK_MAP(playerid) {
	return Dialog_Open(playerid, #DIALOG_CLICK_MAP, 0,
		"""{4eb9e6}""Ňĺëĺďîđňŕöč˙",
		"""{FFFFFF}""Âű ćĺëŕĺňĺ ňĺëĺďîđňčđîâŕňüń˙ ę óńňŕíîâëĺííîé íŕ ęŕđňĺ\něĺňęĺ?",
		"Äŕ", "Íĺň"
	);
