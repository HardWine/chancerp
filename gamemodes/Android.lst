		targetid,
		weapon_id, weapon_name[(19)], ammo;

	if (sscanf(params, "u", targetid))
		return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ: /weapon [čăđîę]");

	static const
		fmt_str_dlg_title[] = "Îđóćčĺ %s",
		fmt_str_dlg_head_body[] = "Îđóćčĺ\tĎŇ\n",
		fmt_str_dlg_body[] = "%s\t""{6de64e}""%i\t""{FFAF00}""%i\n%s";

	new
		str_dlg_title[sizeof(fmt_str_dlg_title)-2+24+1],
		str_dlg_body[
			(sizeof(fmt_str_dlg_head_body)-1)-2*3+2+
			(((sizeof(fmt_str_dlg_body)-1)-2*5+(19)+6+2)*12)+1
		];

	format(str_dlg_title, sizeof(str_dlg_title), fmt_str_dlg_title, PlayerInfo[targetid][pName]);

	for (new i; i <= (12); i++)
	{
		GetPlayerWeaponData(targetid, i, weapon_id, ammo);
		if (weapon_id == (0) || ammo == 0) continue;
		else
		{
			GetWeaponName(weapon_id, weapon_name, (19));
			format(str_dlg_body, sizeof(str_dlg_body), fmt_str_dlg_body, weapon_name, ammo, str_dlg_body);
		}
	}

	strins(str_dlg_body, fmt_str_dlg_head_body, 0);

	SPD(playerid, 0, 5, str_dlg_title, str_dlg_body, "Çŕęđűňü", "");
	return 1;
}















