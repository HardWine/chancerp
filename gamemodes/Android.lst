stock goneaway(playerid) {
    if(ArmyMission[playerid] > 0) {
        SendClientMessage(playerid, -1, """{ff353c}""Миссия по доставке материалов провалена");
		DisablePlayerRaceCheckpoint(playerid);
		ArmyMission[playerid] = 0;
	}
    if(RouteTrash[playerid] > 0) {
        SendClientMessage(playerid, -1, """{ff353c}""Вы покинули рабочий транспорт, работа завершена");
		DisablePlayerRaceCheckpoint(playerid);
		RouteTrash[playerid] = 0;
		CBackSkin(playerid);
		SetPVarInt(playerid,"tempjob", 0);
	}
    if(RouteFarm[playerid] > 0) {
    	SendClientMessage(playerid, -1, """{ff353c}""Вы покинули рабочий комбаин. Посев отменен");
		DisablePlayerRaceCheckpoint(playerid);
		RouteFarm[playerid] = 0;
	}
    if(Route[playerid] > 0) {
        SendClientMessage(playerid, -1, """{ff353c}""Вы покинули рабочий транспорт, работа завершена");
		DisablePlayerRaceCheckpoint(playerid);
		Route[playerid] = 0;
	}
    if(Route2[playerid] > 0) {
    	SendClientMessage(playerid, -1, """{ff353c}""Вы покинули рабочий транспорт, работа завершена");
		DisablePlayerRaceCheckpoint(playerid);
		Route2[playerid] = 0;
	}
    if(Route3[playerid] > 0) {
        SendClientMessage(playerid, -1, """{ff353c}""Вы покинули рабочий транспорт, работа завершена");
		DisablePlayerRaceCheckpoint(playerid);
		Route3[playerid] = 0;
	}
    if(RouteAir[playerid] > 0) {
    	SendClientMessage(playerid, -1, """{ff353c}""Вы покинули рабочий транспорт, работа завершена");
		DisablePlayerRaceCheckpoint(playerid);
		RouteAir[playerid] = 0;
	}
    if(RouteAir2[playerid] > 0) {
        SendClientMessage(playerid, -1, """{ff353c}""Вы покинули рабочий транспорт, работа завершена");
		DisablePlayerRaceCheckpoint(playerid);
		RouteAir2[playerid] = 0;
	}
	return gonecar[playerid] = (0xFFFF);
}
stock onfootverify(playerid) {
	if(gonecar[playerid] == (0xFFFF)) {
		return 1;
	}
	if(ArmyMission[playerid] > 0) {
		gone[playerid] = 20;
		ReturnTimerID[playerid] = ALS_KillTimer(ReturnTimerID[playerid]);
		ReturnTimerID[playerid] = SetTimerEx("count_return", 1000, false, "d", playerid);
		return SendClientMessage(playerid, -1, """{ff353c}""Осталось 20 секунд чтобы вернуться в транспорт");
	}
	if(RouteLic[playerid] > 0) {
		SendClientMessage(playerid, -1, """{ff353c}""Экзамен провален");
		DisablePlayerRaceCheckpoint(playerid);
		gonecar[playerid] = (0xFFFF);
		RouteLicAir[playerid] = 0;
		return 1;
	}
	if(RouteTrash[playerid] > 0) {
		gone[playerid] = 20;
		ReturnTimerID[playerid] = ALS_KillTimer(ReturnTimerID[playerid]);
		ReturnTimerID[playerid] = SetTimerEx("count_return", 1000, false, "d", playerid);
		return SendClientMessage(playerid, -1, """{ff353c}""Осталось 20 секунд чтобы вернуться в транспорт");
	}
	if(RouteFarm[playerid] > 0) {
		gone[playerid] = 20;
		ReturnTimerID[playerid] = ALS_KillTimer(ReturnTimerID[playerid]);
		ReturnTimerID[playerid] = SetTimerEx("count_return", 1000, false, "d", playerid);
		return SendClientMessage(playerid, -1, """{ff353c}""Осталось 20 секунд чтобы вернуться в транспорт");
	}
	if(UnloadFarm[playerid] > 0) {
		gone[playerid] = 20;
		ReturnTimerID[playerid] = ALS_KillTimer(ReturnTimerID[playerid]);
		ReturnTimerID[playerid] = SetTimerEx("count_return", 1000, false, "d", playerid);
		UnloadFarm[playerid] = 0;
		return SendClientMessage(playerid, -1, """{ff353c}""Осталось 20 секунд чтобы вернуться в транспорт");
	}
	if(RouteLicAir[playerid] > 0) {
		SendClientMessage(playerid, -1, """{ff353c}""Экзамен провален");
		DisablePlayerRaceCheckpoint(playerid);
		gonecar[playerid] = (0xFFFF);
		RouteLicAir[playerid] = 0;
		return 1;
	}
	if(Route[playerid] > 0) {
		gone[playerid] = 20;
		ReturnTimerID[playerid] = ALS_KillTimer(ReturnTimerID[playerid]);
		ReturnTimerID[playerid] = SetTimerEx("count_return", 1000, false, "d", playerid);
		return SendClientMessage(playerid, -1, """{ff353c}""Осталось 20 секунд чтобы вернуться в транспорт");
	}
	if(Route2[playerid] > 0) {
		gone[playerid] = 20;
		ReturnTimerID[playerid] = ALS_KillTimer(ReturnTimerID[playerid]);
		ReturnTimerID[playerid] = SetTimerEx("count_return", 1000, false, "d", playerid);
		return SendClientMessage(playerid, -1, """{ff353c}""Осталось 20 секунд чтобы вернуться в транспорт");
	}
	if(Route3[playerid] > 0) {
		gone[playerid] = 20;
		ReturnTimerID[playerid] = ALS_KillTimer(ReturnTimerID[playerid]);
		ReturnTimerID[playerid] = SetTimerEx("count_return", 1000, false, "d", playerid);
		return SendClientMessage(playerid, -1, """{ff353c}""Осталось 20 секунд чтобы вернуться в транспорт");
	}
	if(RouteAir[playerid] > 0) {
		gone[playerid] = 20;
		ReturnTimerID[playerid] = ALS_KillTimer(ReturnTimerID[playerid]);
		ReturnTimerID[playerid] = SetTimerEx("count_return", 1000, false, "d", playerid);
		return SendClientMessage(playerid, -1, """{ff353c}""Осталось 20 секунд чтобы вернуться в транспорт");
	}
	if(RouteAir2[playerid] > 0) {
		gone[playerid] = 20;
		ReturnTimerID[playerid] = ALS_KillTimer(ReturnTimerID[playerid]);
		ReturnTimerID[playerid] = SetTimerEx("count_return", 1000, false, "d", playerid);
		return SendClientMessage(playerid, -1, """{ff353c}""Осталось 20 секунд чтобы вернуться в транспорт");
	}
	return gonecar[playerid] = (0xFFFF);
}
stock Float:GetPlayerDistanceToPlayer(playerid, targetid)
{
	new Float:x, Float:y, Float:z, Float:x2, Float:y2, Float:z2;
	GetPlayerPos(playerid, x, y, z);
	GetPlayerPos(targetid, x2, y2, z2);
	return floatsqroot(floatadd(floatpower(x2-x,2),floatpower(y2-y,2)));
}
stock DoAction(const playerid, const action[], const Float:distance = 13.0)
{
	new mes[128];
	format(mes,sizeof(mes),"%s (%s)",action,PlayerInfo[playerid][pName]);
	for(new  i=_:_Y_ITER_C1:_Y_ITER_C2:sizeof  Player@YSII_Ag-1;_:( i=_:_Y_ITER_C0: Player@YSII_Ag[ i])!=_:_Y_ITER_C1:_Y_ITER_C2:sizeof  Player@YSII_Ag-1;)
	{
		if(GetPlayerDistanceToPlayer(playerid,i) > distance || GetPlayerVirtualWorld(i) != GetPlayerVirtualWorld(playerid)) continue;
		SendClientMessage(i,0xDD90FFFF,mes);
	}
	return true;
}

stock timer_count_off(const playerid) {
	 gone[playerid] = -1; 
	 ReturnTimerID[playerid] = ALS_KillTimer(ReturnTimerID[playerid]);
	 return 1;
}

forward RunwayUpdate(const way);
public RunwayUpdate(const way) {
	if(way == 0) { Runway[0] = 0; }
	if(way == 1) { Runway[1] = 0; }
	return 1;
}
stock Alcohol(const playerid) {
	 	if(GetPVarInt(playerid,"Bought") > gettime()){ return false; }
		if(CheckCash(playerid, 15) == false) return 1;
		GameTextForPlayer(playerid, "~r~-15 ~w~EXP", 3000, 5);
		Player__DownEXP(PlayerInfo[playerid][pID], 15, E_BUY_DRINK, playerid);
		switch(random(7))
		{
		    case 0: {
			    SetPlayerChatBubble(playerid, "выпил(а) бокал виски", 0xDD90FFFF, 30.0, 5000);
				format(small_string, 100, "%s выпил(а) бокал виски", PlayerInfo[playerid][pName]);
				ProxDetector(playerid, (20.00), 0xDD90FFFF, small_string);
				SetPlayerDrunkLevel (playerid, 3000);
		    }
		    case 1: {
			    SetPlayerChatBubble(playerid, "выпил(а) бокал вина", 0xDD90FFFF, 30.0, 5000);
				format(small_string, 100, "%s выпил(а) бокал вина", PlayerInfo[playerid][pName]);
				ProxDetector(playerid, (20.00), 0xDD90FFFF, small_string);
				SetPlayerDrunkLevel (playerid, 2000);
		    }
		    case 2: {
			    SetPlayerChatBubble(playerid, "выпил(а) рюмку водки", 0xDD90FFFF, 30.0, 5000);
				format(small_string, 100, "%s выпил(а) рюмку водки", PlayerInfo[playerid][pName]);
				ProxDetector(playerid, (20.00), 0xDD90FFFF, small_string);
				SetPlayerDrunkLevel (playerid, 5000);
		    }
		    case 3: {
			    SetPlayerChatBubble(playerid, "выпил(а) стопку абсента", 0xDD90FFFF, 30.0, 5000);
				format(small_string, 100, "%s выпил(а) стопку абсента", PlayerInfo[playerid][pName]);
				ProxDetector(playerid, (20.00), 0xDD90FFFF, small_string);
				SetPlayerDrunkLevel (playerid, 4000);
		    }
		    case 4: {
			    SetPlayerChatBubble(playerid, "выпил(а) бокал рома", 0xDD90FFFF, 30.0, 5000);
				format(small_string, 100, "%s выпил(а) бокал рома", PlayerInfo[playerid][pName]);
				ProxDetector(playerid, (20.00), 0xDD90FFFF, small_string);
				SetPlayerDrunkLevel (playerid, 3000);
		    }
		    case 5: {
			    SetPlayerChatBubble(playerid, "выпил(а) кружку пива", 0xDD90FFFF, 30.0, 5000);
				format(small_string, 100, "%s выпил(а) кружку пива", PlayerInfo[playerid][pName]);
				ProxDetector(playerid, (20.00), 0xDD90FFFF, small_string);
				SetPlayerDrunkLevel (playerid, 2000);
		    }
		    case 6: {
			    SetPlayerChatBubble(playerid, "выпил(а) стопку коньяка", 0xDD90FFFF, 30.0, 5000);
				format(small_string, 100, "%s выпил(а) стопку коньяка", PlayerInfo[playerid][pName]);
				ProxDetector(playerid, (20.00), 0xDD90FFFF, small_string);
				SetPlayerDrunkLevel (playerid, 3000);
		    }
		}


		SetPlayerChatBubble(playerid, "выпил(а)", 0xDD90FFFF, 10.0, 2000);
		SendClientMessage(playerid, -1, """{6de64e}""Вы купили алкоголь и выпили");
		SetPVarInt(playerid,"Bought",gettime() + 10);
		return 1;
}

static const AirVeh[] = { 592, 577, 511, 512, 593, 520, 553, 476, 519, 460, 513, 548, 425, 417, 487, 488, 497, 563, 447, 469 };

stock IsAirVehicle(const vehicleid)
{
    for(new i = 0; i < sizeof(AirVeh); i++)
    {
        if(GetVehicleModel(vehicleid) == AirVeh[i]) return 1;
    }
    return 0;
}

stock SetPlayerWanted(const playerid, const level) {
	if(level != 0) {

		if((10801 >= level)) SetPlayerWantedLevel(playerid, 6);
		if((7201 <= level <= 10800)) SetPlayerWantedLevel(playerid, 5);
		if((5401 <= level <= 7200)) SetPlayerWantedLevel(playerid, 4);
		if((3601 <= level <= 5400)) SetPlayerWantedLevel(playerid, 3);
		if((301 <= level <= 3600)) SetPlayerWantedLevel(playerid, 2);
		if((0 <= level <= 300)) SetPlayerWantedLevel(playerid, 1);


		if(Iter_ContainsInternal(_:_Y_ITER_C0:PlayerWanted@YSII_Ag, playerid,_:_Y_ITER_C1:_Y_ITER_C2:sizeof PlayerWanted@YSII_Ag-1) == 0) {
			Iter_AddInternal(_:_Y_ITER_C0:PlayerWanted@YSII_Cg,_:_Y_ITER_C0:PlayerWanted@YSII_Ag, playerid,_:_Y_ITER_C1:_Y_ITER_C2:sizeof PlayerWanted@YSII_Ag-1);
		}
	} else {
		SetPlayerWantedLevel(playerid, 0);
		if(Iter_ContainsInternal(_:_Y_ITER_C0:PlayerWanted@YSII_Ag, playerid,_:_Y_ITER_C1:_Y_ITER_C2:sizeof PlayerWanted@YSII_Ag-1) == 1) {
			Iter_RemoveInternal(_:_Y_ITER_C0:PlayerWanted@YSII_Cg,_:_Y_ITER_C0:PlayerWanted@YSII_Ag, playerid,_:_Y_ITER_C1:_Y_ITER_C2:sizeof PlayerWanted@YSII_Ag-1);
		}
	}

	return PlayerInfo[playerid][pWanted] = level;
}



stock SetVehicleParamsForPlayerEx(vehicleid, playerid, objective, doorslocked) 
{
	SetVehicleParamsForPlayer(vehicleid, playerid, objective, doorslocked);
	new Float:xx,Float:yy,Float:zz;
	GetVehiclePos(vehicleid, xx, yy, zz);
	for(new  i=_:_Y_ITER_C1:_Y_ITER_C2:sizeof  Player@YSII_Ag-1;_:( i=_:_Y_ITER_C0: Player@YSII_Ag[ i])!=_:_Y_ITER_C1:_Y_ITER_C2:sizeof  Player@YSII_Ag-1;) { if(IsPlayerInRangeOfPoint(i, 100, xx, yy, zz)) SetVehicleParamsForPlayer(vehicleid, i, objective, doorslocked); }
    VehicleParameters[vehicleid][0] = objective; 
    VehicleParameters[vehicleid][1] = doorslocked; 
    return 1;
}

forward pc_cmd_lock(playerid, params[]); public pc_cmd_lock(playerid, params[]) {
	if(caridhouse[playerid] != -1) {
		new Float:xx,Float:yy,Float:zz;
		GetVehiclePos(caridhouse[playerid], xx, yy, zz);
		if(IsPlayerInRangeOfPoint(playerid, 4, xx, yy, zz)) {
			PlayerPlaySound(playerid, 24600, 0, 0, 0);
			if(VehicleParameters[caridhouse[playerid]][1] == 1) {
				SetVehicleParamsForPlayerEx(caridhouse[playerid],playerid,0,0);
				format(small_string, 100, "%s открыл(а) замок", PlayerInfo[playerid][pName]);
				ProxDetector(playerid, (20.00), 0xDD90FFFF, small_string);
				return GameTextForPlayer(playerid, "~g~Unlocked", 2500, 4);
			}
			if(VehicleParameters[caridhouse[playerid]][1] == 0) {
				SetVehicleParamsForPlayerEx(caridhouse[playerid],playerid,0,1); 	
				format(small_string, 100, "%s закрыл(а) замок", PlayerInfo[playerid][pName]);
				ProxDetector(playerid, (20.00), 0xDD90FFFF, small_string);
				return GameTextForPlayer(playerid, "~r~Locked", 2500, 4);
			}
		}
	}
	else return 1;
	return 1;
}

