stock update_logo_textdraw_color(playerid) {
	PlayerTextDrawHide(playerid, 	server_logo[playerid][0]);
	PlayerTextDrawHide(playerid, 	server_logo[playerid][1]);

	switch(PlayerInfo[playerid][pColor]) {
		case 1: {
			PlayerTextDrawColor(playerid, server_logo[playerid][0], 0x67da41FF);
			PlayerTextDrawBoxColor(playerid, server_logo[playerid][1], 0x67da41FF);
		}
		case 2: {
			PlayerTextDrawColor(playerid, server_logo[playerid][0], 0x4eb9e6FF);
			PlayerTextDrawBoxColor(playerid, server_logo[playerid][1], 0x4eb9e6FF);
		}
		case 3: {
			PlayerTextDrawColor(playerid, server_logo[playerid][0], 0xFFAF00FF);
			PlayerTextDrawBoxColor(playerid, server_logo[playerid][1], 0xFFAF00FF);
		}
		case 4: {
			PlayerTextDrawColor(playerid, server_logo[playerid][0], 0x333333FF);
			PlayerTextDrawBoxColor(playerid, server_logo[playerid][1], 0x333333FF);
		}		
		default: {
			PlayerTextDrawColor(playerid, server_logo[playerid][0], 0xff353cFF);
			PlayerTextDrawBoxColor(playerid, server_logo[playerid][1], 0xff353cFF);
		}
	}

	PlayerTextDrawShow(playerid, 	server_logo[playerid][0]);
	PlayerTextDrawShow(playerid, 	server_logo[playerid][1]);

	if(IsPlayerInAnyVehicle(playerid)) {
		hide_speedo(playerid);
		show_speedo(playerid, GetVehicleModel(GetPlayerVehicleID(playerid)));
		return 1;
	}
	return 1;
}

