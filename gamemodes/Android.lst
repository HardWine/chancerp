		case 6: format(big_string, sizeof big_string, """{01FCFF}""%s %s\nĚŕňĺđčŕëîâ íŕ ńęëŕäĺ: %d\nŇĺđđčňîđčé ďîä ęîíňđîëĺě: %d\n\nŃîáđŕňü îđóćčĺ: /makegun",GetGangName(gangid),(WStatus[gangid] == 1) ? ("{FFFFFF}(""{6de64e}""îňęđűň{FFFFFF})") : ("{FFFFFF}(""{ff353c}""çŕęđűň{FFFFFF})"), Warehouse[gangid], ownlands);
