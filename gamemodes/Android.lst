stock Saloon_OP_PickUpDynamicPickup(playerid, pickupid) {
	if(pickupid >= Saloon[0] && pickupid <= Saloon[3]) {
		if(GetPVarInt(playerid,"AntiFloodF") > gettime())	{ return false; }
		SetPVarInt(playerid,"AntiFloodF",gettime() + 5);
		new selectedcar = GetPVarInt(playerid, "VehToBuy");
		if(!selectedcar) return SendClientMessage(playerid, -1, """{FFAF00}""Ńíŕ÷ŕëŕ íĺîáőîäčěî ńĺńňü çŕ đóëü ďîíđŕâčâřĺăîń˙ ŕâňîěîáčë˙");
		SendClientMessage(playerid, -1, """{FFAF00}""Ĺńëč ó Âŕń óćĺ čěĺĺňń˙ ňđŕíńďîđň, îí áóäĺň çŕěĺíĺí!");

		SPD(playerid, dBuyCar, 0, "Ďîęóďęŕ ňđŕíńďîđňŕ", "{FFFFFF}Âű äĺéńňâčňĺëüíî őîňčňĺ ęóďčňü ňđŕíńďîđň?\n""{FFAF00}""Ňđŕíńďîđň ďŕđęóĺňń˙ ó íĺäâčćčěîńňč, äë˙ ĺăî čńďîëüçîâŕíč˙ âŕě íóćĺí äîě!\nĹńëč ó âŕń óćĺ ĺńňü ňđŕíńďîđň - îí áóäĺň çŕěĺíĺí", "Ęóďčňü", "Îňěĺíŕ");
	}
	return 1;
}
forward pc_cmd_sellcar(playerid); public pc_cmd_sellcar(playerid) {
	new
    vehicleid = GetPlayerVehicleID(playerid),
    modelid = GetVehicleModel(vehicleid);
	if(vehicleid != caridhouse[playerid]) return SendClientMessage(playerid, -1, """{FFAF00}""Íĺîáőîäčěî íŕőîäčňüń˙ â ńâîĺě ňđŕíńďîđňĺ");
	if(modelid == 509) return 1;
	for(new i = 0; i < 87; i++) {
	if(AutoSalee[i][AS_ModelID] == modelid) {
		new vehprice = AutoSalee[i][AS_Score]/(2);
		new mile = PlayerInfo[playerid][pMileage]/1000;
		if(mile > 1500) vehprice = AutoSalee[i][AS_Score]/(3);
		if(mile > 2000) vehprice = AutoSalee[i][AS_Score]/(4);
		if(mile > 3000) vehprice = AutoSalee[i][AS_Score]/(5);
		if(mile > 4000) vehprice = AutoSalee[i][AS_Score]/(6);
		if(mile > 5000) vehprice = AutoSalee[i][AS_Score]/(7);
		if(mile > 6000) vehprice = AutoSalee[i][AS_Score]/(8);
		if(mile > 7000) vehprice = AutoSalee[i][AS_Score]/(9);
		if(mile > 8000) vehprice = AutoSalee[i][AS_Score]/(10);
		if(mile > 98000) vehprice = AutoSalee[i][AS_Score]/(25);
		if(mile > 10000) vehprice = AutoSalee[i][AS_Score]/(50);
		format(small_string, sizeof small_string, "{FFFFFF}Âű ńîáčđŕĺňĺńü ďđîäŕňü ńâîé ňđŕíńďîđň. Ďđĺäëŕăŕĺěŕ˙ öĺíŕ: %d ""{6de64e}""EXP", vehprice);
		return SPD(playerid, dSellCar, 0, "Ďđîäŕňü ëč÷íűé ňđŕíńďîđň?", small_string, "Äŕ", "Íĺň");

		}
	}
	return 1;
}
stock SellCar_Gov(playerid) {
	new
    vehicleid = GetPlayerVehicleID(playerid),
    modelid = GetVehicleModel(vehicleid);
	if(vehicleid != caridhouse[playerid]) return SendClientMessage(playerid, -1, """{FFAF00}""Íĺîáőîäčěî íŕőîäčňüń˙ â ńâîĺě ňđŕíńďîđňĺ");
	if(modelid == 509) return 1;
	for(new i = 0; i < 87; i++) {
	if(AutoSalee[i][AS_ModelID] == modelid) {

	new vehprice = AutoSalee[i][AS_Score]/(2);

	new mile = PlayerInfo[playerid][pMileage]/1000;

	if(mile > 1500) vehprice = AutoSalee[i][AS_Score]/(3);
	if(mile > 2000) vehprice = AutoSalee[i][AS_Score]/(4);
