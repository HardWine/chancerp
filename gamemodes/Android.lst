forward dre_DIALOG_MANAGER_AVIA(playerid, response, listitem, inputtext[]); public dre_DIALOG_MANAGER_AVIA(playerid, response, listitem, inputtext[]) {
	if(!response) {
		return 0;
	} else {
		if(PlayerAviationModel[playerid] == (-1)) {
			return SendClientMessage(playerid, -1, """{FFAF00}""Ó âŕń íĺň ëč÷íîăî âĺđňîëĺňŕ");
		}

		switch(listitem) {

			case 0: {
				if(PlayerAviationModel[playerid] != 487) {
					SendClientMessage(playerid, -1, """{FFAF00}""Ďĺđĺęđŕńęŕ äîńňóďíŕ ňîëüęî äë˙ âĺđňîëĺňŕ ěŕđęč \"Maverick\"");
					return (1);
				} else {
					return Dialog_Show(playerid, #DIALOG_CHANCE_AVIA_COLOR);
				}
			}

			case 1: {
				PlayerSellAviaTime[playerid] = 10;
				Dialog_Show(playerid, #DIALOG_SELL_AVIA);
				(J@=0,I@=-1,Timer: SellAvia_yT@(playerid));
				return 1;
			}
			default: {
				return Dialog_Show(playerid, #DIALOG_MANAGER_AVIA);
			}
		}
	}
	return 1;
}

stock SellAvia_yT@(playerid)return _Timer_C(O@(# SellAvia@_yT,(I@==-1)?(1000):I@,J@,@Yf:@Yg:@Yf:@Yg:@Yh:#id#,J@,playerid),0);@Yj: SellAvia@_yT(__r,playerid);public @Yj: SellAvia@_yT(__r,playerid){ SellAvia(playerid);} SellAvia(playerid) {
	if(!Dialog_IsOpen(playerid)) {
		return 0;
	}

	new 
		time = PlayerSellAviaTime[playerid];

	if(time >= 0) {
		PlayerSellAviaTime[playerid] = time - 1;
		Dialog_Show(playerid, #DIALOG_SELL_AVIA);

		(J@=0,I@=-1,Timer: SellAvia_yT@(playerid));
	} else {
		PlayerSellAviaTime[playerid] = -1;
	}
	return 1;
}


