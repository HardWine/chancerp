CMD:pet(playerid) {

	if(GetPVarInt(playerid,"parrotflood") > gettime() && GetPlayerAdminLevel(playerid) < 6){ SendClientMessage(playerid, -1, ""COLOR_RED"Пожалуйста, не флудите!"); return false; }
	SetPVarInt(playerid,"parrotflood",gettime() + 3);

	if(PlayerInfo[playerid][pParrot] == 0) return SendClientMessage(playerid, -1, ""COLOR_RED"У вас нет попугая");
	if(GetPVarInt(playerid, "parrot")) {
		RemovePlayerAttachedObject(playerid, 7);
		DeletePVar(playerid, "parrot");
	}
	SetPlayerAttachedObject(playerid, 7, 19078, 1, 0.329150, -0.072101, 0.156082, 0.000000, 0.000000, 0.000000, 1.000000, 1.000000, 1.000000);
	SendClientMessage(playerid, -1, ""COLOR_BLUE"Вы посадили своего питомца на плечо");
	SendClientMessage(playerid, -1, ""COLOR_BLUE"Чем больше времени вы проведете с ним, тем быстрее он начнет говорить");
	SetPVarInt(playerid, "parrot", 1);
	return 1;
}


