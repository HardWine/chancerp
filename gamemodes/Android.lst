       	PlayerInfo[params[0]][pRankGot] = 1; SetPlayerInt(params[0], "RankGot", PlayerInfo[params[0]][pRankGot]);
    	PlayerInfo[playerid][pUpRank] -= 1; SetPlayerInt(params[0], "UpRank", PlayerInfo[playerid][pUpRank]);

		format(small_string, sizeof small_string, """{ff353c}""Âű ďîíčçčëč {FFFFFF}%s""{ff353c}"" äî %d đŕíăŕ. Îńňŕëîńü ďîâűřĺíčé/ďîíčćĺíčé: {FFFFFF}%d", PlayerInfo[params[0]][pName],PlayerInfo[params[0]][pRank],PlayerInfo[playerid][pUpRank]);    
    }
   	else format(small_string, sizeof small_string, """{ff353c}""Âű ďîíčçčëč {FFFFFF}%s""{ff353c}"" äî %d đŕíăŕ", PlayerInfo[params[0]][pName],PlayerInfo[params[0]][pRank]);
