		case 2: SetPlayerRaceCheckpoint(playerid, 0, 2381.6125,-1937.0690,13.5469,1467.5138,-1842.7095,13.5469, 5);
		case 3: SetPlayerRaceCheckpoint(playerid, 0, 1467.5138,-1842.7095,13.5469,1001.5471,-1437.3885,13.5469, 5);
