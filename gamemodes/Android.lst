			if(!response) {
				new sellerid = GetPVarInt(playerid, "CarOffer");
				SendClientMessage(sellerid, -1, """{ff353c}""Ńäĺëęŕ îňěĺíĺíŕ");
				SendClientMessage(playerid, -1, """{ff353c}""Ńäĺëęŕ îňěĺíĺíŕ");
				return CancelOffer(playerid);
			}
			if(GetPVarInt(playerid, "CarOffer") != -1) {
				new sellerid = GetPVarInt(playerid, "CarOffer");
				new price = GetPVarInt(playerid, "OfferPrice");

				if(GetDistanceBetweenPlayerz(playerid, sellerid, 10.00) != 1) return SendClientMessage(playerid, -1, """{ff353c}""Ďđîäŕâĺö ńëčřęîě äŕëĺęî"), CancelOffer(playerid);
				if(PlayerLogged{sellerid} == false || !IsPlayerConnected(sellerid)) return SendClientMessage(playerid, -1, """{ff353c}""Ďđîäŕâĺö íĺ â ńĺňč"), CancelOffer(playerid);

				if(price > 0) {
					if(CheckCash(playerid, price) == false) return SendClientMessage(playerid, -1, """{ff353c}""Íĺäîńňŕňî÷íî ńđĺäńňâ"), CancelOffer(playerid), SendClientMessage(sellerid, -1, """{ff353c}""Ńäĺëęŕ îňěĺíĺíŕ");
					RemovePlayerEXP(playerid, price, "Äîďëŕňŕ ďđč îáěĺíĺ äîěŕěč äë˙ čăđîęŕ %s", PlayerInfo[sellerid][pName]);
					AddPlayerEXP(sellerid, price, "Äîďëŕňŕ ďđč îáěĺíĺ äîěŕěč îň čăđîęŕ %s", PlayerInfo[playerid][pName]);
				}
				SendClientMessage(playerid, -1, """{6de64e}""Ńäĺëęŕ ďîäňâĺđćäĺíŕ");
				SendClientMessage(sellerid, -1, """{6de64e}""Ńäĺëęŕ ďîäňâĺđćäĺíŕ");

				new player_house = GetPlayerHouseID(playerid);
				new seller_house = GetPlayerHouseID(sellerid);
				if(IsValidVehicle(caridhouse[playerid]))
				{
					FUEL_DestroyVehicle(caridhouse[playerid]);
					caridhouse[playerid] = (0xFFFF);
				}
				if(IsValidVehicle(caridhouse[sellerid]))
				{
					FUEL_DestroyVehicle(caridhouse[sellerid]);
					caridhouse[sellerid] = (0xFFFF);
				}
				if(player_house > 0) {

					HouseInfo[player_house][hOwned] = 1;
					HouseInfo[player_house][hTakings] = 1;
					strmid(HouseInfo[player_house][hOwner], PlayerInfo[sellerid][pName], 0, MDialog_strlen(PlayerInfo[sellerid][pName]), 255);

					new MySQL[110];
					mysql_format(database, MySQL, sizeof(MySQL), "UPDATE `apartment` SET Owner = '%e', Owned = 1, Takings = 1 WHERE ID = '%d' LIMIT 1",PlayerInfo[sellerid][pName],player_house);
					mysql_pquery(database, MySQL, "", "");

					Streamer_SetIntData((1), HouseInfo[player_house][hPickup], 23, 1272);
					BuyHouse(player_house);
					SetPVarInt(sellerid, "PlayerHouse", player_house);

					SendClientMessage(sellerid, -1, """{ff353c}""Îďëŕňčňĺ äîě â áŕíęĺ, âî čçáĺćŕíčĺ äŕëüíĺéřĺé ďđîäŕćč äîěŕ ăîńóäŕđńňâó");
					SendClientMessage(sellerid, -1, "(( Îňęđűňü čëč çŕęđűňü äâĺđč äîěŕ ěîćíî ęîěŕíäîé: /homelock ))");
				}

				HouseInfo[seller_house][hOwned] = 1;
				HouseInfo[seller_house][hTakings] = 1;
				strmid(HouseInfo[seller_house][hOwner], PlayerInfo[playerid][pName], 0, MDialog_strlen(PlayerInfo[playerid][pName]), 255);

				new MySQL[110];
				mysql_format(database, MySQL, sizeof(MySQL), "UPDATE `apartment` SET Owner = '%e', Owned = 1, Takings = 1 WHERE ID = '%d' LIMIT 1",PlayerInfo[playerid][pName],seller_house);
				mysql_pquery(database, MySQL, "", "");

				Streamer_SetIntData((1), HouseInfo[seller_house][hPickup], 23, 1272);
				BuyHouse(seller_house);
				SetPVarInt(playerid, "PlayerHouse", seller_house);


				SendClientMessage(playerid, -1, """{ff353c}""Îďëŕňčňĺ äîě â áŕíęĺ, âî čçáĺćŕíčĺ äŕëüíĺéřĺé ďđîäŕćč äîěŕ ăîńóäŕđńňâó");
				SendClientMessage(playerid, -1, "(( Îňęđűňü čëč çŕęđűňü äâĺđč äîěŕ ěîćíî ęîěŕíäîé: /homelock ))");

				CancelOffer(playerid);

				PlayerInfo[playerid][pTransferControl] = PlayerInfo[playerid][pTransferControl]+1;
				SetPlayerInt(playerid, "TransferControl", PlayerInfo[playerid][pTransferControl]);

				PlayerInfo[sellerid][pTransferControl] = PlayerInfo[sellerid][pTransferControl]+1;
				SetPlayerInt(sellerid, "TransferControl", PlayerInfo[sellerid][pTransferControl]);

				LoadCarPlayerId(playerid);
				LoadCarPlayerId(sellerid);

				static string[512];

				mysql_format(database,
					string, sizeof(string),
					"INSERT INTO `changehouse_log` (`Seller`, `Buyer`, `Addition`, `Shouse`, `Bhouse`) VALUES (%i, %i, %i, %i, %i)",
						PlayerInfo[sellerid][pID],
						PlayerInfo[playerid][pID],
						price,
						seller_house,
						player_house
				);
				return mysql_pquery(database, string);
			}
		}
