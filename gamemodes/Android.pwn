stock IncreaseKarma(playerid) {

	PlayerInfo[playerid][pKarma] = PlayerInfo[playerid][pKarma] + 1;

	SetPlayerInt(playerid, "Karma", PlayerInfo[playerid][pKarma]);
	return 1;
}
stock DecreaseKarma(playerid) {

	PlayerInfo[playerid][pKarma] = PlayerInfo[playerid][pKarma] - 1;

	SetPlayerInt(playerid, "Karma", PlayerInfo[playerid][pKarma]);
	return 1;
}

stock AddPlayerBankEXP(const playerid, const value, const format_string[], va_args<>) {
	if(PlayerLogged{playerid} == false || !IsPlayerConnected(playerid)) {
		new name[MAX_PLAYER_NAME + 1];
		GetPlayerName(playerid, name, MAX_PLAYER_NAME);
		
		printf("Попытка начислить денег в банк у не авторизованного игрока name=%s value=%i (get=%i)", name, value, GetPlayerMoney(playerid));
		return false;
	}

	new old_value = PlayerInfo[playerid][pBank];
	PlayerInfo[playerid][pBank] += value;
	new new_value = PlayerInfo[playerid][pBank];

	static const fmt_str_0[] = "UPDATE players SET `Bank` = %i WHERE `ID` = %i LIMIT 1";
	static const fmt_str_1[] = "INSERT INTO `player_log` (`PlayerID`, `Action`, `Text`) VALUES (%i, %i, '%e');";

	goto skip_array_init;
	new string_0[sizeof(fmt_str_0) + 1
		+ (- 2 + 11)
		+ (- 2 + 8)
	];
	new string_1[sizeof(fmt_str_1) + 1
		+ (- 2 + 8)
		+ (- 2 + 2)
		+ (- 2 + 144)
	];
	skip_array_init:

	mysql_format(database,
		string_0, sizeof(string_0),
		fmt_str_0,
			PlayerInfo[playerid][pBank],
			PlayerInfo[playerid][pID]
	);
	new result = mysql_pquery(database, string_0);
	if(!result)
	{
		printf("AddPlayerBankEXP: ошибка в запросе %s", string_0);
	}

	// Логирование
	va_format(string_1, sizeof(string_1), format_string, va_start<3>);

	format(big_string, sizeof(big_string), "(%i EXP): %s (Было %i EXP; Стало: %i EXP)", value, string_1, old_value, new_value);

	mysql_format(database,
		string_1, sizeof(string_1),
		fmt_str_1,
			PlayerInfo[playerid][pID],
			E_LOG_BANK_GIVE,
			big_string
	);
	
	result = mysql_pquery(database, string_1);
	if(!result)
	{
		printf("AddPlayerBankEXP: ошибка в запросе %s", string_1);
	}
	return true;
}

stock RemovePlayerBankEXP(playerid, znach, const format_string[], va_args<>) {
	if(PlayerLogged{playerid} == false || !IsPlayerConnected(playerid)) {
		new name[MAX_PLAYER_NAME + 1];
		GetPlayerName(playerid, name, MAX_PLAYER_NAME);
		
		printf("Попытка отнятия денег в банке у не авторизованного игрока name=%s value=%i (get=%i)", name, znach, GetPlayerMoney(playerid));
		return false;
	}

	new old_value = PlayerInfo[playerid][pBank];
	PlayerInfo[playerid][pBank] -= znach;
	new new_value = PlayerInfo[playerid][pBank];

	static const fmt_str_0[] = "UPDATE players SET `Bank` = %i WHERE `ID` = %i LIMIT 1";
	static const fmt_str_1[] = "INSERT INTO `player_log` (`PlayerID`, `Action`, `Text`) VALUES (%i, %i, '%e');";

	goto skip_array_init;
	new string_0[sizeof(fmt_str_0) + 1
		+ (- 2 + 11)
		+ (- 2 + 8)
	];
	new string_1[sizeof(fmt_str_1) + 1
		+ (- 2 + 8)
		+ (- 2 + 2)
		+ (- 2 + 144)
	];
	skip_array_init:

	mysql_format(database,
		string_0, sizeof(string_0),
		fmt_str_0,
			PlayerInfo[playerid][pBank],
			PlayerInfo[playerid][pID]
	);
	new result = mysql_pquery(database, string_0);
	if(!result)
	{
		printf("RemovePlayerBankEXP: ошибка в запросе %s", string_0);
	}
	
	// Логирование
	va_format(string_1, sizeof(string_1), format_string, va_start<3>);

	format(big_string, sizeof(big_string), "(%i EXP): %s (Было %i EXP; Стало: %i EXP)", znach, string_1, old_value, new_value);

	mysql_format(database,
		string_1, sizeof(string_1),
		fmt_str_1,
			PlayerInfo[playerid][pID],
			E_LOG_BANK_REMOVE,
			big_string
	);
	result = mysql_pquery(database, string_0);
	if(!result)
	{
		printf("RemovePlayerBankEXP: ошибка в запросе %s", string_1);
	}
	return true;
}

stock AddPlayerEXP(const playerid, const value, const format_string[], va_args<>) {
	if(PlayerLogged{playerid} == false || !IsPlayerConnected(playerid)) {
		new name[MAX_PLAYER_NAME + 1];
		GetPlayerName(playerid, name, MAX_PLAYER_NAME);
		
		printf("Попытка сохранения денег у не авторизованного игрока name=%s value=%i (get=%i)", name, value, GetPlayerMoney(playerid));
		return false;
	}

	new old_value = PlayerInfo[playerid][pScore];
	PlayerInfo[playerid][pScore] = PlayerInfo[playerid][pScore] + value;
	new new_value = PlayerInfo[playerid][pScore];

	if(GetPlayerMoney(playerid) != PlayerInfo[playerid][pScore])
	{
		ResetPlayerMoney(playerid);
		GivePlayerMoney(playerid, PlayerInfo[playerid][pScore]);
	}

	static const fmt_str_0[] = "UPDATE players SET `Score` = %i WHERE `ID` = %i LIMIT 1";
	static const fmt_str_1[] = "INSERT INTO `player_log` (`PlayerID`, `Action`, `Text`) VALUES (%i, %i, '%e');";
	
	goto skip_array_init;
	new string_0[sizeof(fmt_str_0) + 1
		+ (- 2 + 11)
		+ (- 2 + 8)
	];
	new string_1[sizeof(fmt_str_1) + 1
		+ (- 2 + 8)
		+ (- 2 + 2)
		+ (- 2 + 144)
	];
	skip_array_init:

	mysql_format(database,
		string_0, sizeof(string_0),
		fmt_str_0,
			PlayerInfo[playerid][pScore],
			PlayerInfo[playerid][pID]
	);
	new result = mysql_pquery(database, string_0);
	if(!result)
	{
		printf("AddPlayerEXP: ошибка в запросе %s", string_0);
	}

	// Логирование
	va_format(string_1, sizeof(string_1), format_string, va_start<3>);

	format(big_string, sizeof(big_string), "(%i EXP): %s (Было %i EXP; Стало: %i EXP)", value, string_1, old_value, new_value);

	mysql_format(database,
		string_1, sizeof(string_1),
		fmt_str_1,
			PlayerInfo[playerid][pID],
			E_LOG_MONEY_GIVE,
			big_string
	);
	result = mysql_pquery(database, string_1);
	if(!result)
	{
		printf("AddPlayerEXP: ошибка в запросе %s", string_1);
	}

	return true;
}

