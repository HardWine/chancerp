				switch(listitem) {
					case 0: {
						ShowPlayerDialog(playerid, dMenuReport, DIALOG_STYLE_INPUT, "Связь с администрацией", ""COLOR_WHITE"Укажите ID нарушителя и как можно подробнее опишите сутациию\n"COLOR_RED"Внимание! Для вопросов по игре, вам нужно обратиться к помощникам администрации\n/mn - Связь с администрацией - > Задать вопрос\nЗа игнорирование этого правила, администрация вправе Вас наказать", "Выбрать", "Закрыть");
					}
					case 1: {
						return ShowPlayerDialog(playerid, dMenuHelper, DIALOG_STYLE_INPUT, "Задать вопрос", "Подробно опишите возникший у Вас вопрос", "Отправить", "Назад");
					}
					case 2: { ShowPlayerDialog(playerid, dMenuBug, DIALOG_STYLE_INPUT, "Сообщить о баге", "Подробно опишите найденную Вами недоработку\n\n"COLOR_GREEN"Если вы первый нашли важную недоработку,\nвозможно вы получите вознаграждение", "Отправить", "Назад");
					}
					case 3: {ShowPlayerDialog(playerid, dMenuSug, DIALOG_STYLE_INPUT, "Предложить улучшение", "{ffffff}Подробно опишите ваше улучшение и для чего оно нужно\n\n"COLOR_GREEN"Повторяться, предлагать чужие и старые идеи\nне стоит, не тратьте своё время", "Отправить", "Назад");
					}
				}
			}
			return 1;
		}
		case dMenuBug:
		{
			if(!response) {
				return SPD(playerid, dMenuFeedback, DIALOG_STYLE_LIST, ""COLOR_BLUE"Связь с администрацией","1. Написать администрации в сети\n2. Оставить сообщение о баге\n3. Предложить улучшение", "Выбрать", "Отмена");
			}
			if(response) {
				new string_length = strlen(inputtext);
				if(string_length > 128 || string_length < 6 || !string_length) {
				SPD(playerid,
					dMenuBug, DIALOG_STYLE_INPUT,
					!"Сообщить о баге",
					"{ffffff}Подробно опишите найденную Вами недоработку\n\
					{009900}Если вы первый нашли важную недоработку,\n\
					возможно вы получите вознаграждение",
					!"Отправить", !"Назад"
				);
				return 1;
				}
				callcmd::bug(playerid, inputtext);
			}
			return 1;
		}
		case dMenuSug:
		{
			if(!response) {
				return SPD(playerid, dMenuFeedback, DIALOG_STYLE_LIST, ""COLOR_BLUE"Связь с администрацией","1. Написать администрации в сети\n2. Оставить сообщение о баге\n3. Предложить улучшение", "Выбрать", "Отмена");
			}
			if(response) {
				new string_length = strlen(inputtext);
				if(string_length > 128 || string_length < 6 || !string_length) {
				SPD(playerid,
					dMenuSug, DIALOG_STYLE_INPUT,
					!"Предложить улучшение",
					"{ffffff}Подробно опишите ваше улучшение и для чего оно нужно\n\
					{009900}Повторяться, предлагать чужие и старые идеи\n\
					не стоит, не тратьте своё время",
					!"Отправить", !"Назад"
				);
				return 1;
				}
				callcmd::sug(playerid, inputtext);
			}
			return 1;
		}
		case dMenuReport:
		{
			if(!response) {
				return ShowPlayerDialog(playerid, dMenuFeedback, DIALOG_STYLE_LIST, "Связь с администрацией","{FFFFFF}1. Сообщить о нарушение\n2. Задать вопрос\n3. Оставить сообщение о баге\n4. Предложить улучшение", "Выбрать","Закрыть");
			}
			if(response) {
				new string_length = strlen(inputtext);
				if(PlayerInfo[playerid][pMuted] == 1) return SendClientMessage(playerid, -1, ""COLOR_RED"У вас бан чата");
				if(string_length > 128 || string_length < 2 || !string_length) {
				ShowPlayerDialog(playerid, dMenuReport, DIALOG_STYLE_INPUT, "Связь с администрацией", ""COLOR_WHITE"Укажите ID нарушителя и как можно подробнее опишите сутациию\n"COLOR_RED"Внимание! Для вопросов по игре, вам нужно обратиться к помощникам администрации\n/mn - Связь с администрацией - > Задать вопрос\nЗа игнорирование этого правила, администрация вправе Вас наказать", "Выбрать", "Закрыть");
				return 1;
				}
				callcmd::report(playerid, inputtext);
			}
			return 1;
		}
		case dMenuHelper:
		{
			if(!response) {
				return 2;
			}
			if(response) {
				new string_length = strlen(inputtext);
				if(PlayerInfo[playerid][pMuted] == 1) return SendClientMessage(playerid, -1, ""COLOR_RED"У вас бан чата");
				if(string_length > 128 || string_length < 2 || !string_length) {
					return ShowPlayerDialog(playerid, dMenuHelper, DIALOG_STYLE_INPUT, "Задать вопрос", "Подробно опишите возникший у Вас вопрос", "Отправить", "Назад");
				}
				callcmd::ask(playerid, inputtext);
			}
			return 1;
		}
	}
	return 1;

}

