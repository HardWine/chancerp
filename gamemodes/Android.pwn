						format(big_string, sizeof(big_string), "{FFFFFF}Лидер: %s\t Назначен: %s\n\nПлатное вступление: %s\n{FFFFFF}Автоповышение ранга: %s\n\n"COLOR_BLUE"Лидер может в любое время изменить состояние настроек",
							Fraction[fractionid][E_FRACTION_LEADER_NAME], Fraction[fractionid][E_FRACTION_DATE_DESTINATION], (Fraction[fractionid][E_FRACTION_AUTO_INVITE] == 1) ? (""COLOR_GREEN"Доступно") : (""COLOR_RED"Недоступно"), (Fraction[fractionid][E_FRACTION_AUTO_RANG] == 1) ? (""COLOR_GREEN"Доступно") : (""COLOR_RED"Недоступно")
						);
