						SetCasinoPlayer(CasinoInfo[i][CI_Table_ID], 2, (0xFFFF));

						if(CasinoInfo[i][CI_Player1] == (0xFFFF)) {
							Player__AddEXP(PlayerInfo[playerid][pID], CasinoInfo[i][CI_Table_Sum], E_LEAVE_RETURN_CASINO_CASH, playerid);
						}
					}
					return 1;
