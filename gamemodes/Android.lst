				SendClientMessage(params[0], -1, """{6de64e}""Âű óńňđîčëčńü íŕ đŕáîňó â LSPD");
				SendClientMessage(params[0], -1, """{6de64e}""Âŕě áűëŕ âűäŕíŕ đŕöč˙, čńďîëüçóéňĺ ĺ¸ äë˙ ńâ˙çč: {FFFFFF}/r č /rn");		
