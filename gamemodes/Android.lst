forward pc_cmd_cn(playerid, params[]); public pc_cmd_cn(playerid, params[]) {
	if(Player__AdminLevel{playerid} < 5) {
		return false;
	}

	new 
		targetid,
		arguments[2];

	if(sscanf(params, "us[2]", targetid, arguments) != 1) {
		new 
			arrayID = Player__IsChangeNick(targetid);

		if(arrayID == -1) {
			return SendClientMessage(playerid, -1, """{FFAF00}""Čăđîę íĺ îňďđŕâë˙ë çŕ˙âęó íŕ ńěĺíó čěĺíč");
		}
		if(strcmp(arguments, "+", false) == 0) {
			format(small_string, sizeof(small_string), 
				"""{6de64e}""Ŕäěčíčńňđŕňîđ %s(%i) îäîáđčë čăđîęó ńěĺíó íčęŕ ń %s(%i) íŕ %s", 
					PlayerInfo[playerid][pName], 
					playerid, 
					PlayerInfo[targetid][pName],
					targetid,
					ChangeNick[arrayID][E_NEW_NAME]
			);
			SendAdminMessage(-1, small_string);

			format(small_string, sizeof(small_string), 
				"""{6de64e}""Âŕřŕ çŕ˙âęŕ íŕ ńěĺíó íčęíĺéěŕ áűëŕ îäîáđĺíŕ ŕäěčíčńňđŕňîđîě %s", 
					PlayerInfo[playerid][pName]
			);
			SendClientMessage(targetid, -1, small_string);

			Player__ChangeNick(targetid, ChangeNick[arrayID][E_NEW_NAME], E_FREE, playerid); 
			return Player__RemoveChangeNick(targetid);
		} else if(strcmp(arguments, "-", false) == 0) {
			format(small_string, sizeof(small_string), 
				"""{ff353c}""Ŕäěčíčńňđŕňîđ %s(%i) îňęëîíčë čăđîęó ńěĺíó íčęŕ ń %s(%i) íŕ %s", 
					PlayerInfo[playerid][pName], 
					playerid, 
					PlayerInfo[targetid][pName],
					targetid,
					ChangeNick[arrayID][E_NEW_NAME]
			);
			SendAdminMessage(-1, small_string);

			format(small_string, sizeof(small_string), 
				"""{ff353c}""Âŕřŕ çŕ˙âęŕ íŕ ńěĺíó íčęíĺéěŕ áűëŕ îňęëîíĺíŕ ŕäěčíčńňđŕňîđîě %s", 
					PlayerInfo[playerid][pName]
			);
			SendClientMessage(targetid, -1, small_string);
			return Player__RemoveChangeNick(targetid);
		} else {
			return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ: /cn [ID Čăđîęŕ] [+(äë˙ îäîáđĺíč˙)/-(äë˙ îňęëîíĺíč˙)");
		}
	} else {
		return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ: /cn [ID Čăđîęŕ] [+(äë˙ îäîáđĺíč˙)/-(äë˙ îňęëîíĺíč˙)");
	}
}

public bool: Player__RemoveChangeNick(const playerid) {
	for(new i = 0; i < (20); i++) {
		if(ChangeNick[i][E_PLAYER_ID] == playerid) {
			ChangeNick[i][E_NEW_NAME][0] = EOS;
			ChangeNick[i][E_PLAYER_ID] = (0xFFFF);
			return true;
		}
	}
	return false;
}
