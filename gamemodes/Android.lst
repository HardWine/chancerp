stock OnLeavePatrol(playerid, state_patrol = 0) {
	if(player_Patrol[playerid] != -1) {
		if(state_patrol == 1) {
		SendClientMessage(playerid, -1, """{FFAF00}""Âű óćĺ íŕ ďîńňó. Ďîęčíüňĺ ĺăî ÷ňîáű âűáđŕňü äđóăîé");
		return 0;
