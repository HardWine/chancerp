forward int_op();
public int_op() {

	for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i=Iterator@Player [_: i])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);) {
		if(GetPlayerState(i) == (1) && PlayerLogged{i} == false) return ImmediateKick(i);
		if(PlayerLogged{i} == false) {
			continue;
		}	
		gettime(hour, minute, seconds);
		if(GetPlayerVirtualWorld(i) != 0 || GetPlayerInterior(i) != 0) {
			SetPlayerWeather(i, 1);
			SetPlayerTime(i, 12, 0);
		} else {
			SetPlayerWeather(i, weather);
			if(hour == 20) hour = 19;
			if(hour == 21) hour = 20;
			if(hour == 22) hour = 20;
			if(hour == 23) hour = 21;
			if(hour == 0) hour = 22;
			if(hour == 1) hour = 23;
			if(hour == 2) hour = 0;
			if(hour == 3) hour = 1;
			if(hour == 4) hour = 2;
			SetPlayerTime(i, hour, minute);
		}
	}
	return SetTimer("int_op", 250, false);
}

