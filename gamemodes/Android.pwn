		if(selected == PlayerInfo[playerid][pSkin]) return SendClientMessage(playerid, -1, ""COLOR_RED"Вы уже приобрели данную одежду");

		RemovePlayerEXP(playerid, 10000, "Покупка одежды");

		SetPlayerInt(playerid, "Skin", selected);
		PlayerInfo[playerid][pSkin] = selected;
		SetPVarInt(playerid, "SelSkin", 0);
		if(IsValidTimer(bskin[playerid])) KillTimer(bskin[playerid]),bskin[playerid] = -1;
		SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы купили одежду. Хорошего дня!");
		return 1;
	}

	if(pickupid == cloth[4])
	{
		
	
		if(fractionid > FRACTION_NONE && GetPlayerJobDayStatus(playerid) == true) return SendClientMessage(playerid, -1, ""COLOR_WHITE"Завершите рабочий день на "COLOR_GREEN"базе организации");
		if(GetPVarInt(playerid,"SkinSel") > gettime()){ return 1; }
		SetPVarInt(playerid,"SkinSel",gettime() + 20);

		Dialog_Show(playerid, Dialog:ClothesShop);
		SetPVarInt(playerid,"ShopSkin",3);

		SendClientMessage(playerid, -1, ""COLOR_ORANGE"Чтобы купить последний примеренный костюм просто пройдите на кассу");
