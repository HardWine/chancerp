}

forward pc_cmd_turnout(playerid, params[]); public pc_cmd_turnout(playerid, params[]) {
	new Fraction:fractionid = GetPlayerFraction(playerid);
	if(fractionid != FRACTION_LSPD)
	{
		return SendClientMessage(playerid, -1, """{FFAF00}""Ęîěŕíäŕ äîńňóďíŕ ńîňđóäíčęŕě LSPD");
	}
	if(GetPlayerJobDayStatus(playerid) == false)
	{
		return SendClientMessage(playerid, -1, """{FFFFFF}""Íĺîáőîäčěî íŕ÷ŕňü đŕáî÷čé äĺíü íŕ ""{6de64e}""áŕçĺ îđăŕíčçŕöčč");
	}
	if(GetPVarInt(playerid, "turnout_num") == 0 && RouteLSPD[playerid] != -1) {
		RouteLSPD[playerid] = -1;
		return Turnout(playerid);
	}
	if(RouteLSPD[playerid] != -1) return 1;
	return Turnout(playerid);
}
forward pc_cmd_t(playerid, params[]); public pc_cmd_t(playerid, params[]) {
