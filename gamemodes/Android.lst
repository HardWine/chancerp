		} else {
			AddPlayerBankEXP(playerid, exp, "Çŕđďëŕňŕ â San News");
		}
		format(small_string, sizeof(small_string), """{FFAF00}""Çŕđďëŕňŕ: {FFFFFF}+ %d EXP", exp);
		SendClientMessage(playerid, -1, small_string);
	}



	if(fractionid > FRACTION_LSPD && fractionid <= FRACTION_DN_BOYS) {
		exp = gang_profit[_:fractionid];
		if(Player__Leader[playerid] != -1) exp += 250;
		if(IsPlayerPremiumAccount(playerid) == true || 0 == 1) {
			AddPlayerBankEXP(playerid, exp*2, "Çŕđďëŕňŕ â áŕíäĺ");
