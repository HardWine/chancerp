CMD:force(playerid) {
	if(GetPlayerAdminLevel(playerid) < 5) return true;

	for(new c = 0; c <= GetVehiclePoolSize(); c++) {
		if(IsVehicleOccupied(c) == -1 && IsVehicleStreamedIn(c, playerid)) {
			
			SetVehicleToRespawn(c);
		}
	}
	veh_update = 0;
	SendClientMessage(playerid, -1, "Вы обновили весь незанятый транспорт в радиусе прорисовки");
	return 1;	
}
CMD:spawncars(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) < 5) return true;
	if(veh_update == 1) {
		return SendClientMessage(playerid, -1, "Уже запущенно обновление свободного транспорта. Попробуйте позже");
	}
	format(small_string, sizeof(small_string), ""COLOR_ORANGE"Администратор %s обновит весь незанятый транспорт через 30 секунд", PlayerInfo[playerid][pName]);
	SendClientMessageToAll(-1, small_string);
	veh_update = 1;
	return SetTimer(!"@_RespawnVehicle", 30_000, false);
}
@_RespawnVehicle();
@_RespawnVehicle() {
	for(new c = 0; c <= GetVehiclePoolSize(); c++) {
		if(IsVehicleOccupied(c) == -1) {
			SetVehicleToRespawn(c);
		}
	}
	veh_update = 0;
	return SendClientMessageToAll(-1, ""COLOR_ORANGE"Незанятые транспортые средства были обновлены");
}

stock HowMuchAdmins() {
	new null = 0;
	foreach(new i: Admin) {
       if(pl_afk_time[i] >= 6) continue;
       null++; 
	}	
	return null;
}

stock AttackModeAuto(text[]) {
	if(HowMuchAdmins() == 0) {
       if(!strcmp(text, "рут")) COMPARES++;
       if(!strcmp(text, "разнос")) COMPARES++;
       if(!strcmp(text, "слив")) COMPARES++;
       if(!strcmp(text, "чит")) COMPARES++;
       if(!strcmp(text, "миниган")) COMPARES++;
       if(!strcmp(text, "бан")) COMPARES++;
	}
}

CMD:report(playerid, params[])
{
	new chat[144];
	if(PlayerInfo[playerid][pMuted] == 1) return SendClientMessage(playerid, -1, ""COLOR_RED"У вас бан чата");
	// if(GetPVarInt(playerid,!"AntiFloodReport") > gettime()){ SendClientMessage(playerid, -1, "Писать в репорт можно раз в минуту"); return false; }
	if(!params[0])return SendClientMessage(playerid, -1, "Используйте: /report [текст]");
	// SetPVarInt(playerid,!"AntiFloodReport",gettime() + 60);
	AttackModeAuto(params[0]);
	format(chat, sizeof(chat), "{FF4500}%s[%d]:{ffd700} %s", PlayerInfo[playerid][pName],playerid, params[0]);
	SendAdminMessage(-1, chat);
	SendClientMessage(playerid, -1, ""COLOR_ORANGE"Ваше сообщение было отправлено администраторам сервера. Ожидайте ответа");
	format(small_string, sizeof(small_string), "{FF4500}Отправленный текст: {ffd700}%s", params[0]);
	SendClientMessage(playerid, -1, small_string);
	admstat[0]++;
	upd_admstat();
	return 1;
}
CMD:ask(playerid, params[])
{
	new chat[144];
	//if(GetPlayerAdminLevel(playerid) == 0) return true;
	if(PlayerInfo[playerid][pMuted] == 1) return SendClientMessage(playerid, -1, ""COLOR_RED"У вас бан чата");
	if(GetPVarInt(playerid,!"AntiFloodHelper") > gettime()){ SendClientMessage(playerid, -1, "Писать в репорт можно раз в минуту"); return false; }
	if(!params[0])return SendClientMessage(playerid, -1, "Используйте: /ask [текст]");
	SetPVarInt(playerid,!"AntiFloodHelper",gettime() + 60);
	AttackModeAuto(params[0]);
	format(chat, sizeof(chat), "[ASK] "COLOR_ORANGE"%s[%d]: %s", PlayerInfo[playerid][pName],playerid, params[0]);
	SendHelperMessage(-1, chat);
	if(Iter_Count(Helper) == 0)
	{
		SendAdminMessage(-1, chat);
	}
	SendClientMessage(playerid, -1, ""COLOR_ORANGE"Ваше сообщение было отправлено. Ожидайте ответа");
	format(small_string, sizeof(small_string), "{FF4500}Отправленный текст: {ffd700}%s", params[0]);
	SendClientMessage(playerid, -1, small_string);
	admstat[0]++;
	upd_admstat();	
	return 1;
}
CMD:pm(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) > 0) {
		if(sscanf(params, "d s[128]",params[0],params[1])) return	SendClientMessage(playerid, -1, !"Используйте: /pm [id игрока] [текст]");
		
		if(!IsPlayerConnected(params[0])) return  1;
		if(params[0] == INVALID_PLAYER_ID) return 1;
		if(GetPVarInt(params[0],!"GotReport") > gettime()) return 1;
		format(small_string, sizeof(small_string), "%s ответил %s: %s",PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName], params[1]);
		SendAdminMessage(0xFF9945FF, small_string);
		format(small_string, sizeof(small_string), "Администратор %s ответил: %s",PlayerInfo[playerid][pName], params[1]);
		SendClientMessage(params[0], 0xFF9945FF, small_string);
		PlayerPlaySound(params[0], 1085, 0.0, 0.0, 0.0);
		SetPVarInt(params[0],!"GotReport",gettime() + 5);
		Admin.UpCountPM(GetPlayerAccountID(playerid));
		admstat[1]++;
		upd_admstat();
	} else if(Player.HelperLevel{playerid} != 0) {
		if(sscanf(params, "d s[128]",params[0],params[1])) return	SendClientMessage(playerid, -1, !"Используйте: /pm [id игрока] [текст]");

		if(!IsPlayerConnected(params[0])) return  1;
		if(params[0] == INVALID_PLAYER_ID) return 1;
		if(GetPVarInt(params[0],!"GotReport") > gettime()) return 1;
		format(small_string, sizeof(small_string), "%s ответил %s: %s",PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName], params[1]);
		SendAdminMessage(0xFF9945FF, small_string);
		SendHelperMessage(0xFF9945FF, small_string);
		format(small_string, sizeof(small_string), "Support %s ответил: %s",PlayerInfo[playerid][pName], params[1]);
		SendClientMessage(params[0], 0xFF9945FF, small_string);
		PlayerPlaySound(params[0], 1085, 0.0, 0.0, 0.0);
		SetPVarInt(params[0],!"GotReport",gettime() + 5);
		Helper.UpCountPM(GetPlayerAccountID(playerid));
		admstat[1]++;
		upd_admstat();		
	} else {
		return 0;
	}
	return 1;
}
cmd:thx(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) >= 1) {
		if(sscanf(params,"d", params[0])) return 1;
		if(GetPVarInt(params[0],!"GotReports") > gettime()) return SendClientMessage(playerid, -1, !"Используйте: /thx [id игрока]");
		format(small_string, sizeof(small_string), "%s пожелал приятной игры %s",PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName]);
		SendAdminMessage(0xFF9945FF, small_string);
		format(small_string, sizeof(small_string),"Администратор %s ответил: Команда Chance RP, желает Вам приятной игры и хорошего настроения :)",PlayerInfo[playerid][pName]);
		SendClientMessage(params[0], 0xFF9945FF, small_string);
		SetPVarInt(params[0],!"GotReports",gettime() + 5);
		PlayerPlaySound(params[0], 1085, 0.0, 0.0, 0.0);
		Admin.UpCountPM(GetPlayerAccountID(playerid));
	} else if(Player.HelperLevel{playerid} != 0) {
		if(sscanf(params,"d", params[0])) return 1;
		if(GetPVarInt(params[0],!"GotReports") > gettime()) return SendClientMessage(playerid, -1, !"Используйте: /thx [id игрока]");
		format(small_string, sizeof(small_string), "%s пожелал приятной игры %s",PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName]);
		SendAdminMessage(0xFF9945FF, small_string);
		SendHelperMessage(0xFF9945FF, small_string);
		format(small_string, sizeof(small_string),"Млад. администратор %s ответил: Команда Chance RP, желает Вам приятной игры и хорошего настроения :)",PlayerInfo[playerid][pName]);
		SendClientMessage(params[0], 0xFF9945FF, small_string);
		SetPVarInt(params[0],!"GotReports",gettime() + 5);
		PlayerPlaySound(params[0], 1085, 0.0, 0.0, 0.0);
		Helper.UpCountPM(GetPlayerAccountID(playerid));
	}
	return 1;
}

