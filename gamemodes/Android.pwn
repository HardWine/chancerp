CMD:door(playerid, params[]) {
	new Fraction: fractionid = GetPlayerFraction(playerid);
	if(fractionid == FRACTION_ARMY) { //Дверь призыв
		if(!IsPlayerInRangeOfPoint(playerid, 3.2, 1167.859130, 1363.050415, 9.722514)) return SendClientMessage(playerid, -1, ""COLOR_RED"Необходимо находиться у двери в призывной пункт");
		if(GetPlayerJobDayStatus(playerid) == false)
		{
			return SendClientMessage(playerid, -1, MSG_START_JOB_DAY);
		}
		if(army_door_timeout > 0) return SendClientMessage(playerid, -1, ""COLOR_RED"Нельзя использовать так часто!");
		if(IsValidDynamicObject(army_door[0])) {
			DestroyDynamicObject(army_door[0]);
		} else {
			return 1;
		}
		army_door_timeout = 30;
		SendClientMessage(playerid, -1, ""COLOR_BLUE"Дверь закроется через 5 секунд...");
		army_door_timer = SetTimer("close_army_door", 5000, 0);
		army_door[1] = CreateDynamicObject(1500, 1167.859130, 1363.050415, 9.722514, 0.000000, 0.000000, -48.800113, -1, -1, -1, 300.00, 300.00);
		foreach(new i: Player) { if(IsPlayerInDynamicArea(i, army_area)) Streamer_Update(i, STREAMER_TYPE_OBJECT); }

	}
	return 1;
}
forward close_army_door(playerid);
public close_army_door(playerid) {
	KillTimer(army_door_timer);
	if(IsValidDynamicObject(army_door[1])) {
	DestroyDynamicObject(army_door[1]);
	} else {
		return 1;
	}
	army_door[0] = CreateDynamicObject(1500, 1167.859130, 1363.050415, 9.722514, 0.000000, 0.000000, 0.000000, -1, -1, -1, 300.00, 300.00);
	new people = 0;
	foreach(new i: Player) {
		if(IsPlayerInDynamicArea(i, army_area)) {
			Streamer_Update(i, STREAMER_TYPE_OBJECT);
			people++;
		}
	}
	format(small_string, sizeof(small_string), ""COLOR_BLUE"Сейчас на призыве: {FFFFFF}%d человек", people);
	UpdateDynamic3DTextLabelText(army3d, -1, small_string);
	return 1;
}

stock InviteArmy(playerid) {
	switch(GetPVarInt(playerid, "inv_id")) {
	case 1: {
		if(CheckCash(playerid, GetPVarInt(playerid, "inv_cost")) == false) return 1;
		RemovePlayerEXP(playerid, GetPVarInt(playerid, "inv_cost"), "Трудоустройство в армию");

		PlayerInfo[playerid][pRank] = 1; SetPlayerInt(playerid, "Rank", PlayerInfo[playerid][pRank]);
		PlayerInfo[playerid][pStatus] = 0; SetPlayerInt(playerid, "Status", PlayerInfo[playerid][pStatus]);
		SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы подписали контракт на срочную службу в армии");
		SendClientMessage(playerid, -1, ""COLOR_GREEN"Вам была выдана рация, используйте её для связи: {FFFFFF}/r и /rn");
		SetPlayerFraction(playerid, FRACTION_ARMY, true);
		SetPlayerColor(playerid, ARMY_COLOR);
		CBackSkin(playerid);
		SetPlayerPos(playerid, 214.2046,1861.9324,13.1406);
		SetPlayerFacingAngle(playerid, 0);
		SetCameraBehindPlayer(playerid);
		ShowPlayerDialog(playerid, dKickMessage, DIALOG_STYLE_MSGBOX,"Армия",""COLOR_BLUE"Данная справка по фракции доступна в любое время (/mm - Помощь - Фракции){FFFFFF}\n\n1 - 2 Ранг: Вашей задачей будет патрулирование базы 'Зоны 51' (/patrol)\n3 - 5 Ранг: Для работы открывается оружейный завод (на территории Зоны)\n6 - 8 Ранг: Доставка военных грузов на  грузовике и вертолетах\n9 Ранг: Проведение официальных призывов (/gov и /invite)\n10 Ранг: Запуск голосования за увольнение служащих","Закрыть","");
		UpdateSpawnInfo(playerid);
	}
	case 2: {
		if(CheckCash(playerid, GetPVarInt(playerid, "inv_cost")) == false) return 1;
		RemovePlayerEXP(playerid, GetPVarInt(playerid, "inv_cost"), "Трудоустройство в LSPD");

	 	PlayerInfo[playerid][pStatus] = 0;
	 	SetPlayerInt(playerid, "Status", PlayerInfo[playerid][pStatus]);
	 	PlayerInfo[playerid][pRank] = 1;
	 	SetPlayerInt(playerid, "Rank", PlayerInfo[playerid][pRank]);

		SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы устроились в Полицейский департамент");
		SendClientMessage(playerid, -1, ""COLOR_GREEN"Вам была выдана рация, используйте её для связи: {FFFFFF}/r и /rn");
		SetPlayerFraction(playerid, FRACTION_LSPD, true);
		SetPlayerColor(playerid, LSPD_COLOR);
		CBackSkin(playerid);
		SetPlayerFacingAngle(playerid, 0);
		SetCameraBehindPlayer(playerid);
		ShowPlayerDialog(playerid, dKickMessage, DIALOG_STYLE_MSGBOX,"Полиция",""COLOR_BLUE"Данная справка по фракции доступна в любое время (/mm - Помощь - Фракции)\n\n"COLOR_ORANGE"Став офицером полиции вашей задачей станет сохранение порядка в штате.\n\n{FFFFFF}1 - 2 Ранг: Патрулирование (/turnout) и проверка документов граждан\n3 - 4 Ранг: Арест\n\n"COLOR_RED"(функционал для 5-8 рангов в стадии разработки){FFFFFF}\n\n9 Ранг: Прием новых сотрудников (/invite)\n10 Ранг: Запуск голосования за увольнение","Закрыть","");
		UpdateSpawnInfo(playerid);
	}
	case 3: {
		if(CheckCash(playerid, GetPVarInt(playerid, "inv_cost")) == false) return 1;
		RemovePlayerEXP(playerid, GetPVarInt(playerid, "inv_cost"), "Трудоустройство в Grove Street");

		PlayerInfo[playerid][pRank] = 1; SetPlayerInt(playerid, "Rank", PlayerInfo[playerid][pRank]);
		PlayerInfo[playerid][pStatus] = 0; SetPlayerInt(playerid, "Status", PlayerInfo[playerid][pStatus]);

		SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы приняты в Grove Street");
		SetPlayerFraction(playerid, FRACTION_GROOVE, true);
		SetPlayerColor(playerid, GROVE_COLOR);
		CBackSkin(playerid);
		SetPlayerFacingAngle(playerid, 0);
		SetCameraBehindPlayer(playerid);
		ShowPlayerDialog(playerid, dKickMessage, DIALOG_STYLE_MSGBOX,"Банды",""COLOR_BLUE"Данная справка по фракции доступна в любое время (/mm - Помощь - Фракции)\n\n"COLOR_ORANGE"Для вас открылись двери в криминальный мир.\nРанг за рангом вы испробуете на себе весь спектр криминальной деятельности.{FFFFFF}\n\n1 - 2 Ранг: Доставка наркотиков (/gps - Другие места - Притон)\n3 - 4 Ранг: Кража материалов с военной базы 'Зона-51'\n5 - 7 Ранг: Автоугон (/gps - Другие места - Автомойка)\n8 Ранг: Начало захвата территории (/capture)\n9 Ранг: Прием людей в банду\n10 Ранг: Запуск голосования за увольнение членов банды","Закрыть","");
		UpdateSpawnInfo(playerid);
	}
	case 4: {
		if(CheckCash(playerid, GetPVarInt(playerid, "inv_cost")) == false) return 1;
		RemovePlayerEXP(playerid, GetPVarInt(playerid, "inv_cost"), "Трудоустройство в The Ballas");

		PlayerInfo[playerid][pRank] = 1; SetPlayerInt(playerid, "Rank", PlayerInfo[playerid][pRank]);
		PlayerInfo[playerid][pStatus] = 0; SetPlayerInt(playerid, "Status", PlayerInfo[playerid][pStatus]);

		SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы приняты в The Ballas Gang");
		SetPlayerFraction(playerid, FRACTION_BALLAS, true);
		SetPlayerColor(playerid, BALLAS_COLOR);
		CBackSkin(playerid);
		SetPlayerFacingAngle(playerid, 0);
		SetCameraBehindPlayer(playerid);
		ShowPlayerDialog(playerid, dKickMessage, DIALOG_STYLE_MSGBOX,"Банды",""COLOR_BLUE"Данная справка по фракции доступна в любое время (/mm - Помощь - Фракции)\n\n"COLOR_ORANGE"Для вас открылись двери в криминальный мир.\nРанг за рангом вы испробуете на себе весь спектр криминальной деятельности.{FFFFFF}\n\n1 - 2 Ранг: Доставка наркотиков (/gps - Другие места - Притон)\n3 - 4 Ранг: Кража материалов с военной базы 'Зона-51'\n5 - 7 Ранг: Автоугон (/gps - Другие места - Автомойка)\n8 Ранг: Начало захвата территории (/capture)\n9 Ранг: Прием людей в банду\n10 Ранг: Запуск голосования за увольнение членов банды","Закрыть","");
		UpdateSpawnInfo(playerid);
	}
	case 5: {
		if(CheckCash(playerid, GetPVarInt(playerid, "inv_cost")) == false) return 1;
		RemovePlayerEXP(playerid, GetPVarInt(playerid, "inv_cost"), "Трудоустройство в Los Santos Vagos");

		PlayerInfo[playerid][pRank] = 1; SetPlayerInt(playerid, "Rank", PlayerInfo[playerid][pRank]);
		PlayerInfo[playerid][pStatus] = 0; SetPlayerInt(playerid, "Status", PlayerInfo[playerid][pStatus]);

		SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы приняты в Los Santos Vagos");
		SetPlayerFraction(playerid, FRACTION_VAGOS, true);
		SetPlayerColor(playerid, VAGOS_COLOR);
		CBackSkin(playerid);
		SetPlayerFacingAngle(playerid, 0);
		SetCameraBehindPlayer(playerid);
		ShowPlayerDialog(playerid, dKickMessage, DIALOG_STYLE_MSGBOX,"Банды",""COLOR_BLUE"Данная справка по фракции доступна в любое время (/mm - Помощь - Фракции)\n\n"COLOR_ORANGE"Для вас открылись двери в криминальный мир.\nРанг за рангом вы испробуете на себе весь спектр криминальной деятельности.{FFFFFF}\n\n1 - 2 Ранг: Доставка наркотиков (/gps - Другие места - Притон)\n3 - 4 Ранг: Кража материалов с военной базы 'Зона-51'\n5 - 7 Ранг: Автоугон (/gps - Другие места - Автомойка)\n8 Ранг: Начало захвата территории (/capture)\n9 Ранг: Прием людей в банду\n10 Ранг: Запуск голосования за увольнение членов банды","Закрыть","");
		UpdateSpawnInfo(playerid);
	}
	case 6: {
		if(CheckCash(playerid, GetPVarInt(playerid, "inv_cost")) == false) return 1;
		RemovePlayerEXP(playerid, GetPVarInt(playerid, "inv_cost"), "Трудоустройство в The Rifa");

		PlayerInfo[playerid][pRank] = 1; SetPlayerInt(playerid, "Rank", PlayerInfo[playerid][pRank]);
		PlayerInfo[playerid][pStatus] = 0; SetPlayerInt(playerid, "Status", PlayerInfo[playerid][pStatus]);

		SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы приняты в The Rifa Gang");
		SetPlayerFraction(playerid, FRACTION_RIFA, true);
		SetPlayerColor(playerid, RIFA_COLOR);
		CBackSkin(playerid);
		SetPlayerFacingAngle(playerid, 0);
		SetCameraBehindPlayer(playerid);
		ShowPlayerDialog(playerid, dKickMessage, DIALOG_STYLE_MSGBOX,"Банды",""COLOR_BLUE"Данная справка по фракции доступна в любое время (/mm - Помощь - Фракции)\n\n"COLOR_ORANGE"Для вас открылись двери в криминальный мир.\nРанг за рангом вы испробуете на себе весь спектр криминальной деятельности.{FFFFFF}\n\n1 - 2 Ранг: Доставка наркотиков (/gps - Другие места - Притон)\n3 - 4 Ранг: Кража материалов с военной базы 'Зона-51'\n5 - 7 Ранг: Автоугон (/gps - Другие места - Автомойка)\n8 Ранг: Начало захвата территории (/capture)\n9 Ранг: Прием людей в банду\n10 Ранг: Запуск голосования за увольнение членов банды","Закрыть","");
		UpdateSpawnInfo(playerid);
	}
	case 7: {
		if(CheckCash(playerid, GetPVarInt(playerid, "inv_cost")) == false) return 1;
		RemovePlayerEXP(playerid, GetPVarInt(playerid, "inv_cost"), "Трудоустройство в Varrios Los Aztecas");

		PlayerInfo[playerid][pRank] = 1; SetPlayerInt(playerid, "Rank", PlayerInfo[playerid][pRank]);
		PlayerInfo[playerid][pStatus] = 0; SetPlayerInt(playerid, "Status", PlayerInfo[playerid][pStatus]);

		SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы приняты в Varrios Los Aztecas");
		SetPlayerFraction(playerid, FRACTION_AZTECAS, true);
		SetPlayerColor(playerid, AZTEC_COLOR);
		CBackSkin(playerid);
		SetPlayerFacingAngle(playerid, 0);
		SetCameraBehindPlayer(playerid);
		ShowPlayerDialog(playerid, dKickMessage, DIALOG_STYLE_MSGBOX,"Банды",""COLOR_BLUE"Данная справка по фракции доступна в любое время (/mm - Помощь - Фракции)\n\n"COLOR_ORANGE"Для вас открылись двери в криминальный мир.\nРанг за рангом вы испробуете на себе весь спектр криминальной деятельности.{FFFFFF}\n\n1 - 2 Ранг: Доставка наркотиков (/gps - Другие места - Притон)\n3 - 4 Ранг: Кража материалов с военной базы 'Зона-51'\n5 - 7 Ранг: Автоугон (/gps - Другие места - Автомойка)\n8 Ранг: Начало захвата территории (/capture)\n9 Ранг: Прием людей в банду\n10 Ранг: Запуск голосования за увольнение членов банды","Закрыть","");
		UpdateSpawnInfo(playerid);
	}
	case 8: {
		if(CheckCash(playerid, GetPVarInt(playerid, "inv_cost")) == false) return 1;
		RemovePlayerEXP(playerid, GetPVarInt(playerid, "inv_cost"), "Трудоустройство в Russian Mafia");

		PlayerInfo[playerid][pRank] = 1; SetPlayerInt(playerid, "Rank", PlayerInfo[playerid][pRank]);
		PlayerInfo[playerid][pStatus] = 0; SetPlayerInt(playerid, "Status", PlayerInfo[playerid][pStatus]);

		SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы приняты в Russian Mafia");
		SetPlayerFraction(playerid, FRACTION_RUSSIAN_MAFIA, true);
		SetPlayerColor(playerid, RUSSIA_COLOR);
		CBackSkin(playerid);
		SetPlayerFacingAngle(playerid, 0);
		SetCameraBehindPlayer(playerid);
		UpdateSpawnInfo(playerid);
	}	
	case 9: {
		if(CheckCash(playerid, GetPVarInt(playerid, "inv_cost")) == false) return 1;
		RemovePlayerEXP(playerid, GetPVarInt(playerid, "inv_cost"), "Трудоустройство в The Triads Mafia");

		PlayerInfo[playerid][pRank] = 1; SetPlayerInt(playerid, "Rank", PlayerInfo[playerid][pRank]);
		PlayerInfo[playerid][pStatus] = 0; SetPlayerInt(playerid, "Status", PlayerInfo[playerid][pStatus]);

		SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы приняты в The Triads Mafia");
		SetPlayerFraction(playerid, FRACTION_TRIADA, true);
		SetPlayerColor(playerid, TRIAD_COLOR);
		CBackSkin(playerid);
		SetPlayerFacingAngle(playerid, 0);
		SetCameraBehindPlayer(playerid);
		UpdateSpawnInfo(playerid);
	}	
	case 10: {
		if(CheckCash(playerid, GetPVarInt(playerid, "inv_cost")) == false) return 1;
		RemovePlayerEXP(playerid, GetPVarInt(playerid, "inv_cost"), "Трудоустройство в Da Nang Boys");

		PlayerInfo[playerid][pRank] = 1; SetPlayerInt(playerid, "Rank", PlayerInfo[playerid][pRank]);
		PlayerInfo[playerid][pStatus] = 0; SetPlayerInt(playerid, "Status", PlayerInfo[playerid][pStatus]);

		SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы приняты в Da Nang Boys");
		SetPlayerFraction(playerid, FRACTION_DN_BOYS, true);
		SetPlayerColor(playerid, DANANG_COLOR);
		CBackSkin(playerid);
		SetPlayerFacingAngle(playerid, 0);
		SetCameraBehindPlayer(playerid);
		UpdateSpawnInfo(playerid);
	}			
	}
	return 1;
}
stock Leave(playerid) {
	SetPlayerColor(playerid, CIVIL_COLOR);
	SetPlayerArmour(playerid, 0);
	ResetPlayerWeapons(playerid);
	RemovePlayerFraction(playerid, true);
 	PlayerInfo[playerid][pStatus] = 0;
 	SetPlayerInt(playerid, "Status", PlayerInfo[playerid][pStatus]);
 	PlayerInfo[playerid][pRank] = 0;
 	SetPlayerInt(playerid, "Rank", PlayerInfo[playerid][pRank]);
	CBackSkin(playerid);
	CopTimerID[playerid] = KillTimer(CopTimerID[playerid]);
	return 1;
}
forward Turnout(playerid);
public Turnout(playerid) {
	new vehicleid = GetPlayerVehicleID(playerid);
	new vehicle_owner;
	for(new i = 0; i < sizeof(VehicleInfo); i++) {
	if(VehicleInfo[i][VI_VehicleID] == vehicleid) {
	vehicle_owner = VehicleInfo[i][VI_Owner];
	}
	}
	if(vehicle_owner != VO_FRACTION_LSPD) {
		LSPDTimer[playerid] = KillTimer(LSPDTimer[playerid]);
		RouteLSPD[playerid] = -1;
		return SendClientMessage(playerid, -1, "Необходимо находиться в служебном автомобиле");
	}
	LSPDTimer[playerid] = KillTimer(LSPDTimer[playerid]);
	TogglePlayerControllable(playerid, 1);
	if(RouteLSPD[playerid] != -1) {
		RouteLSPD[playerid] ++;
	}
	else RouteLSPD[playerid] = 1, SetPVarInt(playerid, "turnout_num", 1);
	if(RouteLSPD[playerid] > 5) {
		SendClientMessage(playerid, -1, ""COLOR_BLUE"Отправляйтесь к департаменту для сдачи отчета");
		return SetPlayerRaceCheckpoint(playerid, 1, 1560.7728,-1694.9004,5.8970, 1560.7728,-1694.9004,5.8970, 5); // unload
	}
	switch(random(10)) {
		case 0: SetPlayerRaceCheckpoint(playerid, 0, 1062.3949,-1740.1267,13.1927,1062.3949,-1740.1267,13.1927, 5),
		SendClientMessage(playerid, -1, ""COLOR_BLUE"Ваша точка патрулирования: {FFFFFF}'Автовокзал'");
		case 1: SetPlayerRaceCheckpoint(playerid, 0, 1421.5691,-1692.4011,13.2670,1421.5691,-1692.4011,13.2670, 5),
		SendClientMessage(playerid, -1, ""COLOR_BLUE"Ваша точка патрулирования: {FFFFFF}'Банк'");
		case 2: SetPlayerRaceCheckpoint(playerid, 0, 1476.6667,-1723.7067,13.2680,1476.6667,-1723.7067,13.2680, 5),
		SendClientMessage(playerid, -1, ""COLOR_BLUE"Ваша точка патрулирования: {FFFFFF}'Мэрия'");
		case 3: SetPlayerRaceCheckpoint(playerid, 0, 1779.2439,-1893.8286,13.1087,1779.2439,-1893.8286,13.1087, 5),
		SendClientMessage(playerid, -1, ""COLOR_BLUE"Ваша точка патрулирования: {FFFFFF}'Таксопарк'");
		case 4: SetPlayerRaceCheckpoint(playerid, 0, 1980.9288,-1994.3115,13.2725,1980.9288,-1994.3115,13.2725, 5),
		SendClientMessage(playerid, -1, ""COLOR_BLUE"Ваша точка патрулирования: {FFFFFF}'Грузчики'");
		case 5: SetPlayerRaceCheckpoint(playerid, 0, 1669.9174,-2312.5007,-2.9385,1669.9174,-2312.5007,-2.9385, 5),
		SendClientMessage(playerid, -1, ""COLOR_BLUE"Ваша точка патрулирования: {FFFFFF}'Аэропорт LS'");
		case 6: SetPlayerRaceCheckpoint(playerid, 0, 998.5723,-1134.4906,23.5552,998.5723,-1134.4906,23.5552, 5),
		SendClientMessage(playerid, -1, ""COLOR_BLUE"Ваша точка патрулирования: {FFFFFF}'Казино'");
		case 7: SetPlayerRaceCheckpoint(playerid, 0, 385.9974,-1514.7029,32.2563,385.9974,-1514.7029,32.2563, 5),
		SendClientMessage(playerid, -1, ""COLOR_BLUE"Ваша точка патрулирования: {FFFFFF}'Отель Rodeo'");
		case 8: SetPlayerRaceCheckpoint(playerid, 0, 2095.0007,-1816.7621,13.3828,2095.0007,-1816.7621,13.3828, 5),
		SendClientMessage(playerid, -1, ""COLOR_BLUE"Ваша точка патрулирования: {FFFFFF}'Пиццерия Idlewood'");
		case 9: SetPlayerRaceCheckpoint(playerid, 0, -366.4332,-1410.7640,25.4481,-366.4332,-1410.7640,25.4481, 5),
		SendClientMessage(playerid, -1, ""COLOR_BLUE"Ваша точка патрулирования: {FFFFFF}'Ферма'");
	}
	return 1;
}
forward ArrestUpdate(playerid);
public ArrestUpdate(playerid) {
	if(GetPlayerState(playerid) != PLAYER_STATE_ONFOOT) goto skip_arrest;
	if(IsAnArmy(playerid)) {
		new temp_id = GetClosestPlayer(playerid);
		if(temp_id == INVALID_PLAYER_ID) goto skip_arrest;
		if(PlayerInGangZone(temp_id,-84, 1632, 437, 2144)) {
			if(PlayerInfo[temp_id][pJailed] == 0 && IsAGang(temp_id))
			{
				if(Caught[playerid] < 0) Caught[playerid] = 5;
				if(!IsPlayerInAnyVehicle(playerid)) {
					if(CaughtID[playerid] == temp_id) { Caught[playerid]--; }
					else Caught[playerid] = 5; CaughtID[playerid] = temp_id;
					new small_update_string[144];
					format(small_update_string, sizeof(small_update_string), "~w~BEFORE ARREST:~b~~h~ %d", Caught[playerid]);
					GameTextForPlayer(playerid, small_update_string, 1100, 4);
					GameTextForPlayer(CaughtID[playerid], small_update_string, 1100, 4);
					SetPVarInt(temp_id,"OffArrest",gettime() + 10);
					switch(Caught[playerid]) {
						case 5: {
							if(GetPVarInt(playerid,"AAntiFlood5") > gettime()) { goto skip_arrest; }
							SetPVarInt(playerid,"AAntiFlood5",gettime() + 90);
							format(small_string, sizeof(small_string), "- %s[%d]: Вы находитесь на запрещенной территории и будете задержаны", PlayerInfo[playerid][pName], playerid);
							ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_CHAT, small_string);
						}
						case 3: {
							if(GetPVarInt(playerid,"AAntiFlood3") > gettime()) { goto skip_arrest; }
							SetPVarInt(playerid,"AAntiFlood3",gettime() + 90);
							format(small_string, sizeof(small_string), "%s достал(а) наручники", PlayerInfo[playerid][pName]);
							ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_PURPLE, small_string);
						}
						case 1: {
							if(GetPVarInt(playerid,"AAntiFlood1") > gettime()) { goto skip_arrest; }
							SetPVarInt(playerid,"AAntiFlood1",gettime() + 90);
							format(small_string, sizeof(small_string), "%s надел(а) наручники на подозреваемого", PlayerInfo[playerid][pName]);
							ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_PURPLE, small_string);
						}
						case 0: {
							format(small_string, sizeof(small_string), "- %s[%d]: Вы задержаны и отправляетесь в КПЗ", PlayerInfo[playerid][pName], playerid);
							ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_CHAT, small_string);
							if(PlayerInfo[CaughtID[playerid]][pWanted] <= 0)
							{
								PlayerInfo[CaughtID[playerid]][pJailTime] = 300;
								PlayerInfo[CaughtID[playerid]][pJailed] = 1;
								SetPlayerWanted(CaughtID[playerid], 0);
								SetPlayerInt(CaughtID[playerid], "Jailed", PlayerInfo[CaughtID[playerid]][pJailed]);
								SetPlayerInt(CaughtID[playerid], "JailTime", PlayerInfo[CaughtID[playerid]][pJailTime]);
							}
							else {
								PlayerInfo[CaughtID[playerid]][pJailTime] = PlayerInfo[CaughtID[playerid]][pWanted];
								PlayerInfo[CaughtID[playerid]][pJailed] = 1;
								SetPlayerInt(CaughtID[playerid], "Jailed", PlayerInfo[CaughtID[playerid]][pJailed]);
								SetPlayerInt(CaughtID[playerid], "JailTime", PlayerInfo[CaughtID[playerid]][pJailTime]);
								PlayerInfo[CaughtID[playerid]][pWanted] = 0;
								SetPlayerWanted(CaughtID[playerid], 0);
								SetPlayerInt(CaughtID[playerid], "Wanted", 0);
								if(PlayerInfo[CaughtID[playerid]][pStuff] > 0) {
									SendClientMessage(playerid, -1, ""COLOR_RED"Все ваши материалы были изъяты");
									PlayerInfo[CaughtID[playerid]][pStuff] = 0;
									SetPlayerInt(playerid, "Stuff", PlayerInfo[playerid][pStuff]);
								}
							}

							IncreaseKarma(playerid);
							IncreaseStatus(playerid, 10); 

							new it = RandomEx(25, 75);
							if(IsPlayerPremiumAccount(playerid) == true || X2_STATUS == 1) {
								it = it * 2;
							}

							new text[90];

							format(text,sizeof(text),"~g~+%d ~w~EXP", it);
							GameTextForPlayer(playerid, text, 3000, 5);

							AddPlayerEXP(playerid, it, "Изъятие материалов у игрока %s", PlayerInfo[CaughtID[playerid]][pName]);

							if(IsPlayerInAnyVehicle(CaughtID[playerid]) != 0) {
								RemovePlayerFromVehicle(CaughtID[playerid]);
							}
							if(PlayerInfo[CaughtID[playerid]][pWanted] > 0) {
								PlayerInfo[CaughtID[playerid]][pWanted] = 0;
								SetPlayerWanted(CaughtID[playerid], 0);
								SetPlayerInt(CaughtID[playerid], "Wanted", 0);
							}
							AddPlayerAchievement(playerid, E_WILL_NOT);
							Caught[playerid] = 0;
							CaughtID[playerid] = INVALID_PLAYER_ID;
						}
					}
				}
			}
		}
	}
	if(IsACop(playerid) && GetPlayerJobDayStatus(playerid) == true) {
		new temp_id = GetClosestPlayer(playerid);
		if(temp_id == INVALID_PLAYER_ID) {
			goto skip_arrest;
		}
		if(pl_afk_time[temp_id] > 2) {
			goto skip_arrest;
		}
		new catchme[128];

		if(GetPVarInt(temp_id, "robbing_now") == 1 && PlayerInfo[temp_id][pWanted] < 1) {
			PlayerInfo[temp_id][pWanted] = 660;	
			SetPVarInt(temp_id,"Wanted",PlayerInfo[temp_id][pWanted]);
		} 

		if(PlayerInfo[temp_id][pWanted] > 0)
		{
			if(!IsPlayerInAnyVehicle(playerid)) {
				if(CaughtID[playerid] == temp_id) { Caught[playerid]--; }
				else Caught[playerid] = 10; CaughtID[playerid] = temp_id;
				if(Caught[playerid] < 0) Caught[playerid] = 10;
				SetPVarInt(temp_id,"OffArrest",gettime() + 10);
				new small_update_string[144];
				format(small_update_string, sizeof(small_update_string), "~w~BEFORE ARREST: ~b~~h~%d", Caught[playerid]);
				GameTextForPlayer(playerid, small_update_string, 1100, 4);
				GameTextForPlayer(CaughtID[playerid], small_update_string, 1100, 4);
				if(GetPVarInt(CaughtID[playerid], "robbing_now") == 1) Caught[playerid] = 0;
				switch(Caught[playerid]) {
					case 10: {
						if(GetPVarInt(playerid,"AAntiFlood10") > gettime()) { goto skip_arrest; }
						SetPVarInt(playerid,"AAntiFlood10",gettime() + 60);
						format(small_string, sizeof(small_string), "- %s[%d]: Подозреваемый %s, немедленно остановитесь!", PlayerInfo[playerid][pName], playerid, PlayerInfo[CaughtID[playerid]][pName]);
						ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_CHAT, small_string);
					}
					case 9: {
						if(GetPVarInt(playerid,"AAntiFlood9") > gettime()) { goto skip_arrest; }
						SetPVarInt(playerid,"AAntiFlood9",gettime() + 60);
						format(small_string, sizeof(small_string), "- %s[%d]: Работает полиция, у Вас есть право хранить молчание", PlayerInfo[playerid][pName], playerid);
						ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_CHAT, small_string);
					}
					case 7: {
						if(GetPVarInt(playerid,"AAntiFlood7") > gettime()) { goto skip_arrest; }
						SetPVarInt(playerid,"AAntiFlood7",gettime() + 60);
						format(small_string, sizeof(small_string), "%s достал(а) наручники", PlayerInfo[playerid][pName]);
						ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_PURPLE, small_string);
					}
					case 5: {
						if(GetPVarInt(playerid,"AAntiFlood5") > gettime()) { goto skip_arrest; }
						SetPVarInt(playerid,"AAntiFlood5",gettime() + 30);
						format(small_string, sizeof(small_string), "- %s[%d]: Вы находитесь в федеральном розыске, и будете задержаны", PlayerInfo[playerid][pName], playerid);
						ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_CHAT, small_string);
					}
					case 1: {
						if(GetPVarInt(playerid,"AAntiFlood1") > gettime()) { goto skip_arrest; }
						SetPVarInt(playerid,"AAntiFlood1",gettime() + 30);
						format(small_string, sizeof(small_string), "%s надел(а) наручники на подозреваемого", PlayerInfo[playerid][pName]);
						ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_PURPLE, small_string);
					}
					case 0: {
						format(small_string, sizeof(small_string), "- %s[%d]: Вы задержаны и отправляетесь в КПЗ", PlayerInfo[playerid][pName], playerid);
						ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_CHAT, small_string);
						format(catchme, 100, ""COLOR_BLUE"Сотрудник %s задержал преступника %s", PlayerInfo[playerid][pName], PlayerInfo[CaughtID[playerid]][pName]);
						new Fraction:fractionid = GetPlayerFraction(playerid);
						SendFamilyMessage(fractionid, -1, small_string);
						if(PlayerInfo[CaughtID[playerid]][pWanted] < 1) PlayerInfo[CaughtID[playerid]][pWanted] = 600;
						PlayerInfo[CaughtID[playerid]][pJailTime] = PlayerInfo[CaughtID[playerid]][pWanted];
						PlayerInfo[CaughtID[playerid]][pJailed] = 1;
						SetPlayerInt(CaughtID[playerid], "Jailed", PlayerInfo[CaughtID[playerid]][pJailed]);
						SetPlayerInt(CaughtID[playerid], "JailTime", PlayerInfo[CaughtID[playerid]][pJailTime]);
						if(PlayerInfo[CaughtID[playerid]][pWanted] > 0) {
						PlayerInfo[CaughtID[playerid]][pWanted] = 0;
						SetPlayerWanted(CaughtID[playerid], 0);
						SetPlayerInt(CaughtID[playerid], "Wanted", 0);
						if(PlayerInfo[CaughtID[playerid]][pStuff] > 0) {
							SendClientMessage(playerid, -1, ""COLOR_RED"Все ваши материалы были изъяты");
							PlayerInfo[CaughtID[playerid]][pStuff] = 0;
							SetPlayerInt(playerid, "Stuff", PlayerInfo[playerid][pStuff]);
						}
						}
						IncreaseKarma(playerid);

						IncreaseStatus(playerid, 10); 

						new it = RandomEx(25, 125);
						if(IsPlayerPremiumAccount(playerid) == true || X2_STATUS == 1) {
							it = it * 2;
						}

						new text[90];

						format(text,sizeof(text),"~g~+%d ~w~EXP", it);
						GameTextForPlayer(playerid, text, 3000, 5);

						AddPlayerEXP(playerid, it, "Поима преступника %s", PlayerInfo[CaughtID[playerid]][pJailed]);
						if(GetPlayerFraction(playerid) == FRACTION_LSPD) {
							AddPlayerAchievement(playerid, E_BENCH_GANGSTER);
						} else {
							AddPlayerAchievement(playerid, E_SLEEP_WELL);
						}
						Caught[playerid] = 0;
						CaughtID[playerid] = INVALID_PLAYER_ID;
					}
				}
			}
			goto skip_arrest;
		}
		if(IsACop(playerid)) { Caught[playerid] = 0; CaughtID[playerid] = INVALID_PLAYER_ID;}
	}
	skip_arrest:
	if(IsACop(playerid)) {
	new count = GetPVarInt(playerid, "arrest_on");
	count -= 1;
	SetPVarInt(playerid, "arrest_on", count);

	if(count <= 0) return SendClientMessage(playerid, -1, ""COLOR_RED"Электрошокер отключился...");
	}

	CopTimerID[playerid] = KillTimer(CopTimerID[playerid]);
	return CopTimerID[playerid] = SetTimerEx("ArrestUpdate", 1250, false, "d", playerid);
}
stock GetClosestPlayer(playerid, Float:radius = 9.0)
{
	if(playerid == INVALID_PLAYER_ID || radius > 30.0) {
		return INVALID_PLAYER_ID;
	}

	new
		Float:pos_x,
		Float:pos_y,
		Float:pos_z,
		Float:max_dist = radius,
		Float:tmp_dist,
		nearest_player = INVALID_PLAYER_ID;

	GetPlayerPos(playerid, pos_x, pos_y, pos_z);

	foreach(new i: Player) {
		if(0 == IsPlayerStreamedIn(i, playerid) || i == playerid) {
			continue;
		}

		tmp_dist = GetPlayerDistanceFromPoint(i, pos_x, pos_y, pos_z);

		if(max_dist > tmp_dist)
		{
			max_dist = tmp_dist;
			nearest_player = i;
		}
	}
	return nearest_player;
}
stock CancelOffer(playerid) {
	if(GetPVarInt(playerid, "CarOffer") != -1) {
		new seller = GetPVarInt(playerid, "CarOffer");
		SetPVarInt(playerid, "CarOffer", -1);
		if(PlayerLogged{seller} == false || !IsPlayerConnected(seller)) return 1;
		SetPVarInt(seller, "SellingCar", -1);
	}
	SetPVarInt(playerid, "CarOffer", -1);
	return 1;
}
forward FixAuth(playerid);
public FixAuth(playerid) {
	AuthTimeFix[playerid] = KillTimer(AuthTimeFix[playerid]);
	if(PlayerLogged{playerid} == false || !IsPlayerConnected(playerid)) {
		SendClientMessage(playerid, -1, ""COLOR_RED"Время на вход в игру истекло. Перезайдите");
		return Kick(playerid);
	}
	return 1;
}


CMD:get(playerid, params) {
	if(GetPlayerAdminLevel(playerid) < 5) {
		return 0;
	} else {
		new 
			inter = GetPlayerInterior(playerid),
			world = GetPlayerVirtualWorld(playerid),
			Float: x,
			Float: y,
			Float: z,
			Float: angle;

		GetPlayerPos(playerid, x, y, z);
		GetPlayerFacingAngle(playerid, angle);

		format(small_string, sizeof(small_string), 
			"(%s (%i)) -- Inter = %i World = %i (X = %f, Y = %f, Z = %f, Angle = %f",
				PlayerInfo[playerid][pName],
				playerid,
				inter,
				world,
				x,
				y,
				z,
				angle
		);
		printf(small_string);
		return SendClientMessage(playerid, -1, small_string);
	}
}

stock Dialog_Bank_Property(const playerid) {

	if(PlayerLogged{playerid} == false) return 1;

	new 
		house_array = GetPVarInt(playerid, "PlayerHouse"),
		hotel_array = Player.Hotel[playerid];
		//business_array = Player.Business[playerid];

	new 
		house_string[2][35],
		hotel_string[35];
		//business_string[35];

	if(house_array == 0) {
		house_string[0] = ""COLOR_ORANGE"Недоступно";
		house_string[1] = ""COLOR_ORANGE"Недоступно";
	} else {
		format(house_string[0], sizeof(house_string[]), ""COLOR_GREEN"%i дн.", HouseInfo[house_array][hTakings]);
		format(house_string[1], sizeof(house_string[]), ""COLOR_GREEN"%i EXP", HouseInfo[house_array][hPrice] / 3);
	}

	if(hotel_array == INVALID_HOTEL_ID) {
		hotel_string = ""COLOR_ORANGE"Недоступно";
	} else {
		format(hotel_string, sizeof(hotel_string), ""COLOR_GREEN"%i дн.", Hotel.Room[hotel_array][E_HOTEL_ROOM_RENT_DAY]);
	}

	if(Platform[playerid] == 0) {
		format(big_string, sizeof(big_string), ""COLOR_WHITE"1. Оплата квартплаты за дом\t\t\t%s\n"COLOR_RED"2. Продажа дома\t\t\t\t%s\n"COLOR_WHITE"3. Оплата аренды за номер в отеле\t\t%s\n"COLOR_WHITE"4. Оплата аренды за бизнес\t\t\t%s\n"INPUT_NUMBER"",
			house_string[0], house_string[1], hotel_string
		);
		return ShowPlayerDialog(playerid, DIALOG_BANK_PROPERTY, DIALOG_STYLE_INPUT, "Операции с недвижимым имуществом", big_string, !"Выбрать", !"Закрыть");
	} else {
		format(big_string, sizeof(big_string), "Действие\tЗначение\n"COLOR_WHITE"Оплата квартплаты за дом\t%s\n"COLOR_RED"Продажа дома\t%s\nОплата аренды за номер в отеле\t%s\nОплатить аренду за бизнес",
			house_string[0], house_string[1], hotel_string
		);
		return ShowPlayerDialog(playerid, DIALOG_BANK_PROPERTY, DIALOG_STYLE_TABLIST_HEADERS, ""COLOR_BLUE"Операции с недвижимым имуществом", big_string, !"Выбрать", !"Закрыть");
	}
}/*
