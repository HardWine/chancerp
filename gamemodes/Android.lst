stock GetPlayerSpeed(playerid)
{
    new Float:ST[4];
  	GetPlayerVelocity(playerid,ST[0],ST[1],ST[2]);
    ST[3] = floatsqroot(floatpower(floatabs(ST[0]), 2.0) + floatpower(floatabs(ST[1]), 2.0) + floatpower(floatabs(ST[2]), 2.0)) * 179.28625;
    return floatround(ST[3]);
}


public OnPlayerUpdate(playerid)
{
	pl_afk_time[playerid] = 0;
	if(IsPlayerInAnyVehicle(playerid) && GetPlayerVehicleSeat(playerid) == 0) {
		if(PlayerInfo[playerid][pSpeedLimit] == 0) return 1;
		new v = GetPlayerVehicleID(playerid);
		new speed_vehicle = floatround(GetVehicleSpeed(v));
		new a = speed_vehicle-PlayerInfo[playerid][pSpeedLimit];
		a = a+6;
		if(speed_vehicle > PlayerInfo[playerid][pSpeedLimit]) SetVehicleSpeed(v,PlayerInfo[playerid][pSpeedLimit]-a);		
	}
	if(IsPlayerInSafeZone(playerid) == 1) {
		SetPlayerArmedWeapon(playerid, 0);
	}

	if(PlayerLogged{playerid} == true && GetPVarInt(playerid, "kicked") == 0)
	{
		if(GetPVarInt(playerid, "mobile") == 1)
		{
			new Float:velX;
			new Float:velY;
			new Float:velZ;
			GetPlayerVelocity(playerid, velX, velY, velZ);

			if(velX > 0.0 || velX < 0.0 || velY > 0.0 || velY < 0.0)
			{
			    if(!GetPlayerAnimationIndex(playerid) == 0)
			    {
			        SetPVarInt(playerid, "mobile", 0);
			    }
			}
		}
	}
	return 1;
}

