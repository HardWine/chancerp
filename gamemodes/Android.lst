forward @yH_OnPlayerConnect@026(playerid);@yH_OnPlayerConnect@026(playerid) {
	for(new i = 0; i < sizeof(AviationBuy); i++) {
		if(AviationBuy[i][E_VEHICLE_ID] != (0xFFFF) && IsValidVehicle(AviationBuy[i][E_VEHICLE_ID])) {
			SetVehicleParamsForPlayerEx(AviationBuy[i][E_VEHICLE_ID], playerid, 0, 1);
		}
	}

	PlayerAviationModel[playerid] = (-1);
	PlayerAviationVehicleID[playerid] = (0xFFFF);
	PlayerAviationColor[playerid] = 1;
	PlayerSellAviaTime[playerid] = -1;
