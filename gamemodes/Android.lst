	format(drug_string, sizeof(drug_string), """{4eb9e6}""Îńňŕëîńü äîńňŕâčňü: {FFFFFF}%d ďŕęĺňîâ", PlayerInfo[playerid][pDrugsSell]);
	SendClientMessage(playerid, -1, drug_string);
