forward dre_BecomeMateAgreement(playerid, response, listitem, inputtext[]); public dre_BecomeMateAgreement(playerid, response, listitem, inputtext[]) {
	new mate = GetPVarInt(playerid, "mate_inv");
	if(!response) {

		SetPVarInt(playerid, "mate", -1);
		SetPVarInt(mate, "mate", -1);
		DeletePVar(playerid, "mate_inv");
		DeletePVar(playerid, "mate_inv");
		SendClientMessage(playerid, -1, """{FFAF00}""Âű îňęëîíčëč ďđčăëŕřĺíčĺ");
		SendClientMessage(mate, -1, """{FFAF00}""Âŕřĺ ďđčăëŕřĺíčĺ îňęëîíčëč");
		return 0;
	} else {
		SetPVarInt(playerid, "mate", mate);
		SetPVarInt(mate, "mate", playerid);
		SendClientMessage(playerid, -1, """{4eb9e6}""Âű ďđčí˙ëč ďđčăëŕřĺíčĺ");
		SendClientMessage(mate, -1, """{6de64e}""Âŕřĺ ďđčăëŕřĺíčĺ ďđčí˙ëč");
	}
	return 1;
}


forward pc_cmd_mate(playerid, params[0]); public pc_cmd_mate(playerid, params[0]) {
	if(IsAGov(playerid)) return 1;
	if(GetPVarInt(playerid, "mate") != -1) {
		format(small_string, sizeof(small_string), """{4eb9e6}""Ęîěŕíäŕ: ""{FFFFFF}""%s[%d], %s[%d]", PlayerInfo[playerid][pName], playerid, PlayerInfo[params[0]][pName], params[0]);
		SendClientMessage(playerid, -1, "×ňîáű ďîęčíóňü ęîěŕíäó, čńďîëüçóéňĺ: /leave");
		return 1;
	}
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ: /mate [id čăđîęŕ]");
	if(IsAGov(params[0])) return 1;
	if(params[0] == playerid) return 1;
	if(GetPVarInt(params[0], "mate") != -1) return SendClientMessage(playerid, -1, """{ff353c}""Čăđîę óćĺ â ęîěŕíäĺ čëč đŕńńěŕňđčâŕĺň äđóăîĺ ďđčăëŕřĺíčĺ");
	if(GetDistanceBetweenPlayerz(playerid, params[0], 8.00) != 1) return SendClientMessage(playerid, -1, """{FFAF00}""Âű ńëčřęîě äŕëĺęî îň óęŕçŕííîăî čăđîęŕ");
	SetPVarInt(playerid, "mate_inv", params[0]);
	SetPVarInt(params[0], "mate_inv", playerid);
	Dialog_Show(params[0], #BecomeMateAgreement);
	SendClientMessage(playerid, -1, """{4eb9e6}""Ďđčăëŕřĺíčĺ â ęîěŕíäó îňďđŕâëĺíî");
	return 1;
}

forward pc_cmd_leave(playerid); public pc_cmd_leave(playerid) {

	if(GetPVarInt(playerid, "robbing_now") == 1) return 1;

	new mate = GetPVarInt(playerid, "mate");

	if(mate != -1) {
		if(GetPVarInt(mate, "mate") == playerid) {
			SetPVarInt(mate,  "mate", -1);
			SendClientMessage(playerid, -1, """{FFAF00}""Âŕřŕ ęîěŕíäŕ đŕńôîđěčđîâŕíŕ");
			SendClientMessage(mate, -1, """{ff353c}""Âŕř ďŕđňíĺđ ďîęčíóë ęîěŕíäó");
		}
		SetPVarInt(playerid, "mate", -1);
	} else {
		return SendClientMessage(playerid, -1, """{ff353c}""Âű íĺ â ęîěŕíäĺ!");
	}
	return 1;
}

forward pc_cmd_rob(playerid); public pc_cmd_rob(playerid) {

	if(IsAGov(playerid)) return 1;
	new player_world = GetPlayerVirtualWorld(playerid),
		menuid = player_world-100,	
		mate = GetPVarInt(playerid, "mate"),
		RobberyTime;

	if(player_world >= 100 && player_world <= 198) {

		if(BusinessInfo[menuid][ID] != -1) {

		} else {

			return 1;
		}


		if(BusinessInfo[menuid][Rob] > 0) return SendClientMessage(playerid, -1, """{FFAF00}""Áčçíĺń áűë íĺäŕâíî îăđŕáëĺí");
		if(mate != -1) {		
			if(GetDistanceBetweenPlayerz(playerid, mate, 15.00) == 1) {
				RobberyTime = 55000+Random(0,30000);
				if(GetPVarInt(mate, "Hidden") != 1) {
					PlayerInfo[mate][pWanted] += 900;
					SetPlayerWanted(mate, PlayerInfo[mate][pWanted]);
				}	
			} else {
				SendClientMessage(playerid, -1, "Âŕř ďŕđňíĺđ ńëčřęîě äŕëĺęî!");
				SendClientMessage(playerid, -1, "Őîňčňĺ ďđîâĺńňč îăđŕáëĺíčĺ â îäčíî÷ęó? Îńňŕâüňĺ ďŕđňíĺđŕ (/leave)");
				return 1;
			}
		} else {
			RobberyTime = 80000+Random(0,25000);
		}

		if(GetPVarInt(playerid, "Hidden") != 1) {
			PlayerInfo[playerid][pWanted] += 900;
			SetPlayerWanted(playerid, PlayerInfo[playerid][pWanted]);
		}		

		RobTimer[playerid] = KillTimer(RobTimer[playerid]);
		RobTimer[playerid] = SetTimerEx("StartRobbery", RobberyTime, 0, "iii", menuid, playerid);

		format(small_string, sizeof(small_string), """{4eb9e6}""Âű íŕ÷ŕëč îăđŕáëĺíčĺ ""{FFFFFF}""%s!", Properties[menuid][IName]);

		SendClientMessage(playerid, -1, small_string);
		SendClientMessage(mate, -1, small_string);

		SendClientMessage(playerid, -1, """{ff353c}""Ďîęčíóâ çäŕíčĺ âű ďđîâŕëčňĺ îăđŕáëĺíčĺ");
		SendClientMessage(mate, -1, """{ff353c}""Ďîęčíóâ çäŕíčĺ âű ďđîâŕëčňĺ îăđŕáëĺíčĺ");

		new normaltime = RobberyTime/1000;
		BusinessInfo[menuid][Rob] = 300+normaltime;

		SetPVarInt(playerid, "MinusTime", normaltime);
		SetPVarInt(mate, "MinusTime", normaltime);

		SetPVarInt(playerid, "robbing_now", 1);
		SetPVarInt(mate, "robbing_now", 1);

		new armed = 0,
			a_factor,
			chance_succeed;

		if(GetPlayerWeapon(playerid) >= 22 && GetPlayerWeapon(playerid) <= 32) armed += 1;
		if(mate != -1) {
			if(GetPlayerWeapon(mate) >= 22 && GetPlayerWeapon(mate) <= 32) armed += 1;
		}

		if(armed == 1) chance_succeed = 1;
		if(armed == 2) chance_succeed = 2;

		chance_succeed = RandomEx(0,a_factor);

		if(armed == 0) chance_succeed = 0;

		if(chance_succeed == 0) {
			new Float:dist;
			new bz = menuid;
			bz = bz+1;
			for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i=Iterator@Player [_: i])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);) {
				if(IsACop(i)) {
					dist = GetPlayerDistanceFromPoint(i, Pickup[bz][ent_X], Pickup[bz][ent_Y], Pickup[bz][ent_Z]);
					format(small_string, sizeof(small_string), """{ff353c}""Ďîńňóďčë ńčăíŕë ňđĺâîćíîé ęíîďęč čç ""{FFFFFF}""%s [ID: %d] (%.2fě.)", Properties[bz][IName], bz, dist);
					SendClientMessage(i, -1, small_string);
