stock Bit_Set(Bit:array[], slot, bool:set)
{

	if (set) array[( slot)>>>(5)]|=Bit:(1<<(( slot)&cellbits-1));
	else array[( slot)>>>(5)]&=Bit:~(1<<(( slot)&cellbits-1));
}

