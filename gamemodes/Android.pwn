			}
			SetPlayerInterior(playerid,0);
			SetPlayerVirtualWorld(playerid,0);	
			SetPlayerPos(playerid,HouseInfo[house][hEntrancex],HouseInfo[house][hEntrancey],HouseInfo[house][hEntrancez]);
			SetPVarInt(playerid,"GoHome",gettime() + 5);
			SetCameraBehindPlayer(playerid);
			return 1;	
		}		
		GetPlayerHouse(playerid);
		house = GetPVarInt(playerid, "PlayerHouse");
		if(GetPVarInt(playerid, "nude") == 1) {
			CBackSkin(playerid);
			SendClientMessage(playerid, -1, ""COLOR_BLUE"Вы оделись");
			DeletePVar(playerid, "nude");
		}
		if(!IsPlayerInRangeOfPoint(playerid, 4,HouseInfo[house][hExitx], HouseInfo[house][hExity], HouseInfo[house][hExitz])) return 1;

		SetPVarInt(playerid,"HouseID",house);
		SetPlayerInterior(playerid,0);
		SetPlayerVirtualWorld(playerid,0);
		SetPlayerPos(playerid,HouseInfo[house][hEntrancex],HouseInfo[house][hEntrancey],HouseInfo[house][hEntrancez]);
		SetPVarInt(playerid,"GoHome",gettime() + 5);
		SetCameraBehindPlayer(playerid);
		DeletePVar(playerid,"HouseID");
		if(GetPVarInt(playerid, "FixedOneTime") == 1) return 1;
		if(IsVehicleOccupied(caridhouse[playerid]) == -1 && Platform[playerid] == 0) {
			vehfixtimer[playerid] = KillTimer(vehfixtimer[playerid]);
			vehfixtimer[playerid] = SetTimerEx("LoadVehFix", 3000, false, "d", playerid);
		}
		return 1;
	}
	if(pickupid == hExit[2])
	{
		new house;
		if(GetPlayerVirtualWorld(playerid) != GetPlayerAccountID(playerid)) {
			house = GetPVarInt(playerid, "guest_house");
			if(!IsPlayerInRangeOfPoint(playerid, 4,HouseInfo[house][hExitx], HouseInfo[house][hExity], HouseInfo[house][hExitz])) return 1;
			if(GetPVarInt(playerid, "nude") == 1) {
				CBackSkin(playerid);
				SendClientMessage(playerid, -1, ""COLOR_BLUE"Вы оделись");
