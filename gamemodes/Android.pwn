				} else {
					switch(player_rank) {
						case 0..3: SetPlayerSkin(playerid,166);
						case 4..7: SetPlayerSkin(playerid, 165);
						case 8..10: SetPlayerSkin(playerid, 286);
					}
				}
			}
			case FRACTION_GOVERMENT: {
				SetPlayerColor(playerid, MAYOR_COLOR);
				if(PlayerInfo[playerid][pSex] != 0) {
					switch(player_rank) {
					case 0..5: SetPlayerSkin(playerid,150);
					case 6..10: SetPlayerSkin(playerid,141);
					}
				} else {
					switch(player_rank) {
						case 0..1: SetPlayerSkin(playerid,71);
						case 2: SetPlayerSkin(playerid,253);
						case 3: SetPlayerSkin(playerid, 163);
						case 4: SetPlayerSkin(playerid, 57);
						case 5: SetPlayerSkin(playerid, 164);
						case 6: SetPlayerSkin(playerid, 187);
						case 7..9: SetPlayerSkin(playerid, 227);
						case 10: SetPlayerSkin(playerid, 147);
					}
				}
			}
			case FRACTION_NEWS: {
				SetPlayerColor(playerid, NEWS_COLOR);
				if(PlayerInfo[playerid][pSex] != 0) {
					switch(player_rank) {
					case 0..5: SetPlayerSkin(playerid,211);
					case 6..10: SetPlayerSkin(playerid,216);
					}
				} else {
					switch(player_rank) {
						case 0..3: SetPlayerSkin(playerid,188);
						case 4..6: SetPlayerSkin(playerid, 217);
						case 7..8: SetPlayerSkin(playerid, 250);
						case 9..10: SetPlayerSkin(playerid, 261);
					}
				}
			}
		}
	}
	else 
	{
		if(fractionid == FRACTION_NONE) {
			SetPlayerColor(playerid, CIVIL_COLOR);
			SetPlayerSkin(playerid,26);

			if(PlayerInfo[playerid][pSex] != 0) {
				SetPlayerSkin(playerid, 193);
			}
		}
		if(PlayerInfo[playerid][pSkin] > 0) {
			SetPlayerSkin(playerid, PlayerInfo[playerid][pSkin]);
			TogglePlayerControllable(playerid, 1);
			//SetPVarInt(playerid, "SelSkin", 0);
		}
	}
	TogglePlayerControllable(playerid, 1);
	//SetPVarInt(playerid, "SelSkin", 0);
	ClearAnimations(playerid);
	return GetPlayerSkin(playerid);
}
forward SetColorName(playerid);
public SetColorName(playerid)
{
	new
		Fraction: fractionid = GetPlayerFraction(playerid);

	if(fractionid == FRACTION_NONE) {
		SetPlayerColor(playerid, CIVIL_COLOR);
	}

	if(GetPlayerJobDayStatus(playerid) == true)
	{
		switch(fractionid) {
			case FRACTION_LSPD: {
				SetPlayerColor(playerid, LSPD_COLOR);
			}
			case FRACTION_GROOVE: {
				SetPlayerColor(playerid, GROVE_COLOR);
			}
			case FRACTION_BALLAS: {
				SetPlayerColor(playerid, BALLAS_COLOR);
			}
			case FRACTION_VAGOS: {
				SetPlayerColor(playerid, VAGOS_COLOR);
			}
			case FRACTION_RIFA: {
				SetPlayerColor(playerid, RIFA_COLOR);
			}
			case FRACTION_AZTECAS: {
				SetPlayerColor(playerid, AZTEC_COLOR);
			}
			case FRACTION_RUSSIAN_MAFIA: {
				SetPlayerColor(playerid, RUSSIA_COLOR);
			}
			case FRACTION_TRIADA: {
				SetPlayerColor(playerid, TRIAD_COLOR);
			}
			case FRACTION_DN_BOYS: {
				SetPlayerColor(playerid, DANANG_COLOR);
			}
			case FRACTION_ARMY: {
				SetPlayerColor(playerid, ARMY_COLOR);
			}
			case FRACTION_FBI: {
				SetPlayerColor(playerid, FBI_COLOR);
			}
			case FRACTION_GOVERMENT: {
				SetPlayerColor(playerid, MAYOR_COLOR);
			}
		}
	}
	return 1;
}
stock ShowSkill(playerid) {
	format(big_string, sizeof(big_string), "Название навыка\tТекущий скилл\n\
		Навык фермера\t"COLOR_GREEN"%d\n\
		Навык автобуса\t"COLOR_GREEN"%d\n\
		Навык пилота\t"COLOR_GREEN"%d\n\
		Навык доставки\t"COLOR_GREEN"%d\n\
		Угон авто\t"COLOR_GREEN"%d",
			PlayerInfo[playerid][pFarmSkill], 
			PlayerInfo[playerid][pBusSkill], 
			PlayerInfo[playerid][pAirSkill], 
			PlayerPizzaSkill[playerid], 
			PlayerInfo[playerid][pTheftSkill]
	);
	return ShowPlayerDialog(playerid, dStats, DIALOG_STYLE_TABLIST_HEADERS, "Навыки", big_string, "Закрыть", "");
}
stock ShowStats(playerid, targetid) {
	if(IsPlayerConnected(playerid) && IsPlayerConnected(targetid)) {

		new Fraction: fractionid = GetPlayerFraction(targetid);
		new pass_string[526];
		big_string[0] = EOS;
		format(small_string, sizeof(small_string), "Осталось до зарплаты\t"COLOR_ORANGE"%s\n",Convert(3600-PlayerInfo[targetid][pOnline]));strcat(pass_string,small_string);
		format(small_string, sizeof(small_string), "Часов отыграно\t"COLOR_ORANGE"%d\n\t\n",PlayerInfo[targetid][pHours]);strcat(pass_string,small_string);

		if(PlayerSIMCardNumber[playerid] != INVALID_SIM_CARD_NUMBER) {
			format(small_string,sizeof(small_string),""COLOR_WHITE"Телефон\t"COLOR_ORANGE"%d\n\t\n",PlayerSIMCardNumber[targetid]); strcat(pass_string,small_string);
		} else {
			format(small_string,sizeof(small_string),""COLOR_WHITE"Телефон\t"COLOR_ORANGE"%s\n\t\n","Отсутсвует"); strcat(pass_string,small_string);
		}
		
		format(small_string,sizeof(small_string),""COLOR_WHITE"Законопослушность\t"COLOR_ORANGE"%d\n",PlayerInfo[targetid][pKarma]); strcat(pass_string,small_string);
		format(small_string,sizeof(small_string),""COLOR_WHITE"Военный билет\t"COLOR_ORANGE"%s\n\t\n", (PlayerInfo[playerid][pArmyDoc] == 0) ? ("Отсутствует") : ("Получен") ); strcat(pass_string,small_string);

		format(small_string,sizeof(small_string),""COLOR_WHITE"Фракция\t"COLOR_ORANGE"%s\n", (fractionid == FRACTION_NONE) ? ("Гражданский") : FractionTitle[_:fractionid-1]); strcat(pass_string,small_string);
		format(small_string,sizeof(small_string),""COLOR_WHITE"Ранг\t"COLOR_ORANGE"%s\n\t\n", (fractionid == FRACTION_NONE) ? ("Отсутствует") : gFractionRankName_RU[_:fractionid-1][PlayerInfo[targetid][pRank]]); strcat(pass_string,small_string);

		format(small_string,sizeof(small_string),""COLOR_WHITE"Транспорт #1\t"COLOR_ORANGE"%s\n",GetVehicleText(PlayerInfo[targetid][pCar])); strcat(pass_string,small_string);
		format(small_string,sizeof(small_string),""COLOR_WHITE"Транспорт #2\t"COLOR_ORANGE"%s\n",GetVehicleText(PlayerInfo[targetid][pCar2])); strcat(pass_string,small_string);
		format(small_string,sizeof(small_string),""COLOR_WHITE"Частный вертолет\t"COLOR_ORANGE"%s\n", (PlayerAviationModel[targetid] == INVALID_AVIATION) ? (""COLOR_ORANGE"Отсутствует") : (GetVehicleText(PlayerAviationModel[targetid]))); strcat(pass_string,small_string);
		format(small_string,sizeof(small_string),""COLOR_WHITE"Частная яхта\t"COLOR_ORANGE"%s\n\t\n", (PlayerYachtModel[targetid] == INVALID_YACHT) ? (""COLOR_ORANGE"Отсутствует") : (GetVehicleText(PlayerYachtModel[targetid]))); strcat(pass_string,small_string);

		format(small_string,sizeof(small_string),""COLOR_WHITE"Недвижимость\t"COLOR_ORANGE"%s",(GetPlayerHouse(targetid)) ? ("Дом") : ("Отсутствует")); strcat(pass_string,small_string);

		if(Player.Hotel[targetid] != INVALID_HOTEL_ID) {
			format(small_string,sizeof(small_string),"\n\t\n"COLOR_WHITE"Номер в отеле\t"COLOR_ORANGE"%s\n",(Player.Hotel[targetid] == INVALID_HOTEL_ID) ? ("Отсутствует") : ("Есть")), strcat(pass_string,small_string);
		}

		SPD(playerid,
			DIALOG_INFO, DIALOG_STYLE_TABLIST,
			""COLOR_BLUE"Статистика",
			pass_string,
			"Назад", "Закрыть"
		);

	}
	return 1;
}

stock ShowPass(playerid, targetid) {
	if(PlayerInfo[targetid][pBirth] == 0) return SendClientMessage(targetid, -1, "У Вас нет паспорта! Получить его можно у сотрудников мэрии");
	if(IsPlayerConnected(playerid) && IsPlayerConnected(targetid)) {

		new FirstName[16],LastName[16];
		sscanf(PlayerInfo[targetid][pName],"p<_>s[16]s[16]",FirstName,LastName);

		new pass_string[768];

		format(small_string, sizeof(small_string), ""COLOR_WHITE"Гражданство: SA\t");strcat(pass_string,small_string);
		format(small_string, sizeof(small_string), ""COLOR_WHITE"Номер паспорта: %d\n\n",GetPlayerAccountID(targetid));strcat(pass_string,small_string);
		format(small_string, sizeof(small_string), ""COLOR_WHITE"Дата рождения: %d\t\t",PlayerInfo[targetid][pBirth]);strcat(pass_string,small_string);
		format(small_string,sizeof(small_string),""COLOR_WHITE"Пол: %s\n\n", (PlayerInfo[targetid][pSex] == 0) ? ("М") : ("Ж")); strcat(pass_string,small_string);
		format(small_string,sizeof(small_string),""COLOR_WHITE"Имя: %s\n", FirstName); strcat(pass_string,small_string);
		format(small_string,sizeof(small_string),""COLOR_WHITE"Фамилия: %s\n", LastName); strcat(pass_string,small_string);
		
		if(PlayerInfo[targetid][pMarried] == 1 && PlayerInfo[targetid][pSex] == 0) {
			format(small_string,sizeof(small_string),""COLOR_WHITE"\nЖена: %s\n\n",PlayerInfo[targetid][pPartner]); strcat(pass_string,small_string); }
		if(PlayerInfo[targetid][pMarried] == 1 && PlayerInfo[targetid][pSex] == 1) {
			format(small_string,sizeof(small_string),""COLOR_WHITE"Муж: %s\n\n",PlayerInfo[targetid][pPartner]); strcat(pass_string,small_string); }

		SPD(playerid,
			dStats, DIALOG_STYLE_MSGBOX,
			"USA Passport",
			pass_string,
			"Назад", "Закрыть"
		);

	}
	return 1;
}
stock ShowLicenses(playerid, targetid) {
	if(IsPlayerConnected(playerid) && IsPlayerConnected(targetid)) {

		new FirstName[16],LastName[16];
		sscanf(PlayerInfo[targetid][pName],"p<_>s[16]s[16]",FirstName,LastName);

		new pass_string[256];

		format(small_string,sizeof(small_string),""COLOR_WHITE"Имя: %s\t", FirstName); strcat(pass_string,small_string);
		format(small_string,sizeof(small_string),""COLOR_WHITE"Фамилия: %s\n\n", LastName); strcat(pass_string,small_string);
		
		format(small_string,sizeof(small_string),""COLOR_WHITE"Вождение легкового авто: %s\n", (PlayerInfo[targetid][pLicense] == 0) ? (""COLOR_RED"Отсутствует") : (""COLOR_GREEN"Разрешено")); strcat(pass_string,small_string);
		format(small_string,sizeof(small_string),""COLOR_WHITE"Управление летательными аппаратами: %s\n", (PlayerInfo[targetid][pLicenseAir] == 0) ? (""COLOR_RED"Отсутствует") : (""COLOR_GREEN"Разрешено")); strcat(pass_string,small_string);

		SPD(playerid,
			dStats, DIALOG_STYLE_MSGBOX,
			"Лицензии",
			pass_string,
			"Назад", "Закрыть"
		);

	}
	return 1;
}

