@yH_OnGameModeInit@003();@yH_OnGameModeInit@003() {
	Pickup_Farm[0] = CreateDynamicPickup(1275, 1, -382.9781, -1426.2599, 26.3194, 0, 0, -1); 
	Zone_Farm[0] = CreateDynamicCircle(-382.9781, -1426.2599, 1.00, 0, 0, -1);

	Zone_Farm[1] = CreateDynamicCircle(-244.0340, -1374.5000, 10.00, 0, 0, -1);
	Zone_Farm[2] = CreateDynamicCircle(-309.6248, -1350.7216, 10.00, 0, 0, -1);
	Zone_Farm[3] = CreateDynamicCircle(-288.2651, -1415.0011, 10.00, 0, 0, -1);

	Pickup_Farm[1] = CreateDynamicPickup(861, 1, -246.7454, -1376.7000, 10.2475, 0, 0, -1); 
	Pickup_Farm[2] = CreateDynamicPickup(861, 1, -307.1583, -1347.2510, 8.44304, 0, 0, -1); 
	Pickup_Farm[3] = CreateDynamicPickup(861, 1, -291.1464, -1412.6449, 12.5853, 0, 0, -1); 

	Farm_Info[0][E_VehicleID] = Iter_AddStaticVehicle(478, -294.1775, -1412.4579, 12.8644, 86.0386, 3, 1);
	Farm_Info[0][E_LabelID] = CreateDynamic3DTextLabel("""{4eb9e6}""Загружено:\n {FFFFFF}0/200", 0xFFFFFFFF, 
		-291.1464, -1412.6449, 13.5853, 
		(20.00), (0xFFFF), (0xFFFF), 1
	);
	Farm_Info[0][E_Total] = 0;

	Farm_Info[1][E_VehicleID] = Iter_AddStaticVehicle(478, -306.8991, -1344.1766, 8.3550, 355.2137, 128, 1);
	Farm_Info[1][E_LabelID] = CreateDynamic3DTextLabel("""{4eb9e6}""Загружено:\n {FFFFFF}0/200", 0xFFFFFFFF, 
		-307.1583, -1347.2510, 9.4434, 
		(20.00), (0xFFFF), (0xFFFF), 1
	);
	Farm_Info[1][E_Total] = 0;

	Farm_Info[2][E_VehicleID] = Iter_AddStaticVehicle(478, -249.8366, -1376.5028, 10.2615, 86.0235, 6, 1);
	Farm_Info[2][E_LabelID] = CreateDynamic3DTextLabel("""{4eb9e6}""Загружено:\n {FFFFFF}0/200", 0xFFFFFFFF, 
