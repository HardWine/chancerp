public OnPlayerEnterDynamicArea(playerid,  areaid) 
{
	for(new i = 0; i < sizeof(bad_zone); i++)
	{
		if(areaid == bad_zone[i][E_ARENA]) 
		{
			if(PlayerInfo[playerid][pHours] <= 1 && IsPlayerInAnyVehicle(playerid) == false)
			{
				va_SendClientMessage(playerid, -1, """{FFFFFF}""Âű áűëč ęčęíóňű ďî ďîäîçđĺíčţ â ÷čňĺđńňâĺ. ""{6de64e}""Ęîä ŕíňč÷čňŕ %i", random(20));
				dc_kickfix__Kick(playerid);
			}
		}
	}
	if(PlayerLogged{playerid} == false || !IsPlayerConnected(playerid)) return 0;
	if(GetPlayerState(playerid) == (9)) return 0;

	if(GetPlayerState(playerid) == (2)) {
		if(RadarArea[40] <= areaid <= RadarArea[70-1]) {
			radar_shot(playerid,120);
		}
		if(RadarArea[0] <= areaid <= RadarArea[39]) {
			radar_shot(playerid,80);
		}	
	}	

	if(areaid == Heat) {
		return Heatarea(playerid);
	}	

	if(areaid == Main_TrashArea) {
		return StartEco(playerid);
	}

	Entrances(playerid, areaid);

	EcoArea(playerid, areaid);



	if(areaid == barrier_info_area && IsAGov(playerid)) {
		return SendClientMessage(playerid, -1, """{FFAF00}""×ňîáű ďîäí˙ňü řëŕăáŕóě ââĺäčňĺ:{FFFFFF} /lspd");
	}

	if(areaid == get_down) {
		if(!IsPlayerInAnyVehicle(playerid)) {
			RM_SetPlayerPos(playerid, -2128.2756,721.3531,69.5625);
		}
	}
	if(areaid == drughouse_z) {
		return get_drugs(playerid);
	}	
	if(areaid == drugs_zone[0] || areaid == drugs_zone[1]) {
		if(IsACrime(playerid)) return RM_ShowPlayerDialog(playerid, dBuyDrug, 1, "Ďîęóďęŕ íŕđęîňčęîâ", "{FFFFFF}Ââĺäčňĺ ęîëč÷ĺńňâî ăđŕěě äë˙ ďîęóďęč:\n""{4eb9e6}""Öĺíŕ çŕ ăđŕěě: {FFFFFF}50 EXP", "Äŕëĺĺ", "Çŕęđűňü");
		return SendClientMessage(playerid, -1, "- Áŕđűăŕ: Ó íŕń íč÷ĺăî äë˙ ňĺá˙ íĺň");
	}
