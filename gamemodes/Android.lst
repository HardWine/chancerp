		return 1;
	}
	format(small_string, sizeof(small_string), """{ff353c}""[Offline] Ŕäěčíčńňđŕňîđ %s çŕáëîęčđîâŕë čăđîęŕ %s íŕ %i äíĺé. Ďđč÷číŕ: %s", PlayerInfo[playerid][pName],name,days,reason);
	SendAdminMessage(-1, small_string);
	Ban__BanPlayer(accID, PlayerInfo[playerid][pID], reason, days);
