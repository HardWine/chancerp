stock ResetDeepArray_Entry(...) {

	assert(numargs() == 3);
	new
		i,
		base,
		size = getarg(1),
		target;
	#emit LOAD.S.alt 12
	#emit STOR.S.alt i
	#emit LOAD.S.pri size
	#emit SHL.C.pri  2
	#emit ADD
	#emit STOR.S.pri base
	#emit STOR.S.pri target
	size = getarg(2) << 2;
	while (i != base) {
		#emit LOAD.S.alt i
		#emit LOAD.S.pri target
		#emit SUB
		#emit STOR.I
		i += 4;
		target += size;
	}
}

