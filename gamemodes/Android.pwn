forward UploadPlayerAccountNumber(playerid);
public UploadPlayerAccountNumber(playerid) PlayerInfo[playerid][pID] = cache_insert_id();
stock CreateNewAccount(playerid, password[], email[])
{
	new query_string[66+MAX_PLAYER_NAME-4+100+6+MAX_PLAYER_NAME];


	if(GetPVarInt(playerid, "RegClass") == 1) {

	if(PlayerInfo[playerid][pSex] == 1) PlayerInfo[playerid][pSkin] = 193;
	else PlayerInfo[playerid][pSkin] = 26;

	} else {

	new random_homeless = RandomEx(0,6);

	if(random_homeless == 0) random_homeless = 78;
	if(random_homeless == 1) random_homeless = 79;
	if(random_homeless == 2) random_homeless = 134;
	if(random_homeless == 3) random_homeless = 135;
	if(random_homeless == 4) random_homeless = 137;
	if(random_homeless == 5) random_homeless = 212;
	if(random_homeless == 6) random_homeless = 230;

	if(PlayerInfo[playerid][pSex] == 1) PlayerInfo[playerid][pSkin] = 77;
	else PlayerInfo[playerid][pSkin] = random_homeless;	

	}

	mysql_format(database,
		query_string, sizeof(query_string),
		"INSERT INTO "TABLE_ACCOUNTS" (`Name`, `Password`, `RegIP`, `Email`, `Sex`, `Skin`, `Referral`) VALUES ('%e', '%e', '%s', '%e', '%d', '%d', '%e')", PlayerInfo[playerid][pName], password, ipsget[playerid], email, PlayerInfo[playerid][pSex], PlayerInfo[playerid][pSkin], PlayerInfo[playerid][pReferral]);
	mysql_query(database, query_string, true);
	PlayerInfo[playerid][pID] = cache_insert_id();

	UpdateSpawnInfo(playerid);
	//format(query_string, sizeof(query_string), "Аккаунт %s успешно зарегистрирован. Администрация желает Вам приятной игры!", PlayerInfo[playerid][pName]);

	SetPVarInt(playerid, "JustCreated", 1);

	if(GetPVarInt(playerid, "RegClass") == 1) {
		startplane(playerid);
	} else {
		finishRegister(playerid);
	}
	return 1;
}
forward SecureVerification(playerid);
public SecureVerification(playerid) {
	PlayerInfo[playerid][pSecured] = cache_get_field_content_int(0, "Secured");
	if(PlayerInfo[playerid][pSecured] == 1) {
		cache_get_field_content(0, "AuthPass", PlayerInfo[playerid][pAuthPass]);
		return ShowPlayerDialog(playerid, dSecureLogin, DIALOG_STYLE_INPUT, "Двухфакторная авторизация", "{FFFFFF}Введите код из приложения Google Authentificator", "Далее", "Закрыть");
	}
	else {
		new query_string[512+MAX_PLAYER_NAME];
		mysql_format(database, query_string, sizeof(query_string), "SELECT players.*, CONVERT(players.State, SIGNED) AS NormState, TIME_TO_SEC(TIMEDIFF(NOW(), `LastTime`)) AS NormTime FROM players WHERE `Name` = '%e' LIMIT 1", PlayerInfo[playerid][pName]);
		printf(query_string);
		mysql_tquery(database, query_string, "UploadPlayerAccount","i", playerid);
	}
	return 1;
}
forward UploadPlayerAccount(playerid);
public UploadPlayerAccount(playerid)
{
	PlayerLogged{playerid} = true;
	cache_get_field_content(0, "Partner", PlayerInfo[playerid][pPartner]);
	cache_get_field_content(0, "Referral", PlayerInfo[playerid][pReferral]);
	PlayerInfo[playerid][pID] = cache_get_field_content_int(0, "ID");
	PlayerInfo[playerid][pJailed] = cache_get_field_content_int(0, "Jailed");
	randomed_jail(playerid);
	PlayerInfo[playerid][pJailTime] = cache_get_field_content_int(0, "JailTime");
	PlayerInfo[playerid][pMuted] = cache_get_field_content_int(0, "Muted");
	PlayerInfo[playerid][pMuteTime] = cache_get_field_content_int(0, "MuteTime");
	PlayerInfo[playerid][pMileage] = cache_get_field_content_int(0, "Mileage");
	PlayerInfo[playerid][pMileage2] = cache_get_field_content_int(0, "Mileage2");
	PlayerInfo[playerid][pSelectedSlot] = cache_get_field_content_int(0, "SelectedSlot");
	new temp_int = cache_get_field_content_int(0, "Job");
	SetPlayerFraction(playerid, Fraction:temp_int);
	PlayerInfo[playerid][pSkin] = cache_get_field_content_int(0, "Skin");
	PlayerInfo[playerid][pSex] = cache_get_field_content_int(0, "Sex");
	PlayerInfo[playerid][pLicense] = cache_get_field_content_int(0, "License");
	PlayerInfo[playerid][pLicenseAir] = cache_get_field_content_int(0, "LicenseAir");
	PlayerInfo[playerid][pBank] = cache_get_field_content_int(0, "Bank");
	PlayerInfo[playerid][pDebt] = cache_get_field_content_int(0, "Debt");
	PlayerInfo[playerid][pDevice] = cache_get_field_content_int(0, "Device");
	PlayerInfo[playerid][pBalance] = cache_get_field_content_int(0, "Balance");
	PlayerInfo[playerid][pRank] = cache_get_field_content_int(0, "Rank");
	PlayerInfo[playerid][pScrew] = cache_get_field_content_int(0, "Screw");
	PlayerInfo[playerid][pPayDayBonus] = cache_get_field_content_int(0, "PayDayBonus");
