forward dre_JOB_PARAMEDIC(playerid, response, listitem, inputtext[]); public dre_JOB_PARAMEDIC(playerid, response, listitem, inputtext[]) {
	if(!response) {
		return 1;
	}
	if(response) {
		new Fraction:player_frac = GetPlayerFraction(playerid);
		if(player_frac == FRACTION_ARMY 
		|| player_frac == FRACTION_LSPD 
		|| player_frac == FRACTION_GOVERMENT 
		|| player_frac == FRACTION_FBI) { 
			SetPVarInt(playerid, "Paramedic", 1);
			SetPVarInt(playerid, "tempjob", 11);
			if(PlayerInfo[playerid][pSex] != 0) {
				SetPlayerSkin(playerid, 308);
			} else {
				SetPlayerSkin(playerid, 275);
			}
			SetPlayerColor(playerid, 0xFF91CCFF);
			SendClientMessage(playerid, -1, """{6de64e}""Âű óńňđîčëčńü ďŕđŕěĺäčęîě. Đŕáîňŕ áóäĺň îęîí÷ĺíŕ ďîńëĺ âűőîäŕ čç čăđű");
			SendClientMessage(playerid, -1, """{6de64e}""Čńďîëüçóéňĺ (/heal [id]) ÷ňîáű ďîďđŕâčňü çäîđîâüĺ óęŕçŕííîăî čăđîęŕ");
		} else {
		return SendClientMessage(playerid, -1, "Äîńňóďíî ňîëüęî ńîňđóäíčęŕě ăîń. ôđŕęöčé");
		}
	}
	return 1;
}
forward pc_cmd_giveweapon(playerid, params[]); public pc_cmd_giveweapon(playerid, params[])
{
	if(Player__AdminLevel{playerid} < 4) return 1;
    new targetid, weaponid, ammo;if (unformat(_:EXTRV:EXTR8:EXTR9:EXTR0:EXTR1: EXTR8:EXTR9:EXTR0:EXTR1:EXTR2:EXTR3:EXTR8:EXTR9:EXTR0:EXTR1:EXTR2:EXTR3:EXTR8:EXTR9:EXTR0:EXTR1:EXTR2: params ,##uii,targetid, weaponid, ammo)) 
        return SendClientMessage(playerid, -1, "Čńďîëüçîâŕíčĺ: /giveweapon [ID čăđîęŕ/÷ŕńňü íčęŕ] [ID îđóćč˙] [ęîë-âî ďŕňđîíîâ]");
    if (targetid == (0xFFFF))
        return SendClientMessage(playerid, -1, "Čăđîę íĺ íŕéäĺí.");
    if (weaponid < 1 || weaponid > 46 || weaponid == 19 || weaponid == 20 || weaponid == 21)
        return SendClientMessage(playerid, -1, "Íĺďđŕâčëüíűé ID îđóćč˙.");
    if (ammo < 0 || ammo > 1000)
        return SendClientMessage(playerid, -1, "Ęîëč÷ĺńňâî ďŕňđîíîâ äîëćíî áűňü îň 1 äî 1000.");
    RM_GivePlayerWeapon(targetid, weaponid, ammo);
    new string[128];
    GetPlayerName(targetid, string, sizeof(string));
    format(string, sizeof(string), "Âű âűäŕëč čăđîęó %s îđóćčĺ \"%s\" c %d ďŕňđîíŕěč.", string, weapon_names[weaponid], ammo);
    return SendClientMessage(playerid, -1, string);
}

