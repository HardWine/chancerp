stock CraftExplosions(playerid, explosion) {
	switch(explosion) {
		case 1: {
			if(PlayerInfo[playerid][pStuff] > 1) {
				SendClientMessage(playerid, -1, """{6de64e}""Âű óńďĺříî ńîáđŕëč ďĺňŕđäó čç 2 ěŕňĺđčŕëîâ");
				PlayerInfo[playerid][pStuff] -= 2;
				SetPlayerInt(playerid, "Stuff", PlayerInfo[playerid][pStuff]);
				PlayerInfo[playerid][pPetard] += 1;
				SetPlayerInt(playerid, "Petard", PlayerInfo[playerid][pPetard]);				
			}
			else SendClientMessage(playerid, -1, """{ff353c}""Äë˙ ńáîđęč ďĺňŕđäű íĺîáőîäčěî 2 ěŕňĺđčŕëŕ");
		}
		case 2: {
			if(PlayerInfo[playerid][pStuff] > 4) {
				SendClientMessage(playerid, -1, """{6de64e}""Âű óńďĺříî ńîáđŕëč ăđŕíŕňó čç 5 ěŕňĺđčŕëîâ");
				PlayerInfo[playerid][pStuff] -= 5;
				SetPlayerInt(playerid, "Stuff", PlayerInfo[playerid][pStuff]);
				PlayerInfo[playerid][pGrenade] += 1;
				SetPlayerInt(playerid, "Grenade", PlayerInfo[playerid][pGrenade]);	
			}
			else SendClientMessage(playerid, -1, """{ff353c}""Äë˙ ńáîđęč ăđŕíŕňű íĺîáőîäčěî 5 ěŕňĺđčŕëîâ");
		}
		case 3: {
			if(PlayerInfo[playerid][pStuff] > 9) {
				SendClientMessage(playerid, -1, """{6de64e}""Âű óńďĺříî ńîáđŕëč äčíŕěčň čç 10 ěŕňĺđčŕëîâ");
				PlayerInfo[playerid][pStuff] -= 10;
				SetPlayerInt(playerid, "Stuff", PlayerInfo[playerid][pStuff]);
				PlayerInfo[playerid][pDynamite] += 1;
				SetPlayerInt(playerid, "Dynamite", PlayerInfo[playerid][pDynamite]);	
			}
			else SendClientMessage(playerid, -1, """{ff353c}""Äë˙ ńáîđęč äčíŕěčňŕ íĺîáőîäčěî 10 ěŕňĺđčŕëîâ");
		}
		default: return 1;
	}
	return 1;
}

