	for(new i = 0; i < sizeof(GpsCategory); i++) {
		format(gps_string, sizeof(gps_string), "%i\t%s\n", GpsCategory[i][GC_ID], GpsCategory[i][GC_Title]);
		strcat(gps_string_all, gps_string);
