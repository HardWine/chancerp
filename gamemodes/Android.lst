	} else {
		Player__CarID[playerid][slot] = cache_get_field_content_int(0, "ID");
		Player__CarModelID[playerid][slot] = cache_get_field_content_int(0, "VehicleID") + 399;
		Player__CarColor_1[playerid][slot] = cache_get_field_content_int(0, "Color_1");
