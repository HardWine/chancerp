		if (temp_size > max_size) {
			max_size = temp_size;
		}


		prev_sep_pos = sep_pos;


		lines_count++;
		if (lines_count >= 100) {
			break;
		}
	}

	if (max_size < 200.0) {
		max_size = 200.0;
	}


	static
		spaces_string[200],
		spaces,
		j;

	for (i = 0; i < lines_count; i++) {
