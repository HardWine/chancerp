		SetPVarInt(playerid,"GetCarFlood",gettime() + 60);

		if(IsValidVehicle(caridhouse[playerid])) {

		if(GetPlayerInterior(playerid) == 0 && GetPlayerVirtualWorld(playerid) == 0) {

			if(IsPlayerInAnyVehicle(playerid)) return SendClientMessage(playerid, -1, """{ff353c}""Âű óćĺ â ňđŕíńďîđňĺ!");
			new Float:vehicle_health;
			GetVehicleHealth(caridhouse[playerid], vehicle_health);
			if(vehicle_health < 370)
			{
				return SendClientMessage(playerid, -1, """{FFAF00}""Ňđŕíńďîđň çíŕ÷čňĺëüíî ďîâđĺćäĺíčĺ. Äŕííîĺ äĺéńňâčĺ íĺäîńňóďíî");
			}

			new Float:x_car,
				Float:y_car,
				Float:z_car;

			GetVehiclePos(caridhouse[playerid], Float:x_car, Float:y_car, Float:z_car);

			new Float:x_p,
				Float:y_p,
				Float:z_p,
				Float:a_p;

			GetPlayerPos(playerid, Float:x_p, Float:y_p, Float:z_p);
