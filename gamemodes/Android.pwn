CMD:ac_off(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) == 0) return 0;

	if(GetPVarInt(playerid, "dis_ac_warning") == 0)
	{
		SendClientMessage(playerid, -1, ""COLOR_WHITE"Уведомления античита "COLOR_ORANGE"выключены"COLOR_WHITE" для Вас");
		return SetPVarInt(playerid, "dis_ac_warning", 1);	
	}
	else 
	{
		SendClientMessage(playerid, -1, ""COLOR_WHITE"Уведомления античита "COLOR_GREEN"включены"COLOR_WHITE" для Вас");
		return SetPVarInt(playerid, "dis_ac_warning", 0);
	}
}

alias:online("onl");
CMD:online(playerid, params[])
{
	huge_string[0] = EOS;
	huge_string = "ID Игрока\tНик\tКол-во отыгранных часов\tПинг\n";

	foreach(new i: Player)
	{
		format(small_string, sizeof(small_string), "%i\t%s%s\t%i\t%i\n", i, FractionColor[(GetPlayerJobDayStatus(i) == true) ? (GetPlayerFraction(i)) : (0)], PlayerInfo[i][pName], PlayerInfo[i][pHours], GetPlayerPing(i));
		strcat(huge_string, small_string);
	}
	ShowPlayerDialog(playerid, DIALOG_INFO, DIALOG_STYLE_TABLIST_HEADERS, ""COLOR_BLUE"Список онлайн игроков", huge_string, "Закрыть", "");
	return 1;
}

CMD:lfind(playerid, params[])
{
	if(GetPVarInt(playerid, "lfind") == 1)
	{
		DisablePlayerRaceCheckpoint(playerid);
		DeletePVar(playerid, "lfind");
		DeletePVar(playerid, "lfind_id");
		return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Слежка прекращена");
	}

	new targetid;
	if(sscanf(params, "r", targetid))
	{
		return SendClientMessage(playerid, -1, "Используйте: /lfind [ID Игрока]");
	}
	new Fraction: fractionid = GetPlayerFraction(playerid);
	if(fractionid != FRACTION_LSPD && fractionid != FRACTION_FBI)
	{
		return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Команда доступна сотрудникам полицейским");
	}
	if(GetPlayerJobDayStatus(playerid) == false)
	{
		return SendClientMessage(playerid, -1, MSG_START_JOB_DAY);
	}
	if(IsPlayerConnected(targetid) == 0 || GetPlayerInterior(targetid) != 0 || GetPlayerVirtualWorld(targetid) != 0 || GetPlayerState(targetid) == PLAYER_STATE_SPECTATING)
	{
		return SendClientMessage(playerid, -1, "В данный момент не удается установить точное местоположение игрока");
	}

	SetPVarInt(playerid, "lfind", 1);
	SetPVarInt(playerid, "lfind_id", targetid);
	SendClientMessage(playerid, -1, ""COLOR_GREEN"Получаем данные со спутника...");
	return SendClientMessage(playerid, -1, ""COLOR_GREEN"Введите команду повторно, для прекращения слежки");
}

ptask CommandLfind[1000](playerid) 
{
	if(GetPVarInt(playerid, "lfind") == 1)
	{
		new targetid = GetPVarInt(playerid, "lfind_id");

		DisablePlayerRaceCheckpoint(playerid);
		if(IsPlayerConnected(targetid) == 0 || GetPlayerInterior(targetid) != 0)
		{
			DeletePVar(playerid, "lfind");
			DeletePVar(playerid, "lfind_id");
			return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Слежка прекращена");
		}
		new Float:x, Float:y, Float:z;
		GetPlayerPos(targetid, x, y, z);
		SetPlayerRaceCheckpoint(playerid, 0, x, y, z, x, y, z, 2.0); 
	}
	return 1;
}	

CMD:m(playerid, params[])
{
	if(GetPlayerFraction(playerid) != FRACTION_FBI && GetPlayerFraction(playerid) != FRACTION_LSPD) 
	{
		return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Доступно только полицейским");
	}
	if(!params[0]) return SendClientMessage(playerid, -1, "Используйте: /m [текст]");
	if(strlen(params) > 80) {
		return SendClientMessage(playerid, -1, "Слишком длинное сообщение");
	}
	if(IsPlayerInAnyVehicle(playerid) == 0)
	{
		return SendClientMessage(playerid, -1, "Вы должны находиться в транспортном средстве");
	}
	if(GetPVarInt(playerid,"AntiFloodAdm") > gettime()){ SendClientMessage(playerid, -1, ""COLOR_RED"Пожалуйста не флудите"); return false; }
	SetPVarInt(playerid,"AntiFloodAdm",gettime() + 3);

	format(small_string, sizeof(small_string), "<< %s %s: %s >>", gFractionRankName_RU[_:GetPlayerFraction(playerid)-1][PlayerInfo[playerid][pRank]], PlayerInfo[playerid][pName], params[0]);
	ProxDetector(playerid, MAX_DISTANCE_VISIBLE * 2, 0xFFFF00AA, small_string);
}

new Tazer[MAX_PLAYERS] = {false, ...};

public OnPlayerTakeDamage(playerid, issuerid, Float:amount, weaponid, bodypart)
{
	if(!IsPlayerConnected(playerid)) return true;
	if(!IsPlayerConnected(issuerid)) return true;
	if((GetPlayerFraction(issuerid) == FRACTION_LSPD || GetPlayerFraction(issuerid) == FRACTION_FBI) && (weaponid == 3 || weaponid == 22))
	{
		if(Tazer[playerid] == true) 
		{
			return SendClientMessage(issuerid, -1, ""COLOR_GREEN"Игрок уже оглушен!");
		}
		TogglePlayerControllable(playerid, false);
		ApplyAnimation(playerid, "CRACK", "crckdeth2", 4.0, 1, 0, 0, 0, 0);
		Tazer[playerid] = true;
		SetTimerEx("TazerOff", 15000, 0, "d", playerid);
		format(small_string, sizeof(small_string), ""COLOR_WHITE"%s "COLOR_GREEN"%s(%i)"COLOR_WHITE" оглушил Вас на 15 секунд", gFractionRankName_RU[_:GetPlayerFraction(issuerid)-1][PlayerInfo[issuerid][pRank]], PlayerInfo[issuerid][pName], issuerid);
		SendClientMessage(playerid, -1, small_string);
		format(small_string, sizeof(small_string), ""COLOR_WHITE"Вы оглушили "COLOR_GREEN"%s(%i)"COLOR_WHITE" на 15 секунд", PlayerInfo[playerid][pName], playerid);
		SendClientMessage(issuerid, -1, small_string);
		ApplyAnimation(playerid, "CRACK", "crckdeth2", 4.0, 1, 0, 0, 0, 0);
	}
	return true;
}

public TazerOff(playerid)
{
	Tazer[playerid] = false;
	ApplyAnimation(playerid,"CARRY","crry_prtial",4.0,0,0,0,0,0,0);
	TogglePlayerControllable(playerid, 1);
	return true;
}

CMD:test2(playerid, params[])
{
	ShowRecentPlayerMessage(playerid, playerid);
}

stock ShowRecentPlayerMessage(playerid, targetplayerid)
{
    if(!recent_player_messages[targetplayerid][0][0]) return SendClientMessage(playerid, 0xFF0000FF, "Ошибка: {FFFFFF}Данный игрок ещё не написал ни одного сообщения в чат");
    new string[144];
    SendClientMessage(playerid, -1, "Последние сообщения игрока:");
    for(new i; i < NUMBER_STORABLE_LINES; i++)
    {
        if(!recent_player_messages[targetplayerid][i][0]) break;
        format(string, sizeof(string), "%i) %s", i+1, recent_player_messages[targetplayerid][i]);
        SendClientMessage(playerid, -1, string);
    }
    return 1;
} 