public OnPlayerText(playerid, text[])
{
	if(PlayerLogged{playerid} == false || !IsPlayerConnected(playerid)) return 0;
	if(GetPVarType(playerid, !"tasered") == 1) {
		return 0;
	}
	if(GetPlayerState(playerid) == (7) && Platform[playerid] == 0) return 0;
	if(GetPVarInt(playerid, "DialogID"))
	{
		return false;
	}
	new speach[144];
	if(PlayerInfo[playerid][pMuted] > 0) {
		format(small_string, sizeof(small_string), """{ff353c}""Âŕě çŕďđĺůĺíî ďčńŕňü â ÷ŕň ĺůĺ %d ěčíóň!",PlayerInfo[playerid][pMuteTime] / 60);
		SendClientMessage(playerid, -1, small_string);
		return 0;
	} else {
		if(GetPVarInt(playerid,"AntiFloodLocal") > gettime() && Player__AdminLevel{playerid} < 4){ SendClientMessage(playerid, -1, """{ff353c}""Ďîćŕëóéńňŕ, íĺ ôëóäčňĺ!"); return false; }
		SetPVarInt(playerid,"AntiFloodLocal",gettime() + 1);
		SetPlayerChatBubble(playerid, text, 0x6ab1ffaa, 20.0, 10000);
		if(PlayerCall[playerid][E_CALL] == true) {
			format(small_string, sizeof(small_string), """{FFFFFF}""[Ňĺëĺôîí] %s: ""{6de64e}""%s", PlayerInfo[playerid][pName], text);
			SendClientMessage(PlayerCall[playerid][E_CALLING_ID], -1, small_string);

			format(small_string, sizeof(small_string), """{FFFFFF}""[Ňĺëĺôîí] %s: ""{6de64e}""%s", PlayerInfo[playerid][pName], text);
			SendClientMessage(playerid, -1, small_string);
			return 0;
		}

		if(GetPVarInt(playerid, "onair")) {
			if(onair != 1) {
				DeletePVar(playerid, "onair");
			}
			if(!IsPlayerInRangeOfPoint(playerid, 40, 1175.2021,-1180.5349,87.0787)) {
				if(!IsPlayerInRangeOfPoint(playerid, 40, 927.6644,-1677.8931,1349.5969)) {
					new vehicle_owner;
					for(new i = 0; i < sizeof(VehicleInfo); i++) {
					if(VehicleInfo[i][VI_VehicleID] == GetPlayerVehicleID(playerid)) {
					vehicle_owner = VehicleInfo[i][VI_Owner];
					}
					}
					if(vehicle_owner != VO_FRACTION_NEWS) {
					DeletePVar(playerid, "onair");
					if(GetPVarInt(playerid, "onair_master")) {
						DeletePVar(playerid, "onair_master");
						onair = 0;
						SendFamilyMessage(FRACTION_NEWS, -1, """{FFAF00}""Âĺäóůčé ďđĺđâŕë ďđ˙ěîé ýôčđ");
					}
					SendClientMessage(playerid, -1, """{ff353c}""Âű ďîęčíóëč ďđ˙ěîé ýôčđ");
					return 0;
					}
				}
			}
			format(speach, sizeof(speach), """{7B68EE}""(Ďđ˙ěîé ýôčđ) {A8A9AD}%s: %s", PlayerInfo[playerid][pName], text);
			printf("%s", speach);
			for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i=Iterator@Player [_: i])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);) {
				if(GetPVarInt(i, "fm")) continue;
				SendClientMessage(i, -1, speach);
			}

		} else {
			format(speach, sizeof(speach), "%s%s(%d):{E6E6E6} %s", FractionColor[(GetPlayerJobDayStatus(playerid) == true) ? (GetPlayerFraction(playerid)) : (0)], PlayerInfo[playerid][pName],playerid, text);
			ProxDetector(playerid, (20.00), 0xE6E6E6E6, speach);
			SetPlayerChatBubble(playerid, text, 0xE6E6E6E6, (20.00), 2000);
		}

		if(GetPVarInt(playerid, "parrot")) {
			new gotcha = RandomEx(0,PlayerInfo[playerid][pParrot]);
			if(gotcha == 0) {
				format(speach, sizeof(speach), "- Ďîďóăŕé[%d]: %s", playerid, text);
				ProxDetector(playerid, (20.00), 0xE6E6E6E6, speach);				
			}
		}

		if(GetPVarInt(playerid, "tempjob") != 1) {
			if(!IsPlayerInAnyVehicle(playerid)) {
				switch(RandomEx(1,4)) {
				case 1:ApplyAnimation(playerid,"MISC","Idle_Chat_02",4.1,0,1,1,1,1,1);
				default: ApplyAnimation(playerid,"PED","IDLE_CHAT",4.1,0,1,1,1,1,1);
				}
				SetTimerEx("Unfreez", MDialog_strlen(text)*250, false, "i", playerid);
			}
		}
	}
	return 0;
}

public OnPlayerCommandReceived(playerid, cmd[], params[], flags)
{
	if(PlayerLogged{playerid} == false || !IsPlayerConnected(playerid)) return 0;
	if(GetPVarType(playerid, !"cuffed") == 1) {
		ApplyAnimation(playerid, "PED", "cower", 1, 1, 0, 0, 0, 0, 1);
		return 0;
	}
	if(GetPlayerState(playerid) == (7) && Platform[playerid] == 0) return 0;

	if(GetPVarInt(playerid, "DialogID") && _:GetPVarInt(playerid, "DialogID") != _:DIALOG_BUY_YACHT && _:GetPVarInt(playerid, "DialogID") != _:DIALOG_BUY_AVIATION)
	{
		return false;
	}
	if(GetPVarInt(playerid, "dialog_tuning")) return 0;
	if(GetPVarInt(playerid, "job_army_plant") == 1) {
	for(new i = 0; i < sizeof(ArmyPlant); i++) { 
		if(ArmyPlant[i][AP_Table_PlayerID] == playerid) {
			ArmyPlant[i][AP_Table_PlayerID] = (0xFFFF);
			ClearPlayerAnimation(playerid);
			RM_TogglePlayerControllable(playerid, true);
			SendClientMessage(playerid, -1, """{ff353c}""Âű îňâëĺęëčńü, đŕáîňŕ ďđčîńňŕíîâëĺíŕ!");
		}
	}
	}

	if(GetPVarInt(playerid,"AntiFloodCMD") > gettime() && Player__AdminLevel{playerid} < 6) {
		SendClientMessage(playerid, -1, """{ff353c}""Ďîćŕëóéńňŕ, íĺ ôëóäčňĺ!");
		return false;
	}
	SetPVarInt(playerid,"AntiFloodCMD",gettime() + 3);
	return 1;
}
public OnPlayerClickMap(playerid, Float:fX, Float:fY, Float:fZ)
{
	if(Player__AdminLevel{playerid} >= 1) {
