stock LoadCarPlayerId(playerid)
{
    if(GetPlayerHouse(playerid) == 0) return true;
	if(caridhouse[playerid] != (0xFFFF))
	{
		Iter_DestroyVehicle(caridhouse[playerid]);
		caridhouse[playerid] = (0xFFFF);
	}
    if(PlayerInfo[playerid][pCar] == 0) PlayerInfo[playerid][pCar] = 509, SetPlayerInt(playerid, "Car", PlayerInfo[playerid][pCar]);
    new he = GetPVarInt(playerid,"PlayerHouse");
    caridhouse[playerid] = (0xFFFF);
    new temp_return = Iter_CreateVehicle(PlayerInfo[playerid][pCar], OLD_HouseInfo[he][hCarx], OLD_HouseInfo[he][hCary], OLD_HouseInfo[he][hCarz], OLD_HouseInfo[he][hCarc], PlayerInfo[playerid][pCarCol], PlayerInfo[playerid][pCarCol2], 86400);
	if(temp_return == (0xFFFF)) {
		caridhouse[playerid] = (0xFFFF);
	} else {
		 caridhouse[playerid] = temp_return;
	}
	switch(Platform[playerid]) {
		case 0: SetVehicleNumberPlate(caridhouse[playerid], "Android");
		case 1: SetVehicleNumberPlate(caridhouse[playerid], "Computer");
		case 2: SetVehicleNumberPlate(caridhouse[playerid], "RakDroid");
	}
	SetVehicleParamsForPlayerEx(caridhouse[playerid],playerid,0,1); 
	return 1;
}

forward BuyApartment(playerid);
public BuyApartment(playerid)
{
	if(test_server == true) {
		return 1;
	}
	new h = GetPVarInt(playerid, "HouseID");
	if(IsPlayerInRangeOfPoint(playerid, 2, OLD_HouseInfo[h][hEntrancex], OLD_HouseInfo[h][hEntrancey], OLD_HouseInfo[h][hEntrancez]))
	{
	    if(CheckCash(playerid, OLD_HouseInfo[h][hPrice]) == false) return 1;
		Player__DownEXP(PlayerInfo[playerid][pID], OLD_HouseInfo[h][hPrice], E_BUY_HOUSE, playerid);
		if(GetPlayerHouse(playerid) > 0) return SendClientMessage(playerid, -1, """{ff353c}""У вас уже есть дом!");
		OLD_HouseInfo[h][hOwned] = 1;
		OLD_HouseInfo[h][hTakings] = 3;
		strmid(OLD_HouseInfo[h][hOwner], PlayerInfo[playerid][pName], 0, MDialog_strlen(PlayerInfo[playerid][pName]), 255);
		SetPlayerInterior(playerid,OLD_HouseInfo[h][hInt]);
		SetPlayerPos(playerid,OLD_HouseInfo[h][hExitx],OLD_HouseInfo[h][hExity]+3,OLD_HouseInfo[h][hExitz]);
		SetPlayerVirtualWorld(playerid,h+50);
		PlayerPlaySound(playerid, 1058, 0.0, 0.0, 10.0);
		if(PlayerInfo[playerid][pCar] == 0) PlayerInfo[playerid][pCar] = 509, SetPlayerInt(playerid, "Car", PlayerInfo[playerid][pCar]);
		new MySQL[110];
		mysql_format(database, MySQL, sizeof(MySQL), "UPDATE `apartment` SET Owner = '%e', Owned = 1, Takings = 3 WHERE ID = '%d' LIMIT 1",PlayerInfo[playerid][pName],h);
		mysql_pquery(database, MySQL, "", "");
		LoadCarPlayerId(playerid);
		Streamer_SetIntData((1), OLD_HouseInfo[h][hPickup], 23, 1272);
		BuyHouse(h);
		SetPVarInt(playerid, "PlayerHouse", h);
		DeletePVar(playerid,"HouseID");
		SendClientMessage(playerid, -1, """{6de64e}""Вы купили дом!");
		SendClientMessage(playerid, -1, """{6de64e}""Государство оплатит Ваше проживание ближайшие три дня");
		SendClientMessage(playerid, -1, """{6de64e}""После этого придется платить за дом в банке");
		GameTextForPlayer(playerid, "~g~Welcome home!", 9000, 0);
		return 1;
	}
	DeletePVar(playerid,"HouseID");
	return 1;
}
