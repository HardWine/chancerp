			house_string[0], house_string[1], hotel_string
		);
		return RM_ShowPlayerDialog(playerid, DIALOG_BANK_PROPERTY, 1, "Îďĺđŕöčč ń íĺäâčćčěűě čěóůĺńňâîě", big_string, !"Âűáđŕňü", !"Çŕęđűňü");
	} else {
		format(big_string, sizeof(big_string), "Äĺéńňâčĺ\tÇíŕ÷ĺíčĺ\n""{FFFFFF}""Îďëŕňŕ ęâŕđňďëŕňű çŕ äîě\t%s\n""{ff353c}""Ďđîäŕćŕ äîěŕ\t%s\nÎďëŕňŕ ŕđĺíäű çŕ íîěĺđ â îňĺëĺ\t%s\nÎďëŕňčňü ŕđĺíäó çŕ áčçíĺń",
			house_string[0], house_string[1], hotel_string
		);
		return RM_ShowPlayerDialog(playerid, DIALOG_BANK_PROPERTY, 5, """{4eb9e6}""Îďĺđŕöčč ń íĺäâčćčěűě čěóůĺńňâîě", big_string, !"Âűáđŕňü", !"Çŕęđűňü");
	}
}   

















