					default: return ShowPlayerDialog(playerid, dBuyDrug, DIALOG_STYLE_INPUT, "Покупка наркотиков", "{FFFFFF}Введите количество грамм для покупки:\n"COLOR_BLUE"Цена за грамм: {FFFFFF}50 EXP", "Далее", "Закрыть");
				}
