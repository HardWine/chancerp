stock IsABMX(carid)
{
    switch(carid)
    {
    case 481: return 1;
    case 509: return 1;
    case 510: return 1;
    case 436: return 1;
    }
    return 0;
} 

stock IsABike(vehicleid)
{
        vehicleid = GetVehicleModel(vehicleid);
        if(319 < vehicleid < 612 && VehicleBikes[vehicleid - 400]) return 1;
        return 0;
}
stock Vehicleforeach(vehicleid)
{
	foreach(new i: Player)
	{
		if(caridhouse[i] == vehicleid) return i;
	}
	return -1;
}
