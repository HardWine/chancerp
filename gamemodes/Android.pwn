ShowPlayerAllBans(const playerid) {
	new 
		current_page = PlayerPageAllBans[playerid];

	mysql_format(database, big_string, sizeof(big_string), "SELECT player_banned.ID, players.Name AS PlayerName, admin.Name AS AdminName, player_banned.Reason, DATEDIFF(player_banned.`UnBanTime`, CURRENT_TIMESTAMP()) AS Days FROM `player_banned` JOIN players ON players.ID = player_banned.PlayerID JOIN players AS admin ON admin.ID = player_banned.AdminID WHERE `UnBanTime` > CURRENT_TIMESTAMP() AND player_banned.Status = 'Заблокирован' ORDER BY player_banned.ID LIMIT %i OFFSET %i",  MAX_ALL_BANS_LIST + 1, MAX_ALL_BANS_LIST * current_page);
	printf(big_string);
	return mysql_pquery(database, big_string, "@_ShowPlayerAllBans", "i", playerid);
}

@_ShowPlayerAllBans(const playerid);
@_ShowPlayerAllBans(const playerid) {
	new 
		rows = cache_get_row_count();

	if(!rows) {
		if(PlayerPageAllBans[playerid] == 0) {
			return SendClientMessage(playerid, -1, ""COLOR_WHITE"Активные блокировки отсутсвуют");
		}
		return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Произошла ошибка");
	} else {

		small_string[0] = EOS;
		huge_string[0] = EOS;

		huge_string = !"ID\tНик\tАдминистратор\tПричина\tОсталось дней\n";

		new 
			player_name[MAX_PLAYER_NAME + 1],
			admin_name[MAX_PLAYER_NAME + 1],
			reason[48 + 1];

		new 
			id,
			days;

		for(new i = 0; i < rows; i++) {
			cache_get_field_content(i, "PlayerName", player_name);
			cache_get_field_content(i, "AdminName", admin_name);
			cache_get_field_content(i, "Reason", reason);

			days = cache_get_field_content_int(i, "Days");
			id = cache_get_field_content_int(i, "ID");

			format(small_string, sizeof(small_string), 
				"%i\t"COLOR_GREEN"%s"COLOR_WHITE"\t"COLOR_RED"%s\t%s\t%i\n", 
					id, 
					player_name,
					admin_name,
					reason,
					days 
			);	
			strcat(huge_string, small_string);

			if(i > MAX_ALL_BANS_LIST - 1) {
				strcat(huge_string, ""COLOR_GREEN"+ Следующая страница\n");
				break;
			}
		}

		if(PlayerPageAllBans[playerid] >= 1) {
			strcat(huge_string, ""COLOR_ORANGE"- Предыдущая страница\n");
		}

		format(small_string, sizeof(small_string), ""COLOR_BLUE"Заблокированные игроки: "COLOR_ORANGE"Страница %i", PlayerPageAllBans[playerid] + 1);
		return Dialog_Open(playerid, Dialog:DIALOG_SHOW_PLAYER_BAN, DIALOG_STYLE_TABLIST_HEADERS,
			small_string,
			huge_string,
			"Назад", "Закрыть"
		);
	}
}

DialogResponse:DIALOG_SHOW_PLAYER_BAN(playerid, response, listitem, inputtext[]) {
	if(response) {
		if(strcmp(inputtext, "+ Следующая страница", false) == 0) {
			PlayerPageAllBans[playerid] = PlayerPageAllBans[playerid] + 1;
			return ShowPlayerAllBans(playerid);
		} else if(strcmp(inputtext, "- Предыдущая страница", false) == 0) {
			PlayerPageAllBans[playerid] = PlayerPageAllBans[playerid] - 1;
			return ShowPlayerAllBans(playerid);
		} else {
			return ShowPlayerAllBans(playerid);
		}
	}
	return 1;
}

CMD:number(playerid, params[]) {
	new 
		phone_number[MAX_PLAYER_NAME + 1];

	if(sscanf(params, "s[" #MAX_PLAYER_NAME "]", phone_number)) {
		return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Используйте: /number [Номер телефона или ник игрока]");
	}

	if(IsNumeric(phone_number) == 1) {
		mysql_format(database, 
			small_string, sizeof(small_string), 
			"SELECT Name, isOnline, SIMCard FROM `players` WHERE SIMCard = %i LIMIT 1", 
				strval(phone_number)
		);
		mysql_pquery(database, small_string, "@_ShowPlayerNumberOwner", "ii", playerid, 0);
	} else {
		mysql_format(database, 
			small_string, sizeof(small_string), 
			"SELECT Name, isOnline, COALESCE(SIMCard, %i) AS SIMCard FROM `players` WHERE Name = '%e' LIMIT 1", 
				INVALID_SIM_CARD_NUMBER,
				phone_number
		);
		mysql_pquery(database, small_string, "@_ShowPlayerNumberOwner", "ii", playerid, 1);
	}
	return 1;
}

@_ShowPlayerNumberOwner(const playerid, const type);
@_ShowPlayerNumberOwner(const playerid, const type) {
	new 
		rows = cache_get_row_count();

	if(rows) {
		new 
			isonline,
			phone,
			name[MAX_PLAYER_NAME];

		isonline = cache_get_field_content_int(0, "isOnline");
		phone = cache_get_field_content_int(0, "SIMCard");
		cache_get_field_content(0, "Name", name);

		if(phone == INVALID_SIM_CARD_NUMBER) {
			return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Указанный Вами номер не зарегистрирован.");
		}

		if(isonline == 0) {
			format(small_string, sizeof(small_string), ""COLOR_WHITE"Номер "COLOR_GREEN"%i"COLOR_WHITE" принадлежит игроку "COLOR_GREEN"%s", phone, name);
		} else {
			format(small_string, sizeof(small_string), ""COLOR_WHITE"Номер "COLOR_GREEN"%i"COLOR_WHITE" принадлежит игроку "COLOR_GREEN"%s"COLOR_WHITE" и в данный момент находится в зоне обслуживания", phone, name);
		}
		SendClientMessage(playerid, -1, small_string);
	} else {
		if(type == 0) {
			return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Указанный Вами номер не зарегистрирован.");
		} else {
			return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Указанный Вами игрок не зарегистрирован.");
		}
	}
	return 1;
}



new
	Float:posCam[MAX_PLAYERS][3],
	Float:Degree[MAX_PLAYERS]
;
new const Float: Radius = 1.7;
new const Float: Height = 1.15;
CMD:selfie(playerid)
{
	if(!GetPVarInt(playerid,"Selfie"))
	{
		PlayerPlaySound(playerid, 17001, 0.0, 0.0, 0.0);
		SendClientMessage(playerid, -1, ""COLOR_WHITE"Введите "COLOR_GREEN"/headmove"COLOR_WHITE", чтобы ваша голова при селфи смотрела в камеру.");
		SendClientMessage(playerid, -1, ""COLOR_WHITE"Нажмите "COLOR_GREEN"F8"COLOR_WHITE", чтобы сделать селфи.");
		SendClientMessage(playerid, -1, ""COLOR_WHITE"Напишите "COLOR_GREEN"/selfie"COLOR_WHITE", чтобы закончить съёмку.");
		GetPlayerPos(playerid,posCam[playerid][0],posCam[playerid][1],posCam[playerid][2]);
		static Float: n1X, Float: n1Y, Float:PosCam;
		GetPlayerFacingAngle(playerid, PosCam);
		n1X = posCam[playerid][0] + Radius * floatcos(180.0, degrees);
		n1Y = posCam[playerid][1] + Radius * floatsin(180.0, degrees);
		SetPlayerAttachedObject(playerid, 0, 18868, 6, 0.06, 0.01, 0.08, 180.0, 90.0, 0.0);
		SetPlayerCameraPos(playerid, n1X, n1Y, posCam[playerid][2] + Height);
		SetPlayerCameraLookAt(playerid, posCam[playerid][0],posCam[playerid][1],posCam[playerid][2]+1);
		SetPlayerFacingAngle(playerid, Degree[playerid] - 270.0);
		ApplyAnimation(playerid, "PED", "gang_gunstand", 4.1, 1, 1, 1, 1, 1, 1);
		SetPVarInt(playerid,"Selfie",1);
		SetPVarInt(playerid,"selfie_knopka",1);
	}
	else
	{
		TogglePlayerControllable(playerid,1);
		SetCameraBehindPlayer(playerid);
		RemovePlayerAttachedObject(playerid, 0);
		ApplyAnimation(playerid, "PED", "ATM", 4.1, 0, 1, 1, 0, 1, 1);
		DeletePVar(playerid,"Selfie");
		DeletePVar(playerid,"selfie_knopka");
	}
}


