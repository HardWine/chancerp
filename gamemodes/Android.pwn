CMD:getcar(playerid) {
	if(IsPlayerPremiumAccount(playerid) == true) {


		if(GetPVarInt(playerid,"GetCarFlood") > gettime()) {
			SendClientMessage(playerid, -1, ""COLOR_RED"Нельзя использовать так часто!");
			return 1;
		}

		SetPVarInt(playerid,"GetCarFlood",gettime() + 60);

		if(IsValidVehicle(caridhouse[playerid])) {

		if(GetPlayerInterior(playerid) == 0 && GetPlayerVirtualWorld(playerid) == 0) {

			if(IsPlayerInAnyVehicle(playerid)) return SendClientMessage(playerid, -1, ""COLOR_RED"Вы уже в транспорте!");
			new Float:vehicle_health;
			GetVehicleHealth(caridhouse[playerid], vehicle_health);
			if(vehicle_health < 370)
			{
				return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Транспорт значительно повреждение. Данное действие недоступно");
			}

			new Float:x_car,
				Float:y_car,
				Float:z_car;

			GetVehiclePos(caridhouse[playerid], Float:x_car, Float:y_car, Float:z_car);

			new Float:x_p,
				Float:y_p,
				Float:z_p,
				Float:a_p;

			GetPlayerPos(playerid, Float:x_p, Float:y_p, Float:z_p);
			GetPlayerFacingAngle(playerid, Float:a_p);

			SetPVarInt(playerid, "enter_vehicleid", caridhouse[playerid]);
			SetVehiclePos(caridhouse[playerid], Float:x_p, Float:y_p, Float:z_p);
			SetVehicleZAngle(caridhouse[playerid], Float:a_p);

			SetPlayerChatBubble(playerid,""COLOR_ORANGE"Premium игрок",C_PURPLE,30.0,3000);

			SendClientMessage(playerid, -1, ""COLOR_GREEN"Транспорт перемещен");
			PutPlayerInVehicle(playerid, caridhouse[playerid], 0);

		} else {
			SendClientMessage(playerid, -1, ""COLOR_RED"Перемещение транспорта в интерьер невозможно");
		}

		} else {
			SendClientMessage(playerid, -1, ""COLOR_RED"Личный транспорт не заспавнен. Перемещение невозможно");
		}
	} else {
		SendClientMessage(playerid, -1, ""COLOR_RED"Функция доступна только игрокам с премиум-аккаунтом");
	}
	return 1;
}

