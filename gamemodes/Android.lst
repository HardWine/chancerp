stock GetDistanceBetweenPlayerz(playerid, targetid, Float:distance) {
	if(!IsPlayerConnected(playerid) || !IsPlayerConnected(targetid)) {
		return 0;
	}
	new Float: pos_x,
		Float: pos_y,
		Float: pos_z;
	GetPlayerPos(targetid, pos_x, pos_y, pos_z);
	new Float: result = GetPlayerDistanceFromPoint(playerid, pos_x, pos_y, pos_z);
	if(floatcmp(result, distance) == -1) {
		return 1;
	} else {
		return 0;
	}
}

stock ProxDetector(playerid, Float:max_range, color, string[]) {
	new
		Float: pos_x,
		Float: pos_y,
		Float: pos_z,
		world;

	GetPlayerPos(playerid, pos_x, pos_y, pos_z);
	world = GetPlayerVirtualWorld(playerid);

	for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i=Iterator@Player [_: i])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);)
	{
		if (!IsPlayerStreamedIn(playerid, i) || world != GetPlayerVirtualWorld(i)) {
			continue;
		}
		new DistanceToParam = GetDistanceBetweenPlayerz(playerid, i, max_range);
		if(DistanceToParam != 1) {
			continue;
		}

		SendClientMessage(i, color, string);
	}
	return SendClientMessage(playerid, color, string);
}

stock ShowAction(const playerid, const text[])
{
	new string[160];
	format(string, sizeof(string), "%s %s", PlayerInfo[playerid][pName], text);
	ProxDetector(playerid, (20.00), 0xDD90FFFF, string);

	format(string, sizeof(string), "%s", text);
	string[0] = toupper(string[0]);
	SetPlayerChatBubble(playerid, string, 0x6de64eFF, (20.00), 3000);
	return true;
}

