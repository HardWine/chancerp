enum 
{
	E_LOG_MONEY_GIVE = 1,
	E_LOG_MONEY_REMOVE,
	E_LOG_BANK_GIVE,
	E_LOG_BANK_REMOVE,
};

stock AddPlayerLog(const playerid, const log_type, const format_string[], {_,Language,Bit,Text,Menu,Style,XML,Bintree,Group,Timer,File,Float,Text3D}:...)
{
	va_format(small_string, sizeof(small_string), format_string, YVA2_DummyPush((3) * 4));

	mysql_format(database, 
		big_string, sizeof(big_string), 
		"INSERT INTO `player_log` (`PlayerID`, `Action`, `Text`) VALUES (%i, %i, '%e');", 
		PlayerInfo[playerid][pID],
		log_type,
		small_string
	);
	printf(big_string);
	mysql_pquery(database, big_string);
}

