CMD:craft(playerid) {
	if(IsAGang(playerid)) {
		ShowPlayerDialog(playerid, dCraft, DIALOG_STYLE_LIST, "Сборка оружия", "{FFFFFF}Собрать петарду\nСобрать гранату\nСобрать динамит", "Выбрать", "Закрыть");
	}
}
stock CraftExplosions(playerid, explosion) {
	switch(explosion) {
		case 1: {
			if(PlayerInfo[playerid][pStuff] > 1) {
				SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы успешно собрали петарду из 2 материалов");
				PlayerInfo[playerid][pStuff] -= 2;
				SetPlayerInt(playerid, "Stuff", PlayerInfo[playerid][pStuff]);
				PlayerInfo[playerid][pPetard] += 1;
				SetPlayerInt(playerid, "Petard", PlayerInfo[playerid][pPetard]);				
			}
			else SendClientMessage(playerid, -1, ""COLOR_RED"Для сборки петарды необходимо 2 материала");
		}
		case 2: {
			if(PlayerInfo[playerid][pStuff] > 4) {
				SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы успешно собрали гранату из 5 материалов");
				PlayerInfo[playerid][pStuff] -= 5;
				SetPlayerInt(playerid, "Stuff", PlayerInfo[playerid][pStuff]);
				PlayerInfo[playerid][pGrenade] += 1;
				SetPlayerInt(playerid, "Grenade", PlayerInfo[playerid][pGrenade]);	
			}
			else SendClientMessage(playerid, -1, ""COLOR_RED"Для сборки гранаты необходимо 5 материалов");
		}
		case 3: {
			if(PlayerInfo[playerid][pStuff] > 9) {
				SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы успешно собрали динамит из 10 материалов");
				PlayerInfo[playerid][pStuff] -= 10;
				SetPlayerInt(playerid, "Stuff", PlayerInfo[playerid][pStuff]);
				PlayerInfo[playerid][pDynamite] += 1;
				SetPlayerInt(playerid, "Dynamite", PlayerInfo[playerid][pDynamite]);	
			}
			else SendClientMessage(playerid, -1, ""COLOR_RED"Для сборки динамита необходимо 10 материалов");
		}
		default: return 1;
	}
	return 1;
}

stock LoadShrooms() {
	for(new i = 0; i < MAX_SHROOMS; i++) {
		ShroomPickup[i] = CreateDynamicPickup(1603, 2, Shroom[i][ShroomX], Shroom[i][ShroomY], Shroom[i][ShroomZ]-0.35, 0, 0);
	}
}
CMD:rw(playerid) {
	if(GetPlayerAdminLevel(playerid) < 6) return 1;
	weather = RandomEx(0,20);
	//SetWeather(weather);
	return 1;
}
CMD:eat(playerid) {
		if(IsPlayerInAnyVehicle(playerid)) return SendClientMessage(playerid, -1, "Нельзя использовать в транспорте");
		if(GetPVarInt(playerid,"AntiFloodMLocal") > gettime()){ SendClientMessage(playerid, -1, ""COLOR_RED"Нельзя использовать так часто"); return false; }
		SetPVarInt(playerid,"AntiFloodMLocal",gettime() + 60);
		if(PlayerInfo[playerid][pShroom] < 1) return SendClientMessage(playerid, -1, "У вас нет ничего съедобного");
		PlayerInfo[playerid][pShroom] -= 1;
		SetPlayerInt(playerid, "Shroom", PlayerInfo[playerid][pShroom]);
		new Float:health;
		GetPlayerHealth(playerid, Float:health);
		health += 25.0;
		if(health > 100) health = 100;
		SetPlayerHealth(playerid, health);
		PlayerInfo[playerid][pHunger] += 5;
		SetPlayerInt(playerid, "Hunger", PlayerInfo[playerid][pHunger]);
		SetPlayerChatBubble(playerid, "скушал(а) гриб", C_PURPLE, 30.0, 5000);
		ClearPlayerAnimation(playerid);
		ApplyAnimation(playerid,"PED","GUM_EAT",4.1,0,0,0,0,0,1);
		format(small_string, sizeof(small_string), "%s скушал(а) гриб", PlayerInfo[playerid][pName]);
		ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_PURPLE, small_string);
		new druggy = RandomEx(0,15);
		if(druggy == 15) {
			SetPlayerHealth(playerid, 150);
			SetPlayerWeather(playerid, -68);
			DrugTimer[playerid] = KillTimer(DrugTimer[playerid]);
			DrugTimer[playerid] = SetTimerEx("DrugsEffect", 30000, false, "i", playerid);
			SetPlayerDrunkLevel(playerid, 6000);
			SendClientMessage(playerid, -1, ""COLOR_ORANGE"Гриб оказался псилоцибиновым!");
		}
		if(PlayerInfo[playerid][pShroom] > 0) {
			format(small_string, sizeof(small_string), ""COLOR_BLUE"Грибов осталось: {ffffff}%d", PlayerInfo[playerid][pShroom]);
			SendClientMessage(playerid, -1, small_string);
		}
		else SendClientMessage(playerid, -1, ""COLOR_RED"Грибы закончились");
		return 1;
}

CMD:sellshroom(playerid) {
	if(!IsPlayerInRangeOfPoint(playerid, 10, 1081.24, -1696.78, 13.55)) return SendClientMessage(playerid, -1, ""COLOR_RED"Необходимо находиться у ресторана (/gps - Другие места)");
	
	if(PlayerInfo[playerid][pShroom] > 0) {
	new total = 0;
	new bad = 0;
	new sum_shroom = PlayerInfo[playerid][pShroom];
	for(new i = 1; i < sum_shroom; i++) {
		if(RandomEx(1,20) == 1) bad += 1;
		else {
			total += 5;
			if(RandomEx(1,10) == 1) total += RandomEx(1,20);
		}
	}
	if(bad != 0) {
		format(small_string, sizeof(small_string), ""COLOR_RED"Всего %d грибов оказались испорченными", bad);
		SendClientMessage(playerid, -1, small_string);
	}
	SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы успешно продали все свои грибы ресторану");
	format(small_string, sizeof small_string, "~g~+%d EXP", total);
	GameTextForPlayer(playerid, small_string, 3500, 0);
	if(IsPlayerPremiumAccount(playerid) == true || X2_STATUS == 1) {
		total = total * 2;
	}
	AddPlayerEXP(playerid, total, "Продажа %i грибов", sum_shroom);

	PlayerInfo[playerid][pShroom] = 0;
	SetPlayerInt(playerid, "Shroom", PlayerInfo[playerid][pShroom]);
	}
	return 1;
}
CMD:marry(playerid, params[]) {

	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, -1, "Используйте: /marry [id игрока]");
	if(params[0] == INVALID_PLAYER_ID) return 1;

	if(PlayerInfo[playerid][pBirth] == 0) return SendClientMessage(playerid, -1, "У Вас нет паспорта! Получить его можно у сотрудников мэрии");
	if(PlayerInfo[params[0]][pBirth] == 0) return SendClientMessage(playerid, -1, "У партнера нет паспорта! Получить его можно у сотрудников мэрии");

	if(!IsPlayerInRangeOfPoint(playerid, 10, 368.9543,2323.9968,1890.6047)) return SendClientMessage(playerid, -1, ""COLOR_RED"Необходимо находиться в церкви (/gps - Общественные места)");
	
	if(GetDistanceBetweenPlayerz(playerid, params[0], 5.00) != 1) return SendClientMessage(playerid, -1, ""COLOR_RED"Вы должны встать перед игроком");

	new player_sex = PlayerInfo[playerid][pSex];
	new target_sex = PlayerInfo[params[0]][pSex];

	if(PlayerInfo[params[0]][pMarried] == 0) {
		if(player_sex == target_sex) return SendClientMessage(playerid, -1, ""COLOR_RED"Необходимо выбрать игрока противоположного пола");
		if(CheckCash(playerid, 5000) == false) return SendClientMessage(playerid, -1, ""COLOR_RED"Недостаточно средств. Пополните счет");
		RemovePlayerEXP(playerid, 5000, "Процесс бракосочетания. Апонент %s", PlayerInfo[params[0]][pName]);
		format(small_string, sizeof(small_string), "%s предлагает %s руку и сердце", PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName]);
		ProxDetector(playerid, 20, C_PURPLE, small_string);
		SetPVarInt(params[0], "marryoffer", playerid);
		format(small_string, sizeof(small_string), ""COLOR_BLUE"%s предлагает вам руку и сердце. Согласиться: {FFFFFF}/yes", PlayerInfo[playerid][pName]);
		SendClientMessage(params[0], -1, small_string);
	}
	else SendClientMessage(playerid, -1, ""COLOR_RED"Данный игрок уже находится в браке. Чтобы развестись:{FFFFFF} /divorce");
	return 1;
}
CMD:yes(playerid) {

	new offerid = GetPVarInt(playerid, "marryoffer");

	if(offerid == INVALID_PLAYER_ID) return 1;
	if(!IsPlayerInRangeOfPoint(playerid, 10, 368.9543,2323.9968,1890.6047)) return SendClientMessage(playerid, -1, ""COLOR_RED"Необходимо находиться в церкви (/gps - Общественные места)");
	if(GetDistanceBetweenPlayerz(playerid, offerid, 5.00) != 1) return SendClientMessage(playerid, -1, ""COLOR_RED"Вы должны встать перед игроком");

	format(small_string, sizeof(small_string), "{FF23EC}Поздравляем %s и %s! Они связали себя узами брака", PlayerInfo[playerid][pName],PlayerInfo[offerid][pName]);
	SendClientMessageToAll(-1, small_string);

	format(small_string, sizeof(small_string), "%s и %s обменялись обручальными кольцами", PlayerInfo[playerid][pName], PlayerInfo[offerid][pName]);
	ProxDetector(playerid, 20, C_PURPLE, small_string);

	PlayerInfo[playerid][pMarried] = 1;
	PlayerInfo[offerid][pMarried] = 1;
	SetPlayerInt(playerid, "Married", PlayerInfo[playerid][pMarried]);
	SetPlayerInt(offerid, "Married", PlayerInfo[offerid][pMarried]);
	PlayerInfo[playerid][pPartner] = EOS;
	PlayerInfo[offerid][pPartner] = EOS;
	strins(PlayerInfo[playerid][pPartner], PlayerInfo[offerid][pName], 0);
	strins(PlayerInfo[offerid][pPartner], PlayerInfo[playerid][pName], 0);
	new Query[128];
	mysql_format(database, Query, sizeof(Query), "UPDATE `players` SET Partner = '%e' WHERE Name = '%e' LIMIT 1", PlayerInfo[playerid][pPartner],PlayerInfo[playerid][pName]);
	mysql_pquery(database, Query, "", "");
	new Query2[128];
	mysql_format(database, Query2, sizeof(Query2), "UPDATE `players` SET Partner = '%e' WHERE Name = '%e' LIMIT 1", PlayerInfo[offerid][pPartner],PlayerInfo[offerid][pName]);
	mysql_pquery(database, Query2, "", "");
	return 1;
}
CMD:divorce(playerid) {
	if(PlayerInfo[playerid][pMarried] == 0) return 1;

	if(!IsPlayerInRangeOfPoint(playerid, 10, 368.9543,2323.9968,1890.6047)) return SendClientMessage(playerid, -1, ""COLOR_RED"Необходимо находиться в церкви (/gps - Общественные места)");
	PlayerInfo[playerid][pMarried] = 0;
	SetPlayerInt(playerid, "Married", PlayerInfo[playerid][pMarried]);
	SendClientMessage(playerid, -1, ""COLOR_RED"Вы вышли из брака");
	new partner = _ReturnPlayerID(PlayerInfo[playerid][pPartner]);
	if(partner == INVALID_PLAYER_ID) {
	new Query[128];
	mysql_format(database, Query, sizeof(Query), "UPDATE `players` SET Married = '0' WHERE Name = '%e' LIMIT 1", PlayerInfo[playerid][pPartner]);
	mysql_pquery(database, Query, "", "");
	}
	else {
	PlayerInfo[partner][pMarried] = 0;
	SetPlayerInt(partner, "Married", PlayerInfo[partner][pMarried]);
	SendClientMessage(partner, -1, ""COLOR_RED"Ваш партнер предпочел развестись с вами");		
	}
	return 1;
}
stock _ReturnPlayerID(name[])
{
/*
 * Функция для определения ID Пользователя по его NickName/ID.
 * Использование: 
 *              _ReturnPlayerID("Player");
 */
        if ((name[0] >= 'a' || name[0] >= 'A') && (name[0] <= 'z' || name[0] <= 'Z')) {
                for (new i = 0; i < GetMaxPlayers(); i++) {
                        if (IsPlayerConnected(i)) {
                                new uName[MAX_PLAYER_NAME];
                                GetPlayerName(i, uName, sizeof(uName));
                                if (strcmp(uName, name, false, strlen(uName) + strlen(name)) == 0) {
                                        return i;
                                }
                        }       
                }
        }
        return INVALID_PLAYER_ID;
}
CMD:adv(playerid) 
{
	if(PlayerInfo[playerid][pDevice] == 0) {
		return SendClientMessage(playerid, -1, ""COLOR_RED"Вам нужен пейджер или телефон. Купите его в магазине");
	}
	if(PlayerSIMCardNumber[playerid] == INVALID_SIM_CARD_NUMBER) {
		return SendClientMessage(playerid, -1, ""COLOR_RED"У вас нет SIM-карты");
	}

    for(new i = 0; i < 19; i++) 
    { 
        if(!strcmp(AllAd[i][0], "-", true, 10 )) // если -, то свободно  
        { 
            SetPVarInt(playerid, "AD",i); 
            format(big_string, sizeof(big_string), "{ffffff}Введите текст вашего объявления\n"COLOR_GREEN"Стоимость 1 введеного символа: {FFFFFF}%d EXP",
            	EXP_PER_SYM
            );
            return ShowPlayerDialog(playerid, dTypeAdvert, DIALOG_STYLE_INPUT, "Объявление", big_string, "Отправить", "Закрыть"); 
        }
    } 
	SendClientMessage(playerid, -1, ""COLOR_RED"Очередь объявлений занята. Попробуйте позже");
    return 1;
}
CMD:edit(playerid) {
	if(GetPlayerFraction(playerid) != FRACTION_NEWS) return 1;
	if(GetPlayerJobDayStatus(playerid) == false)
	{
		return SendClientMessage(playerid, -1, MSG_START_JOB_DAY);
	}
	if(PlayerInfo[playerid][pRank] < 2) return SendClientMessage(playerid, -1, "Редактировать объявления можно со 2 ранга");

	if(!IsPlayerInRangeOfPoint(playerid, 40, 1175.2021,-1180.5349,87.0787)) {
		if(!IsPlayerInRangeOfPoint(playerid, 40, 927.6644,-1677.8931,1349.5969)) {
			new vehicle_owner;
			for(new i = 0; i < sizeof(VehicleInfo); i++) {
			if(VehicleInfo[i][VI_VehicleID] == GetPlayerVehicleID(playerid)) {
			vehicle_owner = VehicleInfo[i][VI_Owner];
			}
			}
			if(vehicle_owner != VO_FRACTION_NEWS) {
			return SendClientMessage(playerid, -1, "Необходимо находится в офисе San News или в фракционном транспорте");
			}
		}
	}

	new sctring[3000],str[144]; 
	if(Platform[playerid] == 1) {
	    for(new i = 0; i < 19; i++) 
	    {
	        if(strval(AllAd[i][2]) == 0 && strcmp(AllAd[i][0], "-", true, 10 )) { format(str, 144,"{ffffff}%d. Отправитель: %s"COLOR_GREEN" [Ожидает]\n",i+1,AllAd[i][0]); strcat(sctring,str); } 
	        else if(strval(AllAd[i][2]) == 1 && strcmp(AllAd[i][0], "-", true, 10 )) { format(str, 144,"{ffffff}%d. Отправитель: %s"COLOR_RED" [На проверке]\n",i+1,AllAd[i][0]); strcat(sctring,str); }  
	        if(!strcmp(AllAd[i][0], "-", true, 10 )) { format(str, 144,"%d. Отсутствует\n",i+1); strcat(sctring,str); } 
	    }
    	return SPD(playerid,dEditAdvert,DIALOG_STYLE_LIST,"Проверка объявлений",sctring,"Проверка","Отмена"); 
    }
    else {
		for(new i; i < 19; i++) 
	    {
	    	SendClientMessage(playerid, -1, ""COLOR_RED"");
	        if(strval(AllAd[i][2]) == 0 && strcmp(AllAd[i][0], "-", true, 10 )) { format(str, 144,"{ffffff}%d. Отправитель: %s"COLOR_GREEN" [Ожидает]\n",i+1,AllAd[i][0]); strcat(sctring,str); } 
	        else if(strval(AllAd[i][2]) == 1 && strcmp(AllAd[i][0], "-", true, 10 )) { format(str, 144,"{ffffff}%d. Отправитель: %s"COLOR_RED" [На проверке]\n",i+1,AllAd[i][0]); strcat(sctring,str); }  
	        if(!strcmp(AllAd[i][0], "-", true, 10 )) { format(str, 144,"{ffffff}%d. Отсутствует\n",i+1); strcat(sctring,str); } 
	    }    	
    }
    return SPD(playerid,dEditAdvertAdaptive,DIALOG_STYLE_INPUT,"Проверка объявлений",sctring,"Проверка","Отмена"); 
}

forward SendADList();
public SendADList() 
{ 
    if(strlen(adlist[0][0]) < 2) return SetTimer("SendADList",15*1000,0); 
    format(small_string, sizeof small_string, "[Объявление]{55B94E} %s", adlist[0][0]); 
    foreach(new i: Player) {
		if(GetPVarInt(i, "fm")) continue;
		SendClientMessage(i, -1, small_string);
	}
    new senderid = _ReturnPlayerID(adlist[0][1]);
    new senderstring[24];
    new editorid = _ReturnPlayerID(adlist[0][2]);
    new editorstring[24];

	if(senderid != INVALID_PLAYER_ID) {
	format(senderstring, 24, "[%d] (тел. %i)", senderid, PlayerSIMCardNumber[senderid]);
	} else {
	format(senderstring, 24, "[?]");
	}

	if(editorid != INVALID_PLAYER_ID) {
	format(editorstring, 24, "[%d]", editorid);
	} else {
	format(editorstring, 24, "[?]");
	}

    format(small_string, sizeof small_string, "{55B94E}Отправитель: {FFFFFF}%s%s {55B94E}Редактор: {FFFFFF}%s%s", adlist[0][1], senderstring, adlist[0][2], editorstring); 
    foreach(new i: Player) {
		if(GetPVarInt(i, "fm")) continue;
		SendClientMessage(i, -1, small_string);
	}
    adlist[0][0] = adlist[1][0], adlist[0][1] = adlist[1][1], adlist[0][2] = adlist[1][2];
    adlist[1][0] = adlist[2][0], adlist[1][1] = adlist[2][1], adlist[1][2] = adlist[2][2]; 
    adlist[2][0] = adlist[3][0], adlist[2][1] = adlist[3][1], adlist[2][2] = adlist[3][2]; 
    adlist[3][0] = adlist[4][0], adlist[3][1] = adlist[4][1], adlist[3][2] = adlist[4][2]; 
    adlist[4][0] = adlist[5][0], adlist[4][1] = adlist[5][1], adlist[4][2] = adlist[5][2]; 
    adlist[5][0] = adlist[6][0], adlist[5][1] = adlist[6][1], adlist[5][2] = adlist[6][2]; 
    adlist[6][0] = adlist[7][0], adlist[6][1] = adlist[7][1], adlist[6][2] = adlist[7][2]; 
    adlist[7][0] = adlist[8][0], adlist[7][1] = adlist[8][1], adlist[7][2] = adlist[8][2]; 
    adlist[8][0] = adlist[9][0], adlist[8][1] = adlist[9][1], adlist[8][2] = adlist[9][2]; 
    adlist[9][0] = "0"; 
    return SetTimer("SendADList",15*1000,0); 
}
stock ShowEditOptions(playerid) {
	if(Platform[playerid] == 1) {
		return ShowPlayerDialog(playerid,dEditAdvertOption,DIALOG_STYLE_LIST, "Редактирование объявления","1. {FFFFFF}Редактировать объявление\n2. {FFFFFF}Отправить объявление\n3. {FFFFFF}Пожаловаться","Продолжить","Назад");	
	}
	else {
		ShowPlayerDialog(playerid, dEditAdvertOptionAdaptive, DIALOG_STYLE_INPUT, "Редактирование объявления","1. Редактировать объявление\n2. Отправить объявление\n3. Пожаловаться\n\n"COLOR_BLUE"Введите номер пункта, для продолжения","Продолжить","Назад");
	}
	return 1;
}
CMD:cars(playerid) {
	new house = GetPVarInt(playerid, "PlayerHouse");
	switch(HouseInfo[house][hClass]) {
		case 2..5: {
			if(GetPVarInt(playerid, "CarOffer") == -1 || GetPVarInt(playerid, "OfferPrice") == -1) {
				format(big_string, sizeof(big_string), "{ffffff}1."COLOR_BLUE" %s {ffffff}(%d км.)\n2."COLOR_BLUE" %s {ffffff}(%d км.)",
					GetVehicleText(PlayerInfo[playerid][pCar]), PlayerInfo[playerid][pMileage]/1000, GetVehicleText(PlayerInfo[playerid][pCar2]), PlayerInfo[playerid][pMileage2]/1000
				);
				return ShowPlayerDialog(playerid, dSelectCar, DIALOG_STYLE_MSGBOX, "Выбор транспорта", big_string, ">> 1 <<", ">> 2 <<");
			} else return 1;
		}
		default: {
			SendClientMessage(playerid, -1, "Использовать два автомобиля можно только с домом не ниже среднего класса!");
		}
	}
	return 1;
}
CMD:stats(playerid, params[]) {
	if(sscanf(params, "d",params[0])) return ShowStats(playerid, playerid);
	if(GetPVarInt(params[0], !"spec") == 1) return SendClientMessage(playerid, -1, ""COLOR_RED"Вы слишком далеко от указанного игрока");
	if(GetDistanceBetweenPlayerz(playerid, params[0], 2.00) != 1) return SendClientMessage(playerid, -1, ""COLOR_RED"Вы слишком далеко от указанного игрока");
	if(PlayerLogged{params[0]} == false || !IsPlayerConnected(params[0])) return SendClientMessage(playerid, -1, "Игрок не авторизован");
	ShowStats(params[0], playerid);
	return 1;
}
CMD:pass(playerid, params[])
{
	if(PlayerInfo[playerid][pBirth] == 0) return SendClientMessage(playerid, -1, "У Вас нет паспорта! Получить его можно у сотрудников мэрии");
	if(sscanf(params, "d",params[0])) return ShowPass(playerid, playerid);
	if(GetPVarInt(params[0], !"spec") == 1) return SendClientMessage(playerid, -1, ""COLOR_RED"Вы слишком далеко от указанного игрока");
	if(GetDistanceBetweenPlayerz(playerid, params[0], 2.00) != 1) return SendClientMessage(playerid, -1, ""COLOR_RED"Вы слишком далеко от указанного игрока");
	if(PlayerLogged{params[0]} == false || !IsPlayerConnected(params[0])) return SendClientMessage(playerid, -1, "Игрок не авторизован");
	format(small_string, sizeof(small_string), "%s предъявил(а) паспорт %s", PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName]);
	ProxDetector(playerid, 20, C_PURPLE, small_string);
	ShowPass(params[0], playerid);
	if(GetPlayerFraction(params[0]) == FRACTION_LSPD && PlayerInfo[playerid][pShowed] == 0 && params[0] != playerid) {

		IncreaseStatus(params[0], 1); 

		AddPlayerAchievement(params[0], E_COPS_IN);
		PlayerInfo[playerid][pShowed] = 1;
		SetPlayerInt(playerid, "Showed", PlayerInfo[playerid][pShowed]);
	}
	return 1;
}
CMD:lic(playerid, params[]) {
	if(sscanf(params, "d",params[0])) return ShowLicenses(playerid, playerid);
	if(GetPVarInt(params[0], !"spec") == 1) return SendClientMessage(playerid, -1, ""COLOR_RED"Вы слишком далеко от указанного игрока");
	if(GetDistanceBetweenPlayerz(playerid, params[0], 2.00) != 1) return SendClientMessage(playerid, -1, ""COLOR_RED"Вы слишком далеко от указанного игрока");
	
	format(small_string, sizeof(small_string), "%s предъявил(а) лицензии %s", PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName]);
	ProxDetector(playerid, 20, C_PURPLE, small_string);
	if(PlayerLogged{params[0]} == false || !IsPlayerConnected(params[0])) return SendClientMessage(playerid, -1, "Игрок не авторизован");
	ShowLicenses(params[0], playerid);
	return 1;
}
CMD:passport(playerid, params[]) {
	new Fraction: fractionid = GetPlayerFraction(playerid);

	if(!IsPlayerInRangeOfPoint(playerid, 80, 1481.4032,-1747.0007,479.2806)) return SendClientMessage(playerid, -1, ""COLOR_RED"Необходимо находиться в здании Мэрии!");	
	

	if(fractionid == FRACTION_GOVERMENT) {
		if(PlayerInfo[playerid][pRank] < 8) return SendClientMessage(playerid, -1, ""COLOR_RED"Доступно только после достижения 8 ранга");	
		if(GetPlayerJobDayStatus(playerid) == false)
		{
			return SendClientMessage(playerid, -1, MSG_START_JOB_DAY);
		}
		if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, -1, "Используйте: /passport [id игрока]");

		if(PlayerInfo[params[0]][pBirth] != 0) return SendClientMessage(playerid, -1, ""COLOR_RED"Данный игрок уже получил паспорт");

		if(params[0] == playerid) return SendClientMessage(playerid, -1, "Нельзя выдать паспорт самому себе!");

		if(GetDistanceBetweenPlayerz(playerid, params[0], 5.00) != 1) return SendClientMessage(playerid, -1, ""COLOR_RED"Вы слишком далеко от указанного игрока");

		format(small_string, sizeof(small_string), "%s начал(а) заполнять документы на выдачу паспорта", PlayerInfo[playerid][pName]);
		ProxDetector(playerid, 20, C_PURPLE, small_string);

		SetPVarInt(playerid, "player_passport", params[0]);
		SetPVarInt(params[0], "player_passport", playerid);

		ShowPlayerDialog(playerid, dGetPassport, DIALOG_STYLE_INPUT, "Выдача паспорта", "{FFFFFF}Введите дату рождения горожанина", "Выбрать", "Закрыть");
	}
	return 1;
}


forward SendFamilyMessage(Fraction:family, color, string[]);
public SendFamilyMessage(Fraction:family, color, string[])
{
	foreach(new i: Player)
	{
		if(GetPlayerFraction(i) == family)
		{
			SendClientMessage(i, color, string);
		}
	}
}

forward SendAdminMessage(color, string[]);
public SendAdminMessage(color, string[])
{
	foreach(new i: Admin) {
		SendClientMessage(i, color, string);
	}
}

forward SendAdminMessageAC(color, string[]);
public SendAdminMessageAC(color, string[])
{
	foreach(new i: Admin) {
		if(GetPVarInt(i, "dis_ac_warning") == 1) continue;
		SendClientMessage(i, color, string);
	}
}

CMD:acout(playerid) {
	if(GetPlayerAdminLevel(playerid) > 4) {
		if(GetPVarInt(playerid, "ac_output") == 0) {
			SetPVarInt(playerid, "ac_output", 1);
			SendClientMessage(playerid, -1, ""COLOR_GREEN"Вывод срабатываний включен");
		} else {
			DeletePVar(playerid, "ac_output");
			SendClientMessage(playerid, -1, ""COLOR_RED"Вывод срабатываний отключен");
		}
	}
	return 1;
}

forward SendAdminMessageAO(color, string[]);
public SendAdminMessageAO(color, string[])
{
	foreach(new i: Admin) {
		if(GetPVarInt(i, "ac_output") == 1) {
			SendClientMessage(i, color, string);
		}
	}
}

forward SendHelperMessage(color, string[]);
public SendHelperMessage(color, string[])
{
	foreach(new i: Helper) {
		SendClientMessage(i, color, string);
	}
}


forward SendJudgeMessageToAll(string[], getid);
public SendJudgeMessageToAll(string[], getid)
{
	if(getid != -1) SendClientMessage(getid, -1, string);
	foreach(new i: Player)
	{
		if(PlayerInfo[i][pAdmAdv] == 1 || GetPlayerAdminLevel(i) != 0)
		{
			SendClientMessage(i, -1, string);
		}
	}
}

CMD:armydoc(playerid, params[]) {
	new Fraction: fractionid = GetPlayerFraction(playerid);
	if(fractionid == FRACTION_ARMY) {
		if(GetPlayerJobDayStatus(playerid) == false)
		{
			return SendClientMessage(playerid, -1, MSG_START_JOB_DAY);
		}

		if(PlayerInfo[playerid][pRank] < 9) return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Выдавать военный билет можно с 9 ранга");	
		if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, -1, "Используйте: /armydoc [id]");
		if(GetDistanceBetweenPlayerz(playerid, params[0], 2.00) != 1) return SendClientMessage(playerid, -1, ""COLOR_RED"Вы слишком далеко от указанного игрока");
		if(GetPlayerFraction(params[0]) == FRACTION_ARMY) {
			if(PlayerInfo[params[0]][pArmyDoc] == 1) return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Служащий уже получил свой билет");
			PlayerInfo[params[0]][pArmyDoc] = 1;
			SetPlayerInt(params[0], "ArmyDoc", PlayerInfo[params[0]][pArmyDoc]);
			SendClientMessage(params[0], -1, ""COLOR_GREEN"Поздравляем! Вы получили военный билет!");
			SendClientMessage(playerid, -1, "Военный билет выдан");
		} else {

			return SendClientMessage(playerid, -1, "Персонаж не является военнослужащим");
		}
	}
	return 1;
}
CMD:heal(playerid, params[]) {
	if(GetPVarInt(playerid,"AntiFloodHeal") > gettime()){ SendClientMessage(playerid, -1, "Подождите немного"); return false; }
	SetPVarInt(playerid,"AntiFloodHeal",gettime() + 30);
	if(GetPVarInt(playerid, "Paramedic") != 1) return 1;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, -1, "Используйте: /heal [id]");
	if(params[0] == playerid) return 1;
	if(GetDistanceBetweenPlayerz(playerid, params[0], 2.00) != 1) return SendClientMessage(playerid, -1, ""COLOR_RED"Вы слишком далеко от указанного игрока");
	SetPlayerHealth(params[0], 100.0);
	SendClientMessage(params[0], -1, ""COLOR_GREEN"Вы были вылечены");
	GameTextForPlayer(params[0], "~g~100 HP", 2000, 1);
	GameTextForPlayer(playerid, "~b~Good Job!", 2000, 1);
	SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы вылечили человека");
	return 1;
}
CMD:exitjob(playerid) {
	if(GetPVarInt(playerid, "Paramedic") == 1) {
		DeletePVar(playerid, "Paramedic");
		SetPVarInt(playerid, "tempjob", 0);
		CBackSkin(playerid);
		SendClientMessage(playerid, -1, "Вы завершили работу волонтера в Госпитале");
	}
}
DialogCreate:JOB_PARAMEDIC(playerid) {
return Dialog_Open(playerid, Dialog:JOB_PARAMEDIC, DIALOG_STYLE_MSGBOX,
        "Подработка",
        ""COLOR_WHITE"Нам в больницу требуются волонтеры, готовые помогать людям.\nБрать плату или нет это полностью ваш выбор\n\nСогласны?",
        "Да", "Нет");
}
DialogResponse:JOB_PARAMEDIC(playerid, response, listitem, inputtext[]) {
	if(!response) {
		return 1;
	}
	if(response) {
		new Fraction:player_frac = GetPlayerFraction(playerid);
		if(player_frac == FRACTION_ARMY 
		|| player_frac == FRACTION_LSPD 
		|| player_frac == FRACTION_GOVERMENT 
		|| player_frac == FRACTION_FBI) { 
			SetPVarInt(playerid, "Paramedic", 1);
			SetPVarInt(playerid, "tempjob", 11);
			if(PlayerInfo[playerid][pSex] != 0) {
				SetPlayerSkin(playerid, 308);
			} else {
				SetPlayerSkin(playerid, 275);
			}
			SetPlayerColor(playerid, 0xFF91CCFF);
			SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы устроились парамедиком. Работа будет окончена после выхода из игры");
			SendClientMessage(playerid, -1, ""COLOR_GREEN"Используйте (/heal [id]) чтобы поправить здоровье указанного игрока");
		} else {
		return SendClientMessage(playerid, -1, "Доступно только сотрудникам гос. фракций");
		}
	}
	return 1;
}
CMD:giveweapon(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) < 4) return 1;
    extract params -> new player:targetid, weaponid, ammo; else // sscanf2
        return SendClientMessage(playerid, -1, "Использование: /giveweapon [ID игрока/часть ника] [ID оружия] [кол-во патронов]");
    if (targetid == INVALID_PLAYER_ID)
        return SendClientMessage(playerid, -1, "Игрок не найден.");
    if (weaponid < 1 || weaponid > 46 || weaponid == 19 || weaponid == 20 || weaponid == 21)
        return SendClientMessage(playerid, -1, "Неправильный ID оружия.");
    if (ammo < 0 || ammo > 1000)
        return SendClientMessage(playerid, -1, "Количество патронов должно быть от 1 до 1000.");
    GivePlayerWeapon(targetid, weaponid, ammo);
    new string[128];
    GetPlayerName(targetid, string, sizeof(string));
    format(string, sizeof(string), "Вы выдали игроку %s оружие \"%s\" c %d патронами.", string, weapon_names[weaponid], ammo);
    return SendClientMessage(playerid, -1, string);
}

CMD:mask(playerid, params[]) {
	if(PlayerInfo[playerid][pMask] == 0) return SendClientMessage(playerid, -1, ""COLOR_RED"У вас нет маски");
	PlayerInfo[playerid][pMask] = 0;
	SetPlayerInt(playerid, "Mask", PlayerInfo[playerid][pMask]);
	SetPlayerChatBubble(playerid, "надевает маску", C_PURPLE, 10.0, 2000);
	ApplyAnimation(playerid,"SHOP","ROB_shifty",4.1,0,0,0,0,0,1);
	SetPlayerColor(playerid, 0x7a766700);
	SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы купили и надели маску. Местоположение скрыто");	
	SetPVarInt(playerid, "Hidden", 1);
	return 1;
}
CMD:hunger(playerid) {
	if(PlayerInfo[playerid][pHours] < 3) return SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы недавно начали игру, голод вашего персонажа никак не проявляет себя");
	format(small_string, sizeof(small_string), ""COLOR_ORANGE"Ваша сытость: {FFFFFF}%d/100", PlayerInfo[playerid][pHunger]);
	SendClientMessage(playerid, -1, small_string);
	return 1;
}

public OnPlayerWeaponShot(playerid, weaponid, hittype, hitid, Float:fX, Float:fY, Float:fZ) {
	new bool: isShot = false;

	for(new i = 0; i < sizeof(allowed_weapons); i++) {
		if(weaponid == allowed_weapons[i]) {
			isShot = true;
		}
	}

	if(isShot == false) 
	{
		// SendClientMessage(playerid, -1, "Выстрел запрещен");
		return 0;
	} 
	else 
	{
		return 1;
	}
}
