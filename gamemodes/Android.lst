forward dre_tuning_menu(playerid, response, listitem, inputtext[]); public dre_tuning_menu(playerid, response, listitem, inputtext[]) {
	if(!response) {
		SendClientMessage(playerid, -1, """{FFAF00}""×ňîáű ďîęčíóňü ńĺđâčń íŕćěčňĺ ""{FFFFFF}""EXIT");
		SendClientMessage(playerid, -1, """{FFAF00}""×ňîáű âĺđíóňüń˙ ę ěĺíţ íŕćěčňĺ ""{FFFFFF}""MENU");
		SelectTextDraw(playerid, 0x2A3439FF);
		return 1;
	} else {
		switch(listitem) {
			case 0: {
				Dialog_Show(playerid, #paintjob);
			}			
			case 1: {
				Dialog_Show(playerid, #vynil);
			}
			case 2: {
				new
				    compatible_types[(14)],
				    compatible_types_count;

				GetVehicleCompatibleTypes(GetVehicleModel(caridhouse[playerid]), compatible_types, compatible_types_count);

				if(compatible_types_count == 0) {
					SendClientMessage(playerid, -1, """{ff353c}""Ę ńîćŕëĺíčţ, íŕ âŕř ňđŕíńďîđň äĺňŕëĺé íĺň");
					return Dialog_Show(playerid, #tuning_menu);
				}

				Dialog_Show(playerid, #elements);
			}
			case 3: {
				Dialog_Show(playerid, #radar_buy);
			}
			case 4: {
				SendClientMessage(playerid, -1, "3");
			}
		}
	}
	return 1;
}

forward dre_elements(playerid, response, listitem, inputtext[]); public dre_elements(playerid, response, listitem, inputtext[]) {
	if(!response) {
		return Dialog_Show(playerid, #tuning_menu);
	} else {

		new cats;

		for(new i = 0; i < 14; i++) {
			if(cached_cat[playerid][i] != -1) cats++;
			printf("TYPE: %d | LISTITEM (SLOT):%d", cached_cat[playerid][i], i);
		}
		if(cats == 0) return 1;
		if(listitem >= 0 && listitem <= cats) {
			printf("%d", cached_cat[playerid][listitem]);
			SetPVarInt(playerid, "element_type", cached_cat[playerid][listitem]);
			Dialog_Show(playerid, #elements_cat);
		}
	}
	return 1;
}

