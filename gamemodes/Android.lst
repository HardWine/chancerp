forward pc_cmd_gps(playerid, params[]); public pc_cmd_gps(playerid, params[]) {
	if(Platform[playerid] == 0) return SendClientMessage(playerid, -1, !"Мобильная версия навигатора в разработке");
	if(GetPVarInt(playerid, "Gps_Active") == 1) {
		SendClientMessage(playerid, -1, """{ff353c}""GPS Навигация отключена.");
		HideGpsForPlayer(playerid);
	}
	return Dialog_Show(playerid, #DIALOG_GPS_SHOW_CATEGORY);
}

forward dcr_DIALOG_GPS_SHOW_CATEGORY(playerid); public dcr_DIALOG_GPS_SHOW_CATEGORY(playerid) {
