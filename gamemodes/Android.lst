			#emit LOAD.S.alt iAddress
			#emit FILL       512
			iAddress += 512;
		}
		if (iSize & 256)
		{
			#emit LOAD.S.pri iValue
			#emit LOAD.S.alt iAddress
			#emit FILL       256
			iAddress += 256;
		}
