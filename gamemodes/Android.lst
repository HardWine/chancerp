forward getPayment(playerid);
public getPayment(playerid) {
	PlayerPlaySound(playerid, 40405, 0.0, 0.0, 10.0);
	new distanceRan = floatround(GetPVarFloat(playerid, "DistanceToDestination")); 
	distanceRan = (distanceRan/15); 
	if(distanceRan < 2) return SendClientMessage(playerid, -1, """{ff353c}""Ńóěěŕ çŕ ďîĺçäęó íĺ íŕ÷čńëĺíŕ. Ńëčřęîě ęîđîňęîĺ đŕńńňî˙íčĺ");
	PlayerInfo[playerid][pTaxiTotal] += distanceRan;
    SetPlayerInt(playerid, "TaxiTotal", PlayerInfo[playerid][pTaxiTotal]);

	format(small_string, sizeof(small_string), "~g~+%d EXP", distanceRan);
	SendClientMessage(playerid, -1, """{6de64e}""Ńóěěŕ çŕ ďîĺçäęó áűëŕ ďđčáŕâëĺíŕ ę âŕřĺé çŕđďëŕňĺ");
	GameTextForPlayer(playerid, small_string, 3500, 0);
	AddPlayerEXP(playerid, distanceRan, "Đŕáîňŕ ňŕęńčńňîě");
	return 1;
}

