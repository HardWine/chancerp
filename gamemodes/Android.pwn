			vehfixtimer[playerid] = SetTimerEx("LoadVehFix", 3000, false, "d", playerid);
		}
		return 1;
	}
	if(pickupid == hExit[3])
	{
		new house;
		if(GetPlayerVirtualWorld(playerid) != GetPlayerAccountID(playerid)) {
			house = GetPVarInt(playerid, "guest_house");
			if(!IsPlayerInRangeOfPoint(playerid, 4,HouseInfo[house][hExitx], HouseInfo[house][hExity], HouseInfo[house][hExitz])) return 1;
			if(GetPVarInt(playerid, "nude") == 1) {
				CBackSkin(playerid);
				SendClientMessage(playerid, -1, ""COLOR_BLUE"Вы оделись");
				DeletePVar(playerid, "nude");
			}
			SetPlayerInterior(playerid,0);
			SetPlayerVirtualWorld(playerid,0);	
			SetPlayerPos(playerid,HouseInfo[house][hEntrancex],HouseInfo[house][hEntrancey],HouseInfo[house][hEntrancez]);
			SetPVarInt(playerid,"GoHome",gettime() + 5);
			SetCameraBehindPlayer(playerid);
			return 1;	
		}		
		GetPlayerHouse(playerid);
		house = GetPVarInt(playerid, "PlayerHouse");
		if(!IsPlayerInRangeOfPoint(playerid, 4,HouseInfo[house][hExitx], HouseInfo[house][hExity], HouseInfo[house][hExitz])) return 1;
		if(GetPVarInt(playerid, "nude") == 1) {
			CBackSkin(playerid);
			SendClientMessage(playerid, -1, ""COLOR_BLUE"Вы оделись");
			DeletePVar(playerid, "nude");
		}


		SetPVarInt(playerid,"HouseID",house);
		SetPlayerInterior(playerid,0);
		SetPlayerVirtualWorld(playerid,0);
		SetPlayerPos(playerid,HouseInfo[house][hEntrancex],HouseInfo[house][hEntrancey],HouseInfo[house][hEntrancez]);
		SetPVarInt(playerid,"GoHome",gettime() + 5);
		SetCameraBehindPlayer(playerid);
		DeletePVar(playerid,"HouseID");
		if(GetPVarInt(playerid, "FixedOneTime") == 1) return 1;
		if(IsVehicleOccupied(caridhouse[playerid]) == -1 && Platform[playerid] == 0) {
			vehfixtimer[playerid] = KillTimer(vehfixtimer[playerid]);
			vehfixtimer[playerid] = SetTimerEx("LoadVehFix", 3000, false, "d", playerid);
		}
		return 1;
	}
	for(new h = 1; h <= TOTALHOUSE; h++)
	{
		if(pickupid == HouseInfo[h][hPickup]) {
			if(HouseInfo[h][hOwned] == 0)
			{
				if(GetPlayerHouse(playerid) > 0) {
					format(small_string, sizeof(small_string), ""COLOR_ORANGE"Цена недвижимости: {FFFFFF}%i EXP", HouseInfo[h][hPrice]);
					SendClientMessage(playerid, -1, small_string);
					SendClientMessage(playerid, -1, ""COLOR_ORANGE"У Вас уже есть дом. Продать его можно в банке");
					return 1;
				}
				SetPVarInt(playerid,"HouseID",h);
				if(GetPVarInt(playerid,"AntiFlo") > gettime()){ return false; }
				if(Player.Hotel[playerid] != INVALID_HOTEL_ID) {
					return SendClientMessage(playerid, -1, ""COLOR_ORANGE"У вас арендован номер в отеле. Покупка дома невозможна.");
				}
				if(CheckCash(playerid, HouseInfo[h][hPrice]) == false) return 1;
				format(small_string, sizeof(small_string), ""COLOR_ORANGE"Цена недвижимости: {FFFFFF}%i EXP", HouseInfo[h][hPrice]);
				SendClientMessage(playerid, -1, small_string);

				ShowPlayerDialog(playerid, dBuyApartment, DIALOG_STYLE_MSGBOX, "Покупка недвижимости", "{FFFFFF}Вы действительно хотите купить данный дом?", "Купить", "Закрыть");
				SetPVarInt(playerid,"AntiFlo",gettime() + 17);
			}
			else
			{
				GetPlayerHouse(playerid);
				if(h == GetPVarInt(playerid, "PlayerHouse")) {
					if(GetPVarInt(playerid,"GoHome") > gettime()){ return false; }
					SetPlayerInterior(playerid,HouseInfo[h][hInt]);
					SetPlayerVirtualWorld(playerid,GetPlayerAccountID(playerid));
					switch(HouseInfo[h][hClass]) {
						case 0..1: SetPlayerPos(playerid, HouseInfo[h][hExitx]-4, HouseInfo[h][hExity]+2,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -270);
						case 2: SetPlayerPos(playerid, HouseInfo[h][hExitx], HouseInfo[h][hExity]+3,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -180);
						case 3..4: SetPlayerPos(playerid, HouseInfo[h][hExitx], HouseInfo[h][hExity]+8,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -180);
						case 5: SetPlayerPos(playerid, HouseInfo[h][hExitx]+2, HouseInfo[h][hExity]+12,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -180);
						default: SetPlayerPos(playerid, HouseInfo[h][hExitx]-4, HouseInfo[h][hExity]+2,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -270);
					}
					return true;
				}				
				if(HouseInfo[h][hDoor] == 1) {
					if(GetPVarInt(playerid,"GoHome") > gettime()){ return false; }

					new nick[MAX_PLAYER_NAME];
					format(nick,sizeof(nick),"%s",HouseInfo[h][hOwner]);
					new owner_id = ReturnUser(nick);

					if(IsPlayerConnected(owner_id) && PlayerLogged{owner_id} == true)
					{
						SetPVarInt(playerid, "guest_house", h);
						SetPlayerInterior(playerid,HouseInfo[h][hInt]);
						SetPlayerVirtualWorld(playerid, GetPlayerAccountID(owner_id));
						switch(HouseInfo[h][hClass]) {
							case 0..1: SetPlayerPos(playerid, HouseInfo[h][hExitx]-4, HouseInfo[h][hExity]+2,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -270);
							case 2: SetPlayerPos(playerid, HouseInfo[h][hExitx], HouseInfo[h][hExity]+3,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -180);
							case 3..4: SetPlayerPos(playerid, HouseInfo[h][hExitx], HouseInfo[h][hExity]+8,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -180);
							case 5: SetPlayerPos(playerid, HouseInfo[h][hExitx]+2, HouseInfo[h][hExity]+12,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -180);
							default: SetPlayerPos(playerid, HouseInfo[h][hExitx]-4, HouseInfo[h][hExity]+2,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -270);
						}
						return 1;
					} else {
						SendClientMessage(playerid, -1, "Дверь заперта изнутри "COLOR_RED"(игрок не в сети)");
					}				
				} else {
					SendClientMessage(playerid, -1, ""COLOR_ORANGE"Дверь жилища заперта владельцем");
				}
				/*
				format(small_string, sizeof(small_string), ""COLOR_ORANGE"Недвижимость куплена. Владелец: "COLOR_WHITE"%s", HouseInfo[h][hOwner]);
				SendClientMessage(playerid, -1, small_string);*/
				return 1;
			}
		}
	}
	for(new i = 0; i < MAX_BUSINESS; i++) {
		if(IsPlayerInRangeOfPoint(playerid, 9.9, Pickup[i][ent_X],Pickup[i][ent_Y],Pickup[i][ent_Z])) {
			SetPVarInt(playerid, "bz_rob", i);
			Dialog_Show(playerid, Dialog:rob);
		}
	}

	return 1;
}
public OnPlayerEnterDynamicCP(playerid, checkpointid)
{
	if(OpenBusinessMenu(playerid, checkpointid) == 1) {
		return 1;
	}
	if(Dealer_OnPlayerEnterDynamicCP(playerid, checkpointid) == 1) {
		return 1;
	}
	if(Porter_OnPlayerEnterDynamicCP(playerid, checkpointid) == 1) {
		return 1;
	}
	if(Saloon_OnPlayerEnterDynamicCP(playerid, checkpointid) == 1) {
		return 1;
	}
	if(Taxi_OnPlayerEnterDynamicCP(playerid, checkpointid) == 1) {
		return 1;
	}
	if(CallLocalFunction("OnPlayerEnterPatrolCP", "ii", playerid, checkpointid) == 1) {
		return 1;
	}
	if(CallLocalFunction("Gps_OnPlayerEnterDynamicCP", "ii", playerid, checkpointid) == 1) {
		return 1;
	}
	if(checkpointid == cars_triad) {
		return cars_triad_get(playerid);
	}
	if(checkpointid >= ATM[0] && checkpointid <= ATM[49])
	{
		if(PlayerLogged{playerid} == false) return 1;

		if(GetPVarInt(playerid, "payment_check") == 1) {
			return Dialog_Show(playerid, Dialog:PassPayment);
		}

		ShowPlayerDialog(playerid, dBank, DIALOG_STYLE_LIST, ""COLOR_BLUE"Банкомат", ""COLOR_WHITE"1. Снять средства\n2. Положить средства\n3. Пополнить счет мобильного\n4. Оплатить штрафы", "Выбрать", "Закрыть");
		PlayerPlaySound(playerid, 4203, 0, 0, 0);
		format(small_string, sizeof(small_string), ""COLOR_GREEN"Ваш банковский баланс: {FFFFFF} %d EXP", PlayerInfo[playerid][pBank]);
		SendClientMessage(playerid, -1, small_string);
		return 1;
	}
	if(checkpointid == Player.FarmCP[playerid]) {
		if(GetPVarInt(playerid, "tempjob") == 1) {
			if(IsValidTimer(farming[playerid])) {
				KillTimer(farming[playerid]);
				farming[playerid] = -1;
			}
			if(GetPVarInt(playerid, "Pizdui") == 0) {
				return 1;
			}
			if(Player.FarmCP[playerid] != INVALID_DYNAMIC_CP) {
				DestroyDynamicCP(Player.FarmCP[playerid]);
				Player.FarmCP[playerid] = INVALID_DYNAMIC_CP;
			}
			farming[playerid] = SetTimerEx("CFarm", 10000, false, "d", playerid);
			ApplyAnimation(playerid,"BOMBER","BOM_Plant",4.0,1,1,1,1,0);
			SendClientMessage(playerid, -1, "Подождите 10 секунд...");
			SetPVarInt(playerid, "MinusTime", 10);
		}
		return 1;
	}
	if(checkpointid == Player.SteelCar[playerid]) {
		if(ThefStatus[playerid] == 2) {
		new tmpcar = GetPlayerVehicleID(playerid);
		if(GetVehicleModel(tmpcar) != TCar[playerid]) {
			return SendClientMessage(playerid, -1, ""COLOR_RED"Это не та машина, которую мы заказывали!");
		}
		if(tmpcar == caridhouse[playerid]) {
			return SendClientMessage(playerid, -1, ""COLOR_RED"Свою машину оставь себе!");
		}
		for(new i = 0; i < MAX_ADMIN_CAR; i++) {
		if(AdminCar[i] == tmpcar) {
			return SendClientMessage(playerid, -1, ""COLOR_RED"Эта тачка не подойдет! У кого ты её взял?");
		}
		}

		new price;

		if(IsANope(tmpcar))
		{
			new 
				value = RandomEx(2, 4);


			IncreaseStatus(playerid, value); 
			price = RandomEx(75, 125);
			if(IsPlayerPremiumAccount(playerid) == true || X2_STATUS == 1) {
				price = price * 2;
			}

			format(small_string, sizeof(small_string), ""COLOR_GREEN"Неплохое ведро, держи: {FFFFFF}%d EXP", price);
			SendClientMessage(playerid, -1, small_string);
		}
		if(IsAB(tmpcar))
		{
			new 
				value = RandomEx(5, 7);

			IncreaseStatus(playerid, value); 
			price = RandomEx(155, 225);
			if(IsPlayerPremiumAccount(playerid) == true || X2_STATUS == 1) {
				price = price * 2;
			}

			format(small_string, sizeof(small_string), ""COLOR_GREEN"То что нужно, получай: {FFFFFF}%d EXP", price);
			SendClientMessage(playerid, -1, small_string);
		}
		if(IsAA(tmpcar))
		{
			new 
				value = RandomEx(8, 10);

			IncreaseStatus(playerid, value); 

			price = RandomEx(250, 750);
			if(IsPlayerPremiumAccount(playerid) == true || X2_STATUS == 1) {
				price = price * 2;
			}

			format(small_string, sizeof(small_string), ""COLOR_GREEN"Отличная тачка, вот твои: {FFFFFF}%d EXP", price);
			SendClientMessage(playerid, -1, small_string);
		}

		AddPlayerAchievement(playerid, E_CAR_RENTAL);
		AddPlayerEXP(playerid, price, "Угон автомобиля");
		DecreaseKarma(playerid);

		TimeTCar[playerid] = 0;
		//SetVehicleToRespawn(tmpcar);
		ThefStatus[playerid] = 0;
		TCar[playerid] = 0;

		if(PlayerInfo[playerid][pTheftSkill] < 250) {

			PlayerInfo[playerid][pTheftSkill] += 1;	

			SetPlayerInt(playerid, "TheftSkill", PlayerInfo[playerid][pTheftSkill]);
		}
		format(small_string, sizeof(small_string), ""COLOR_BLUE"Навык автоугона: %d", PlayerInfo[playerid][pTheftSkill]);
		SendClientMessage(playerid, -1, small_string);
		SendClientMessage(playerid, -1, ""COLOR_BLUE"Чем выше ваш навык тем более дорогие машины вы сможете угонять");

		if(Player.SteelCar[playerid] != INVALID_DYNAMIC_CP) {
			DestroyDynamicCP(Player.SteelCar[playerid]);
			Player.SteelCar[playerid] = INVALID_DYNAMIC_CP;
		}

		new homecar = 0;
		foreach(new i: Player) {
			if(tmpcar == caridhouse[i]) {
				if(Player.Hotel[i] == INVALID_HOTEL_ID) {
					LoadCarPlayerId(i);
				}
				homecar = 1;
			}
		}
		if(homecar == 0) {
		//DestroyVehicle(robbin[playerid]);
		//robbin[playerid] = INVALID_VEHICLE_ID;
		} else {
		//robbin[playerid] = INVALID_VEHICLE_ID;
		}
		return 1;
		}
		return 1;
	}
	return 1;
}

public OnPlayerLeaveCheckpoint(playerid)
{
	return 1;
}

public OnPlayerEnterDynamicArea(playerid, STREAMER_TAG_AREA areaid) 
{
	for(new i = 0; i < sizeof(bad_zone); i++)
	{
		if(areaid == bad_zone[i][E_ARENA]) 
		{
			if(PlayerInfo[playerid][pHours] <= 1 && IsPlayerInAnyVehicle(playerid) == false)
			{
				va_SendClientMessage(playerid, -1, ""COLOR_WHITE"Вы были кикнуты по подозрению в читерстве. "COLOR_GREEN"Код античита %i", random(20));
				Kick(playerid);
			}
		}
	}
	if(PlayerLogged{playerid} == false || !IsPlayerConnected(playerid)) return 0;
	if(GetPlayerState(playerid) == PLAYER_STATE_SPECTATING) return 0;

	if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER) {
		if(RadarArea[40] <= areaid <= RadarArea[MAX_RADAR-1]) {
			radar_shot(playerid,120);
		}
		if(RadarArea[0] <= areaid <= RadarArea[39]) {
			radar_shot(playerid,80);
		}	
	}	

	if(areaid == Heat) {
		return Heatarea(playerid);
	}	

	if(areaid == Main_TrashArea) {
		return StartEco(playerid);
	}

	Entrances(playerid, areaid);

	EcoArea(playerid, areaid);

	//trucker_area(playerid, areaid);

	if(areaid == barrier_info_area && IsAGov(playerid)) {
		return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Чтобы поднять шлагбаум введите:{FFFFFF} /lspd");
	}

	if(areaid == get_down) {
		if(!IsPlayerInAnyVehicle(playerid)) {
			SetPlayerPos(playerid, -2128.2756,721.3531,69.5625);
		}
	}
	if(areaid == drughouse_z) {
		return get_drugs(playerid);
	}	
	if(areaid == drugs_zone[0] || areaid == drugs_zone[1]) {
		if(IsACrime(playerid)) return ShowPlayerDialog(playerid, dBuyDrug, DIALOG_STYLE_INPUT, "Покупка наркотиков", "{FFFFFF}Введите количество грамм для покупки:\n"COLOR_BLUE"Цена за грамм: {FFFFFF}50 EXP", "Далее", "Закрыть");
		return SendClientMessage(playerid, -1, "- Барыга: У нас ничего для тебя нет");
	}
	if(areaid == drughouse_pickup[2]) {
		SetPlayerPos(playerid, 318.5828,1117.2263,1083.8828);
		SetPlayerFacingAngle(playerid, 0);
		SetCameraBehindPlayer(playerid);
		SetPlayerInterior(playerid, 5);
		SetPlayerVirtualWorld(playerid, 1);
	}
	if(areaid == drughouse_pickup[3]) {
		SetPlayerPos(playerid, 2167.9006,-1673.3541,15.0821);
		SetPlayerFacingAngle(playerid, 223);
		SetCameraBehindPlayer(playerid);
		SetPlayerInterior(playerid, 0);
		SetPlayerVirtualWorld(playerid, 0);
	}
	if(areaid == army_invite_area) {
		if(INVITATION_ARMY == 1) return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Добро пожаловать на призыв в ряды армии 'Зона-51'. Соблюдайте порядок!");
		
		if(Fraction[9][E_FRACTION_AUTO_INVITE] == 1) {
			new Fraction: fractionid = GetPlayerFraction(playerid);
			if(fractionid != FRACTION_NONE) return SendClientMessage(playerid, -1, "Вы уже состоите в другой фракции");
			switch(PlayerInfo[playerid][pHours]) {
				case 0..4: SetPVarInt(playerid, "inv_cost", 50);
				case 5..23: SetPVarInt(playerid, "inv_cost", 100);
				case 24..48: SetPVarInt(playerid, "inv_cost", 200);
				case 49..72: SetPVarInt(playerid, "inv_cost", 350);
				default:  SetPVarInt(playerid, "inv_cost", 500);
			}
			SetPVarInt(playerid, "inv_id", 1);
			format(big_string, sizeof(big_string), "{FFFFFF}Для вас подписание контракта на службу будет стоить %d EXP\n"COLOR_ORANGE"Вы согласны?",
				GetPVarInt(playerid, "inv_cost")
			);	
			return ShowPlayerDialog(playerid, dInvArea, DIALOG_STYLE_MSGBOX, "Контракт на службу", big_string, "Далее", "Закрыть");
		}
		else SendClientMessage(playerid, -1, ""COLOR_RED"Вступление за оплату отключено лидером армии");
	}
	if(areaid == lspd_invite_area) {
		if(Fraction[0][E_FRACTION_AUTO_INVITE] == 1) {
			if(PlayerInfo[playerid][pRank] >= 4 && GetPlayerFraction(playerid) == FRACTION_ARMY) {
			if(GetPVarInt(playerid, "tempjob") > 0) return SendClientMessage(playerid, -1, "Вы уже устроены на другую работу");
			switch(PlayerInfo[playerid][pHours]) {
				case 0..4: SetPVarInt(playerid, "inv_cost", 50);
				case 5..23: SetPVarInt(playerid, "inv_cost", 100);
				case 24..48: SetPVarInt(playerid, "inv_cost", 200);
				case 49..72: SetPVarInt(playerid, "inv_cost", 350);
				default:  SetPVarInt(playerid, "inv_cost", 500);
			}
			SetPVarInt(playerid, "inv_id", 2);
			format(big_string, sizeof(big_string), "{FFFFFF}Для вас трудоустройство будет стоить %d EXP\n"COLOR_ORANGE"Вы согласны?",
				GetPVarInt(playerid, "inv_cost")
			);
			return ShowPlayerDialog(playerid, dInvArea, DIALOG_STYLE_MSGBOX, "Трудоустройство", big_string, "Далее", "Закрыть");
			}
			else return SendClientMessage(playerid, -1, ""COLOR_RED"Чтобы устроиться в LSPD вы должны быть 4 ранга в Армии");
		}
		else SendClientMessage(playerid, -1, ""COLOR_RED"Вступление за оплату отключено лидером LSPD");
	}
	if(gang_invite_area[0] <= areaid <= gang_invite_area[7]) {
		new Fraction: fractionid = GetPlayerFraction(playerid);
		switch(fractionid) {
			case 2: if(areaid == gang_invite_area[0]) {
