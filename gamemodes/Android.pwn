public OnPlayerSpawn(playerid)
{	

	if(GetPVarInt(playerid, "first_spawn")) {
		DeletePVar(playerid, "is_setting_pos");
		DeletePVar(playerid, "first_spawn");
		SetPlayerPos(playerid, 964.5407, -53.1483, 1001.1172);
		SetPlayerFacingAngle(playerid, 90.0000);
		SetPlayerVirtualWorld(playerid, 10);
		SetPlayerInterior(playerid, 3);
		SetCameraBehindPlayer(playerid);
		SetPVarInt(playerid, "area", 4);
		Streamer_Update(playerid);
		return 1;
	}
	if(GetPVarInt(playerid, "is_setting_pos") == 2)
	{
		DeletePVar(playerid, "is_setting_pos");
		if(GetPVarInt(playerid, "load_pos_state") == 2)
		{
			SetVehiclePos(caridhouse[playerid], GetPVarFloat(playerid, !"load_pos_x"), GetPVarFloat(playerid, !"load_pos_y"), GetPVarFloat(playerid, !"load_pos_z"));
			SetVehicleZAngle(caridhouse[playerid], GetPVarFloat(playerid, !"load_pos_angle"));
			PutPlayerInVehicle(playerid, caridhouse[playerid], 0);
		}
		else
		{
			SetPlayerPos(playerid, GetPVarFloat(playerid, !"load_pos_x"), GetPVarFloat(playerid, !"load_pos_y"), GetPVarFloat(playerid, !"load_pos_z"));
			SetPlayerFacingAngle(playerid, GetPVarFloat(playerid, !"load_pos_angle"));
		}
		SetCameraBehindPlayer(playerid);
		SetPlayerInterior(playerid, GetPVarInt(playerid, !"load_pos_interior"));
		SetPlayerVirtualWorld(playerid, GetPVarInt(playerid, !"load_pos_world"));
		Streamer_Update(playerid);
		return 1;
	}
	if(PlayerArea[playerid] == true) {
		new 
			random_point = random(sizeof(AreaSpawnPoint));

		SetPlayerPos(playerid, AreaSpawnPoint[random_point][E_X], AreaSpawnPoint[random_point][E_Y], AreaSpawnPoint[random_point][E_Z]);
		SetPlayerFacingAngle(playerid, AreaSpawnPoint[random_point][E_ANGLE]);
		SetPlayerVirtualWorld(playerid, GetPVarInt(playerid, "mobile") ? (AREA_VIRTUAL_WORLD_ANDROID) : (AREA_VIRTUAL_WORLD_PC));

		if(PlayerInfo[playerid][pHours] < 3) {
			SetPlayerVirtualWorld(playerid, AREA_VIRTUAL_WORLD_NEWBIE);
			return 1;
		}

		SetPlayerInterior(playerid, AREA_INTER);
		SetCameraBehindPlayer(playerid);

		ResetPlayerWeapons(playerid);

		SetPlayerHealth(playerid, 100.00);

		GivePlayerWeapon(playerid, 24, AREA_GIVE_AMMO);
		GivePlayerWeapon(playerid, 25, AREA_GIVE_AMMO);
		GivePlayerWeapon(playerid, 31, AREA_GIVE_AMMO);		
		return 1;
	}

	if(IsPlayerNPC(playerid)) {
		return 0;
	}
	if(GetPVarInt(playerid, "parrot")) {
		SetPlayerAttachedObject(playerid, 7, 19078, 1, 0.329150, -0.072101, 0.156082, 0.000000, 0.000000, 0.000000, 1.000000, 1.000000, 1.000000);
	}

	if(GetPVarInt(playerid, "dialog_tuning")) {
		hide_tuning(playerid);
		DeletePVar(playerid, "dialog_tuning");
	}
	Streamer_Update(playerid, STREAMER_TYPE_OBJECT);
	SetCameraBehindPlayer(playerid);
	SetPlayerSpecialAction(playerid,SPECIAL_ACTION_NONE);
	PlayerPlaySound(playerid, 1098 , 0.0, 0.0, 0.0);
	if(!GetPVarInt(playerid, "Animations")) PreloadAnimLib(playerid);
	DeletePVar(playerid, "OnPlayerRequestClass_F4_Bug");
	DeletePVar(playerid, "Hidden");
	GetGun(playerid);
	if(RouteAir2[playerid] != 0) RouteAir2[playerid] = 0;
	if(RouteAir[playerid] != 0) RouteAir[playerid] = 0;
	if(GetPVarInt(playerid, !"spec") == 1) {
		DeletePVar(playerid, !"spec");
		SetPlayerPos(playerid,GetPVarFloat(playerid, !"pos_x"), GetPVarFloat(playerid, !"pos_y"), GetPVarFloat(playerid, !"pos_z"));
		SetPlayerFacingAngle(playerid, GetPVarFloat(playerid, !"pos_angle"));
		SetCameraBehindPlayer(playerid);
		SetPlayerInterior(playerid, GetPVarInt(playerid, !"pos_int"));
		SetPlayerVirtualWorld(playerid, GetPVarInt(playerid, !"pos_vw"));
		DeletePVar(playerid, !"pos_x");
		DeletePVar(playerid, !"pos_y");
		DeletePVar(playerid, !"pos_z");
		DeletePVar(playerid, !"pos_angle");
		DeletePVar(playerid, !"pos_int");
		DeletePVar(playerid, !"pos_vw");
		return 1;
	}	
	if(PlayerInfo[playerid][pHunger] < 10) SetPlayerHealth(playerid, 55.0);
	if(GetPVarInt(playerid, "buy_mode") == 1) {
		SetPlayerPos(playerid, 1913.9541, -2638.9438, 13.5469);
		SetPlayerFacingAngle(playerid, 360.000);
		SetPlayerInterior(playerid, 0);
		SetPlayerVirtualWorld(playerid, 0);
		SetCameraBehindPlayer(playerid);
		DeletePVar(playerid, "buy_mode");
		return 1;
	}
	if(GetPVarInt(playerid, "buy_mode_yacht") == 1) {
		SetPlayerPos(playerid, 2289.1655, 532.6104, 1.7944);
		SetPlayerFacingAngle(playerid, 270.000);
		SetPlayerInterior(playerid, 0);
		SetPlayerVirtualWorld(playerid, 0);
		SetCameraBehindPlayer(playerid);
		DeletePVar(playerid, "buy_mode_yacht");
		return 1;
	}	
	ReturnTimerID[playerid] = KillTimer(ReturnTimerID[playerid]);
	if(gone[playerid] != -1) {
		gone[playerid] = -1;
		gonecar[playerid] = INVALID_VEHICLE_ID;
		goneaway(playerid);
	}	
	if(PlayerInfo[playerid][pJailed] > 0) {
		SetPlayerVirtualWorld(playerid, 50);
		SetPlayerInterior(playerid, 5);
		return 1;
	}
	new 
		Fraction:fractionid = GetPlayerFraction(playerid),
		facing_angle = -1,
		interior = -1,
		virtual_world = -1;
	
	if(fractionid != FRACTION_ARMY) {
		
		new player_house = GetPlayerHouse(playerid);

		if(player_house > 0) {
			if(PlayerInfo[playerid][pSpawn] == 1 && fractionid != FRACTION_NONE) goto fraction_spawn;
			new house = GetPVarInt(playerid, "PlayerHouse");
			SetPlayerVirtualWorld(playerid, GetPlayerAccountID(playerid));
			SetPlayerInterior(playerid,HouseInfo[house][hInt]);
			return 1;
		}

		if(Player.Hotel[playerid] != INVALID_HOTEL_ID) {
			if(PlayerInfo[playerid][pSpawn] == 1 && fractionid != FRACTION_NONE) goto fraction_spawn;
			new arrayID = Player.Hotel[playerid];
			SetPlayerInterior(playerid, Hotel.Room[arrayID][E_HOTEL_ROOM_INTER]);
			SetPlayerVirtualWorld(playerid, Hotel.Room[arrayID][E_HOTEL_ROOM_WOLRD]);
			return 1; 
		}

	}
	fraction_spawn:
	switch(fractionid) {
		case FRACTION_ARMY: {
			SendClientMessage(playerid, -1, ""COLOR_RED"До окончания службы вы будете появляться в военной казарме");
			facing_angle = 90;
			interior = 4;
			virtual_world = 4;		
		}
		case FRACTION_FBI: {
			interior = 2;
			virtual_world = 2;		
		}		
		case FRACTION_GOVERMENT: {
			interior = 1;
			virtual_world = 0;		
		}	
		case FRACTION_NEWS: {

			interior = 0;
			virtual_world = 206;		
		}	
		case FRACTION_LSPD: interior = 0;
		case FRACTION_BALLAS: interior = 1;
		case FRACTION_VAGOS: interior = 1;
		case FRACTION_RIFA: interior = 1;
		case FRACTION_AZTECAS: interior = 1;
		case FRACTION_RUSSIAN_MAFIA: interior = 1;
		case FRACTION_TRIADA: interior = 1;
		case FRACTION_DN_BOYS: interior = 1;
		case FRACTION_NONE: {
			virtual_world = 0;
			interior = 0;
			/*if(GetPlayerAdminLevel(playerid) > 0) {
				virtual_world = 400;
				interior = 1;
			}	*/		
		}
	}

	if(interior != -1) SetPlayerInterior(playerid, interior);
	if(virtual_world != -1) SetPlayerVirtualWorld(playerid, virtual_world);
	if(facing_angle != -1) SetPlayerFacingAngle(playerid, facing_angle);
	return 1;
}
forward UpdateSpawnInfo(playerid);
public UpdateSpawnInfo(playerid)
{
	if(PlayerInfo[playerid][pJailed] == 1) {
		return SetSpawnInfo(playerid, 0, GBackSkin(playerid), GetPVarFloat(playerid, "jail_x"),GetPVarFloat(playerid, "jail_y"),GetPVarFloat(playerid, "jail_z"), 0, 0, 0, 0, 0, 0, 0);
	}
	new
		Fraction:fractionid = GetPlayerFraction(playerid);
	if(GetPVarInt(playerid, "Corrupt") == 2) return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 911.2905,-1069.3212,24.4278, 90, 0, 0, 0, 0, 0, 0);
	if(fractionid == FRACTION_ARMY) {
		new why_not_to = RandomEx(0,5);
		switch(why_not_to) {
			case 0: SetSpawnInfo(playerid, 0, GBackSkin(playerid), 162.8263,1449.3154,10.6288, 0, 0, 0, 0, 0, 0, 0);
			case 1: SetSpawnInfo(playerid, 0, GBackSkin(playerid), 162.7948,1454.6697,10.6314, 0, 0, 0, 0, 0, 0, 0);
			case 2: SetSpawnInfo(playerid, 0, GBackSkin(playerid), 165.1229,1449.6304,10.6340, 0, 0, 0, 0, 0, 0, 0);
			case 3: SetSpawnInfo(playerid, 0, GBackSkin(playerid), 165.1330,1454.7574,10.6366, 0, 0, 0, 0, 0, 0, 0);
			case 4: SetSpawnInfo(playerid, 0, GBackSkin(playerid), 167.1684,1454.7437,10.6402, 0, 0, 0, 0, 0, 0, 0);
			case 5: SetSpawnInfo(playerid, 0, GBackSkin(playerid), 167.2228,1449.5183,10.6386, 0, 0, 0, 0, 0, 0, 0);
		}
		return 1;
	}
	if(GetPlayerHouse(playerid) > 0) {
		if(fractionid != FRACTION_NONE && PlayerInfo[playerid][pSpawn] == 1) goto fraction_spawn;
		new house = GetPVarInt(playerid, "PlayerHouse");
		switch(HouseInfo[house][hClass]) {
			case 0..1: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), HouseInfo[house][hExitx]-4, HouseInfo[house][hExity]+2,HouseInfo[house][hExitz], 270, 0, 0, 0, 0, 0, 0);
			case 2: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), HouseInfo[house][hExitx], HouseInfo[house][hExity]+3,HouseInfo[house][hExitz], 180, 0, 0, 0, 0, 0, 0);
			case 3..4: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), HouseInfo[house][hExitx], HouseInfo[house][hExity]+8,HouseInfo[house][hExitz], 180, 0, 0, 0, 0, 0, 0);
			case 5: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), HouseInfo[house][hExitx]+2, HouseInfo[house][hExity]+12,HouseInfo[house][hExitz], 180, 0, 0, 0, 0, 0, 0);
			default: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), HouseInfo[house][hExitx]-4, HouseInfo[house][hExity]+2,HouseInfo[house][hExitz], 270, 0, 0, 0, 0, 0, 0);
		}
	}
	new arrayID = Player.Hotel[playerid];
	if(arrayID != INVALID_HOTEL_ID) {
		if(fractionid != FRACTION_NONE && PlayerInfo[playerid][pSpawn] == 1) goto fraction_spawn;
		SetSpawnInfo(playerid, 0, GBackSkin(playerid), 337.4198, -1491.3781, 36.0391, 45.000, 0, 0, 0, 0, 0, 0);
		return 1;
	}
	fraction_spawn:
	if(fractionid == FRACTION_NONE) {
	if(GetPVarInt(playerid, "JustCreated") == 1) {
		callcmd::help(playerid, "");
		SendClientMessage(playerid, -1, ""COLOR_GREEN"Если у Вас появятся какие-либо вопросы по ходу игры, то Вы ...");
		SendClientMessage(playerid, -1, ""COLOR_GREEN"всегда можете задать их, помощникам по игровому процессу: /ask [свой вопрос]");
	}
	if(GetPlayerAdminLevel(playerid) > 1) return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 2144.7192,2436.8203,10.8231, 280, 0, 0, 0, 0, 0, 0);
	if(GetPlayerScore(playerid) < 1) {

	if(PlayerInfo[playerid][pSkin] == 26 || PlayerInfo[playerid][pSkin] == 193) {
			switch(random(4)) {
				case 0: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1664.2942,-2297.4575,-1.2072, 0, 0, 0, 0, 0, 0, 0);
				case 1: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1664.3304,-2283.1606,-1.2395, 360, 0, 0, 0, 0, 0, 0);
				case 2: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1682.3468,-2297.1970,-1.2161, 0, 0, 0, 0, 0, 0, 0);
				case 3: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1682.3192,-2283.2170,-1.2377, 360, 0, 0, 0, 0, 0, 0);
			}
		} else {
			switch(random(4)) {
				case 0: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1550.5521,-2081.1970,25.5156, 180, 0, 0, 0, 0, 0, 0);
				case 1: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1541.9470,-2088.0232,25.7010, 336, 0, 0, 0, 0, 0, 0);
				case 2: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1546.4351,-2089.9075,25.5156, 19, 0, 0, 0, 0, 0, 0);
				case 3: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1544.8513,-2073.9299,26.8513, 208, 0, 0, 0, 0, 0, 0);
			}			
		}
	}
	if(GetPlayerScore(playerid) >= 1) {
		switch(random(7)) {
			case 0: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1755.4962,-1925.4510,13.5747, 0, 0, 0, 0, 0, 0, 0);
			case 1: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1755.4924,-1924.4202,13.5742, 0, 0, 0, 0, 0, 0, 0);
			case 2: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1108.5388,-1790.3772,16.5938, 90, 0, 0, 0, 0, 0, 0);
			case 3: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1109.2759,-1793.3378,16.5938, 90, 0, 0, 0, 0, 0, 0);
			case 4: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1108.8644,-1796.4742,16.5938, 90, 0, 0, 0, 0, 0, 0);
			case 5: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1108.9258,-1799.5568,16.5938, 90, 0, 0, 0, 0, 0, 0);
			case 6: return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1109.0804,-1802.7028,16.5938, 90, 0, 0, 0, 0, 0, 0);
		}
	}
	}
	if(fractionid == FRACTION_LSPD) return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1552.4500,-1674.9900,16.1953, 90, 0, 0, 0, 0, 0, 0);
	if(fractionid == FRACTION_GROOVE) return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 2495.2859,-1688.5461,13.8737, 0, 0, 0, 0, 0, 0, 0);
	if(fractionid == FRACTION_BALLAS) return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 2742.2385,-1774.7386,25.5106, 0, 0, 0, 0, 0, 0, 0);
	if(fractionid == FRACTION_VAGOS)  return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 2692.4290,-1566.8107,20.0395, 0, 0, 0, 0, 0, 0, 0);
	if(fractionid == FRACTION_RIFA)  return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 2163.1985,-1778.1453,13.7867, 0, 0, 0, 0, 0, 0, 0);
	if(fractionid == FRACTION_AZTECAS)  return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1674.5515,-2056.9834,14.2142, 0, 0, 0, 0, 0, 0, 0);
	if(fractionid == FRACTION_RUSSIAN_MAFIA)  return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1085.6416,1552.5817,5.9481, 0, 0, 0, 0, 0, 0, 0);
	if(fractionid == FRACTION_TRIADA)  return SetSpawnInfo(playerid, 0, GBackSkin(playerid), -2264.1753,476.8297,43.8076, 0, 0, 0, 0, 0, 0, 0);
	if(fractionid == FRACTION_DN_BOYS)  return SetSpawnInfo(playerid, 0, GBackSkin(playerid), -1539.7102,1144.3630,7.2198, 0, 0, 0, 0, 0, 0, 0);
	if(fractionid == FRACTION_FBI)  return SetSpawnInfo(playerid, 0, GBackSkin(playerid), -2455.2639,535.3552,432.6741, 90, 0, 0, 0, 0, 0, 0);
	if(fractionid == FRACTION_GOVERMENT)  return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 1491.7451,-1759.5736,485.0971, 90, 0, 0, 0, 0, 0, 0);
	if(fractionid == FRACTION_NEWS)  return SetSpawnInfo(playerid, 0, GBackSkin(playerid), 924.6260,-1676.8136,1349.5969, 90, 0, 0, 0, 0, 0, 0);
	return 1;
}
public OnPlayerRequestClass(playerid, classid) {
	if(IsPlayerNPC(playerid)) return 1;
	ac_1{playerid} = true; 
	UpdateSpawnInfo(playerid);
	if(!GetPVarInt(playerid, "OnPlayerRequestClassFix"))
	{
		if(GetPVarInt(playerid, "OnPlayerRequestClass_F4_Bug")) return SpawnPlayer(playerid);
		TogglePlayerSpectating(playerid, true);
		SetTimerEx("TogglePlayerSpectatingOff", 500, 0, "i", playerid);
	}
	else {
	DeletePVar(playerid, "OnPlayerRequestClassFix");
	SpawnPlayer(playerid);   
	}
	return 1;
}
public OnPlayerDeath(playerid, killerid, reason)
{
	foreach(new i: Admin)
	{
		SendDeathMessageToPlayer(i, killerid, playerid, reason);
	}

	if(PlayerArea[playerid] == true && PlayerInfo[killerid][pHours] > 3) {

		// По умолчанию игрок с компьютера
		new 
			convert_platform_to_enum_value = 2;

		if(GetPVarInt(playerid, "mobile") == 1) {
			convert_platform_to_enum_value = 1;
		}

		if(killerid == INVALID_PLAYER_ID) { // взорвался, умер нет от выстрела другого игрока
			small_string[0] = EOS;
			format(small_string, sizeof(small_string), "INSERT INTO `dm_area`(`PlayerID`, `Type`, `Platform`, `Time`) VALUES (%i, 'Смерть', %i, CURRENT_TIMESTAMP())", PlayerInfo[playerid][pID], convert_platform_to_enum_value);
			printf(small_string);
			mysql_pquery(database, small_string);
		} else if(PlayerArea[killerid] == true) { // убил другой игрок


			format(small_string, sizeof(small_string), "~b~KILLED BY ~y~%s", PlayerInfo[killerid][pName]);
			GameTextForPlayer(playerid, small_string, 5000, 5);

			format(small_string, sizeof(small_string), "+1 ~b~KILL~w~~n~R.I.P. ~y~%s", PlayerInfo[playerid][pName]);
			GameTextForPlayer(killerid, small_string, 5000, 5);


			small_string[0] = EOS;
			format(small_string, sizeof(small_string), "INSERT INTO `dm_area`(`PlayerID`, `Type`, `Platform`, `Time`) VALUES (%i, 'Смерть', %i, CURRENT_TIMESTAMP())", PlayerInfo[playerid][pID], convert_platform_to_enum_value);
			printf(small_string);
			mysql_pquery(database, small_string);

			format(small_string, sizeof(small_string), "INSERT INTO `dm_area`(`PlayerID`, `Type`, `Platform`, `Time`) VALUES (%i, 'Убийство другого игрока', %i, CURRENT_TIMESTAMP())", PlayerInfo[killerid][pID], convert_platform_to_enum_value);
			printf(small_string);
			mysql_pquery(database, small_string);

			UpdatePlayerProgressQuest(killerid, E_ARENAS);
		}
		return 1;
	}

	//race_Death(playerid, killerid, reason);
	if(GetPVarInt(playerid, "dialog_tuning")) {
		hide_tuning(playerid);
		DeletePVar(playerid, "dialog_tuning");
	}	
	ResetPlayerWeapons(playerid);

	DelGuns(playerid);

	UpdateSpawnInfo(playerid);
	if(IsPlayerInRangeOfPoint(playerid, 10, 325.2081,2544.4429,17.1558)) {
		SetPVarInt(playerid, "deadbattle", 1);
	}
	CallLocalFunction("GPS_OnPlayerDeath", "i", playerid);
	if(GetPVarInt(playerid, "tempjob") != 0) {
		DeletePVar(playerid, "tempjob");
	}

	if(GetPVarInt(playerid, "oncapture") > 0) {
		new c_op = GetPVarInt(playerid, "opponent");

		printf("opponrnt: %d", c_op);

		capture_info[c_op][score] += 1;

		DeletePVar(playerid, "opponent");
		DeletePVar(playerid, "oncapture");

		if(killerid != INVALID_PLAYER_ID) {
		AddPlayerAchievement(killerid, E_BATTLE_SQUARES);	
		}
	}
	SetTimerEx("fix_spawn", 250+GetPlayerPing(playerid), false, "i", playerid);
	return 1;
}
