forward dre_BusinessManageInput(playerid, response, listitem, inputtext[]); public dre_BusinessManageInput(playerid, response, listitem, inputtext[]) {
	if(!response) {

		if(IsPlayerInRangeOfPoint(playerid, 5, 1401.232543, -1684.396850, 13.583753)) {
			return Dialog_Bank_Property(playerid);
		}

		return 0;
	} else {
		new 
			strval_inputtext = strval(inputtext);

		if(strval_inputtext < 0 || strval_inputtext > 99) return pc_cmd_business(playerid);
		if(BusinessInfo[strval_inputtext-1][OwnerID] == PlayerInfo[playerid][pID]) {		
		SetPVarInt(playerid, "b_info_get", strval_inputtext);

		SetPVarInt(playerid, "b_rent", strval_inputtext-1);

		if(IsPlayerInRangeOfPoint(playerid, 5, 1401.232543, -1684.396850, 13.583753)) {
			return Dialog_Show(playerid, #BusinessRentInput);
		}

		Dialog_Show(playerid, #InputBusinessInfo);

		} else {
			pc_cmd_business(playerid);
		}

	}
	return 1;
}


forward dre_BusinessManage(playerid, response, listitem, inputtext[]); public dre_BusinessManage(playerid, response, listitem, inputtext[]) {
	if(!response) {
		if(IsPlayerInRangeOfPoint(playerid, 5, 1401.232543, -1684.396850, 13.583753)) {
			return Dialog_Bank_Property(playerid);
		}
	} else {
		if(IsPlayerInRangeOfPoint(playerid, 5, 1401.232543, -1684.396850, 13.583753)) {

			new business_chosen;
			switch(listitem) {
				case 0: {
					business_chosen = GetPVarInt(playerid, "business_n_1");
				}
				case 1: {
					business_chosen = GetPVarInt(playerid, "business_n_2");
				}
				case 2: {
					business_chosen = GetPVarInt(playerid, "business_n_3");
				}
			}
			SetPVarInt(playerid, "b_rent", business_chosen);
			Dialog_Show(playerid, #BusinessRentInput);
		}
	}
	return 1;
}

