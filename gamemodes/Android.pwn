stock DelGuns(playerid) {
		PlayerInfo[playerid][slot_2_gun] = 0;
		PlayerInfo[playerid][slot_2_ammo] = 0;
		PlayerInfo[playerid][slot_3_gun] = 0;
		PlayerInfo[playerid][slot_3_ammo] = 0;
		PlayerInfo[playerid][slot_4_gun] = 0;
		PlayerInfo[playerid][slot_4_ammo] = 0;
		PlayerInfo[playerid][slot_5_gun] = 0;
		PlayerInfo[playerid][slot_5_ammo] = 0;
		PlayerInfo[playerid][slot_8_gun] = 0;
		PlayerInfo[playerid][slot_8_ammo] = 0;

		SetPlayerInt(playerid, "slot_2_gun", 0);
		SetPlayerInt(playerid, "slot_3_gun", 0);
		SetPlayerInt(playerid, "slot_4_gun", 0);
		SetPlayerInt(playerid, "slot_5_gun", 0);
		SetPlayerInt(playerid, "slot_8_gun", 0);

		SetPlayerInt(playerid, "slot_2_ammo", 0);
		SetPlayerInt(playerid, "slot_3_ammo", 0);
		SetPlayerInt(playerid, "slot_4_ammo", 0);
		SetPlayerInt(playerid, "slot_5_ammo", 0);
		SetPlayerInt(playerid, "slot_8_ammo", 0);
		return 1;
}

stock GetGun(playerid) {

	ResetPlayerWeapons(playerid);

	new Fraction:fractionid = GetPlayerFraction(playerid);

	if(GetPlayerJobDayStatus(playerid) == true)
	{
		if(IsAGang(playerid)) {
			GivePlayerWeapon(playerid, 41, 250);
			GivePlayerWeapon(playerid, 5, 1);
		}
		if(IsACop(playerid)) {
			GivePlayerWeapon(playerid, 3, 1);
		}	
		if(fractionid == FRACTION_GOVERMENT) {
				new rank = PlayerInfo[playerid][pRank];
				if(rank == 1 || rank == 3 || rank == 5) {
					SetPlayerArmour(playerid, 100);
					ResetPlayerWeapons(playerid);
					GivePlayerWeapon(playerid, 3, 1);
					GivePlayerWeapon(playerid, 24, 60);
				}
		}	
		if(fractionid == FRACTION_NEWS) {
			GivePlayerWeapon(playerid, 43, 50);
		}
	}
	
	if(PlayerInfo[playerid][slot_2_gun] != 0) GivePlayerWeapon(playerid, PlayerInfo[playerid][slot_2_gun], PlayerInfo[playerid][slot_2_ammo]);
	if(PlayerInfo[playerid][slot_3_gun] != 0) GivePlayerWeapon(playerid, PlayerInfo[playerid][slot_3_gun], PlayerInfo[playerid][slot_3_ammo]);
	if(PlayerInfo[playerid][slot_4_gun] != 0) GivePlayerWeapon(playerid, PlayerInfo[playerid][slot_4_gun], PlayerInfo[playerid][slot_4_ammo]);
	if(PlayerInfo[playerid][slot_5_gun] != 0) GivePlayerWeapon(playerid, PlayerInfo[playerid][slot_5_gun], PlayerInfo[playerid][slot_5_ammo]);
	if(PlayerInfo[playerid][slot_8_gun] != 0) GivePlayerWeapon(playerid, PlayerInfo[playerid][slot_8_gun], PlayerInfo[playerid][slot_8_ammo]);		
	return 1;
}


CMD:makegun(playerid, params[]) {

	if(PlayerArea[playerid] == true) return 1;
	//new fractionid = GetPlayerFractionInt(playerid);
	
	if(PlayerInGangZone(playerid,-84+150, 1632+150, 437+150, 2144+150)) return 1;

	if(IsAGang(playerid) || IsAMafia(playerid)) {
		if(GetPlayerJobDayStatus(playerid) == false)
		{
			return SendClientMessage(playerid, -1, MSG_START_JOB_DAY);
		}
		return Dialog_Show(playerid, Dialog:DIALOG_CMD_MAKEGUN);
	}
	return 1;
}

DialogCreate:DIALOG_CMD_MAKEGUN(playerid) {
	return Dialog_Open(playerid, Dialog:DIALOG_CMD_MAKEGUN, DIALOG_STYLE_TABLIST_HEADERS,
		""COLOR_BLUE"Cборка оружия",
		"Оружие\tРасход патронов\n\
			Desert Eagle\t"COLOR_GREEN"4\n\
			Shotgun\t"COLOR_GREEN"3\n\
			AK-47\t"COLOR_GREEN"2\n\
			M4\t"COLOR_GREEN"2\n\
			Molotov\t"COLOR_GREEN"10\n\
			Tec9\t"COLOR_GREEN"3\n",
		"Далее", "Закрыть"
	);
}

DialogResponse:DIALOG_CMD_MAKEGUN(playerid, response, listitem, inputtext[]) {
	if(!response) {
		return false;
	} else {
		SetPVarInt(playerid, "cmd_makegun_listitem", listitem);
		small_string[0] = EOS;

		switch(listitem) {
			case 0: small_string = "Desert Eagle";
			case 1: small_string = "Shotgun";
			case 2: small_string = "AK-47";
			case 3: small_string = "M4";
			case 4: small_string = "Molotov";
			case 5: small_string = "Tec9";
		}

		format(big_string, sizeof(big_string), ""COLOR_WHITE"Введите желаемое количество патронов для сборки оружия\n"COLOR_GREEN"%s", small_string);
		return Dialog_Open(playerid, Dialog:DIALOG_CMD_MAKEGUN_CRAFT, DIALOG_STYLE_INPUT,
			""COLOR_BLUE"Cборка оружия",
			big_string,
			"Далее", "Закрыть"
		);
	}
}

DialogResponse:DIALOG_CMD_MAKEGUN_CRAFT(playerid, response, listitem, inputtext[]) {
	if(!response) {
		return Dialog_Show(playerid, Dialog:DIALOG_CMD_MAKEGUN);
	} else {
		new 
			strval_inputtext = strval(inputtext);

		if(strval_inputtext < 0 || strval_inputtext > 999) {
			SendClientMessage(playerid, -1, ""COLOR_ORANGE"Указано неверное количество патронов.");
			return Dialog_Show(playerid, Dialog:DIALOG_CMD_MAKEGUN_CRAFT);
		}
		new 
			modelid = GetPVarInt(playerid, "cmd_makegun_listitem"),
			gun_id,
			cost_pt;

		if(modelid == 0) gun_id = 24, cost_pt = 4;
		if(modelid == 1) gun_id = 25, cost_pt = 3;
		if(modelid == 2) gun_id = 30, cost_pt = 2;
		if(modelid == 3) gun_id = 31, cost_pt = 2;
		if(modelid == 4) gun_id = 18, cost_pt = 10;
		if(modelid == 5) gun_id = 32, cost_pt = 3;

		new stuff_need = strval_inputtext * cost_pt;

		if(PlayerInfo[playerid][pStuff] < stuff_need) {
			Dialog_Show(playerid, Dialog:DIALOG_CMD_MAKEGUN_CRAFT);
			format(small_string, sizeof small_string, ""COLOR_RED"Не хватает %d материалов", stuff_need-PlayerInfo[playerid][pStuff]);
			return SendClientMessage(playerid, -1, small_string);
		} else {

			PlayerInfo[playerid][pStuff] -= stuff_need;
			SetPlayerInt(playerid, "Stuff", PlayerInfo[playerid][pStuff]);

			GivePlayerWeapon(playerid, gun_id, strval_inputtext);

			new save_gun,
				save_ammo;

			format(small_string, sizeof small_string, "~r~~n~~n~-%d Stuff~g~~n~+%d Ammo", stuff_need, strval_inputtext);
			GameTextForPlayer(playerid, small_string, 2000, 6);

			SetPlayerChatBubble(playerid, "собрал(а) оружие", C_PURPLE, 30.0, 5000);
			format(small_string, sizeof(small_string), "%s собрал(а) оружие", PlayerInfo[playerid][pName]);
			ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_PURPLE, small_string);

			if(gun_id == 22 || gun_id == 23 || gun_id == 24) {
				ApplyAnimation(playerid,"COLT45","colt45_reload",4.1,0,1,1,1,1,1);
				GetPlayerWeaponData(playerid, 2, save_gun, save_ammo);
				PlayerInfo[playerid][slot_2_gun] = save_gun;
				PlayerInfo[playerid][slot_2_ammo] = save_ammo;
			}
			if(gun_id == 25 || gun_id == 26 || gun_id == 27) {
				ApplyAnimation(playerid,"COLT45","colt45_reload",4.1,0,1,1,1,1,1);
				GetPlayerWeaponData(playerid, 3, save_gun, save_ammo);
				PlayerInfo[playerid][slot_3_gun] = save_gun;
				PlayerInfo[playerid][slot_3_ammo] = save_ammo;
			}
			if(gun_id == 28 || gun_id == 29 || gun_id == 32) {
				ApplyAnimation(playerid,"COLT45","colt45_reload",4.1,0,1,1,1,1,1);
				GetPlayerWeaponData(playerid, 4, save_gun, save_ammo);
				PlayerInfo[playerid][slot_4_gun] = save_gun;
				PlayerInfo[playerid][slot_4_ammo] = save_ammo;
			}
			if(gun_id == 30 || gun_id == 31) {
				ApplyAnimation(playerid,"COLT45","colt45_reload",4.1,0,1,1,1,1,1);
				GetPlayerWeaponData(playerid, 5, save_gun, save_ammo);
				PlayerInfo[playerid][slot_5_gun] = save_gun;
				PlayerInfo[playerid][slot_5_ammo] = save_ammo;
			}
			if(gun_id == 15 || gun_id == 16 || gun_id == 17) {
				GetPlayerWeaponData(playerid, 8, save_gun, save_ammo);
				PlayerInfo[playerid][slot_8_gun] = save_gun;
				PlayerInfo[playerid][slot_8_ammo] = save_ammo;
			}		
		}	
	}
	return 1;
}

