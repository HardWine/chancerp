@yH_OnPlayerConnect@003(playerid);@yH_OnPlayerConnect@003(playerid) {
	Player__FarmCP[playerid] = (-1);

	Player__FarmTimer[playerid] = (-1);
	Player__ZoneType{playerid} = 0;
	Player__FarmMoney[playerid] = 0;
	Player__TotalBush[playerid] = 0;
	Player__FarmIsEnd{playerid} = false;
	Player__isJobFarm{playerid} = false;
	return (1);
}

@yH_OnPlayerDisconnect@003(playerid, reason);@yH_OnPlayerDisconnect@003(playerid, reason) {
	if(Player__FarmCP[playerid] != (-1)) {
		DestroyDynamicCP(Player__FarmCP[playerid]);
	}

	if(Player__FarmTimer[playerid] != (-1)) {
		{_Timer_F(_: Player__FarmTimer[playerid]);}
	}

	Player__FarmCP[playerid] = (-1);
	Player__FarmTimer[playerid] = (-1);

	Player__ZoneType{playerid} = 0;
	Player__FarmMoney[playerid] = 0;
	Player__TotalBush[playerid] = 0;
	Player__FarmIsEnd{playerid} = false;
	Player__isJobFarm{playerid} = false;
	return (1);
}

@yH_OnPlayerEnterDynArea@003(playerid,  areaid);@yH_OnPlayerEnterDynArea@003(playerid,  areaid) {
	if(areaid == Zone_Farm[0]) { 
		if(Player__isJobFarm{playerid} == true) {
			SendClientMessage(playerid, -1, """{ff353c}""Вы уволились с работы фермера");
			CBackSkin(playerid);

			return Player__isJobFarm{playerid} = false;
		} else {
			if(IsPlayerInFraction(playerid) == true) {
				return SendClientMessage(playerid, -1, "Вы состоите в организации.");
			}
			Player__isJobFarm{playerid} = true;

			if(PlayerInfo[playerid][pFarmSkill] < 200) {
				if(PlayerInfo[playerid][pSex] == 1) {
					SetPlayerSkin(playerid, 131);
				} else {
					new RandomF = random(sizeof(Farm_Skin));
					SetPlayerSkin(playerid, Farm_Skin[RandomF]);
				}
			}
			if(PlayerInfo[playerid][pFarmSkill] >= 200) {
				if(PlayerInfo[playerid][pSex] == 1) {
					SetPlayerSkin(playerid, 201);
				} else {
					SetPlayerSkin(playerid, 161);
				}
			}
			if(PlayerInfo[playerid][pFarmSkill] > 500) {
				if(PlayerInfo[playerid][pSex] == 1) {
					SetPlayerSkin(playerid, 198);
				} else {
					SetPlayerSkin(playerid, 34);
				}
			}

			SendClientMessage(playerid, -1, """{FFAF00}""Вы начали работу фермера. Отправляйтесь в поле");
			SendClientMessage(playerid, -1, """{FFAF00}""Увеличивая скилл фермера вы получите больше EXP!");
			SendClientMessage(playerid, -1, """{FFAF00}""Подойдите к одной из машин на поле, а после встаньте на красную метку.");
			return (-2);
		}
	}
	if(Player__isJobFarm{playerid} == true) {
		if(areaid == Zone_Farm[1]) {
			if(Player__FarmCP[playerid] == (-1)) {
				Player__ZoneType{playerid} = 0;
				new 
					random_value = random((5));
				Player__FarmCP[playerid] = CreateDynamicCP(Farm_Coord_0[random_value][E_FARM_X], Farm_Coord_0[random_value][E_FARM_Y], Farm_Coord_0[random_value][E_FARM_Z], 
					1.50, 0, 0, playerid
				);
			}
			return (-2);
		}

		if(areaid == Zone_Farm[2]) {
			if(Player__FarmCP[playerid] == (-1)) {
				Player__ZoneType{playerid} = 1;
				new 
					random_value = random((5));
				Player__FarmCP[playerid] = CreateDynamicCP(Farm_Coord_1[random_value][E_FARM_X], Farm_Coord_1[random_value][E_FARM_Y], Farm_Coord_1[random_value][E_FARM_Z], 
					1.50, 0, 0, playerid
				);
			}
			return (-2);
		}

		if(areaid == Zone_Farm[3]) {
			if(Player__FarmCP[playerid] == (-1)) {
				Player__ZoneType{playerid} = 2;
				new 
					random_value = random((5));
				Player__FarmCP[playerid] = CreateDynamicCP(Farm_Coord_2[random_value][E_FARM_X], Farm_Coord_2[random_value][E_FARM_Y], Farm_Coord_2[random_value][E_FARM_Z], 
					1.50, 0, 0, playerid
				);
			}
			return (-2);
		}
	}	
	return (1);
}

@yH_OnPlayerLeaveDynArea@003(playerid,  areaid);@yH_OnPlayerLeaveDynArea@003(playerid,  areaid) {
	if(areaid == Zone_Farm[0]) { 
		return (-2);
	}
	if(Player__isJobFarm{playerid} == true) {
		if(areaid == Zone_Farm[1]) {
			if(Player__FarmCP[playerid] != (-1)) {
				Player__ZoneType{playerid} = 0;
				DestroyDynamicCP(Player__FarmCP[playerid]);
				Player__FarmCP[playerid] = (-1);
			}
			return (-2);
		}

		if(areaid == Zone_Farm[2]) {
			if(Player__FarmCP[playerid] != (-1)) {
				Player__ZoneType{playerid} = 0;
				DestroyDynamicCP(Player__FarmCP[playerid]);
				Player__FarmCP[playerid] = (-1);
			}
			return (-2);
		}

		if(areaid == Zone_Farm[3]) {
			if(Player__FarmCP[playerid] != (-1)) {
				Player__ZoneType{playerid} = 0;
				DestroyDynamicCP(Player__FarmCP[playerid]);
				Player__FarmCP[playerid] = (-1);
			}
			return (-2);
		}
	}	
	return (1);
}

