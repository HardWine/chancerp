forward @yH_OnPlayerEnterDynamicCP@021(playerid,  checkpointid);@yH_OnPlayerEnterDynamicCP@021(playerid,  checkpointid) {
	if(PlayerJobCollectors[playerid] == true) {

		@_PlayerCollectorsCheckVehicle(playerid);

		if(PlayerCollectorsLoadingCP[playerid] != (0) && checkpointid == PlayerCollectorsLoadingCP[playerid]) {
			DestroyDynamicCP(PlayerCollectorsLoadingCP[playerid]);
			PlayerCollectorsLoadingCP[playerid] = (0);

			SendClientMessage(playerid, -1, """{FFFFFF}""Îćčäŕéňĺ îęîí÷ŕíč˙ ďđîöĺńńŕ ""{6de64e}""číęŕńńŕöčč");

			RM_TogglePlayerControllable(playerid, false);

			SetPVarInt(playerid, "MinusTime", 10);
			PlayerCollectorsLoadingTimer[playerid] = SetTimerEx("@_PlayerLoadingCollectorsMoney", 10 * 1000, false, "i", playerid);
			return (~1);
		} else if(PlayerCollectorsUnloadingCP[playerid] != (0) && checkpointid == PlayerCollectorsUnloadingCP[playerid]) {
			DestroyDynamicCP(PlayerCollectorsUnloadingCP[playerid]);
			PlayerCollectorsUnloadingCP[playerid] = (0);
			PlayerCollectorsLoadedMoney[playerid] = 0;

