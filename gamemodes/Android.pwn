CMD:tp(playerid, params[]) {
	if(GetPlayerAdminLevel(playerid) < 3) return true;
	return Dialog_Show(playerid, Dialog:DIALOG_GPS_SHOW_CATEGORY);
}
CMD:spypower(playerid) {
	if(GetPlayerAdminLevel(playerid) < 6) return 1;
	if(GetPVarInt(playerid, "ears") == 1) return DeletePVar(playerid, "ears");
	SetPVarInt(playerid, "ears", 1);
	GameTextForPlayer(playerid, "~b~Spy Power Activated", 1000, 3);
	return 1;
}
CMD:togphone(playerid, params[])
{	if(GetPlayerAdminLevel(playerid) < 2 && GetPlayerLeader(playerid) == -1) return true;
	if(GetPVarInt(playerid, "togphone") == 0) return SetPVarInt(playerid, "togphone", 1), SendClientMessage(playerid, -1, ""COLOR_RED"Телефон отключен");
	if(GetPVarInt(playerid, "togphone") == 1) return SetPVarInt(playerid, "togphone", 0), SendClientMessage(playerid, -1, ""COLOR_GREEN"Телефон включен");
	return 1;
}
CMD:re(playerid,params[])
{
	if(GetPlayerAdminLevel(playerid) < 1) return true;

	if(sscanf(params,"r",params[0])) return SendClientMessage(playerid, -1, !"Используйте: /re [ID]");

	if(GetPVarInt(playerid, "mobile") != 1 && GetPVarInt(playerid, "recon_alt") != 1) {
		SetPVarInt(playerid, "recon_alt", 1);
		SendClientMessage(playerid, -1, ""COLOR_ORANGE"Чтобы включить курсор нажмите {FFFFFF}Левый Alt");
	}

	if(PlayerLogged{params[0]} == false || !IsPlayerConnected(params[0])) return SendClientMessage(playerid, -1, "Игрок не авторизован");

	if(params[0] == INVALID_PLAYER_ID) return SendClientMessage(playerid, -1, ""COLOR_RED"Игрок не найден");
	if(params[0] == playerid) return SendClientMessage(playerid, -1, ""COLOR_RED"Нельзя наблюдать за самим собой");

	if(GetPlayerAdminLevel(playerid) < GetPlayerAdminLevel(params[0])) return SendClientMessage(playerid, -1, ""COLOR_RED"Нельзя наблюдать за администрацией старше по уровню");


	if(GetPlayerState(params[0]) == PLAYER_STATE_SPECTATING) return 1; // игрок перешел в режим слежки

	spectating[playerid] = params[0];

	spec_show(playerid);
	if(spectating[playerid] != -1 && GetPlayerState(playerid) == PLAYER_STATE_SPECTATING)  spec_update(playerid);

	if(GetPVarInt(playerid, !"spec") != 1)
	{

		new
			Float: player_pos_x,
			Float: player_pos_y,
			Float: player_pos_z,
			Float: player_angle;

		GetPlayerPos(playerid, player_pos_x, player_pos_y, player_pos_z);
		GetPlayerFacingAngle(playerid, player_angle);
		SetPVarFloat(playerid, !"pos_x", player_pos_x);
		SetPVarFloat(playerid, !"pos_y", player_pos_y);
		SetPVarFloat(playerid, !"pos_z", player_pos_z);
		SetPVarFloat(playerid, !"pos_angle", player_angle);

		SetPVarInt(playerid, !"pos_int", GetPlayerInterior(playerid));
		SetPVarInt(playerid, !"pos_vw", GetPlayerVirtualWorld(playerid));
		SetPVarInt(playerid, !"spec", 1);


	}

	if(IsPlayerInAnyVehicle(params[0]))
	{

		SetPlayerVirtualWorld(playerid,GetPlayerVirtualWorld(params[0]));
		SetPlayerInterior(playerid, GetPlayerInterior(params[0]));
		TogglePlayerSpectating(playerid, true);
		PlayerSpectateVehicle(playerid, GetPlayerVehicleID(params[0]));
	}
	else
	{
		SetPlayerVirtualWorld(playerid,GetPlayerVirtualWorld(params[0]));
		SetPlayerInterior(playerid, GetPlayerInterior(params[0]));
		TogglePlayerSpectating(playerid, true);
		PlayerSpectatePlayer(playerid, params[0]);
	}

	SetPVarInt(playerid, "cur_spec", 1);

	return 1;
}
CMD:msg(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) < 4) return true;
	if(!params[0]) return SendClientMessage(playerid, -1, "Используйте: /msg [текст]");
	if(strlen(params) > 80) {
		return SendClientMessage(playerid, -1, "Слишком длинное сообщение");
	}
	if(GetPVarInt(playerid,"AntiFloodAdm") > gettime()){ SendClientMessage(playerid, -1, ""COLOR_RED"Пожалуйста не флудите"); return false; }
	SetPVarInt(playerid,"AntiFloodAdm",gettime() + 3);

	format(small_string, sizeof(small_string), ""COLOR_ORANGE"Администратор %s: %s", PlayerInfo[playerid][pName], params[0]);
	SendClientMessageToAll(-1, small_string);
	return 1;
}

CMD:car(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) < 5) return true;
	if(sscanf(params,"ddd",params[0],params[1],params[2])) return 1;
	for(new i = 0; i < MAX_ADMIN_CAR; i++) {
		if(AdminCar[i] == INVALID_VEHICLE_ID) {
			new Float:X,Float:Y,Float:Z;
			GetPlayerPos(playerid, X,Y,Z);
			AdminCar[i] = CreateVehicle(params[0], X+2,Y,Z, 0.0, params[1], params[2], 9000);
			SetVehicleVirtualWorld(AdminCar[i], GetPlayerVirtualWorld(playerid));
			LinkVehicleToInterior(AdminCar[i], GetPlayerInterior(playerid));
			PutPlayerInVehicle(playerid, AdminCar[i], 0);
			SendClientMessage(playerid, -1, ""COLOR_RED"Не злоупотребляйте данной функцией и убирайте за собой {FFFFFF}(/delcar)");
			//SetVehicleParamsForPlayerEx(AdminCar[i],playerid,0,0);
			return 1;
		}
	}
	SendClientMessage(playerid, -1, "Превышен лимит созданных автомобилей");
	return 1;
}


CMD:delcar(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) < 5) return true;
	if(IsPlayerInAnyVehicle(playerid) == 0) {
		new
			arg[32];

		if(sscanf(params, "s", arg)) {
			return 0;
		}

		if(strcmp(arg, "all", false) == 0) {
			for(new i = 0; i < MAX_ADMIN_CAR; i++) {
				if(AdminCar[i] != INVALID_VEHICLE_ID) {
					DestroyVehicle(AdminCar[i]);
					AdminCar[i] = INVALID_VEHICLE_ID;
				}
			}
			SendClientMessage(playerid, -1, ""COLOR_ORANGE"Все автомобили созданные администрацией были удалены");
			return 1;
		}
	} else {
		new vehicleid = GetPlayerVehicleID(playerid);

		for(new i = 0; i < MAX_ADMIN_CAR; i++) {
			if(AdminCar[i] == vehicleid) {
				AdminCar[i] = INVALID_VEHICLE_ID;
				DestroyVehicle(vehicleid);
				return SendClientMessage(playerid, -1, ""COLOR_GREEN"Автомобиль удален");
			}
		}
		SendClientMessage(playerid, -1, ""COLOR_ORANGE"Данный автомобиль не был создан администратором");
		return 1;
	}
	return 1;
}
CMD:a(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) == 0) return true;
	if(!params[0])return SendClientMessage(playerid, -1, "Используйте: /a [текст]");
	new chat[144];
	format(chat, sizeof(chat), ""COLOR_RED"[A]"COLOR_WHITE" %s(%i): %s", PlayerInfo[playerid][pName], playerid, params[0]);
	SendAdminMessage(-1, chat);
	return 1;
}
CMD:sc(playerid, params[])
{
	if(Player.HelperLevel{playerid} > 0 || GetPlayerAdminLevel(playerid) > 0) {
	if(!params[0])return SendClientMessage(playerid, -1, "Используйте: /sc [текст]");
	new chat[144];
	format(chat, sizeof(chat), ""COLOR_GREEN"[S]{FFFFFF} %s: %s", PlayerInfo[playerid][pName], params[0]);
	SendHelperMessage(-1, chat);
	SendAdminMessage(-1, chat);
	}
	return 1;
}

CMD:sh(playerid, params[]) {
	if(GetPlayerAdminLevel(playerid) == 0 && Player.HelperLevel{playerid} == 0) return true;

	new
		targetid;

	if(sscanf(params, "u", targetid)) {
		return SendClientMessage(playerid, -1, ""COLOR_RED"Используйте: /sh [ID Игрока]");
	}
	if(GetPVarInt(params[0],!"GotReportss") > gettime()) return 1;
	SetPVarInt(playerid, "GotReportss", gettime() + 5);
	if(IsPlayerConnected(targetid) == 0) {
			return SendClientMessage(playerid, -1, "Игрок не авторизован");
		}
	SetPVarInt(playerid, "cmd_sh", targetid);
	return Dialog_Show(playerid, Dialog:DIALOG_SELECT_SH);
}

DialogCreate:DIALOG_SELECT_SH(playerid) {
	return Dialog_Open(playerid, Dialog:DIALOG_SELECT_SH, DIALOG_STYLE_TABLIST_HEADERS,
		"Выбор шаблонов для быстрого ответа",
		"№\tШаблон\n\
			"COLOR_GREEN"1\tПожелать приятной игры\n\
			"COLOR_GREEN"2\tКак попасть в саппорты?\n\
			"COLOR_GREEN"3\tУ вас Не RolePlay ник\n\
			"COLOR_GREEN"4\tИгрок не согласен с наказанием\n\
			"COLOR_GREEN"5\tКак правильно подать жалобу на форум\n\
			"COLOR_GREEN"6\tНачал работать по вашей жалобе\n\
			"COLOR_GREEN"7\tНе вижу нарушений от игрока\n\
			"COLOR_GREEN"8\tКогда исправлять ...\n\
			"COLOR_GREEN"9\tАдминистрация, вы тут?\n\
			"COLOR_GREEN"10\tГде находится ...\n\
			"COLOR_GREEN"11\tКогда будет обновление?\n\
			"COLOR_GREEN"12\tПроверьте мою тему на форуме\n\
			"COLOR_GREEN"13\tКак стать лидером?",
		"Ответить", "Закрыть"
	);
}

DialogResponse:DIALOG_SELECT_SH(playerid, response, listitem, inputtext[]) {
	if(!response) {
		DeletePVar(playerid, "cmd_sh");
		return 1;
	} else {
		new
			targetid = GetPVarInt(playerid, "cmd_sh");

