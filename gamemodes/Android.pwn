				{
					return SendClientMessage(playerid, -1, MSG_START_JOB_DAY);
				}

				return ShowPlayerDialog(playerid, dWarehouse, DIALOG_STYLE_LIST, ""COLOR_BLUE"Склад", "{FFFFFF}Положить материалы\nВзять материалы\nОнлайн фракции", "Далее", "Закрыть");
			}
