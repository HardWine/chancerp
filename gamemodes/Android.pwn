					SetPlayerInt(sellerid, "Roof_2", PlayerInfo[sellerid][Roof_2]);
					SetPlayerInt(sellerid, "Sideskirt_2", PlayerInfo[sellerid][Sideskirt_2]);
					SetPlayerInt(sellerid, "Lamps_2", PlayerInfo[sellerid][Lamps_2]);
					SetPlayerInt(sellerid, "Nitro_2", PlayerInfo[sellerid][Nitro_2]);
					SetPlayerInt(sellerid, "Exhaust_2", PlayerInfo[sellerid][Exhaust_2]);
					SetPlayerInt(sellerid, "Wheels_2", PlayerInfo[sellerid][Wheels_2]);
					SetPlayerInt(sellerid, "Stereo_2", PlayerInfo[sellerid][Stereo_2]);
					SetPlayerInt(sellerid, "Hydraulics_2", PlayerInfo[sellerid][Hydraulics_2]);
					SetPlayerInt(sellerid, "Front_Bumper_2", PlayerInfo[sellerid][Front_Bumper_2]);
					SetPlayerInt(sellerid, "Rear_Bumper_2", PlayerInfo[sellerid][Rear_Bumper_2]);
					SetPlayerInt(sellerid, "Vent_Right_2", PlayerInfo[sellerid][Vent_Right_2]);
					SetPlayerInt(sellerid, "Vent_Left_2", PlayerInfo[sellerid][Vent_Left_2]);
					SetPlayerInt(sellerid, "Vynil_2", PlayerInfo[sellerid][Vynil_2]);					

					SetPlayerInt(playerid, "Car2", PlayerInfo[playerid][pCar2]);
					SetPlayerInt(sellerid, "Car2", PlayerInfo[sellerid][pCar2]);

					SetPlayerInt(playerid, "Car2Col", PlayerInfo[playerid][pCar2Col]);
					SetPlayerInt(playerid, "Car2Col2", PlayerInfo[playerid][pCar2Col2]);
					SetPlayerInt(sellerid, "Car2Col", PlayerInfo[sellerid][pCar2Col]);
					SetPlayerInt(sellerid, "Car2Col2", PlayerInfo[sellerid][pCar2Col2]);

					SetPlayerInt(playerid, "Mileage2", PlayerInfo[playerid][pMileage2]);
					SetPlayerInt(sellerid, "Mileage2", PlayerInfo[sellerid][pMileage2]);

					SetPlayerInt(playerid, "RadarDetect2", PlayerInfo[playerid][pRadarDetect2]);
					SetPlayerInt(sellerid, "RadarDetect2", PlayerInfo[sellerid][pRadarDetect2]);	
				}

				LoadCarPlayerId(playerid);
				LoadCarPlayerId(sellerid);

				PlayerInfo[playerid][pTransferControl2] = PlayerInfo[playerid][pTransferControl2]+1;
				SetPlayerInt(playerid, "TransferControl2", PlayerInfo[playerid][pTransferControl2]);

				PlayerInfo[sellerid][pTransferControl2] = PlayerInfo[sellerid][pTransferControl2]+1;
				SetPlayerInt(sellerid, "TransferControl2", PlayerInfo[sellerid][pTransferControl2]);

				CancelOffer(playerid);

				static string[512];

				mysql_format(database,
					string, sizeof(string),
					"INSERT INTO `changecar_log` (`Seller`, `Buyer`, `Addition`, `BuyerCar`, `SellerCar`, `BuyerMileage`, `SellerMileage`) VALUES (%i, %i, %i, %i, %i, %i, %i)",
						GetPlayerAccountID(sellerid),
						GetPlayerAccountID(playerid),
						price,
						oldcar,
						sellercar,
						mile,
						s_mile
				);
				return mysql_pquery(database, string);
			}
		}
		case dStats: {
			if(!response) {
				return 1;
			}
			if(response) {
				callcmd::mn(playerid,"\0");
			}
		}
		case dGetPassport: {
			if(!response) {
				return SendClientMessage(playerid, -1, ""COLOR_RED"Выдача паспорта отозвана");
			}
			if(response) {
				new strval_inputtext = strval(inputtext);

				if(strval_inputtext > 1974 || strval_inputtext < 1920) {
					SendClientMessage(playerid, -1, ""COLOR_RED"Дата выдачи должна быть от 1920 до 1974!");
					return ShowPlayerDialog(playerid, dGetPassport, DIALOG_STYLE_INPUT, "Выдача паспорта", "{FFFFFF}Введите дату рождения горожанина", "Выбрать", "Закрыть");
				}

				format(small_string, sizeof(small_string), ""COLOR_ORANGE"Дата рождения: {FFFFFF}%d", strval_inputtext);
				SendClientMessage(playerid, -1, small_string);
				new player_get = GetPVarInt(playerid, "player_passport");

				if(GetDistanceBetweenPlayerz(playerid, player_get, 5.00) != 1) {
					SendClientMessage(playerid, -1, ""COLOR_RED"Вы слишком далеко от указанного игрока");
					return SendClientMessage(playerid, -1, ""COLOR_RED"Выдача паспорта отозвана");
				}
				format(small_string, sizeof(small_string), "%s заполнил(а) документы", PlayerInfo[playerid][pName]);
				ProxDetector(playerid, 20, C_PURPLE, small_string);				

				SetPVarInt(player_get, "player_birth", strval_inputtext);
				SetPVarInt(player_get, "passport_giver", playerid);
				format(big_string, sizeof(big_string), "{FFFFFF}Проверьте данные указанные ниже\n\nДата рождения: %d (возраст %d)",
					strval_inputtext, 1992-strval_inputtext
				);
				return ShowPlayerDialog(player_get, dGetPassport2, DIALOG_STYLE_MSGBOX, "Получение паспорта", big_string, "Подписать", "Отмена");
			}

		}
		case dGetPassport2: {
			if(!response) {
				SendClientMessage(GetPVarInt(playerid, "passport_giver"), -1, ""COLOR_RED"Выдача паспорта отозвана");
				return SendClientMessage(playerid, -1, ""COLOR_RED"Выдача паспорта отозвана");
			}
			if(response) {
				new player_giver = GetPVarInt(playerid, "player_passport");

				format(small_string, sizeof(small_string), "%s проверил(а) документы", PlayerInfo[playerid][pName]);
				ProxDetector(playerid, 20, C_PURPLE, small_string);						

				SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы получили свой паспорт!");
				SendClientMessage(player_giver, -1, ""COLOR_GREEN"Вы выдали горожанину паспорт");

				format(small_string, sizeof(small_string), "%s вручил(а) %s паспорт гражданина San Andreas", PlayerInfo[player_giver][pName], PlayerInfo[playerid][pName]);
				ProxDetector(playerid, 20, C_PURPLE, small_string);					
				AddPlayerAchievement(player_giver, E_MAKE_CITIZENSHIP);
				PlayerInfo[playerid][pBirth] = GetPVarInt(playerid, "player_birth"); SetPlayerInt(playerid, "Birth", PlayerInfo[playerid][pBirth]);
			}
		}
