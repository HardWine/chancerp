forward CGen_OOM(ctx[AsmContext]);

public CGen_OOM(ctx[AsmContext])
{
	switch (AsmGetError(ctx))
	{
	case ASM_ERROR_OPCODE:
	{
		Debug_Print0("\7\7\7*** YSI Error: " #"Unknown opcode written to code generation (CGen) space.");
	}
	case ASM_ERROR_OPERAND:
	{
		Debug_Print0("\7\7\7*** YSI Error: " #"Invalid operand written to code generation (CGen) space.");
	}
	case ASM_ERROR_SPACE:
	{
		static excess = 0;


		excess += 6;
		Debug_Print0("\7\7\7\7\7*** YSI Fatal Error: " #"Out of code generation (CGen) space.  The current value of `CGEN_MEMORY` is `%d`, please recompile with a higher value (approximately %d).", (10000), (10000) + excess);
	}
	case ASM_ERROR_LABEL_OVERFLOW:
	{
		Debug_Print0("\7\7\7\7\7*** YSI Fatal Error: " #"Out of label space.  The current value of `ASM_MAX_LABELS` is `%d`, please recompile with a higher value.", (8));
	}
	case ASM_ERROR_LABEL_DUPLICATE:
	{
		Debug_Print0("\7\7\7\7\7*** YSI Fatal Error: " #"Duplicate label in code generation.");
	}
	}
	AsmClearError(ctx);
}

