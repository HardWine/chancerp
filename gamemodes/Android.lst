forward Casino_OnPlayerEnterDynArea(playerid,  areaid);
public Casino_OnPlayerEnterDynArea(playerid,  areaid) {
	static 
		data[2];

	Streamer_GetArrayData((6), areaid, E_STREAMER_EXTRA_ID, data, 2);

	switch(data[0]) {
		case (7845): {
			for(new i = 0; i < sizeof(CasinoInfo); i++) {
				if(CasinoInfo[i][CI_Area1] == areaid) {
					if(CasinoInfo[i][CI_Player1] != (0xFFFF)) {
						SendClientMessage(playerid, -1, """{FFAF00}""Этот столик уже занят.");
						return 1;
					} else {
						CallLocalFunction("CheckGame", "iii", playerid, i, 1);
						return 1;
					}
				} else if(CasinoInfo[i][CI_Area2] == areaid) {
					if(CasinoInfo[i][CI_Player2] != (0xFFFF)) {
						SendClientMessage(playerid, -1, """{FFAF00}""Этот столик уже занят.");
						return 1;
					} else {
						CallLocalFunction("CheckGame", "iii", playerid, i, 2);
						return 1;
					}
				}
			}
		}
		case (7843): {
			for(new i = 0; i < sizeof(CasinoInfo); i++) {
				if(CasinoInfo[i][CI_Croupier_Area] == areaid) {
					if(CasinoInfo[i][CI_CroupierID] == (0xFFFF)) {
						SendClientMessage(playerid, -1, """{FFAF00}""Вы устроились крупье. Займите стол и принимайте ставки");
