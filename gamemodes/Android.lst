    if(PlayerInfo[playerid][pRank] < 9) return SendClientMessage(playerid, -1, """{ff353c}""Ôóíęöč˙ äîńňóďíŕ ń 9 đŕíăŕ");
    if(Fraction[crutch][E_FRACTION_LEADER_ID] == (-1)) {
