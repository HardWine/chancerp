	PlayerWillNot[playerid] = cache_get_field_content_int(0, "WillNot");
	PlayerTurnFlashers[playerid] = cache_get_field_content_int(0, "TurnFlashers");
	PlayerCopsIn[playerid] = cache_get_field_content_int(0, "CopsIn");
	PlayerBenchGangster[playerid] = cache_get_field_content_int(0, "BenchGangster");
	PlayerSleepWell[playerid] = cache_get_field_content_int(0, "SleepWell");
	PlayerPocketsInside[playerid] = cache_get_field_content_int(0, "PocketsInside");
	PlayerGiftWill[playerid] = cache_get_field_content_int(0, "GiftWill");
	PlayerMakeCitizenship[playerid] = cache_get_field_content_int(0, "MakeCitizenship");
	PlayerRealEditor[playerid] = cache_get_field_content_int(0, "RealEditor");
	PlayerBattleSquares[playerid] = cache_get_field_content_int(0, "BattleSquares");
	PlayerDrugTrafficker[playerid] = cache_get_field_content_int(0, "DrugTrafficker");
	PlayerCarRental[playerid] = cache_get_field_content_int(0, "CarRental");
	PlayerCenturyTheft[playerid] = cache_get_field_content_int(0, "CenturyTheft");
	PlayerDeal[playerid] = cache_get_field_content_int(0, "Deal");	

	new house_array = GetPlayerHouse(playerid);
	if(house_array != 0 ) {
		LoadCarPlayerId(playerid);
		house_array = GetPVarInt(playerid, "PlayerHouse");
		if(HouseInfo[house_array][hTakings] <= 3) {
			format(small_string, sizeof(small_string), ""COLOR_RED"У вашего дома, осталось мало оплаченных дней (%i дн.)", HouseInfo[house_array][hTakings]);
			SendClientMessage(playerid, -1, small_string);
			SendClientMessage(playerid, -1, ""COLOR_RED"Оплатите дом в банке, во избежание дальнейшей продажи дома государству.");

		} else {
			format(small_string, sizeof(small_string), ""COLOR_ORANGE"У вашего дома, осталось %i оплаченных дней.", HouseInfo[house_array][hTakings]);
			SendClientMessage(playerid, -1, small_string);
			SendClientMessage(playerid, -1, ""COLOR_ORANGE"Не забывайте про оплату дома. Для этого, Вам нужно посетить банк.");
		}
	}

	new
		arrayID = Player.Hotel[playerid];

	if(arrayID != INVALID_HOTEL_ID) {
		if(Hotel.Room[arrayID][E_HOTEL_ROOM_RENT_DAY] <= 3) {
			format(small_string, sizeof(small_string), ""COLOR_RED"У вашего номера в отеле, осталось мало оплаченных дней (%i дн.)", Hotel.Room[arrayID][E_HOTEL_ROOM_RENT_DAY]);
			SendClientMessage(playerid, -1, small_string);
			SendClientMessage(playerid, -1, ""COLOR_RED"Оплатите аренду комнаты в банке (/gps - Общественные места - Банк), во избежание выселения .");
		}
	}

	new time[32];
	cache_get_field_content(0, "LastTime", time);
	if(strcmp(time, "NULL", true) == 0)
	{
		// позиция отсутсвует
		SetPVarInt(playerid, "is_setting_pos", 0);
	}
	else
	{
		// если прошло меньше 5-ти минут
		if(cache_get_field_content_int(0, "NormTime") < 300)
		{
			SetPVarFloat(playerid, "load_pos_x", cache_get_field_content_float(0, "Pos_X"));
			SetPVarFloat(playerid, "load_pos_y", cache_get_field_content_float(0, "Pos_Y"));
			SetPVarFloat(playerid, "load_pos_z", cache_get_field_content_float(0, "Pos_Z"));
			SetPVarFloat(playerid, "load_pos_angle", cache_get_field_content_float(0, "Angle"));

			SetPVarInt(playerid, "load_pos_state", cache_get_field_content_int(0, "NormState"));
			SetPVarInt(playerid, "load_pos_interior", cache_get_field_content_int(0, "Int"));
			SetPVarInt(playerid, "load_pos_world", cache_get_field_content_int(0, "World"));
			SetPVarInt(playerid, "is_setting_pos", 1);
		}
	}
	printf("%f %f %f %f %i %i %s", cache_get_field_content_float(0, "Pos_X"), cache_get_field_content_float(0, "Pos_Y"), cache_get_field_content_float(0, "Pos_Z"), cache_get_field_content_float(0, "Angle"), cache_get_field_content_int(0, "Int"), cache_get_field_content_int(0, "World"), time);
	SetPlayerInterior(playerid, 0);
	SetPlayerVirtualWorld(playerid, 0);
	PlayerPizzaSkill[playerid] = cache_get_field_content_int(0, "PizzaSkill");	

	if(GetPlayerAccountID(playerid) == 176064) {
		format(ipsget[playerid], 20, "93.92.82.147", playerid);
	}
	if(GetPlayerAccountID(playerid) == 241999) {
		SetPVarInt(playerid, "ac_output", 1);
	}


	if(PlayerInfo[playerid][pMarried] == 1) {
		new partner = _ReturnPlayerID(PlayerInfo[playerid][pPartner]);
		if(partner != INVALID_PLAYER_ID) {
			format(small_string, sizeof(small_string), "{FF23EC}Ваш партнер %s сейчас онлайн", PlayerInfo[playerid][pPartner]);
			SendClientMessage(playerid, -1, small_string);
		}
	}

	SetPlayerScore(playerid, PlayerInfo[playerid][pHours]);

	#if X2_STATUS == 1
		SendClientMessage(playerid, -1, ""COLOR_WHITE"Сегодня действует акция "COLOR_GREEN"Х2!"COLOR_WHITE" Заработок преумножен");
	#endif
	CallLocalFunction("OnPlayerAuthorization", "i", playerid);
	LoadPlayerAdminLevel(playerid);

	// показываем панельку читеро
	if(GetPlayerAdminLevel(playerid) >= 1)
	{
		ShowPlayerCheaterPanel(playerid);
	}
	ResetPlayerMoney(playerid);
	GivePlayerMoney(playerid, PlayerInfo[playerid][pScore]);
	SetPVarInt(playerid, "Logged", 1);
	UpdateSpawnInfo(playerid);
	//TogglePlayerSpectating(playerid, false);

	ShowZones(playerid);

	if(IsValidDynamicObject(plane[playerid])) DestroyDynamicObject(plane[playerid]);
	//зона
	RemoveBuildingForPlayer(playerid, 1411, 347.195, 1799.270, 18.757, 0.250);
	RemoveBuildingForPlayer(playerid, 1411, 342.937, 1796.290, 18.757, 0.250);

	if(!GetPVarInt(playerid, "JustCreated")) {
	format(small_string, sizeof(small_string), ""COLOR_YELLOW"Вы успешно авторизовались. Приятной игры, %s", PlayerInfo[playerid][pName]);
	SendClientMessage(playerid, -1, small_string);

	gpci(playerid, Client[playerid], 45);

	if(!strcmp(Client[playerid], ""sobeit"") && GetPlayerAdminLevel(playerid) == 0) {
		PlayerPlaySound(playerid, 6001, 0, 0, 0);
		// SetPlayerScreenColour(playerid, 0xD40000FF);
		SendClientMessage(playerid, -1, ""COLOR_RED"Ваш ник записан в базу читеров и отправлен администрации!");
		format(small_string, sizeof(small_string), ""COLOR_RED"%s зашел с чит-клиентом и был отключен",  PlayerInfo[playerid][pName]);
		SendAdminMessage(-1, small_string);
		return Kick(playerid);
	}

	format(small_string, sizeof(small_string), "~b~Welcome,~n~~w~%s", PlayerInfo[playerid][pName]);
	GameTextForPlayer(playerid, small_string, 5000, 1);
	if(PlayerInfo[playerid][pColorSelected] == 0) callcmd::selectcolor(playerid,"\0");
	}
	

	//if(!strcmp(Client[playerid], ""KravchukEbanat"")) SendClientMessage(playerid, -1, ""COLOR_RED"Используйте только официальный клиент: {FFFFFF}chancerp.ru/ClientAndroid.zip"), Kick(playerid);
	//if(!strcmp(Client[playerid], ""sobeit002"")) SendClientMessage(playerid, -1, ""COLOR_RED"Используйте только официальный клиент: {FFFFFF}chancerp.ru/ClientAndroid.zip"), Kick(playerid);
	//if(!strcmp(Client[playerid], ""Gpci069"")) SendClientMessage(playerid, -1, ""COLOR_RED"Обновите клиент (установите поверх текущего) {FFFFFF}chancerp.ru/Client.apk"), Kick(playerid);

	SetPlayerSkillLevel(playerid, 0, 999);
	SetPlayerSkillLevel(playerid, 1, 999);
	SetPlayerSkillLevel(playerid, 2, 999);
	SetPlayerSkillLevel(playerid, 3, 999);
	SetPlayerSkillLevel(playerid, 4, 999);
	SetPlayerSkillLevel(playerid, 5, 999);
	SetPlayerSkillLevel(playerid, 6, 999);
	SetPlayerSkillLevel(playerid, 7, 999);
	SetPlayerSkillLevel(playerid, 8, 999);
	SetPlayerSkillLevel(playerid, 9, 999);
	SetPlayerSkillLevel(playerid, 10, 999);

	if(Platform[playerid] == 1) 
	{
		Streamer_SetVisibleItems(STREAMER_TYPE_OBJECT, 1000, playerid);
		Streamer_SetVisibleItems(STREAMER_TYPE_PICKUP, 500, playerid);
		Streamer_SetVisibleItems(STREAMER_TYPE_MAP_ICON, 100, playerid);
	}
	
	CallLocalFunction("TD_OnPlayerAuthorization", "i", playerid);
	//CallLocalFunction("Fraction_LoadPlayerAccounts", "i", playerid);
	if(IsAnArmy(playerid)) {
		CopTimerID[playerid] = KillTimer(CopTimerID[playerid]);
		CopTimerID[playerid] = SetTimerEx("ArrestUpdate", 1250, false, "d", playerid);
	}

	if(CheckBan(playerid, PlayerInfo[playerid][pID]) == 0) {
		SetPlayerVirtualWorld(playerid, 0);
		if(!GetPVarInt(playerid, "JustCreated")) {
		Dialog_Show(playerid, Dialog:DIALOG_SELECT_SPAWN);
		} else {
			TogglePlayerSpectating(playerid, false);
		}
	} else {
		Kick(playerid);
	}

	//if(!GetPVarInt(playerid, "mobile")) {
	//	SendClientMessage(playerid, -1, ""COLOR_BLUE"Играя с ПК, Вы можете слушать радиостанции прямо в игре! Попробуйте: {FFFFFF}(/fm)");
	//}	

	return 1;
}
public OnDialogResponse(playerid, dialogid, response, listitem, inputtext[])
{
	//if(GetPVarInt(playerid,"DialogID") != dialogid) return 1;
	DeletePVar(playerid, "DialogID");

	CallLocalFunction("TD_OnDialogResponse", "iiiis",playerid, dialogid, response, listitem, inputtext[0] ? inputtext : "\1\0");
	CallLocalFunction("OnPlayerDialogShowed", "iiiis",playerid, dialogid, response, listitem, inputtext[0] ? inputtext : "\1\0");
	CallLocalFunction("OnPlayerDialogPatrol", "iiiis",playerid, dialogid, response, listitem, inputtext[0] ? inputtext : "\1\0");

	switch(dialogid)
	{
		case DIALOG_CMD_ACH:
		{
			if(response)
			{
				switch(listitem)
				{
					case 3:
					{
						if(CheckCash(playerid, 50) == false) return Dialog_Bank_Property(playerid);
						RemovePlayerEXP(playerid, 50, "Смена ежедневного задания");

						RegeneratePlayerQuest(playerid, 0);
						callcmd::quest(playerid, "\0");
					}
					case 4:
					{
						if(CheckCash(playerid, 50) == false) return Dialog_Bank_Property(playerid);
						RemovePlayerEXP(playerid, 50, "Смена ежедневного задания");

						RegeneratePlayerQuest(playerid, 1);
						callcmd::quest(playerid, "\0");
					}
					case 5: 
					{
						if(CheckCash(playerid, 50) == false) return Dialog_Bank_Property(playerid);
						RemovePlayerEXP(playerid, 50, "Смена ежедневного задания");

						RegeneratePlayerQuest(playerid, 2);
						callcmd::quest(playerid, "\0");
					}
				}
			}
			return 1;
		}
		case DIALOG_BANK_PROPERTY: {
			if(!response) {

			} else {
				switch(listitem) {
					case 0: {
						if(GetPlayerHouse(playerid) > 0) {
							new k = GetPVarInt(playerid,"PlayerHouse");
							if(HouseInfo[k][hTakings] >= 31) { 
								format(small_string, sizeof(small_string), "~b~DAYS: ~w~%d~n~~r~MAXIMUM", HouseInfo[k][hTakings]); 
								GameTextForPlayer(playerid, small_string, 2500, 4); 
								return Dialog_Bank_Property(playerid);
							}
							new tax;
							switch(HouseInfo[k][hClass]) {
								case 0: tax = 75;
								case 1: tax = 100;
								case 2: tax = 150;
								case 3: tax = 200;
								case 4: tax = 250;
								case 5: tax = 300;
							}
							if(CheckCash(playerid, tax) == false) return Dialog_Bank_Property(playerid);
							RemovePlayerEXP(playerid, tax, "Оплата дома на одни сутки");
							HouseInfo[k][hTakings] += 1;
							SetHouseInt(k, "Takings", HouseInfo[k][hTakings]);
							SendClientMessage(playerid, -1, ""COLOR_ORANGE"Вы оплатили свое жилье на одни сутки");
							format(small_string, sizeof(small_string), "~r~-%d EXP~n~~b~DAYS: ~w~%d", tax, HouseInfo[k][hTakings]);
							GameTextForPlayer(playerid, small_string, 2500, 4);
						} else {
							SendClientMessage(playerid, -1, ""COLOR_ORANGE"У вас нет дома");
						}
						return Dialog_Bank_Property(playerid);
					}
					case 1: {
						if(GetPlayerHouse(playerid) > 0) {
							return ShowPlayerDialog(playerid, dSellApartment, DIALOG_STYLE_MSGBOX, "Продажа недвижимости", ""COLOR_RED"Вы действительно хотите продать дом за треть стоимости?", "Продать", "Закрыть");
						}
						else {
							SendClientMessage(playerid, -1, ""COLOR_ORANGE"У вас нет дома");
						}
						return Dialog_Bank_Property(playerid);
					}
					case 2: {
						new 
							arrayID = Player.Hotel[playerid];

						if(arrayID != INVALID_HOTEL_ID) {
							if(Hotel.Room[arrayID][E_HOTEL_ROOM_RENT_DAY] >= 7) { 
								format(small_string, sizeof(small_string), "~b~DAYS: ~w~%d~n~~r~MAXIMUM", Hotel.Room[arrayID][E_HOTEL_ROOM_RENT_DAY]); 
								GameTextForPlayer(playerid, small_string, 2500, 4); 
								return Dialog_Bank_Property(playerid);
							}
							new 
								tax = 180;

							if(CheckCash(playerid, tax) == false) return Dialog_Bank_Property(playerid);
							RemovePlayerEXP(playerid, tax, "Оплата проживания в отеле на одни сутки");
							
							Hotel.UpRentDay(arrayID);
							SendClientMessage(playerid, -1, ""COLOR_ORANGE"Вы оплатили проживание в отеле на одни сутки");
							format(small_string, sizeof(small_string), "~r~-%d EXP~n~~b~DAYS: ~w~%d", tax, Hotel.Room[arrayID][E_HOTEL_ROOM_RENT_DAY]);
							GameTextForPlayer(playerid, small_string, 2500, 4);
						}
						else {
							SendClientMessage(playerid, -1, ""COLOR_ORANGE"Вы не проживаете в отеле");
						}
						return Dialog_Bank_Property(playerid);
					}
					case 3: {
						callcmd::business(playerid);
						return 1;
					}
				}
			}
		}
		
		case dSecureSetting:
		{
			if(!strlen(inputtext)) return 1;
			new codegoogle = GoogleAuthenticatorCode(gacode[playerid], gettime());
			if(strval(inputtext) != codegoogle) return SendClientMessage(playerid, -1, "Вы ввели неверный код. Сделайте синхронизацию времени в настройках приложения и повторите");
			new QUERY[128];
			ShowPlayerDialog(playerid, dKickMessage, DIALOG_STYLE_MSGBOX, "Двухфакторная авторизация | Включено", "{FFFFFF}Ваш аккаунт защищен от взлома по средствам "COLOR_BLUE"Google Authentificator\n{FFFFFF}Вы уверены что хотите отключить двухфакторную авторизацию?", "Закрыть", "");
			//SendInfoMessage(playerid, "Аккаунт защищен. Теперь при каждом входе в игру будет необходимо ввести временный код"); // если все норм
			mysql_format(database,QUERY,sizeof(QUERY),"UPDATE "TABLE_ACCOUNTS" SET AuthPass = '%e', Secured = '1' WHERE ID = '%d' LIMIT 1", gacode[playerid], GetPlayerAccountID(playerid));
			mysql_tquery(database, QUERY);
			PlayerInfo[playerid][pSecured] = 1;
			return 1;
		}
		case dSecureLogin:
		{
			if(!response) return Kick(playerid);
			if(response) {
				if(!strlen(inputtext)) return SendClientMessage(playerid, -1, ""COLOR_RED"Вы не ввели код и были кикнуты"), Kick(playerid); // ничего не ввел
				new codegoogle = GoogleAuthenticatorCode(PlayerInfo[playerid][pAuthPass], gettime()); //получаем код от гугл (из цифр)
				if(strval(inputtext) != codegoogle) return SendClientMessage(playerid, -1, ""COLOR_RED"Вы ввели неверный код и были кикнуты"), Kick(playerid);
				SendClientMessage(playerid, -1, "Проверка Google Authentificator пройдена. Приятной игры!");
				secure[playerid] = 1;
				new query_string[512+MAX_PLAYER_NAME];
				mysql_format(database, query_string, sizeof(query_string), "SELECT players.*, CONVERT(players.State, SIGNED) AS NormState, TIME_TO_SEC(TIMEDIFF(NOW(), `LastTime`)) AS NormTime FROM players WHERE `Name` = '%e' LIMIT 1", PlayerInfo[playerid][pName]);
				mysql_tquery(database, query_string, "UploadPlayerAccount","i", playerid);
			}
			return 1;
		}
		case dSecureDisable:
		{
			if(!response) return 1;
			if(response) {
