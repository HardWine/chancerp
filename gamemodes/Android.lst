forward pc_cmd_lspd(playerid); public pc_cmd_lspd(playerid) {
	if(IsPlayerInAnyVehicle(playerid) && IsPlayerInRangeOfPoint(playerid, 10.0, 1544.65894, -1630.77771, 13.20900)) {
		if(barrier_lspd_state == 0) {
		if(!IsAGov(playerid)) return SendClientMessage(playerid, -1, """{ff353c}""Âű íĺ ăîńóäŕđńňâĺííűé ńëóćŕůčé, ďđîĺçä çŕęđűň!");
		MoveObject(barrier_lspd, 1544.65894, -1630.77771, 13.20900, 1500, 0.00000, 0.00000, -90.00000);
		SendClientMessage(playerid, -1, """{6de64e}""Ďđîĺçä îňęđűň íŕ {FFFFFF}10 ńĺęóíä""{6de64e}"", ďđîĺçćŕéňĺ!");
		barrier_lspd_state = 1;
		SetTimer("back_barrier_lspd", 10000, false);
		}
	}
	return 1;
}

forward back_barrier_lspd();
public back_barrier_lspd() {
	barrier_lspd_state = 0;
	MoveObject(barrier_lspd, 1544.65894, -1630.77771, 13.20900, 1500, 0.00000, -90.00000, -90.00000);
}



