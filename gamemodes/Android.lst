forward pc_cmd_boat(playerid); public pc_cmd_boat(playerid) {
	new 
		model = PlayerYachtModel[playerid];

	if(IsPlayerInAnyVehicle(playerid) == 1) return 1;
	if(GetPlayerVirtualWorld(playerid) != 0) return 1;
	if(GetPlayerInterior(playerid) != 0) return 1;
	if(GetPlayerState(playerid) != (1)) return 1;

	if(GetPVarInt(playerid,"Destroyed") > gettime()) return SendClientMessage(playerid, -1, """{ff353c}""Âŕř âîäíűé ňđŕíńďîđň íĺäŕâíî áűë óíč÷ňîćĺí, çŕáĺđčňĺ ĺăî â ďîđňó");

	if(model == (-1)) {
		return SendClientMessage(playerid, -1, """{FFAF00}""Ó âŕń íĺň ëč÷íîăî âîäíîăî ňđŕíńďîđňŕ");
	}
	if(PlayerYachtVehicleID[playerid] != (0xFFFF)) {
		return SendClientMessage(playerid, -1, """{FFAF00}""Âŕř âîäíűé ňđŕíńďîđň óćĺ çŕńďŕâíĺí");
	}

	if(IsPlayerSwimming(playerid) == 0) return SendClientMessage(playerid, -1, """{FFAF00}""Íĺîáőîäčěî íŕőîäčňüń˙ â âîäĺ");

	new
		Float: player_pos_x,
		Float: player_pos_y,
		Float: player_pos_z,
		Float: player_angle;	

	GetPlayerPos(playerid, player_pos_x, player_pos_y, player_pos_z);
	GetPlayerFacingAngle(playerid, player_angle);		

	PlayerYachtVehicleID[playerid] = Iter_CreateVehicle(model, player_pos_x,player_pos_y,player_pos_z+3,player_angle, 1, 1, 86400);
	RM_PutPlayerInVehicle(playerid, PlayerYachtVehicleID[playerid], 0);

	Streamer_Update(playerid, (2));
	ChangeVehicleColor(PlayerYachtVehicleID[playerid], PlayerYachtColor[playerid], 1);
	SetVehicleParamsForPlayerEx(PlayerYachtVehicleID[playerid], playerid, 0, 1);
	SendClientMessage(playerid, -1, """{6de64e}""Âű óńďĺříî âűçâŕëč č ďĺđĺěĺńňčëčńü â ëč÷íűé âîäíűé ňđŕíńďîđň");

	return 1;
}


