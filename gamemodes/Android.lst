		SendClientMessage(playerid, -1, small_string);
	}
	return 1;
}
forward pc_cmd_giverank(playerid, params[]); public pc_cmd_giverank(playerid, params[]) { 
	new fractionid = GetPlayerFractionInt(playerid);
	new crutch = LeaderPlayerFraction(playerid);
    if(fractionid == 0) return 1; 
    if(GetPlayerJobDayStatus(playerid) == false)
    {
    	return SendClientMessage(playerid, -1, """{FFFFFF}""Íĺîáőîäčěî íŕ÷ŕňü đŕáî÷čé äĺíü íŕ ""{6de64e}""áŕçĺ îđăŕíčçŕöčč");
    }
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ: /giverank [id čăđîęŕ]");
    if(PlayerInfo[playerid][pRank] < 9) return SendClientMessage(playerid, -1, """{ff353c}""Ôóíęöč˙ äîńňóďíŕ ń 9 đŕíăŕ");
    if(Fraction[crutch][E_FRACTION_LEADER_ID] == (-1)) {
    	if(PlayerInfo[playerid][pUpRank] <= 0) return SendClientMessage(playerid, -1, """{ff353c}""Ëčěčň ďîâűřĺíčé/ďîíčćĺíčé íŕ ńĺăîäí˙ ďđĺâűřĺí");
	}	
	if(PlayerInfo[playerid][pRank] < PlayerInfo[params[0]][pRank]) return 1;
	if(params[0] == playerid) return 1;
	if(GetPlayerFraction(params[0]) != GetPlayerFraction(playerid)) return 1;	

    if(Fraction[crutch][E_FRACTION_LEADER_ID] == (-1)) {
    	if(PlayerInfo[params[0]][pRankGot] != 0) return SendClientMessage(playerid, -1, """{ff353c}""Äŕííűé čăđîę ńĺăîäí˙ óćĺ ďîëó÷ŕë ďîâűřĺíčĺ");
    }

	new max_rank = PlayerInfo[playerid][pRank];
	max_rank --;
	if(PlayerInfo[params[0]][pRank] >= max_rank) return SendClientMessage(playerid, -1, """{ff353c}""Âű íĺ ěîćĺňĺ äŕňü đŕíă âűřĺ");

    PlayerInfo[params[0]][pRank] += 1; SetPlayerInt(params[0], "Rank", PlayerInfo[params[0]][pRank]);
    PlayerInfo[params[0]][pStatus] = 0; SetPlayerInt(params[0], "Status", PlayerInfo[params[0]][pStatus]);

    if(Fraction[crutch][E_FRACTION_LEADER_ID] == (-1)) {

    	PlayerInfo[params[0]][pRankGot] = 1; SetPlayerInt(params[0], "RankGot", PlayerInfo[params[0]][pRankGot]);
    	PlayerInfo[playerid][pUpRank] -= 1; SetPlayerInt(params[0], "UpRank", PlayerInfo[playerid][pUpRank]);

		format(small_string, sizeof small_string, """{6de64e}""Âű ďîâűńčëč {FFFFFF}%s""{6de64e}"" äî %d đŕíăŕ. Îńňŕëîńü ďîâűřĺíčé/ďîíčćĺíčé: {FFFFFF}%d", PlayerInfo[params[0]][pName],PlayerInfo[params[0]][pRank],PlayerInfo[playerid][pUpRank]);    
    }
   	else format(small_string, sizeof small_string, """{6de64e}""Âű ďîâűńčëč {FFFFFF}%s""{6de64e}"" äî %d đŕíăŕ", PlayerInfo[params[0]][pName],PlayerInfo[params[0]][pRank]);
    SendClientMessage(playerid, -1, small_string);
    format(small_string, sizeof small_string, "{FFFFFF}%s""{6de64e}"" ďîâűńčë âŕń äî %d đŕíăŕ, ďîçäđŕâë˙ĺě!", PlayerInfo[playerid][pName],PlayerInfo[params[0]][pRank]);
    SendClientMessage(params[0], -1, small_string);
    CBackSkin(params[0]);
    return 1;
}
forward pc_cmd_gunlock(playerid, params[]); public pc_cmd_gunlock(playerid, params[]) { 
	new Fraction:fractionid = GetPlayerFraction(playerid);

	if(!IsACrime(playerid)) return 1;
	if(GetPlayerJobDayStatus(playerid) == false)
	{
		return SendClientMessage(playerid, -1, """{FFFFFF}""Íĺîáőîäčěî íŕ÷ŕňü đŕáî÷čé äĺíü íŕ ""{6de64e}""áŕçĺ îđăŕíčçŕöčč");
	}
	new crutch = LeaderPlayerFraction(playerid);
	if(Fraction[crutch][E_FRACTION_LEADER_ID] == (-1)) return 1;
    if(PlayerInfo[playerid][pRank] < 9) return SendClientMessage(playerid, -1, """{ff353c}""Ôóíęöč˙ äîńňóďíŕ ń 9 đŕíăŕ");
    if(WStatus[_:fractionid] == 0) {
    	WStatus[_:fractionid] = 1;
    	SetWareInt(fractionid, "status", 1); 
		format(small_string, sizeof(small_string), """{6de64e}""%s %s îňęđűë ńęëŕä áŕíäű",gFractionRankName_RU[_:fractionid-1][PlayerInfo[playerid][pRank]], PlayerInfo[playerid][pName]);
		SendFamilyMessage(fractionid, -1, small_string);
		UpdateGangEmblem(_:fractionid);
    }
    else {
    	WStatus[_:fractionid] = 0;
		SetWareInt(fractionid, "status", 0);

		format(small_string, sizeof(small_string), """{ff353c}""%s %s çŕęđűë ńęëŕä áŕíäű",gFractionRankName_RU[_:fractionid-1][PlayerInfo[playerid][pRank]], PlayerInfo[playerid][pName]);
		SendFamilyMessage(fractionid, -1, small_string);
		UpdateGangEmblem(_:fractionid);
    }
    return 1;
}
