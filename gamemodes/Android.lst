forward pc_cmd_carjack(playerid, params[]); public pc_cmd_carjack(playerid, params[]) {
	new
		Fraction:fractionid = GetPlayerFraction(playerid);

	if(fractionid < FRACTION_RUSSIAN_MAFIA && fractionid > FRACTION_LSPD) {
		if(GetPlayerJobDayStatus(playerid) == false)
		{
			return SendClientMessage(playerid, -1, """{FFFFFF}""Íĺîáőîäčěî íŕ÷ŕňü đŕáî÷čé äĺíü íŕ ""{6de64e}""áŕçĺ îđăŕíčçŕöčč");
		}

		new nearid = GetNearestVehicle(playerid);
		if(PlayerInfo[playerid][pScrew] == 0) return SendClientMessage(playerid, -1, """{ff353c}""Ó Âŕń íĺň îňâĺđňęč");
		if(nearid == 1) return SendClientMessage(playerid, -1, """{ff353c}""Ďîäîéäčňĺ áëčćĺ ę ŕâňîěîáčëţ");
		if(IsVehicleOccupied(nearid) != -1) return SendClientMessage(playerid, -1, """{ff353c}""Ŕâňîěîáčëü äîëćĺí áűňü áĺç âîäčňĺë˙");
		new nearmodel = GetVehicleModel(nearid);
		if(nearmodel == TCar[playerid]) {
			PlayerInfo[playerid][pScrew] = 0;
			SetPlayerInt(playerid, "Screw", PlayerInfo[playerid][pScrew]);

			new engine, lights, alarm, doors, bonnet, boot, objective;
			GetVehicleParamsEx(nearid, engine, lights, alarm, doors, bonnet, boot, objective);
			SetVehicleParamsEx(nearid, engine, lights, alarm, 0, bonnet, boot, objective);
			SendClientMessage(playerid, -1, """{6de64e}""Âű âńęđűëč çŕěîę ŕâňîěîáčë˙");
			format(small_string, sizeof(small_string), "%s âçëîěŕë(ŕ) öĺíňđŕëüíűé çŕěîę ŕâňîěîáčë˙ %s", PlayerInfo[playerid][pName], GetVehicleText(nearmodel));
			ProxDetector(playerid, (20.00), 0xDD90FFFF, small_string);
		}
		else SendClientMessage(playerid, -1, """{ff353c}""Ó Âŕń íĺň çŕęŕçŕ íŕ ýňó ěîäĺëü");
	}
	return 1;
}
