stock engine_car(playerid) {
	if(GetPVarInt(playerid,"car_options") > gettime()) return 1;
	SetPVarInt(playerid,"car_options",gettime() + 2);
	if(IsPlayerInAnyVehicle(playerid) && GetPlayerVehicleSeat(playerid) == 0) {
		new vehicleid = GetPlayerVehicleID(playerid);
		if(IsABMX(GetVehicleModel(vehicleid)) == 1) return 1;
		//if(GetVehicleFuel(vehicleid) <= 0) {
		//	return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Бензобак автомобиля пуст");
		//}
		if(GetVehicleFuel(vehicleid) <= 0 && fuel_consumption >= 1) {
			return SendClientMessage(playerid, -1, ""COLOR_WHITE"В бензобаке автомобиля "COLOR_ORANGE"недостаточно топлива.");
		}
		new engine, lights, alarm, doors, bonnet, boot, objective;
		new Float:veh_health;
		GetVehicleParamsEx(vehicleid, engine, lights, alarm, doors, bonnet, boot, objective);
		GetVehicleHealth(vehicleid, Float:veh_health);
		if(engine == 0) {
			if(veh_health < 350.0) return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Двигатель неисправен"COLOR_WHITE" и не заводится");
			SetVehicleParamsEx(vehicleid, 1, lights, alarm, doors, bonnet, boot, objective);
			SetPlayerChatBubble(playerid, "завел(а) двигатель", C_PURPLE, 30.0, 5000);
			format(small_string, sizeof(small_string), "%s завел(а) двигатель", PlayerInfo[playerid][pName]);
			ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_PURPLE, small_string);
		}
		if(engine == -1) {
			if(veh_health < 350.0) return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Двигатель неисправен"COLOR_WHITE" и не заводится");
			SetVehicleParamsEx(vehicleid, 1, lights, alarm, doors, bonnet, boot, objective);
			SetPlayerChatBubble(playerid, "завел(а) двигатель", C_PURPLE, 30.0, 5000);
			format(small_string, sizeof(small_string), "%s завел(а) двигатель", PlayerInfo[playerid][pName]);
			ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_PURPLE, small_string);
		}		
		if(engine == 1) {
			SetVehicleParamsEx(vehicleid, 0, lights, alarm, doors, bonnet, boot, objective);
			SetPlayerChatBubble(playerid, "заглушил(а) двигатель", C_PURPLE, 30.0, 5000);
			format(small_string, sizeof(small_string), "%s заглушил(а) двигатель", PlayerInfo[playerid][pName]);
			ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_PURPLE, small_string);				
		}	
	}
	return 1;
}

stock lamp_car(playerid) {
	if(IsPlayerInAnyVehicle(playerid) && GetPlayerVehicleSeat(playerid) == 0) {
		if(GetPVarInt(playerid,"car_options") > gettime()) return 1;
		SetPVarInt(playerid,"car_options",gettime() + 2);

		new vehicleid = GetPlayerVehicleID(playerid);
		if(IsABMX(GetVehicleModel(vehicleid)) == 1) return 1;
		new engine, lights, alarm, doors, bonnet, boot, objective;
		new Float:veh_health;
		GetVehicleParamsEx(vehicleid, engine, lights, alarm, doors, bonnet, boot, objective);
	

		GetVehicleHealth(vehicleid, Float:veh_health);
		if(lights == 0 || lights == -1) {
			SetVehicleParamsEx(vehicleid, engine, 1, alarm, doors, bonnet, boot, objective);
			SetPlayerChatBubble(playerid, "включил(а) дальний свет", C_PURPLE, 30.0, 5000);
		}
		if(lights == 1) {
			SetVehicleParamsEx(vehicleid, engine, 0, alarm, doors, bonnet, boot, objective);
			SetPlayerChatBubble(playerid, "выключил(а) дальний свет", C_PURPLE, 30.0, 5000);		
		}			
	}
	return 1;
}

