CMD:stop(playerid, params[]) {
	if(GetPVarInt(playerid, "Ecologyst") == 1) return 1;
	return ClearPlayerAnimation(playerid);
}
alias:animlist("anim");
CMD:animlist(playerid, params[])
{
	if(GetPVarInt(playerid, "Ecologyst") == 1) return 1;
