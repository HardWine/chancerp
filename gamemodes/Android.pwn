					SetPVarInt(playerid,"GetLicAir", 1);
					return 1;
				}
			}
			return 1;
		}
		
		case dName: {
			if(!response) return 1;
			if(response) {
				new nick[MAX_PLAYER_NAME];
				format(nick,sizeof(nick),"%s",inputtext);
