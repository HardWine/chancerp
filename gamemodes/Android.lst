forward ArrestUpdate(playerid);
public ArrestUpdate(playerid) {
	if(GetPlayerState(playerid) != (1)) goto skip_arrest;
	if(IsAnArmy(playerid)) {
		new temp_id = GetClosestPlayer(playerid);
		if(temp_id == (0xFFFF)) goto skip_arrest;
		if(PlayerInGangZone(temp_id,-84, 1632, 437, 2144)) {
			if(PlayerInfo[temp_id][pJailed] == 0 && IsAGang(temp_id))
			{
				if(Caught[playerid] < 0) Caught[playerid] = 5;
				if(!IsPlayerInAnyVehicle(playerid)) {
					if(CaughtID[playerid] == temp_id) { Caught[playerid]--; }
					else Caught[playerid] = 5; CaughtID[playerid] = temp_id;
					new small_update_string[144];
					format(small_update_string, sizeof(small_update_string), "~w~BEFORE ARREST:~b~~h~ %d", Caught[playerid]);
					GameTextForPlayer(playerid, small_update_string, 1100, 4);
					GameTextForPlayer(CaughtID[playerid], small_update_string, 1100, 4);
					SetPVarInt(temp_id,"OffArrest",gettime() + 10);
					switch(Caught[playerid]) {
						case 5: {
							if(GetPVarInt(playerid,"AAntiFlood5") > gettime()) { goto skip_arrest; }
							SetPVarInt(playerid,"AAntiFlood5",gettime() + 90);
							format(small_string, sizeof(small_string), "- %s[%d]: Âű íŕőîäčňĺńü íŕ çŕďđĺůĺííîé ňĺđđčňîđčč č áóäĺňĺ çŕäĺđćŕíű", PlayerInfo[playerid][pName], playerid);
							ProxDetector(playerid, (20.00), 0xE6E6E6E6, small_string);
						}
						case 3: {
							if(GetPVarInt(playerid,"AAntiFlood3") > gettime()) { goto skip_arrest; }
							SetPVarInt(playerid,"AAntiFlood3",gettime() + 90);
							format(small_string, sizeof(small_string), "%s äîńňŕë(ŕ) íŕđó÷íčęč", PlayerInfo[playerid][pName]);
							ProxDetector(playerid, (20.00), 0xDD90FFFF, small_string);
						}
						case 1: {
							if(GetPVarInt(playerid,"AAntiFlood1") > gettime()) { goto skip_arrest; }
							SetPVarInt(playerid,"AAntiFlood1",gettime() + 90);
							format(small_string, sizeof(small_string), "%s íŕäĺë(ŕ) íŕđó÷íčęč íŕ ďîäîçđĺâŕĺěîăî", PlayerInfo[playerid][pName]);
							ProxDetector(playerid, (20.00), 0xDD90FFFF, small_string);
						}
						case 0: {
							format(small_string, sizeof(small_string), "- %s[%d]: Âű çŕäĺđćŕíű č îňďđŕâë˙ĺňĺńü â ĘĎÇ", PlayerInfo[playerid][pName], playerid);
							ProxDetector(playerid, (20.00), 0xE6E6E6E6, small_string);
							if(PlayerInfo[CaughtID[playerid]][pWanted] <= 0)
							{
								PlayerInfo[CaughtID[playerid]][pJailTime] = 300;
								PlayerInfo[CaughtID[playerid]][pJailed] = 1;
								SetPlayerWanted(CaughtID[playerid], 0);
								SetPlayerInt(CaughtID[playerid], "Jailed", PlayerInfo[CaughtID[playerid]][pJailed]);
								SetPlayerInt(CaughtID[playerid], "JailTime", PlayerInfo[CaughtID[playerid]][pJailTime]);
							}
							else {
								PlayerInfo[CaughtID[playerid]][pJailTime] = PlayerInfo[CaughtID[playerid]][pWanted];
								PlayerInfo[CaughtID[playerid]][pJailed] = 1;
								SetPlayerInt(CaughtID[playerid], "Jailed", PlayerInfo[CaughtID[playerid]][pJailed]);
								SetPlayerInt(CaughtID[playerid], "JailTime", PlayerInfo[CaughtID[playerid]][pJailTime]);
								PlayerInfo[CaughtID[playerid]][pWanted] = 0;
								SetPlayerWanted(CaughtID[playerid], 0);
								SetPlayerInt(CaughtID[playerid], "Wanted", 0);
								if(PlayerInfo[CaughtID[playerid]][pStuff] > 0) {
									SendClientMessage(playerid, -1, """{ff353c}""Âńĺ âŕřč ěŕňĺđčŕëű áűëč čçú˙ňű");
									PlayerInfo[CaughtID[playerid]][pStuff] = 0;
									SetPlayerInt(playerid, "Stuff", PlayerInfo[playerid][pStuff]);
								}
							}

							IncreaseKarma(playerid);
							IncreaseStatus(playerid, 10); 

							new it = RandomEx(25, 75);
							if(IsPlayerPremiumAccount(playerid) == true || 0 == 1) {
								it = it * 2;
							}

							new text[90];

							format(text,sizeof(text),"~g~+%d ~w~EXP", it);
							GameTextForPlayer(playerid, text, 3000, 5);

							AddPlayerEXP(playerid, it, "Čçú˙ňčĺ ěŕňĺđčŕëîâ ó čăđîęŕ %s", PlayerInfo[CaughtID[playerid]][pName]);

							if(IsPlayerInAnyVehicle(CaughtID[playerid]) != 0) {
								RemovePlayerFromVehicle(CaughtID[playerid]);
							}
							if(PlayerInfo[CaughtID[playerid]][pWanted] > 0) {
								PlayerInfo[CaughtID[playerid]][pWanted] = 0;
								SetPlayerWanted(CaughtID[playerid], 0);
								SetPlayerInt(CaughtID[playerid], "Wanted", 0);
							}
							AddPlayerAchievement(playerid, E_WILL_NOT);
							Caught[playerid] = 0;
							CaughtID[playerid] = (0xFFFF);
						}
					}
				}
			}
		}
	}
	if(IsACop(playerid) && GetPlayerJobDayStatus(playerid) == true) {
		new temp_id = GetClosestPlayer(playerid);
		if(temp_id == (0xFFFF)) {
			goto skip_arrest;
		}
		if(pl_afk_time[temp_id] > 2) {
			goto skip_arrest;
		}
		new catchme[128];

		if(GetPVarInt(temp_id, "robbing_now") == 1 && PlayerInfo[temp_id][pWanted] < 1) {
			PlayerInfo[temp_id][pWanted] = 660;	
			SetPVarInt(temp_id,"Wanted",PlayerInfo[temp_id][pWanted]);
		} 

		if(PlayerInfo[temp_id][pWanted] > 0)
		{
			if(!IsPlayerInAnyVehicle(playerid)) {
				if(CaughtID[playerid] == temp_id) { Caught[playerid]--; }
				else Caught[playerid] = 10; CaughtID[playerid] = temp_id;
				if(Caught[playerid] < 0) Caught[playerid] = 10;
				SetPVarInt(temp_id,"OffArrest",gettime() + 10);
				new small_update_string[144];
				format(small_update_string, sizeof(small_update_string), "~w~BEFORE ARREST: ~b~~h~%d", Caught[playerid]);
				GameTextForPlayer(playerid, small_update_string, 1100, 4);
				GameTextForPlayer(CaughtID[playerid], small_update_string, 1100, 4);
				if(GetPVarInt(CaughtID[playerid], "robbing_now") == 1) Caught[playerid] = 0;
				switch(Caught[playerid]) {
					case 10: {
						if(GetPVarInt(playerid,"AAntiFlood10") > gettime()) { goto skip_arrest; }
						SetPVarInt(playerid,"AAntiFlood10",gettime() + 60);
						format(small_string, sizeof(small_string), "- %s[%d]: Ďîäîçđĺâŕĺěűé %s, íĺěĺäëĺííî îńňŕíîâčňĺńü!", PlayerInfo[playerid][pName], playerid, PlayerInfo[CaughtID[playerid]][pName]);
						ProxDetector(playerid, (20.00), 0xE6E6E6E6, small_string);
					}
					case 9: {
						if(GetPVarInt(playerid,"AAntiFlood9") > gettime()) { goto skip_arrest; }
						SetPVarInt(playerid,"AAntiFlood9",gettime() + 60);
						format(small_string, sizeof(small_string), "- %s[%d]: Đŕáîňŕĺň ďîëčöč˙, ó Âŕń ĺńňü ďđŕâî őđŕíčňü ěîë÷ŕíčĺ", PlayerInfo[playerid][pName], playerid);
						ProxDetector(playerid, (20.00), 0xE6E6E6E6, small_string);
					}
					case 7: {
						if(GetPVarInt(playerid,"AAntiFlood7") > gettime()) { goto skip_arrest; }
						SetPVarInt(playerid,"AAntiFlood7",gettime() + 60);
						format(small_string, sizeof(small_string), "%s äîńňŕë(ŕ) íŕđó÷íčęč", PlayerInfo[playerid][pName]);
						ProxDetector(playerid, (20.00), 0xDD90FFFF, small_string);
					}
					case 5: {
						if(GetPVarInt(playerid,"AAntiFlood5") > gettime()) { goto skip_arrest; }
						SetPVarInt(playerid,"AAntiFlood5",gettime() + 30);
						format(small_string, sizeof(small_string), "- %s[%d]: Âű íŕőîäčňĺńü â ôĺäĺđŕëüíîě đîçűńęĺ, č áóäĺňĺ çŕäĺđćŕíű", PlayerInfo[playerid][pName], playerid);
						ProxDetector(playerid, (20.00), 0xE6E6E6E6, small_string);
					}
					case 1: {
						if(GetPVarInt(playerid,"AAntiFlood1") > gettime()) { goto skip_arrest; }
						SetPVarInt(playerid,"AAntiFlood1",gettime() + 30);
						format(small_string, sizeof(small_string), "%s íŕäĺë(ŕ) íŕđó÷íčęč íŕ ďîäîçđĺâŕĺěîăî", PlayerInfo[playerid][pName]);
						ProxDetector(playerid, (20.00), 0xDD90FFFF, small_string);
					}
					case 0: {
						format(small_string, sizeof(small_string), "- %s[%d]: Âű çŕäĺđćŕíű č îňďđŕâë˙ĺňĺńü â ĘĎÇ", PlayerInfo[playerid][pName], playerid);
						ProxDetector(playerid, (20.00), 0xE6E6E6E6, small_string);
						format(catchme, 100, """{4eb9e6}""Ńîňđóäíčę %s çŕäĺđćŕë ďđĺńňóďíčęŕ %s", PlayerInfo[playerid][pName], PlayerInfo[CaughtID[playerid]][pName]);
						new Fraction:fractionid = GetPlayerFraction(playerid);
						SendFamilyMessage(fractionid, -1, small_string);
						if(PlayerInfo[CaughtID[playerid]][pWanted] < 1) PlayerInfo[CaughtID[playerid]][pWanted] = 600;
						PlayerInfo[CaughtID[playerid]][pJailTime] = PlayerInfo[CaughtID[playerid]][pWanted];
						PlayerInfo[CaughtID[playerid]][pJailed] = 1;
						SetPlayerInt(CaughtID[playerid], "Jailed", PlayerInfo[CaughtID[playerid]][pJailed]);
						SetPlayerInt(CaughtID[playerid], "JailTime", PlayerInfo[CaughtID[playerid]][pJailTime]);
						if(PlayerInfo[CaughtID[playerid]][pWanted] > 0) {
						PlayerInfo[CaughtID[playerid]][pWanted] = 0;
						SetPlayerWanted(CaughtID[playerid], 0);
						SetPlayerInt(CaughtID[playerid], "Wanted", 0);
						if(PlayerInfo[CaughtID[playerid]][pStuff] > 0) {
							SendClientMessage(playerid, -1, """{ff353c}""Âńĺ âŕřč ěŕňĺđčŕëű áűëč čçú˙ňű");
							PlayerInfo[CaughtID[playerid]][pStuff] = 0;
							SetPlayerInt(playerid, "Stuff", PlayerInfo[playerid][pStuff]);
						}
						}
						IncreaseKarma(playerid);

						IncreaseStatus(playerid, 10); 

						new it = RandomEx(25, 125);
						if(IsPlayerPremiumAccount(playerid) == true || 0 == 1) {
							it = it * 2;
						}

						new text[90];

						format(text,sizeof(text),"~g~+%d ~w~EXP", it);
						GameTextForPlayer(playerid, text, 3000, 5);

						AddPlayerEXP(playerid, it, "Ďîčěŕ ďđĺńňóďíčęŕ %s", PlayerInfo[CaughtID[playerid]][pJailed]);
						if(GetPlayerFraction(playerid) == FRACTION_LSPD) {
							AddPlayerAchievement(playerid, E_BENCH_GANGSTER);
						} else {
							AddPlayerAchievement(playerid, E_SLEEP_WELL);
						}
						Caught[playerid] = 0;
						CaughtID[playerid] = (0xFFFF);
					}
				}
			}
			goto skip_arrest;
		}
		if(IsACop(playerid)) { Caught[playerid] = 0; CaughtID[playerid] = (0xFFFF);}
	}
	skip_arrest:
	if(IsACop(playerid)) {
	new count = GetPVarInt(playerid, "arrest_on");
	count -= 1;
	SetPVarInt(playerid, "arrest_on", count);

	if(count <= 0) return SendClientMessage(playerid, -1, """{ff353c}""Ýëĺęňđîřîęĺđ îňęëţ÷čëń˙...");
	}

	CopTimerID[playerid] = KillTimer(CopTimerID[playerid]);
	return CopTimerID[playerid] = SetTimerEx("ArrestUpdate", 1250, false, "d", playerid);
}
stock GetClosestPlayer(playerid, Float:radius = 9.0)
{
	if(playerid == (0xFFFF) || radius > 30.0) {
		return (0xFFFF);
	}

	new
		Float:pos_x,
		Float:pos_y,
		Float:pos_z,
		Float:max_dist = radius,
		Float:tmp_dist,
		nearest_player = (0xFFFF);

	GetPlayerPos(playerid, pos_x, pos_y, pos_z);

	for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i=Iterator@Player [_: i])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);) {
		if(0 == IsPlayerStreamedIn(i, playerid) || i == playerid) {
			continue;
		}

		tmp_dist = GetPlayerDistanceFromPoint(i, pos_x, pos_y, pos_z);

		if(max_dist > tmp_dist)
		{
			max_dist = tmp_dist;
			nearest_player = i;
		}
	}
	return nearest_player;
}
stock CancelOffer(playerid) {
	if(GetPVarInt(playerid, "CarOffer") != -1) {
		new seller = GetPVarInt(playerid, "CarOffer");
		SetPVarInt(playerid, "CarOffer", -1);
		if(PlayerLogged{seller} == false || !IsPlayerConnected(seller)) return 1;
		SetPVarInt(seller, "SellingCar", -1);
	}
	SetPVarInt(playerid, "CarOffer", -1);
	return 1;
}
forward FixAuth(playerid);
public FixAuth(playerid) {
	AuthTimeFix[playerid] = KillTimer(AuthTimeFix[playerid]);
	if(PlayerLogged{playerid} == false || !IsPlayerConnected(playerid)) {
		SendClientMessage(playerid, -1, """{ff353c}""Âđĺě˙ íŕ âőîä â čăđó čńňĺęëî. Ďĺđĺçŕéäčňĺ");
		return dc_kickfix__Kick(playerid);
	}
	return 1;
}


forward pc_cmd_get(playerid, params); public pc_cmd_get(playerid, params) {
	if(Player__AdminLevel{playerid} < 5) {
		return 0;
	} else {
		new 
			inter = GetPlayerInterior(playerid),
			world = GetPlayerVirtualWorld(playerid),
			Float: x,
			Float: y,
			Float: z,
			Float: angle;

		GetPlayerPos(playerid, x, y, z);
		GetPlayerFacingAngle(playerid, angle);

		format(small_string, sizeof(small_string), 
			"(%s (%i)) -- Inter = %i World = %i (X = %f, Y = %f, Z = %f, Angle = %f",
				PlayerInfo[playerid][pName],
				playerid,
				inter,
				world,
				x,
				y,
				z,
				angle
		);
		printf(small_string);
		return SendClientMessage(playerid, -1, small_string);
	}
}

stock Dialog_Bank_Property(const playerid) {

	if(PlayerLogged{playerid} == false) return 1;

	new 
		house_array = GetPVarInt(playerid, "PlayerHouse"),
		hotel_array = Player__Hotel[playerid];


	new 
		house_string[2][35],
		hotel_string[35];


