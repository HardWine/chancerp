					SetPlayerInterior(playerid,HouseInfo[h][hInt]);
					SetPlayerVirtualWorld(playerid,PlayerInfo[playerid][pID]);
					switch(HouseInfo[h][hClass]) {
						case 0..1: RM_SetPlayerPos(playerid, HouseInfo[h][hExitx]-4, HouseInfo[h][hExity]+2,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -270);
						case 2: RM_SetPlayerPos(playerid, HouseInfo[h][hExitx], HouseInfo[h][hExity]+3,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -180);
						case 3..4: RM_SetPlayerPos(playerid, HouseInfo[h][hExitx], HouseInfo[h][hExity]+8,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -180);
						case 5: RM_SetPlayerPos(playerid, HouseInfo[h][hExitx]+2, HouseInfo[h][hExity]+12,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -180);
						default: RM_SetPlayerPos(playerid, HouseInfo[h][hExitx]-4, HouseInfo[h][hExity]+2,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -270);
					}
					return true;
				}				
				if(HouseInfo[h][hDoor] == 1) {
					if(GetPVarInt(playerid,"GoHome") > gettime()){ return false; }

					new nick[24];
					format(nick,sizeof(nick),"%s",HouseInfo[h][hOwner]);
					new owner_id = ReturnUser(nick);

					if(IsPlayerConnected(owner_id) && PlayerLogged{owner_id} == true)
					{
						SetPVarInt(playerid, "guest_house", h);
						SetPlayerInterior(playerid,HouseInfo[h][hInt]);
						SetPlayerVirtualWorld(playerid, PlayerInfo[owner_id][pID]);
						switch(HouseInfo[h][hClass]) {
							case 0..1: RM_SetPlayerPos(playerid, HouseInfo[h][hExitx]-4, HouseInfo[h][hExity]+2,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -270);
							case 2: RM_SetPlayerPos(playerid, HouseInfo[h][hExitx], HouseInfo[h][hExity]+3,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -180);
							case 3..4: RM_SetPlayerPos(playerid, HouseInfo[h][hExitx], HouseInfo[h][hExity]+8,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -180);
							case 5: RM_SetPlayerPos(playerid, HouseInfo[h][hExitx]+2, HouseInfo[h][hExity]+12,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -180);
							default: RM_SetPlayerPos(playerid, HouseInfo[h][hExitx]-4, HouseInfo[h][hExity]+2,HouseInfo[h][hExitz]), SetPlayerFacingAngle(playerid, -270);
						}
						return 1;
					} else {
						SendClientMessage(playerid, -1, "Äâĺđü çŕďĺđňŕ čçíóňđč ""{ff353c}""(čăđîę íĺ â ńĺňč)");
					}				
				} else {
					SendClientMessage(playerid, -1, """{FFAF00}""Äâĺđü ćčëčůŕ çŕďĺđňŕ âëŕäĺëüöĺě");
				}



				return 1;
			}
		}
	}
	for(new i = 0; i < 99; i++) {
		if(IsPlayerInRangeOfPoint(playerid, 9.9, Pickup[i][ent_X],Pickup[i][ent_Y],Pickup[i][ent_Z])) {
			SetPVarInt(playerid, "bz_rob", i);
			Dialog_Show(playerid, #rob);
		}
	}

	return 1;
}
public OnPlayerEnterDynamicCP(playerid, checkpointid)
{
	if(OpenBusinessMenu(playerid, checkpointid) == 1) {
		return 1;
	}
	if(Dealer_OnPlayerEnterDynamicCP(playerid, checkpointid) == 1) {
		return 1;
	}
	if(Porter_OnPlayerEnterDynamicCP(playerid, checkpointid) == 1) {
		return 1;
	}
	if(Saloon_OnPlayerEnterDynamicCP(playerid, checkpointid) == 1) {
		return 1;
	}
	if(Taxi_OnPlayerEnterDynamicCP(playerid, checkpointid) == 1) {
		return 1;
	}
	if(CallLocalFunction("OnPlayerEnterPatrolCP", "ii", playerid, checkpointid) == 1) {
		return 1;
	}
	if(CallLocalFunction("Gps_OnPlayerEnterDynamicCP", "ii", playerid, checkpointid) == 1) {
		return 1;
	}
	if(checkpointid == cars_triad) {
		return cars_triad_get(playerid);
	}
	if(checkpointid >= ATM[0] && checkpointid <= ATM[49])
	{
		if(PlayerLogged{playerid} == false) return 1;

		if(GetPVarInt(playerid, "payment_check") == 1) {
			return Dialog_Show(playerid, #PassPayment);
		}

		RM_ShowPlayerDialog(playerid, dBank, 2, """{4eb9e6}""Áŕíęîěŕň", """{FFFFFF}""1. Ńí˙ňü ńđĺäńňâŕ\n2. Ďîëîćčňü ńđĺäńňâŕ\n3. Ďîďîëíčňü ń÷ĺň ěîáčëüíîăî\n4. Îďëŕňčňü řňđŕôű", "Âűáđŕňü", "Çŕęđűňü");
		PlayerPlaySound(playerid, 4203, 0, 0, 0);
		format(small_string, sizeof(small_string), """{6de64e}""Âŕř áŕíęîâńęčé áŕëŕíń: {FFFFFF} %d EXP", PlayerInfo[playerid][pBank]);
		SendClientMessage(playerid, -1, small_string);
		return 1;
	}
	if(checkpointid == Player__FarmCP[playerid]) {
		if(GetPVarInt(playerid, "tempjob") == 1) {
			if(IsValidTimer(farming[playerid])) {
				KillTimer(farming[playerid]);
				farming[playerid] = -1;
			}
			if(GetPVarInt(playerid, "Pizdui") == 0) {
				return 1;
			}
			if(Player__FarmCP[playerid] != (-1)) {
				DestroyDynamicCP(Player__FarmCP[playerid]);
				Player__FarmCP[playerid] = (-1);
			}
			farming[playerid] = SetTimerEx("CFarm", 10000, false, "d", playerid);
			ApplyAnimation(playerid,"BOMBER","BOM_Plant",4.0,1,1,1,1,0);
			SendClientMessage(playerid, -1, "Ďîäîćäčňĺ 10 ńĺęóíä...");
			SetPVarInt(playerid, "MinusTime", 10);
		}
		return 1;
	}
	if(checkpointid == Player__SteelCar[playerid]) {
		if(ThefStatus[playerid] == 2) {
		new tmpcar = GetPlayerVehicleID(playerid);
		if(GetVehicleModel(tmpcar) != TCar[playerid]) {
			return SendClientMessage(playerid, -1, """{ff353c}""Ýňî íĺ ňŕ ěŕřčíŕ, ęîňîđóţ ěű çŕęŕçűâŕëč!");
		}
		if(tmpcar == caridhouse[playerid]) {
			return SendClientMessage(playerid, -1, """{ff353c}""Ńâîţ ěŕřčíó îńňŕâü ńĺáĺ!");
		}
		for(new i = 0; i < 40; i++) {
		if(AdminCar[i] == tmpcar) {
			return SendClientMessage(playerid, -1, """{ff353c}""Ýňŕ ňŕ÷ęŕ íĺ ďîäîéäĺň! Ó ęîăî ňű ĺ¸ âç˙ë?");
		}
		}

		new price;

		if(IsANope(tmpcar))
		{
			new 
				value = RandomEx(2, 4);


			IncreaseStatus(playerid, value); 
			price = RandomEx(75, 125);
			if(IsPlayerPremiumAccount(playerid) == true || 0 == 1) {
				price = price * 2;
			}

			format(small_string, sizeof(small_string), """{6de64e}""Íĺďëîőîĺ âĺäđî, äĺđćč: {FFFFFF}%d EXP", price);
			SendClientMessage(playerid, -1, small_string);
		}
		if(IsAB(tmpcar))
		{
			new 
				value = RandomEx(5, 7);

			IncreaseStatus(playerid, value); 
			price = RandomEx(155, 225);
			if(IsPlayerPremiumAccount(playerid) == true || 0 == 1) {
				price = price * 2;
			}

			format(small_string, sizeof(small_string), """{6de64e}""Ňî ÷ňî íóćíî, ďîëó÷ŕé: {FFFFFF}%d EXP", price);
			SendClientMessage(playerid, -1, small_string);
		}
		if(IsAA(tmpcar))
		{
			new 
				value = RandomEx(8, 10);

			IncreaseStatus(playerid, value); 

			price = RandomEx(250, 750);
			if(IsPlayerPremiumAccount(playerid) == true || 0 == 1) {
				price = price * 2;
			}

			format(small_string, sizeof(small_string), """{6de64e}""Îňëč÷íŕ˙ ňŕ÷ęŕ, âîň ňâîč: {FFFFFF}%d EXP", price);
			SendClientMessage(playerid, -1, small_string);
		}

		AddPlayerAchievement(playerid, E_CAR_RENTAL);
		AddPlayerEXP(playerid, price, "Óăîí ŕâňîěîáčë˙");
		DecreaseKarma(playerid);

		TimeTCar[playerid] = 0;

		ThefStatus[playerid] = 0;
		TCar[playerid] = 0;

		if(PlayerInfo[playerid][pTheftSkill] < 250) {

			PlayerInfo[playerid][pTheftSkill] += 1;	

			SetPlayerInt(playerid, "TheftSkill", PlayerInfo[playerid][pTheftSkill]);
		}
		format(small_string, sizeof(small_string), """{4eb9e6}""Íŕâűę ŕâňîóăîíŕ: %d", PlayerInfo[playerid][pTheftSkill]);
		SendClientMessage(playerid, -1, small_string);
		SendClientMessage(playerid, -1, """{4eb9e6}""×ĺě âűřĺ âŕř íŕâűę ňĺě áîëĺĺ äîđîăčĺ ěŕřčíű âű ńěîćĺňĺ óăîí˙ňü");

		if(Player__SteelCar[playerid] != (-1)) {
			DestroyDynamicCP(Player__SteelCar[playerid]);
			Player__SteelCar[playerid] = (-1);
		}

		new homecar = 0;
		for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i=Iterator@Player [_: i])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);) {
			if(tmpcar == caridhouse[i]) {
				if(Player__Hotel[i] == (-1)) {
					LoadCarPlayerId(i);
				}
				homecar = 1;
			}
		}
		if(homecar == 0) {


		} else {

		}
		return 1;
		}
		return 1;
	}
	return 1;
}

