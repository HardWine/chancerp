	} else {
		new strval_inputtext = strval(inputtext);

		if(strval_inputtext <= 7 && strval_inputtext > 0) {
			SetPVarInt(playerid, "days_rent_b", strval_inputtext);
			Dialog_Show(playerid, #BusinessRent);
			return 1;
		} else {
			return Dialog_Show(playerid, #BusinessRentInput);
		}
	}
}

forward dcr_BusinessRent(playerid); public dcr_BusinessRent(playerid) {


	new business_chosen = GetPVarInt(playerid, "b_rent"),
		days_rent = GetPVarInt(playerid, "days_rent_b"),
		rent_string[64],
		income_hourly = Properties[business_chosen][ICost]/60,
		just_business = income_hourly/2;		

	format(rent_string, sizeof(rent_string), "%s", Properties[business_chosen][IName]);
	format(small_string, sizeof(small_string), """{FFFFFF}""Îďëŕňčňü %d EXP çŕ %d äíĺé ŕđĺíäű?", just_business*days_rent, days_rent);

	Dialog_Open(playerid, #BusinessRent, 0,
        rent_string,
        small_string,
        "Äŕ", "Îňěĺíŕ");	

}

forward dre_BusinessRent(playerid, response, listitem, inputtext[]); public dre_BusinessRent(playerid, response, listitem, inputtext[]) {
	if(!response) {
		return Dialog_Bank_Property(playerid);
	} else {
		new business_chosen = GetPVarInt(playerid, "b_rent"),
			days_rent = GetPVarInt(playerid, "days_rent_b"),
			income_hourly = Properties[business_chosen][ICost]/60,
			just_business = income_hourly/2;

		if(BusinessInfo[business_chosen][Taxes] >= 7) {
			return SendClientMessage(playerid, -1, """{FFAF00}""Áčçíĺń óćĺ îďëŕ÷ĺí íŕ ěŕęńčěŕëüíűé ńđîę"), Dialog_Bank_Property(playerid);
		}

		if(BusinessInfo[business_chosen][Taxes]+days_rent > 7) {
			format(small_string, sizeof(small_string), """{ff353c}""Áčçíĺń îďëŕ÷ĺí íŕ %d äíĺé, âű ńîáčđŕĺňĺńü îďëŕňčňü íŕ %d äíĺé", BusinessInfo[business_chosen][Taxes], days_rent);
			SendClientMessage(playerid, -1, small_string);	
			SendClientMessage(playerid, -1, """{ff353c}""Îďëŕňčňü ěîćíî ěŕęńčěóě íŕ 7 äíĺé!");
			Dialog_Show(playerid, #BusinessRentInput);
			return 1;
		}	

		if(CheckCash(playerid, just_business*days_rent) == false) return 1;
		RemovePlayerEXP(playerid, just_business*days_rent, "Îďëŕňŕ ŕđĺíäíîé ďëŕňű áčçíĺńŕ");	

		format(small_string, sizeof small_string, "~n~~n~~n~~n~~n~~r~-%d EXP~n~~g~+%d DAYS", just_business*days_rent, days_rent);
		GameTextForPlayer(playerid, small_string, 2000, 6);		

		BusinessInfo[business_chosen][Taxes] += days_rent;
		SetBusinessInt("Taxes", BusinessInfo[business_chosen][Taxes], business_chosen);	
		pc_cmd_me(playerid, "îďëŕňčë(ŕ) ŕđĺíäíóţ ďëŕňó çŕ áčçíĺń");
		SendClientMessage(playerid, -1, """{6de64e}""Âű îďëŕňčëč ŕđĺíäó âŕřĺăî áčçíĺńŕ");

	}
	return 1;
}

forward pc_cmd_business(playerid); public pc_cmd_business(playerid) {
	if(Platform[playerid] == 0) {
		Dialog_Show(playerid, #BusinessManageInput);
		return 1;
	} else Dialog_Show(playerid, #BusinessManage);
	return 1;
}

forward pc_cmd_income(playerid); public pc_cmd_income(playerid) {
	new 
		player_world = GetPlayerVirtualWorld(playerid);

	if(player_world < 100) return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ ýňó ôóíęöčţ íŕőîä˙ńü âíóňđč ńâîĺăî áčçíĺńŕ");

	new menuid = player_world-100;

	if(BusinessInfo[menuid][OwnerID] == PlayerInfo[playerid][pID]) {
		new income = BusinessInfo[menuid][Income];
		if(income <= 0) return SendClientMessage(playerid, -1, "Ďđčáűëü îňńóňńňâóĺň");
		printf("[bizz_debug] [bid:%d] Ńíčěŕĺňń˙ ďđčáűëü, ďĺđĺěĺííŕ˙ áűëŕ đŕâíŕ %d", menuid, BusinessInfo[menuid][Income]);
		BusinessInfo[menuid][Income] = 0;
		printf("[bizz_debug] [bid:%d] Ńíčěŕĺňń˙ ďđčáűëü, ďĺđĺěĺííŕ˙ ňĺďĺđü đŕâíŕ %d", menuid, BusinessInfo[menuid][Income]);
		SetBusinessInt("Income", BusinessInfo[menuid][Income], menuid);

		AddPlayerEXP(playerid, income, "Ńí˙ňčĺ ďđčáűëč ń áčçíĺńŕ");
		PlayerPlaySound(playerid, 20801, 0, 0, 0);	

		pc_cmd_me(playerid, "äîńňŕë(ŕ) íŕëč÷íűĺ čç ęŕńńű");

		format(small_string, sizeof small_string, "Âŕřŕ ďđčáűëü: %i$", income);
		SendClientMessage(playerid, -1, small_string);
	} else {
		return SendClientMessage(playerid, -1, "Âű äîëćíű áűňü â ńâîĺě áčçíĺńĺ");
	}
	return 1;
}

forward pc_cmd_sell(playerid); public pc_cmd_sell(playerid) {
	new 
		player_world = GetPlayerVirtualWorld(playerid);

	if(player_world < 100) return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ ýňó ôóíęöčţ íŕőîä˙ńü âíóňđč ńâîĺăî áčçíĺńŕ");
	new menuid = player_world-100;

	if(BusinessInfo[menuid][OwnerID] == PlayerInfo[playerid][pID]) {

		SetPVarInt(playerid, "b_id_buy", menuid);
		SetPVarInt(playerid, "b_info_get", 10);

		Dialog_Show(playerid, #BusinessSellAgreement);

	} else {
		return 1;
	}
	return 1;
}

forward pc_cmd_buy(playerid); public pc_cmd_buy(playerid) {
	new 
		player_world = GetPlayerVirtualWorld(playerid);


	if(player_world < 100) return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ ýňó ôóíęöčţ íŕőîä˙ńü âíóňđč áčçíĺńŕ");
	new menuid = player_world-100;

	if(BusinessInfo[menuid][OwnerID] == (-1)) {
	    new total_b = 0;

		for(new i = 0; i < 99; i++) {
			if(BusinessInfo[i][OwnerID] != PlayerInfo[playerid][pID]) continue;
			total_b += 1;
		}
		if(total_b >= 3) return SendClientMessage(playerid, -1, "Âű äîńňčăëč ěŕęńčěŕëüíî äîďóńňčěîĺ ęîëč÷ĺńňâî áčçíĺńîâ");


		if(CheckCash(playerid, Properties[menuid][ICost]) == false) return 1;

		SetPVarInt(playerid, "b_id_buy", menuid);
		SetPVarInt(playerid, "b_info_get", 10);

		Dialog_Show(playerid, #BusinessBuyAgreement);
	} else {
		return SendClientMessage(playerid, -1, """{ff353c}""Áčçíĺń óćĺ čěĺĺň âëŕäĺëüöŕ");
	}
	return 1;
}

stock BusinessIncome() {
		for(new i = 0; i < 99; i++) {
		if(BusinessInfo[i][OwnerID] == (-1)) continue;
		printf("[bizz_debug] [bid:%d] Ďđčáűëü ďđčřëŕ íŕőóé áűëî: %d", i, BusinessInfo[i][Income]);
		new income_hourly = Properties[i][ICost]/30;
		BusinessInfo[i][Income] += income_hourly/24;
		SetBusinessInt("Income", BusinessInfo[i][Income], i);
		printf("[bizz_debug] [bid:%d] Ďđčáűëü ďđčřëŕ íŕőóé ńňŕëî: %d", i, BusinessInfo[i][Income]);
	}
}

