forward dre_DIALOG_GIVEGUN_INITIAL(playerid, response, listitem, inputtext[]); public dre_DIALOG_GIVEGUN_INITIAL(playerid, response, listitem, inputtext[]) {
	if(!response) return 1;

	new recipient = strval(inputtext);

	if(playerid == recipient) return SendClientMessage(playerid, -1, """{FFAF00}""Íĺâĺđíűé ID!");
	if(recipient < 0 || recipient > 1000) return SendClientMessage(playerid, -1, """{FFAF00}""Íĺâĺđíűé ID!");
	if(PlayerLogged{recipient} == false) return SendClientMessage(playerid, -1, """{FFAF00}""Íĺâĺđíűé ID!");

	if(GetDistanceBetweenPlayerz(playerid, recipient, 5.00) != 1) return SendClientMessage(playerid, -1, """{FFAF00}""Âű ńëčřęîě äŕëĺęî îň óęŕçŕííîăî čăđîęŕ");
	SetPVarInt(playerid, "givegun", recipient);
	Dialog_Show(playerid, #DIALOG_GIVEGUN);
	return 1;
}

forward dcr_DIALOG_GIVEGUN(playerid); public dcr_DIALOG_GIVEGUN(playerid) {

