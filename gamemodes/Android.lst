forward dre_GunAmmo(playerid, response, listitem, inputtext[]); public dre_GunAmmo(playerid, response, listitem, inputtext[]) {
	if(!response) {
		return Dialog_Show(playerid, #BusinessMenu);
	} else {
	new b_buy_id = GetPVarInt(playerid, "b_menu_id"),
		gun_id = GetPVarInt(playerid, "gun_id_buy"),
		strval_inputtext = strval(inputtext);		

	if(strval_inputtext < 0 || strval_inputtext > 999) return Dialog_Show(playerid, #BusinessMenu);

	SetPVarInt(playerid, "ammo_to_buy", strval_inputtext);

	buy_shop_item(playerid, b_buy_id, 5, gun_id);	
	}
	return 1;
}

forward dre_BusinessMenu(playerid, response, listitem, inputtext[]); public dre_BusinessMenu(playerid, response, listitem, inputtext[]) {
	if(!response) {
		return 0;
	} else {
	new menuid = GetPVarInt(playerid, "shop_type"),
		b_buy_id = GetPVarInt(playerid, "b_menu_id"),
		item_buy;

	if(Platform[playerid] == 0) {
	item_buy = strval(inputtext);
	} else {
	item_buy = listitem+1;
	}

	if(menuid == 5) return Dialog_Show(playerid, #GunAmmo), SetPVarInt(playerid, "gun_id_buy", item_buy);

	buy_shop_item(playerid, b_buy_id, menuid, item_buy);	
	}
	return 1;
}

