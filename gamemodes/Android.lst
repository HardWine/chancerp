ShowPlayerAllBans(const playerid) {
	new 
		current_page = PlayerPageAllBans[playerid];

	mysql_format(database, big_string, sizeof(big_string), "SELECT player_banned.ID, players.Name AS PlayerName, admin.Name AS AdminName, player_banned.Reason, DATEDIFF(player_banned.`UnBanTime`, CURRENT_TIMESTAMP()) AS Days FROM `player_banned` JOIN players ON players.ID = player_banned.PlayerID JOIN players AS admin ON admin.ID = player_banned.AdminID WHERE `UnBanTime` > CURRENT_TIMESTAMP() AND player_banned.Status = 'Çŕáëîęčđîâŕí' ORDER BY player_banned.ID LIMIT %i OFFSET %i",  (30) + 1, (30) * current_page);
	printf(big_string);
	return mysql_pquery(database, big_string, "@_ShowPlayerAllBans", "i", playerid);
}

@_ShowPlayerAllBans(const playerid);
@_ShowPlayerAllBans(const playerid) {
	new 
		rows = cache_get_row_count();

	if(!rows) {
		if(PlayerPageAllBans[playerid] == 0) {
			return SendClientMessage(playerid, -1, """{FFFFFF}""Ŕęňčâíűĺ áëîęčđîâęč îňńóňńâóţň");
		}
		return SendClientMessage(playerid, -1, """{FFAF00}""Ďđîčçîřëŕ îřčáęŕ");
	} else {

		small_string[0] = EOS;
		huge_string[0] = EOS;

		huge_string = !"ID\tÍčę\tŔäěčíčńňđŕňîđ\tĎđč÷číŕ\tÎńňŕëîńü äíĺé\n";

		new 
			player_name[24 + 1],
			admin_name[24 + 1],
			reason[48 + 1];

		new 
			id,
			days;

		for(new i = 0; i < rows; i++) {
			cache_get_field_content(i, "PlayerName", player_name);
			cache_get_field_content(i, "AdminName", admin_name);
			cache_get_field_content(i, "Reason", reason);

			days = cache_get_field_content_int(i, "Days");
			id = cache_get_field_content_int(i, "ID");

			format(small_string, sizeof(small_string), 
				"%i\t""{6de64e}""%s""{FFFFFF}""\t""{ff353c}""%s\t%s\t%i\n", 
					id, 
					player_name,
					admin_name,
					reason,
					days 
			);	
			strcat(huge_string, small_string);

			if(i > (30) - 1) {
				strcat(huge_string, """{6de64e}""+ Ńëĺäóţůŕ˙ ńňđŕíčöŕ\n");
				break;
			}
		}

		if(PlayerPageAllBans[playerid] >= 1) {
			strcat(huge_string, """{FFAF00}""- Ďđĺäűäóůŕ˙ ńňđŕíčöŕ\n");
		}

		format(small_string, sizeof(small_string), """{4eb9e6}""Çŕáëîęčđîâŕííűĺ čăđîęč: ""{FFAF00}""Ńňđŕíčöŕ %i", PlayerPageAllBans[playerid] + 1);
		return Dialog_Open(playerid, #DIALOG_SHOW_PLAYER_BAN, 5,
			small_string,
			huge_string,
			"Íŕçŕä", "Çŕęđűňü"
		);
	}
}

forward dre_DIALOG_SHOW_PLAYER_BAN(playerid, response, listitem, inputtext[]); public dre_DIALOG_SHOW_PLAYER_BAN(playerid, response, listitem, inputtext[]) {
	if(response) {
		if(strcmp(inputtext, "+ Ńëĺäóţůŕ˙ ńňđŕíčöŕ", false) == 0) {
			PlayerPageAllBans[playerid] = PlayerPageAllBans[playerid] + 1;
			return ShowPlayerAllBans(playerid);
		} else if(strcmp(inputtext, "- Ďđĺäűäóůŕ˙ ńňđŕíčöŕ", false) == 0) {
			PlayerPageAllBans[playerid] = PlayerPageAllBans[playerid] - 1;
			return ShowPlayerAllBans(playerid);
		} else {
			return ShowPlayerAllBans(playerid);
		}
	}
	return 1;
}

forward pc_cmd_number(playerid, params[]); public pc_cmd_number(playerid, params[]) {
	new 
		phone_number[24 + 1];

	if(sscanf(params, "s[" #24 "]", phone_number)) {
		return SendClientMessage(playerid, -1, """{FFAF00}""Čńďîëüçóéňĺ: /number [Íîěĺđ ňĺëĺôîíŕ čëč íčę čăđîęŕ]");
	}

	if(IsNumeric(phone_number) == 1) {
		mysql_format(database, 
			small_string, sizeof(small_string), 
			"SELECT Name, isOnline, SIMCard FROM `players` WHERE SIMCard = %i LIMIT 1", 
				strval(phone_number)
		);
		mysql_pquery(database, small_string, "@_ShowPlayerNumberOwner", "ii", playerid, 0);
	} else {
		mysql_format(database, 
			small_string, sizeof(small_string), 
			"SELECT Name, isOnline, COALESCE(SIMCard, %i) AS SIMCard FROM `players` WHERE Name = '%e' LIMIT 1", 
				(-1),
				phone_number
		);
		mysql_pquery(database, small_string, "@_ShowPlayerNumberOwner", "ii", playerid, 1);
	}
	return 1;
}

