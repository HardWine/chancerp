forward pc_cmd_offban(playerid,params[]); public pc_cmd_offban(playerid,params[])
{
	if(Player__AdminLevel{playerid} < 5) return 1; 
	new query[128],param_name[24],param_reason[32]; 
	new days;
	if(sscanf(params, "s[24]ds[32]", param_name, days, param_reason)) return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ: /offban [íčę] [ęîëč÷ĺńňâî äíĺé] [ďđč÷číŕ]");
	if(days < 2 && days != 2038) {
		return SendClientMessage(playerid, -1, """{FFAF00}""Ęîëč÷ĺńňâî äíĺé äîëćíî áűňü â äčŕďîçîíĺ îň 2 äî 30");
	}
	if(days > 30 && days != 2038) {
		return SendClientMessage(playerid, -1, """{FFAF00}""Ęîëč÷ĺńňâî äíĺé äîëćíî áűňü â äčŕďîçîíĺ îň 2 äî 30");
	}
	if(days == 2038) {
		days = 365*19;
	}
	mysql_format(database, query,sizeof(query), "SELECT * FROM ""players"" WHERE `Name` = '%e'", param_name); 
	mysql_tquery(database, query, "OffBan", "isis", playerid, param_name, days, param_reason); 
	return 1;
}
