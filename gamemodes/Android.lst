stock LoadTrash() {

	for(new i = 0; i < 182; i++) {

		TrashObjects[i][spawned] = 1;

		if(IsValidDynamicObject(TrashObjects[i][trash_obj])) DestroyDynamicObject(TrashObjects[i][trash_obj]);
		TrashObjects[i][trash_obj] = CreateDynamicObject(TrashObjects[i][trash_obj_id],
			TrashObjects[i][trash_x],  
	        TrashObjects[i][trash_y],
	        TrashObjects[i][trash_z], 
			TrashObjects[i][trash_x2],  
	        TrashObjects[i][trash_y2],
	        TrashObjects[i][trash_z2], 0, 0, -1, 75.0, 75.0);

		if(IsValidDynamicArea(TrashObjects[i][trash_area])) DestroyDynamicArea(TrashObjects[i][trash_area]);
		TrashObjects[i][trash_area] = CreateDynamicCylinder(TrashObjects[i][trash_x],  
	        TrashObjects[i][trash_y],
	        TrashObjects[i][trash_z]-2.0,
	        TrashObjects[i][trash_z]+2.0, 3.0, 0, 0);

	}
	return 1;
}

stock StartEco(playerid) {
	if(GetPVarInt(playerid, "Ecologyst")) {
		SendClientMessage(playerid, -1, """{6de64e}""Âű çŕâĺđřčëč đŕáîňó");
		RemovePlayerAttachedObject(playerid, 8);
		DeletePVar(playerid, "Ecologyst");
		SetPVarInt(playerid, "trash_collected", 0);
	} else {
		SetPVarInt(playerid, "Ecologyst", 1);

		format(small_string, sizeof(small_string), "%s íŕäĺë(ŕ) çŕůčňíűĺ ďĺđ÷ŕňęč", PlayerInfo[playerid][pName]);
		ProxDetector(playerid, 20, 0xDD90FFFF, small_string);

		RM_ShowPlayerDialog(playerid, dKickMessage, 0, "Đŕáîňŕ", """{FFFFFF}""Âű óńňđîčëčńü íŕ đŕáîňó óáîđůčęŕ ďë˙ćŕ, âŕě áűë âűäŕí ďŕęĺň č ďĺđ÷ŕňęč\n""{4eb9e6}""Ńîáčđŕéňĺ ěóńîđ, ŕ çŕňĺě îňíîńčňĺ â áŕę. Çŕ ęŕćäűé ńäŕííűé ěĺřîę âű ďîëó÷čňĺ {FFFFFF}175 EXP", "ÎĘ", "");

		SetPVarInt(playerid, "trash_collected", 0);
	}
	return 1;
}

forward EcoArea(playerid, areaid);
public EcoArea(playerid, areaid) {

	if(IsPlayerInAnyVehicle(playerid)) return 1;

	if(GetPVarInt(playerid, "Ecologyst") == 0) return 1;

	new trash_collected = GetPVarInt(playerid, "trash_collected");

	if(trash_collected >= 15) {
		return SendClientMessage(playerid, -1, """{4eb9e6}""Ďŕęĺň ďĺđĺďîëíĺí, ńäŕéňĺ ĺăî č ďîëó÷čňĺ çŕđďëŕňó");
	}

	for(new i = 0; i < 182; i++) {
		if(areaid == TrashObjects[i][trash_area] && TrashObjects[i][spawned] == 1) {
			PlayerPlaySound(playerid, 1039, 0, 0, 0);
			TrashObjects[i][spawned] = 0;
			if(IsValidDynamicObject(TrashObjects[i][trash_obj])) DestroyDynamicObject(TrashObjects[i][trash_obj]);
			GameTextForPlayer(playerid, "~g~Clean ~w~...", 10000, 3);
			ApplyAnimation(playerid,"BOMBER","BOM_Plant",4.0,1,1,1,1,0);
			BeachTimer[playerid] = KillTimer(BeachTimer[playerid]);
			BeachTimer[playerid] = SetTimerEx("EcoFinish", 12000, false, "d", playerid);
			SetPVarInt(playerid, "trash", TrashObjects[i][trash_area]);
		}
	}
	return 1;
}
forward EcoFinish(playerid, areaid);
public EcoFinish(playerid, areaid) {

	BeachTimer[playerid] = KillTimer(BeachTimer[playerid]);

	if(!IsPlayerInDynamicArea(playerid, GetPVarInt(playerid, "trash"))) {
		RemovePlayerAttachedObject(playerid, 8);
		DeletePVar(playerid, "Ecologyst");
		GameTextForPlayer(playerid, "~r~Clean ~w~Failed", 2000, 3);
		SendClientMessage(playerid, -1, """{ff353c}""Íĺ äâčăŕéňĺńü ďđč ńáîđĺ ěóńîđŕ!");
		SetPVarInt(playerid, "trash_collected", 0);

		PlayerPlaySound(playerid, 1053, 0, 0, 0);

		format(small_string, sizeof(small_string), "%s ďîđâŕë(ŕ) ńâîé ďŕęĺň", PlayerInfo[playerid][pName]);
		ProxDetector(playerid, 20, 0xDD90FFFF, small_string);
		return 1;
	}

	SetPlayerAttachedObject(playerid,8,1264,6,0.199999,0.065,0.100000,0.000000,-83.000000,0.000000,0.40000,0.40000,0.40000); 

	PlayerPlaySound(playerid, 1052, 0, 0, 0);

	GameTextForPlayer(playerid, "~g~Clean ~w~++", 1500, 3);
	ClearPlayerAnimation(playerid);

	new trash_collected = GetPVarInt(playerid, "trash_collected");

	if(trash_collected >= 15) {
		SendClientMessage(playerid, -1, """{ff353c}""Ďŕęĺň ďĺđĺďîëíĺí, ńäŕéňĺ ĺăî ŕ ňîëüęî ďîňîě îňęđűâŕéňĺ íîâűé!");
		return 1;
	}

	trash_collected = trash_collected+1;
	SetPVarInt(playerid, "trash_collected", trash_collected);

	format(small_string, sizeof(small_string), "%s cëîćčë(ŕ) ěóńîđ â ďŕęĺň", PlayerInfo[playerid][pName]);
	ProxDetector(playerid, 20, 0xDD90FFFF, small_string);


	format(small_string, sizeof(small_string), """{6de64e}""Ďŕęĺň íŕďîëíĺí: {FFFFFF}%d/%d ", trash_collected, 15);
	SendClientMessage(playerid, -1, small_string);

	if(trash_collected >= 15) {
		SendClientMessage(playerid, -1, """{FFAF00}""Ďŕęĺň çŕďîëíĺí, âű ěîćĺňĺ ńäŕňü ĺăî č ďîëó÷čňü äĺíüăč");
	}

	new random_show = random(4);
	if(random_show == 0) {
		new random_quote = random(8);
		RM_ShowPlayerDialog(playerid, dKickMessage, 0, " ", eco_quotes[random_quote], "Çŕęđűňü", "");
	}

	return 1;
}

forward pc_cmd_recycle(playerid); public pc_cmd_recycle(playerid) {

	if(!IsPlayerInRangeOfPoint(playerid, 6, 147.8,-1948.81,3.7)) return 1;

	new trash_collected = GetPVarInt(playerid, "trash_collected");

	if(trash_collected >= 15) {
		PlayerPlaySound(playerid, 1050, 0, 0, 0);
		format(small_string, sizeof(small_string), "%s ńäŕë(ŕ) ďîëíűé ďŕęĺň", PlayerInfo[playerid][pName]);
		ProxDetector(playerid, 20, 0xDD90FFFF, small_string);
		SetPVarInt(playerid, "trash_collected", 0);
		RemovePlayerAttachedObject(playerid, 8);
		GameTextForPlayer(playerid, "Completed", 5000, 3);
		SendClientMessage(playerid, -1, """{6de64e}""Âű ńäŕëč ďîëíűé ďŕęĺň č ďîëó÷čëč {FFFFFF}175 EXP");
		if(IsPlayerPremiumAccount(playerid) == true || 0 == 1) {
			AddPlayerEXP(playerid, (175*2), "Óáîđęŕ ďë˙ćŕ");
		} else {
			AddPlayerEXP(playerid, 175, "Óáîđęŕ ďë˙ćŕ");
		}
		UpdatePlayerProgressQuest(playerid, E_CLEANING);
		SendClientMessage(playerid, -1, """{6de64e}""Ďđîäîëćŕéňĺ â ňîě ćĺ äóőĺ!");
	}

	return 1;
}
