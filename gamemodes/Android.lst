		}
		else if (diff > 0)
		{
			end = mid - 1;
		}
		else
		{
			return AMX_Read(heap + mid * 8 + 4);
		}
	}
	return cellmin;
}

static stock YHNPS_Insert(heap, count, value, ptr)
{
	new
		start = 0,
		mid,
		end = count - 1;
	while (start <= end)
	{
		mid = (start + end) / 2;
		new
			diff = value - AMX_Read(heap + mid * 8);
		if (diff < 0)
		{
			start = mid + 1;
		}
		else if (diff > 0)
		{
			end = mid - 1;
		}
		else
		{
			return;
		}
	}
	if (start == count)
	{

		AMX_Write(heap + count * 8, value);
		AMX_Write(heap + count * 8 + 4, ptr);
	}
	else
	{

		rawMemcpy_((heap + mid * 8 + 8),( heap + mid * 8),0,( (count - mid) * 8),(cellmax>>>2));
		AMX_Write(heap + mid * 8, value);
		AMX_Write(heap + mid * 8 + 4, ptr);
	}
}

