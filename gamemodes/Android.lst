	SetCameraBehindPlayer(playerid);
	return true;
}

stock House_UnLinkPlayer(const playerid) {
	new 
		arrayID = Player__LinkHouseID[playerid];

	if(arrayID == (-1)) {
		return false;
	}

	if(Player__ViemTime{playerid} > 0) {
