				mysql_query(database, "SELECT p.Name, Count(d.Type) As `Kill` FROM dm_area AS d LEFT OUTER JOIN players AS p ON p.ID = d.PlayerID WHERE DATE(d.Time) > CURRENT_DATE() - INTERVAL 30 DAY AND d.Type='Óáčéńňâî äđóăîăî čăđîęŕ' AND d.Platform = 'Ęîěďüţňĺđ' GROUP BY d.PlayerID ORDER BY `Kill` DESC LIMIT 10", true);
			}
			case 3: {
				mysql_query(database, "SELECT p.Name, Count(d.Type) As `Kill` FROM dm_area AS d LEFT OUTER JOIN players AS p ON p.ID = d.PlayerID WHERE d.Type='Óáčéńňâî äđóăîăî čăđîęŕ' AND d.Platform = 'Ęîěďüţňĺđ' GROUP BY d.PlayerID ORDER BY `Kill` DESC LIMIT 10", true);
			}
			default: {
				return Dialog_Show(playerid, #DIALOG_SELECT_AREA_LIST_PC);
			}
		}
		new 
			rows = cache_get_row_count();

		new 
			name[24],
			kill;

		big_string[0] = EOS;
		big_string = !"Čăđîę\tĘîëč÷ĺńňâî óáčéńňâ\n";

		for(new i = 0; i < rows; i++) {
			cache_get_field_content(i, "Name", name);
			kill = cache_get_field_content_int(i, "Kill");

			if(i == 0 && strcmp(name, "NULL") == 0) {
				strcat(big_string, """{FFAF00}""Đĺéňčíă čăđîęîâ ĺůĺ íĺ ńôîđěčđîâŕí");
				break;
			}
			format(small_string, sizeof(small_string), "%s\t""{6de64e}""%i\n", name, kill);
			strcat(big_string, small_string);
		}
		return Dialog_Open(playerid, #DIALOG_RETURN_LIST_PC, 5, """{4eb9e6}""Ëó÷řčĺ čăđîęč", big_string, "Íŕçŕä", "");
	}
}

forward dre_DIALOG_RETURN_LIST_PC(playerid, response, listitem, inputtext[]); public dre_DIALOG_RETURN_LIST_PC(playerid, response, listitem, inputtext[]) {
	return Dialog_Show(playerid, #DIALOG_SELECT_AREA_LIST_PC);
