	PlayerInfo[playerid][pDrugsSell] --;
	AddPlayerAchievement(playerid, E_DRUG_TRAFFICKET);
	SetPlayerInt(playerid, "DrugsSell", PlayerInfo[playerid][pDrugsSell]);
    if(PlayerInfo[playerid][pDrugsSell]  <= 0) {
	    PlayerInfo[playerid][pDrugsSell]  = 0;
	    SetPlayerInt(playerid, "DrugsSell", PlayerInfo[playerid][pDrugsSell]);
	    SetPVarInt(playerid, "deliver_started", 0);
	    IncreaseStatus(playerid, 1);
	    SendClientMessage(playerid, -1, """{6de64e}""Ňű äîńňŕâčë âńĺ íŕđęîňčęč");
		for(new i = 0; i < 41; i++) {
			if(IsValidDynamicCP(point_sell[i])) {
				TogglePlayerDynamicCP(playerid, point_sell[i], false);
			}
		}
		return 1;
	}

	DecreaseKarma(playerid);

	switch(random(10)) {
		case 0: SendClientMessage(playerid, 0xE6E6E6E6, "- Ďîęóďŕňĺëü: Îňëč÷íűé ńňŕôô, ÷óâŕę. Óäŕ÷č ňĺáĺ");
		case 1: SendClientMessage(playerid, 0xE6E6E6E6, "- Ďîęóďŕňĺëü: Çŕĺçćŕé ĺůĺ, íčăăĺđ");
		case 2: SendClientMessage(playerid, 0xE6E6E6E6, "- Ďîęóďŕňĺëü: Ěîă áű č ďîáűńňđĺé, áŕđűăŕ");
		case 3: SendClientMessage(playerid, 0xE6E6E6E6, "- Ďîęóďŕňĺëü: Ęëŕńńíŕ˙ ďĺňđóřęŕ, ŕ ňĺďĺđü âŕëč îňńţäŕ!");
		case 4: SendClientMessage(playerid, 0xE6E6E6E6, "- Ďîęóďŕňĺëü: Ďŕőíĺň âîëřĺáńňâîě, ńďŕńčáî ěýí");
		case 5: SendClientMessage(playerid, 0xE6E6E6E6, "- Ďîęóďŕňĺëü: Íčăăŕ, ěű ňĺá˙ óćĺ çŕćäŕëčńü");
		case 6: SendClientMessage(playerid, 0xE6E6E6E6, "- Ďîęóďŕňĺëü: Íŕäĺţńü íĺ áóäĺň ęŕę â ďđîřëűé đŕç...");
		case 7: SendClientMessage(playerid, 0xE6E6E6E6, "- Ďîęóďŕňĺëü: Đŕäč ýňîăî ˙ ďđîäŕë ěŕěčíî îáđó÷ŕëüíîĺ ęîëüöî");
		case 8: SendClientMessage(playerid, 0xE6E6E6E6, "- Ďîęóďŕňĺëü: Óő, ůŕń ďîëĺňŕĺě");
		case 9: SendClientMessage(playerid, 0xE6E6E6E6, "- Ďîęóďŕňĺëü: Íŕäĺţńü ýňî íĺ ěóęŕ!");
	}

	format(drug_string, sizeof(drug_string), """{4eb9e6}""Ďîëó÷ĺíî: ""{FFFFFF}""%d EXP", 50);
