forward pc_cmd_bang(playerid, params[]); public pc_cmd_bang(playerid, params[])
{
	if(IsPlayerInDynamicArea(playerid, safe_zone[0]) || IsPlayerInDynamicArea(playerid, safe_zone[1]) ||
	IsPlayerInDynamicArea(playerid, safe_zone[2]) || IsPlayerInDynamicArea(playerid, safe_zone[3]) ||
	IsPlayerInDynamicArea(playerid, safe_zone[4]) || IsPlayerInDynamicArea(playerid, safe_zone[5]) ||
	IsPlayerInDynamicArea(playerid, safe_zone[6]) || IsPlayerInDynamicArea(playerid, safe_zone[7]) ||
	IsPlayerInDynamicArea(playerid, safe_zone[8]) || IsPlayerInDynamicArea(playerid, safe_zone[9])) {
	return SendClientMessage(playerid, -1, """{ff353c}""Čńďîëüçîâŕíčĺ âçđűâíűő óńňđîéńňâ â áĺçîďŕńíîé çîíĺ çŕďđĺůĺí");
	}
	if(GetPlayerVirtualWorld(playerid) != 0 || GetPlayerInterior(playerid) != 0) {
		return SendClientMessage(playerid, -1, """{ff353c}""Čńďîëüçîâŕíčĺ âçđűâíűő óńňđîéńňâ â ďîěĺůĺíč˙ő íĺâîçěîćíî");

	}

	new bomb_id, dist;
	if(sscanf(params, "dd", bomb_id, dist)) return SendClientMessage(playerid, -1, !"Čńďîëüçóéňĺ: /bang [id óńňđîéńňâŕ] [äčńňŕíöč˙]");
	if(GetPVarInt(playerid,"bomb_dropped") > gettime()) {
		return SendClientMessage(playerid, -1, """{ff353c}""Ďîäîćäčňĺ íĺěíîăî");
	}
	if(IsPlayerInAnyVehicle(playerid)) {
		return SendClientMessage(playerid, -1, """{ff353c}""Čńďîëüçîâŕíčĺ äŕííîé ęîěŕíäű â ňđŕíńďîđňĺ íĺâîçěîćíî");
	}
	if(bomb_id > 3 || bomb_id < 1) return SendClientMessage(playerid, -1, "(( id 1 - ďĺňŕđäŕ, id 2 - ăđŕíŕňŕ, id 3 - äčíŕěčň ))");

	if(dist > 10 || dist < 2) return SendClientMessage(playerid, -1, """{ff353c}""Äčńňŕíöč˙ äîëćíŕ áűňü îň 2 äî 10 ěĺňđîâ");
	new delay = 10;








	SetPVarInt(playerid, "delay_bomb", delay);

	SetPVarInt(playerid,"bomb_dropped",gettime()+15);

	new Float:bpos_x, Float:bpos_y, Float:bpos_z;
	GetPlayerPos(playerid, bpos_x, bpos_y, bpos_z);


