		SetPlayerInt(playerid, "PayDayBonus", PlayerInfo[playerid][pPayDayBonus]);
		format(small_string, sizeof small_string, ""COLOR_BLUE"За сегодня вы отыграли: {FFFFFF}%d ч.", PlayerInfo[playerid][pPayDayBonus]);
		SendClientMessage(playerid, -1, small_string);
		SendClientMessage(playerid, -1, ""COLOR_BLUE"Отыграв 6 часов вы получите 49 руб. на свой донат-счет!");
		SendClientMessage(playerid, -1, ""COLOR_BLUE"Этого хватит:{FFFFFF} прокрутить рулетку / получить ~1000 EXP / сменить РП Ник");
	}

	*/
	return 1;
}

