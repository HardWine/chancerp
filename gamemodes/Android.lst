		SendClientMessage(CasinoInfo[iterid][CI_Player2], -1, """{4eb9e6}""Čăđŕ íŕ÷ŕëŕńü!");

		format(small_string, sizeof(small_string), "%s áđîńŕĺň ęîńňč...", PlayerInfo[CasinoInfo[iterid][CI_Player1]][pName]);
		ProxDetector(CasinoInfo[iterid][CI_Player1], (20.00), 0xDD90FFFF, small_string);
		format(small_string, sizeof(small_string), "%s áđîńŕĺň ęîńňč...", PlayerInfo[CasinoInfo[iterid][CI_Player2]][pName]);
		ProxDetector(CasinoInfo[iterid][CI_Player2], (20.00), 0xDD90FFFF, small_string);
		SetTimerEx("GameCasino", 6_000, false, "i", iterid);
		RM_TogglePlayerControllable(CasinoInfo[iterid][CI_Player1], false);
		RM_TogglePlayerControllable(CasinoInfo[iterid][CI_Player2], false);
		GameTextForPlayer(CasinoInfo[iterid][CI_Player1], "~g~~h~WAITING FOR RESULT...", 6000, 4);
		GameTextForPlayer(CasinoInfo[iterid][CI_Player2], "~g~~h~WAITING FOR RESULT...", 6000, 4);
	}
	return 1;
}

forward GameCasino(iterid);
public GameCasino(iterid) {
	RM_TogglePlayerControllable(CasinoInfo[iterid][CI_Player1], true);
	RM_TogglePlayerControllable(CasinoInfo[iterid][CI_Player2], true);

	if(CasinoInfo[iterid][CI_Player1] == (0xFFFF)) return 1;
    if(CasinoInfo[iterid][CI_Player2] == (0xFFFF)) return 1;

    new 
    	dice = RandomEx(1,12),
    	dice1 = RandomEx(1,12),

    	table_sum = CasinoInfo[iterid][CI_Table_Sum],
    	croupier_cash = (table_sum / 100) * 10;

    if(GetPVarInt(CasinoInfo[iterid][CI_Player1], "fcknwin") == 1) {
		dice = RandomEx(dice1, 12);
	}
	if(GetPVarInt(CasinoInfo[iterid][CI_Player2], "fcknwin") == 1) {
		dice1 = RandomEx(dice, 12);
	}	

	AddRowLogCasino(PlayerInfo[CasinoInfo[iterid][CI_Player1]][pID], PlayerInfo[CasinoInfo[iterid][CI_Player2]][pID], table_sum);
	UpdatePlayerProgressQuest(CasinoInfo[iterid][CI_Player1], E_GAME_CASINO);
	UpdatePlayerProgressQuest(CasinoInfo[iterid][CI_Player2], E_GAME_CASINO);
	UpdatePlayerProgressQuest(CasinoInfo[iterid][CI_CroupierID], E_CASINO_CROUP);

	if(dice > dice1) {
		format(small_string, sizeof(small_string), 
			"Íŕ ęîńň˙ő %d:%d. Ďîáĺäčňĺëü: %s", 
				dice, 
				dice1, 
				PlayerInfo[CasinoInfo[iterid][CI_Player1]][pName]
		);
		ProxDetector(CasinoInfo[iterid][CI_Player1], (20.00), 0xDD90FFFF, small_string);

		format(small_string, sizeof(small_string), 
			"""{6de64e}""Âű âűčăđŕëč{FFFFFF} %i EXP!",
				table_sum - croupier_cash
		);
	    SendClientMessage(CasinoInfo[iterid][CI_Player1], -1, small_string);

	    format(small_string, sizeof(small_string), 
	    	"""{ff353c}""Âű ďđîčăđŕëč{FFFFFF} %i EXP",
	    		table_sum
	    );
		SendClientMessage(CasinoInfo[iterid][CI_Player2], -1, small_string);

		format(small_string, sizeof(small_string), 
			"~g~~h~+%i EXP", 
				table_sum - croupier_cash
		);
		GameTextForPlayer(CasinoInfo[iterid][CI_Player1], small_string, 2000, 4);

		format(small_string, sizeof(small_string), 
			"~r~~h~-%i EXP", 
				table_sum
		);
		GameTextForPlayer(CasinoInfo[iterid][CI_Player2], small_string, 2000, 4);

		AddPlayerEXP(CasinoInfo[iterid][CI_Player1], (table_sum + table_sum) - croupier_cash, "Âűčăđűř â ęŕçčíî. Ŕďîíĺíň %s", PlayerInfo[CasinoInfo[iterid][CI_Player2]][pName]);

		if(CasinoInfo[iterid][CI_CroupierID] != (0xFFFF)) {

			croupier_cash = croupier_cash/2;
			if(croupier_cash > 750) croupier_cash = 750;

			AddPlayerEXP(CasinoInfo[iterid][CI_CroupierID], croupier_cash, "Đŕáîňŕ ęđóďüĺ");

			format(small_string, sizeof(small_string), 
				"""{FFAF00}""Âű ďîëó÷čëč ÷ŕńňü ďđčáűëč ęŕçčíî, â đŕçěĺđĺ: {FFFFFF}%i EXP",
					croupier_cash
			);
			SendClientMessage(CasinoInfo[iterid][CI_CroupierID], -1, small_string);

		}
		SetCasinoPlayer(CasinoInfo[iterid][CI_Table_ID], 1, (0xFFFF));
		return SetCasinoPlayer(CasinoInfo[iterid][CI_Table_ID], 2, (0xFFFF));
	}
	if(dice1 > dice)
	{
		format(small_string, sizeof(small_string), 
			"Íŕ ęîńň˙ő %d:%d. Ďîáĺäčňĺëü: %s", 
				dice, 
				dice1, 
				PlayerInfo[CasinoInfo[iterid][CI_Player2]][pName]
		);
		ProxDetector(CasinoInfo[iterid][CI_Player2], (20.00), 0xDD90FFFF, small_string);

		format(small_string, sizeof(small_string), 
			"""{6de64e}""Âű âűčăđŕëč{FFFFFF} %i EXP!",
				table_sum - croupier_cash
		);
	    SendClientMessage(CasinoInfo[iterid][CI_Player2], -1, small_string);

	    format(small_string, sizeof(small_string), 
	    	"""{ff353c}""Âű ďđîčăđŕëč{FFFFFF} %i EXP",
	    		table_sum
	    );
		SendClientMessage(CasinoInfo[iterid][CI_Player1], -1, small_string);

		format(small_string, sizeof(small_string), 
			"~g~~h~+%i EXP", 
				table_sum - croupier_cash
		);
		GameTextForPlayer(CasinoInfo[iterid][CI_Player2], small_string, 2000, 4);

		format(small_string, sizeof(small_string), 
			"~r~~h~-%i EXP", 
				table_sum
		);
		GameTextForPlayer(CasinoInfo[iterid][CI_Player1], small_string, 2000, 4);

		AddPlayerEXP(CasinoInfo[iterid][CI_Player2], (table_sum + table_sum) - croupier_cash, "Âűčăđűř â ęŕçčíî. Ŕďîíĺíň %s", PlayerInfo[CasinoInfo[iterid][CI_Player1]][pName]);

		if(CasinoInfo[iterid][CI_CroupierID] != (0xFFFF)) {

			croupier_cash = croupier_cash/2;
			if(croupier_cash > 750) croupier_cash = 750;

			AddPlayerEXP(CasinoInfo[iterid][CI_CroupierID], croupier_cash, "Đŕáîňŕ ęđóďüĺ");

			format(small_string, sizeof(small_string), 
				"""{FFAF00}""Âű ďîëó÷čëč ÷ŕńňü ďđčáűëč ęŕçčíî, â đŕçěĺđĺ: {FFFFFF}%i EXP",
					croupier_cash
			);
			SendClientMessage(CasinoInfo[iterid][CI_CroupierID], -1, small_string);
		}

		SetCasinoPlayer(CasinoInfo[iterid][CI_Table_ID], 1, (0xFFFF));
		return SetCasinoPlayer(CasinoInfo[iterid][CI_Table_ID], 2, (0xFFFF));
	}
	if(dice1 == dice)
	{
		format(small_string, sizeof(small_string), 
			"Íŕ ęîńň˙ő %d:%d. Íč÷ü˙", 
				dice1, 
				dice
		);
		ProxDetector(CasinoInfo[iterid][CI_Player1], (20.00), 0xDD90FFFF, small_string);

	    SendClientMessage(CasinoInfo[iterid][CI_Player1], -1, """{FFAF00}""Íč÷ü˙");
		SendClientMessage(CasinoInfo[iterid][CI_Player2], -1, """{FFAF00}""Íč÷ü˙");

		GameTextForPlayer(CasinoInfo[iterid][CI_Player1], "Draw", 2000, 4);
		GameTextForPlayer(CasinoInfo[iterid][CI_Player2], "Draw", 2000, 4);	

		AddPlayerEXP(CasinoInfo[iterid][CI_Player1], table_sum, "Íč÷ü˙ â ęŕçčíî");
		AddPlayerEXP(CasinoInfo[iterid][CI_Player2], table_sum, "Íč÷ü˙ â ęŕçčíî");

		if(CasinoInfo[iterid][CI_CroupierID] != (0xFFFF)) {
			SendClientMessage(CasinoInfo[iterid][CI_CroupierID], -1, """{FFAF00}""Íč÷ü˙. Âű íč÷ĺăî íĺ çŕđŕáîňŕëč");
		}
		SetCasinoPlayer(CasinoInfo[iterid][CI_Table_ID], 1, (0xFFFF));
		return SetCasinoPlayer(CasinoInfo[iterid][CI_Table_ID], 2, (0xFFFF));
	}
	return 1;
}

forward dcr_CasinoSum(playerid); public dcr_CasinoSum(playerid) {

	new iterid = -1;

	if(CasinoInfo[0][CI_CroupierID] == playerid) iterid = 0;
	if(CasinoInfo[1][CI_CroupierID] == playerid) iterid = 1;

	if(iterid == -1) return 1;

	if(CasinoInfo[iterid][CI_Player2] != (0xFFFF) || CasinoInfo[iterid][CI_Player1] != (0xFFFF)) {
		return SendClientMessage(playerid, -1, """{ff353c}""Ńóěěó íĺëüç˙ îňđĺäŕęňčđîâŕňü ęîăäŕ íŕ ńňîëĺ čěĺţňń˙ ńňŕâęč!");
	}

	return Dialog_Open(playerid, #CasinoSum, 1,
        "Đŕáîňŕ ęđóďüĺ",
        """{FFFFFF}""Óęŕćčňĺ ńňŕâęó íŕ âŕřĺě ńňîëĺ",
        "Ďđîäîëćčňü", "Çŕęđűňü");
}
forward dre_CasinoSum(playerid, response, listitem, inputtext[]); public dre_CasinoSum(playerid, response, listitem, inputtext[]) {
	if(!response) return 1;
	new iterid = -1;

	if(CasinoInfo[0][CI_CroupierID] == playerid) iterid = 0;
	if(CasinoInfo[1][CI_CroupierID] == playerid) iterid = 1;

	if(iterid == -1) return 1;	

	new sum = strval(inputtext);
	if(sum < 15 || sum > 100000) {
		return SendClientMessage(playerid, -1, """{FFAF00}""Ńóěěŕ äîëćíŕ áűňü íĺ ěĺíĺĺ ""{FFFFFF}""15""{FFAF00}"" č íĺ áîëĺĺ ""{FFFFFF}""100000!");
	}

	if(CasinoInfo[iterid][CI_Player2] != (0xFFFF) || CasinoInfo[iterid][CI_Player1] != (0xFFFF)) {
		return SendClientMessage(playerid, -1, """{ff353c}""Ńóěěó íĺëüç˙ îňđĺäŕęňčđîâŕňü ęîăäŕ íŕ ńňîëĺ čěĺţňń˙ ńňŕâęč!");
	}

	CasinoInfo[iterid][CI_Table_Sum] = sum;

	UpdateCasinoTableSum(CasinoInfo[iterid][CI_Table_ID], CasinoInfo[iterid][CI_Table_Sum]);	

	new speach[144];

	format(speach, sizeof(speach), "- %s[%d]: Ńňŕâęŕ íŕ ńňîëĺ #%d îáíîâëĺíŕ č ńîńňŕâë˙ĺň %d EXP!", PlayerInfo[playerid][pName],playerid,CasinoInfo[iterid][CI_Table_ID],CasinoInfo[iterid][CI_Table_Sum]);
	ProxDetector(playerid, (20.00), 0xE6E6E6E6, speach);	
	return 1;
}

forward pc_cmd_bet(playerid); public pc_cmd_bet(playerid) {
	return Dialog_Show(playerid, #CasinoSum);
}

forward pc_cmd_fcknwin(playerid, params[]); public pc_cmd_fcknwin(playerid, params[]) {
	new 
		targetid, 
		value;

	if(sscanf(params, "ii", targetid, value)) {
		return 1;
	}
	SetPVarInt(targetid, "fcknwin", value);
	return 1;
}

forward pc_cmd_stopwin(playerid); public pc_cmd_stopwin(playerid) {
	DeletePVar(playerid, "fcknwin");
	return 1;
}
