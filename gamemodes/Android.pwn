		case dRolePlay2: { return ShowPlayerDialog(playerid, dRolePlay3, DIALOG_STYLE_MSGBOX, "Помощь", "{FFFFFF}Основные команды:\n "COLOR_ORANGE"/mm{FFFFFF}, основное игровое меню.\n "COLOR_ORANGE"/gps{FFFFFF} активирует панель GPS, с её помощью можно найти то или иное место", "Далее", ""); }
		case dRolePlay3: { return ShowPlayerDialog(playerid, dRolePlay4, DIALOG_STYLE_MSGBOX, "Помощь", "{FFFFFF}У нас запрещено:\n"COLOR_ORANGE"ДМ{FFFFFF} - Убийство без причины\n"COLOR_ORANGE"ДБ{FFFFFF} - Убийство с машины (машиной)\n"COLOR_ORANGE"СК{FFFFFF} - Спавн килл, т.е. убийство при появлении\n"COLOR_ORANGE"МГ{FFFFFF} - Meta Gaming - Использование информации из реального мира в игровом чате", "Далее", ""); }
