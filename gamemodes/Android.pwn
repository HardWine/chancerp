				SetVehicleParamsEx(PlayerAviationVehicleID[playerid], engine, lights, alarm, 0, bonnet, boot, objective);
				format(small_string, sizeof(small_string), "%s открыл(а) замок", PlayerInfo[playerid][pName]);
				PlayerPlaySound(playerid, 24600, 0, 0, 0);
				ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_PURPLE, small_string);
				return GameTextForPlayer(playerid, "~g~Unlocked", 2500, 4);
			}
			if(doors == 0) {
				SetVehicleParamsEx(PlayerAviationVehicleID[playerid], engine, lights, alarm, 1, bonnet, boot, objective);
				format(small_string, sizeof(small_string), "%s закрыл(а) замок", PlayerInfo[playerid][pName]);
				PlayerPlaySound(playerid, 24600, 0, 0, 0);
				ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_PURPLE, small_string);
				return GameTextForPlayer(playerid, "~r~Locked", 2500, 4);
			}
			if(doors == -1) {
				SetVehicleParamsEx(PlayerAviationVehicleID[playerid], engine, lights, alarm, 0, bonnet, boot, objective);
				format(small_string, sizeof(small_string), "%s открыл(а) замок", PlayerInfo[playerid][pName]);
				PlayerPlaySound(playerid, 24600, 0, 0, 0);
				ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_PURPLE, small_string);
				return GameTextForPlayer(playerid, "~g~Unlocked", 2500, 4);
			}
		}
	} else if(PlayerYachtVehicleID[playerid] != INVALID_VEHICLE_ID) {
		GetVehicleParamsEx(PlayerYachtVehicleID[playerid], engine, lights, alarm, doors, bonnet, boot, objective);

		new Float:xx,Float:yy,Float:zz;
		GetVehiclePos(PlayerYachtVehicleID[playerid], xx, yy, zz);
		if(IsPlayerInRangeOfPoint(playerid, 14, xx, yy, zz)) {
			if(doors == 1) {
				SetVehicleParamsEx(PlayerYachtVehicleID[playerid], engine, lights, alarm, 0, bonnet, boot, objective);
				format(small_string, sizeof(small_string), "%s открыл(а) замок", PlayerInfo[playerid][pName]);
				PlayerPlaySound(playerid, 24600, 0, 0, 0);
				ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_PURPLE, small_string);
				return GameTextForPlayer(playerid, "~g~Unlocked", 2500, 4);
			}
			if(doors == 0) {
				SetVehicleParamsEx(PlayerYachtVehicleID[playerid], engine, lights, alarm, 1, bonnet, boot, objective);
				format(small_string, sizeof(small_string), "%s закрыл(а) замок", PlayerInfo[playerid][pName]);
				PlayerPlaySound(playerid, 24600, 0, 0, 0);
