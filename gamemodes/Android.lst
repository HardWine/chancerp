forward pc_cmd_eat(playerid); public pc_cmd_eat(playerid) {
		if(IsPlayerInAnyVehicle(playerid)) return SendClientMessage(playerid, -1, "Íĺëüç˙ čńďîëüçîâŕňü â ňđŕíńďîđňĺ");
		if(GetPVarInt(playerid,"AntiFloodMLocal") > gettime()){ SendClientMessage(playerid, -1, """{ff353c}""Íĺëüç˙ čńďîëüçîâŕňü ňŕę ÷ŕńňî"); return false; }
		SetPVarInt(playerid,"AntiFloodMLocal",gettime() + 60);
		if(PlayerInfo[playerid][pShroom] < 1) return SendClientMessage(playerid, -1, "Ó âŕń íĺň íč÷ĺăî ńúĺäîáíîăî");
		PlayerInfo[playerid][pShroom] -= 1;
		SetPlayerInt(playerid, "Shroom", PlayerInfo[playerid][pShroom]);
		new Float:health;
		GetPlayerHealth(playerid, Float:health);
		health += 25.0;
		if(health > 100) health = 100;
		SetPlayerHealth(playerid, health);
		PlayerInfo[playerid][pHunger] += 5;
		SetPlayerInt(playerid, "Hunger", PlayerInfo[playerid][pHunger]);
		SetPlayerChatBubble(playerid, "ńęóřŕë(ŕ) ăđčá", 0xDD90FFFF, 30.0, 5000);
		ClearPlayerAnimation(playerid);
		ApplyAnimation(playerid,"PED","GUM_EAT",4.1,0,0,0,0,0,1);
		format(small_string, sizeof(small_string), "%s ńęóřŕë(ŕ) ăđčá", PlayerInfo[playerid][pName]);
		ProxDetector(playerid, (20.00), 0xDD90FFFF, small_string);
		new druggy = RandomEx(0,15);
		if(druggy == 15) {
			SetPlayerHealth(playerid, 150);
			SetPlayerWeather(playerid, -68);
			DrugTimer[playerid] = KillTimer(DrugTimer[playerid]);
			DrugTimer[playerid] = SetTimerEx("DrugsEffect", 30000, false, "i", playerid);
			SetPlayerDrunkLevel(playerid, 6000);
			SendClientMessage(playerid, -1, """{FFAF00}""Ăđčá îęŕçŕëń˙ ďńčëîöčáčíîâűě!");
		}
		if(PlayerInfo[playerid][pShroom] > 0) {
			format(small_string, sizeof(small_string), """{4eb9e6}""Ăđčáîâ îńňŕëîńü: {ffffff}%d", PlayerInfo[playerid][pShroom]);
			SendClientMessage(playerid, -1, small_string);
		}
		else SendClientMessage(playerid, -1, """{ff353c}""Ăđčáű çŕęîí÷čëčńü");
		return 1;
}

forward pc_cmd_sellshroom(playerid); public pc_cmd_sellshroom(playerid) {
	if(!IsPlayerInRangeOfPoint(playerid, 10, 1081.24, -1696.78, 13.55)) return SendClientMessage(playerid, -1, """{ff353c}""Íĺîáőîäčěî íŕőîäčňüń˙ ó đĺńňîđŕíŕ (/gps - Äđóăčĺ ěĺńňŕ)");

	if(PlayerInfo[playerid][pShroom] > 0) {
	new total = 0;
	new bad = 0;
	new sum_shroom = PlayerInfo[playerid][pShroom];
	for(new i = 1; i < sum_shroom; i++) {
		if(RandomEx(1,20) == 1) bad += 1;
		else {
			total += 5;
			if(RandomEx(1,10) == 1) total += RandomEx(1,20);
		}
	}
	if(bad != 0) {
		format(small_string, sizeof(small_string), """{ff353c}""Âńĺăî %d ăđčáîâ îęŕçŕëčńü čńďîđ÷ĺííűěč", bad);
		SendClientMessage(playerid, -1, small_string);
	}
	SendClientMessage(playerid, -1, """{6de64e}""Âű óńďĺříî ďđîäŕëč âńĺ ńâîč ăđčáű đĺńňîđŕíó");
	format(small_string, sizeof small_string, "~g~+%d EXP", total);
	GameTextForPlayer(playerid, small_string, 3500, 0);
	if(IsPlayerPremiumAccount(playerid) == true || 0 == 1) {
		total = total * 2;
	}
	AddPlayerEXP(playerid, total, "Ďđîäŕćŕ %i ăđčáîâ", sum_shroom);

	PlayerInfo[playerid][pShroom] = 0;
	SetPlayerInt(playerid, "Shroom", PlayerInfo[playerid][pShroom]);
	}
	return 1;
}
forward pc_cmd_marry(playerid, params[]); public pc_cmd_marry(playerid, params[]) {

	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ: /marry [id čăđîęŕ]");
	if(params[0] == (0xFFFF)) return 1;

	if(PlayerInfo[playerid][pBirth] == 0) return SendClientMessage(playerid, -1, "Ó Âŕń íĺň ďŕńďîđňŕ! Ďîëó÷čňü ĺăî ěîćíî ó ńîňđóäíčęîâ ěýđčč");
	if(PlayerInfo[params[0]][pBirth] == 0) return SendClientMessage(playerid, -1, "Ó ďŕđňíĺđŕ íĺň ďŕńďîđňŕ! Ďîëó÷čňü ĺăî ěîćíî ó ńîňđóäíčęîâ ěýđčč");

	if(!IsPlayerInRangeOfPoint(playerid, 10, 368.9543,2323.9968,1890.6047)) return SendClientMessage(playerid, -1, """{ff353c}""Íĺîáőîäčěî íŕőîäčňüń˙ â öĺđęâč (/gps - Îáůĺńňâĺííűĺ ěĺńňŕ)");

	if(GetDistanceBetweenPlayerz(playerid, params[0], 5.00) != 1) return SendClientMessage(playerid, -1, """{ff353c}""Âű äîëćíű âńňŕňü ďĺđĺä čăđîęîě");

	new player_sex = PlayerInfo[playerid][pSex];
	new target_sex = PlayerInfo[params[0]][pSex];

	if(PlayerInfo[params[0]][pMarried] == 0) {
		if(player_sex == target_sex) return SendClientMessage(playerid, -1, """{ff353c}""Íĺîáőîäčěî âűáđŕňü čăđîęŕ ďđîňčâîďîëîćíîăî ďîëŕ");
		if(CheckCash(playerid, 5000) == false) return SendClientMessage(playerid, -1, """{ff353c}""Íĺäîńňŕňî÷íî ńđĺäńňâ. Ďîďîëíčňĺ ń÷ĺň");
		RemovePlayerEXP(playerid, 5000, "Ďđîöĺńń áđŕęîńî÷ĺňŕíč˙. Ŕďîíĺíň %s", PlayerInfo[params[0]][pName]);
		format(small_string, sizeof(small_string), "%s ďđĺäëŕăŕĺň %s đóęó č ńĺđäöĺ", PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName]);
		ProxDetector(playerid, 20, 0xDD90FFFF, small_string);
		SetPVarInt(params[0], "marryoffer", playerid);
		format(small_string, sizeof(small_string), """{4eb9e6}""%s ďđĺäëŕăŕĺň âŕě đóęó č ńĺđäöĺ. Ńîăëŕńčňüń˙: {FFFFFF}/yes", PlayerInfo[playerid][pName]);
		SendClientMessage(params[0], -1, small_string);
	}
	else SendClientMessage(playerid, -1, """{ff353c}""Äŕííűé čăđîę óćĺ íŕőîäčňń˙ â áđŕęĺ. ×ňîáű đŕçâĺńňčńü:{FFFFFF} /divorce");
	return 1;
}
forward pc_cmd_yes(playerid); public pc_cmd_yes(playerid) {

	new offerid = GetPVarInt(playerid, "marryoffer");

	if(offerid == (0xFFFF)) return 1;
	if(!IsPlayerInRangeOfPoint(playerid, 10, 368.9543,2323.9968,1890.6047)) return SendClientMessage(playerid, -1, """{ff353c}""Íĺîáőîäčěî íŕőîäčňüń˙ â öĺđęâč (/gps - Îáůĺńňâĺííűĺ ěĺńňŕ)");
	if(GetDistanceBetweenPlayerz(playerid, offerid, 5.00) != 1) return SendClientMessage(playerid, -1, """{ff353c}""Âű äîëćíű âńňŕňü ďĺđĺä čăđîęîě");

	format(small_string, sizeof(small_string), "{FF23EC}Ďîçäđŕâë˙ĺě %s č %s! Îíč ńâ˙çŕëč ńĺá˙ óçŕěč áđŕęŕ", PlayerInfo[playerid][pName],PlayerInfo[offerid][pName]);
	SendClientMessageToAll(-1, small_string);

	format(small_string, sizeof(small_string), "%s č %s îáěĺí˙ëčńü îáđó÷ŕëüíűěč ęîëüöŕěč", PlayerInfo[playerid][pName], PlayerInfo[offerid][pName]);
	ProxDetector(playerid, 20, 0xDD90FFFF, small_string);

	PlayerInfo[playerid][pMarried] = 1;
	PlayerInfo[offerid][pMarried] = 1;
	SetPlayerInt(playerid, "Married", PlayerInfo[playerid][pMarried]);
	SetPlayerInt(offerid, "Married", PlayerInfo[offerid][pMarried]);
	PlayerInfo[playerid][pPartner] = EOS;
	PlayerInfo[offerid][pPartner] = EOS;
	strins(PlayerInfo[playerid][pPartner], PlayerInfo[offerid][pName], 0);
	strins(PlayerInfo[offerid][pPartner], PlayerInfo[playerid][pName], 0);
	new Query[128];
	mysql_format(database, Query, sizeof(Query), "UPDATE `players` SET Partner = '%e' WHERE Name = '%e' LIMIT 1", PlayerInfo[playerid][pPartner],PlayerInfo[playerid][pName]);
	mysql_pquery(database, Query, "", "");
	new Query2[128];
	mysql_format(database, Query2, sizeof(Query2), "UPDATE `players` SET Partner = '%e' WHERE Name = '%e' LIMIT 1", PlayerInfo[offerid][pPartner],PlayerInfo[offerid][pName]);
	mysql_pquery(database, Query2, "", "");
	return 1;
}
forward pc_cmd_divorce(playerid); public pc_cmd_divorce(playerid) {
	if(PlayerInfo[playerid][pMarried] == 0) return 1;

	if(!IsPlayerInRangeOfPoint(playerid, 10, 368.9543,2323.9968,1890.6047)) return SendClientMessage(playerid, -1, """{ff353c}""Íĺîáőîäčěî íŕőîäčňüń˙ â öĺđęâč (/gps - Îáůĺńňâĺííűĺ ěĺńňŕ)");
	PlayerInfo[playerid][pMarried] = 0;
	SetPlayerInt(playerid, "Married", PlayerInfo[playerid][pMarried]);
	SendClientMessage(playerid, -1, """{ff353c}""Âű âűřëč čç áđŕęŕ");
	new partner = _ReturnPlayerID(PlayerInfo[playerid][pPartner]);
	if(partner == (0xFFFF)) {
	new Query[128];
	mysql_format(database, Query, sizeof(Query), "UPDATE `players` SET Married = '0' WHERE Name = '%e' LIMIT 1", PlayerInfo[playerid][pPartner]);
	mysql_pquery(database, Query, "", "");
	}
	else {
	PlayerInfo[partner][pMarried] = 0;
	SetPlayerInt(partner, "Married", PlayerInfo[partner][pMarried]);
	SendClientMessage(partner, -1, """{ff353c}""Âŕř ďŕđňíĺđ ďđĺäďî÷ĺë đŕçâĺńňčńü ń âŕěč");		
	}
	return 1;
}
stock _ReturnPlayerID(name[])
{





        if ((name[0] >= 'a' || name[0] >= 'A') && (name[0] <= 'z' || name[0] <= 'Z')) {
                for (new i = 0; i < GetMaxPlayers(); i++) {
                        if (IsPlayerConnected(i)) {
                                new uName[24];
                                GetPlayerName(i, uName, sizeof(uName));
                                if (strcmp(uName, name, false, MDialog_strlen(uName) + MDialog_strlen(name)) == 0) {
                                        return i;
                                }
                        }       
                }
        }
        return (0xFFFF);
}
