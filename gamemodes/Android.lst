	SendClientMessage(playerid, -1, """{6de64e}""Íŕăđŕäŕ â đŕçěĺđĺ 500 EXP âűäŕíŕ");
	isUsedCarprize = true;
	return 1;
}

forward pc_cmd_gethere(playerid,params[]); public pc_cmd_gethere(playerid,params[])
{
	if(Player__AdminLevel{playerid} < 4) {
		return true;
