CMD:sl(playerid, params[])
{
	if(!IsPlayerInAnyVehicle(playerid) && GetPlayerVehicleSeat(playerid) != 0) return SendClientMessage(playerid, -1, "Ограничитель скорости необходимо за рулем транспорта");
	if(sscanf(params, "d",params[0])) {
		if(PlayerInfo[playerid][pSpeedLimit] != 0) {
			SendClientMessage(playerid, -1, ""COLOR_ORANGE"Ограничитель скорости выключен");
			PlayerInfo[playerid][pSpeedLimit] = 0;
			SetPlayerInt(playerid, "SpeedLimit", PlayerInfo[playerid][pSpeedLimit]);
			return 1;
		}
		PlayerInfo[playerid][pSpeedLimit] = 60;
		SetPlayerInt(playerid, "SpeedLimit", PlayerInfo[playerid][pSpeedLimit]);
		return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Ограничение скорости в {FFFFFF}60км/ч"COLOR_ORANGE" было установлено");
	}
	if(params[0] == 0) {
		if(PlayerInfo[playerid][pSpeedLimit] != 0) {
			SendClientMessage(playerid, -1, ""COLOR_ORANGE"Ограничитель скорости выключен");
			PlayerInfo[playerid][pSpeedLimit] = 0;
			SetPlayerInt(playerid, "SpeedLimit", PlayerInfo[playerid][pSpeedLimit]);
			return 1;
		}
	}
	if(params[0] < 30) { 
		SendClientMessage(playerid, -1, ""COLOR_RED"Минимальная скорость для ограничителя: {FFFFFF}30км/ч");
		SendClientMessage(playerid, -1, ""COLOR_RED"Чтобы выключить ограничитель просто введите: {FFFFFF}/sl");
		return 1;
	}
	if(params[0] > 90) return SendClientMessage(playerid, -1, ""COLOR_RED"Максимальная скорость для ограничителя: {FFFFFF}90км/ч");
	PlayerInfo[playerid][pSpeedLimit] = params[0];
	SetPlayerInt(playerid, "SpeedLimit", PlayerInfo[playerid][pSpeedLimit]);
	format(small_string, sizeof(small_string), ""COLOR_ORANGE"Ограничение скорости в {FFFFFF}%dкм/ч"COLOR_ORANGE" было установлено", params[0]);	
	SendClientMessage(playerid, -1, small_string);
	return 1;
}
