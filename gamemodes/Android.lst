forward pc_cmd_door(playerid, params[]); public pc_cmd_door(playerid, params[]) {
	new Fraction: fractionid = GetPlayerFraction(playerid);
	if(fractionid == FRACTION_ARMY) { 
		if(!IsPlayerInRangeOfPoint(playerid, 3.2, 1167.859130, 1363.050415, 9.722514)) return SendClientMessage(playerid, -1, """{ff353c}""Íĺîáőîäčěî íŕőîäčňüń˙ ó äâĺđč â ďđčçűâíîé ďóíęň");
		if(GetPlayerJobDayStatus(playerid) == false)
		{
			return SendClientMessage(playerid, -1, """{FFFFFF}""Íĺîáőîäčěî íŕ÷ŕňü đŕáî÷čé äĺíü íŕ ""{6de64e}""áŕçĺ îđăŕíčçŕöčč");
		}
		if(army_door_timeout > 0) return SendClientMessage(playerid, -1, """{ff353c}""Íĺëüç˙ čńďîëüçîâŕňü ňŕę ÷ŕńňî!");
		if(IsValidDynamicObject(army_door[0])) {
			DestroyDynamicObject(army_door[0]);
		} else {
			return 1;
		}
		army_door_timeout = 30;
		SendClientMessage(playerid, -1, """{4eb9e6}""Äâĺđü çŕęđîĺňń˙ ÷ĺđĺç 5 ńĺęóíä...");
		army_door_timer = SetTimer("close_army_door", 5000, 0);
		army_door[1] = CreateDynamicObject(1500, 1167.859130, 1363.050415, 9.722514, 0.000000, 0.000000, -48.800113, -1, -1, -1, 300.00, 300.00);
		for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i=Iterator@Player [_: i])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);) { if(IsPlayerInDynamicArea(i, army_area)) Streamer_Update(i, (0)); }

	}
	return 1;
}
forward close_army_door(playerid);
public close_army_door(playerid) {
	KillTimer(army_door_timer);
	if(IsValidDynamicObject(army_door[1])) {
	DestroyDynamicObject(army_door[1]);
	} else {
		return 1;
	}
	army_door[0] = CreateDynamicObject(1500, 1167.859130, 1363.050415, 9.722514, 0.000000, 0.000000, 0.000000, -1, -1, -1, 300.00, 300.00);
	new people = 0;
	for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i=Iterator@Player [_: i])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);) {
		if(IsPlayerInDynamicArea(i, army_area)) {
			Streamer_Update(i, (0));
			people++;
		}
	}
	format(small_string, sizeof(small_string), """{4eb9e6}""Ńĺé÷ŕń íŕ ďđčçűâĺ: {FFFFFF}%d ÷ĺëîâĺę", people);
	UpdateDynamic3DTextLabelText(army3d, -1, small_string);
	return 1;
}

