			if(gangwar_delay_gang == 1) return SendClientMessage(playerid, -1, """{ff353c}""Âîéíŕ çŕ ňĺđđčňîđčţ óćĺ íŕ÷číŕëŕńü â ýňîě ÷ŕńó");
