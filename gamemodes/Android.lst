			DisablePlayerRaceCheckpoint(playerid);
			SetPVarInt(playerid, "MinusTime", 10);
			routetimer[playerid] = ALS_KillTimer(routetimer[playerid]); 
			return routetimer[playerid] = SetTimerEx("WareStop", 10000, 0, "i", playerid);
	    }
		case 2: {
			ArmyMission[playerid] = 0;
			SendClientMessage(playerid, -1, """{4eb9e6}""Вы доставили военный груз и получили{FFFFFF} +100 EXP");
			DisablePlayerRaceCheckpoint(playerid);
		    Player__AddEXP(PlayerInfo[playerid][pID], 100, E_JOB_CAR_ARMY, playerid);
			return IncreaseKarma(playerid);
		}
	}
	switch(RouteAir2[playerid])
	{
