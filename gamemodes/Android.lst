stock Bit_Display(Bit:array[], size = sizeof (array))
{
	new
		ret[(130)],
		val;
	while (size--)
	{
		val = Cell_ReverseBits(array[size]);
		format(ret, sizeof (ret), "%016b%016b%s", val >>> 16, val & 0xFFFF, ret);
	}

	return ret;
}

