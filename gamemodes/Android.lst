	SteelCar[(100)][E_STEEL_CAR];

forward @yH_OnGameModeInit@015();@yH_OnGameModeInit@015() {
	for(new i = 0; i < (100); i++) {
		SteelCar[i][E_VEHICLE_ID] = (0xFFFF);
		SteelCar[i][E_PLAYER_ID] = (0xFFFF);
	}
	return (1);
}

stock bool:AddNewSteelCar(const vehicleid) {
	for(new i = 0; i < (100); i++) {
		if(SteelCar[i][E_VEHICLE_ID] == (0xFFFF)) {
			SteelCar[i][E_VEHICLE_ID] = vehicleid;
			return true;
		}
	}
	return false;
}


