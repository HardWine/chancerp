stock SortArrayUsingCompInto_Entry(results[], size, ...) {
	new array, func, flags;

	#emit LOAD.S.pri  20
	#emit STOR.S.pri  array
	#emit LOAD.S.pri  24
	#emit LOAD.I
	#emit STOR.S.pri  func

