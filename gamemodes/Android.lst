		case (7843): {
			for(new i = 0; i < sizeof(CasinoInfo); i++) {
				if(CasinoInfo[i][CI_Croupier_Area] == areaid) {
					if(CasinoInfo[i][CI_CroupierID] == playerid) {
						CBackSkin(playerid);
						SendClientMessage(playerid, -1, """{FFAF00}""Ваш рабочий день был завершен.");

						SetCasinoCroupier(CasinoInfo[i][CI_Table_ID], (0xFFFF));
