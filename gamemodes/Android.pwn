		case dRolePlay5: { return ShowPlayerDialog(playerid, dRolePlay6, DIALOG_STYLE_MSGBOX, "Помощь", "{FFFFFF}Подробнее ознакомиться с функционалом сервера можно на нашем Wiki-портале "COLOR_ORANGE"wiki.chancerp.ru", "Закрыть", ""); }
		case dRolePlay6: { return callcmd::selectcolor(playerid,"\0"); }
