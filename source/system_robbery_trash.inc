hook OnGameModeInit() {
	for(new i = 0; i < sizeof(LocationGarbage); i++) {
		LocationGarbage[i][E_PICKUP_ID] = CreateDynamicPickup(19134, 23, LocationGarbage[i][E_X], LocationGarbage[i][E_Y], LocationGarbage[i][E_Z] + 1.00, 0, 0);
		LocationGarbage[i][E_ZONE_ID] = CreateDynamicSphere(LocationGarbage[i][E_X], LocationGarbage[i][E_Y], LocationGarbage[i][E_Z] + 1.00, 1.00);
		LocationGarbage[i][E_LABEL] = CreateDynamic3DTextLabel(!""COLOR_BLUE"Мусорный бак\n"COLOR_GREEN"(можно осмотреть)", -1, LocationGarbage[i][E_X], LocationGarbage[i][E_Y], LocationGarbage[i][E_Z] + 2.00,
			MAX_DISTANCE_VISIBLE, INVALID_PLAYER_ID, INVALID_VEHICLE_ID, 1, -1, -1, -1, MAX_DISTANCE_VISIBLE
		);
	}
	SetTimer("@_UpdateGarbage", 1000, true);
	return Y_HOOKS_CONTINUE_RETURN_1;
}

hook OnPlayerConnect(playerid) {
	PlayerTimerRobbertyGarbage[playerid] = INVALID_TIMER_ID;
	return Y_HOOKS_CONTINUE_RETURN_1;
}

hook OnPlayerDisconnect(playerid, reason) {
	#pragma unused reason 

	if(PlayerTimerRobbertyGarbage[playerid] != INVALID_TIMER_ID) {
		KillTimer(PlayerTimerRobbertyGarbage[playerid]);
		PlayerTimerRobbertyGarbage[playerid] = INVALID_TIMER_ID;
	}
	return Y_HOOKS_CONTINUE_RETURN_1;
}

hook OnPlayerPickUpDynPickup(playerid, pickupid) {
	for(new i = 0; i < sizeof(LocationGarbage); i++) {
		new local_pickupid = LocationGarbage[i][E_PICKUP_ID];

		if(IsValidDynamicPickup(local_pickupid) && local_pickupid != INVALID_STREAMER_ID && pickupid == local_pickupid) {
			return Y_HOOKS_BREAK_RETURN_1;
		}
	}
	return Y_HOOKS_CONTINUE_RETURN_1;
}


hook OnPlayerEnterDynArea(playerid, STREAMER_TAG_AREA areaid) {
	for(new i = 0; i < sizeof(LocationGarbage); i++) {
		new local_areaid = LocationGarbage[i][E_ZONE_ID];

		if(IsValidDynamicArea(local_areaid) && local_areaid != INVALID_STREAMER_ID && areaid == local_areaid) {
			if(LocationGarbage[i][E_LAST_TIME] > 0) {
				SendClientMessage(playerid, -1, ""COLOR_ORANGE"Этот мусорный бак недавно уже был осмотрен другим игроком. Пожалуйста подождите");
				return Y_HOOKS_BREAK_RETURN_1;
			}

			// Сразу же устанавливаем интревал между ограблениями
			LocationGarbage[i][E_LAST_TIME] = INRERVAL_ROBBERTY_GARBAGE * 60;

			// Если таймер уже сущесвует, то уничтожаем его
			if(PlayerTimerRobbertyGarbage[playerid] != INVALID_TIMER_ID) {
				return Y_HOOKS_BREAK_RETURN_1;
			}

			// Время для рендеринга на экране
			SetPVarInt(playerid, "MinusTime", TIME_ROBBERTY_GARBAGE);
			
			SetPlayerPos(playerid, LocationGarbage[i][E_X], LocationGarbage[i][E_Y], LocationGarbage[i][E_Z] + 1.00);

			// Запускаем таймер для игрока
			PlayerTimerRobbertyGarbage[playerid] = SetTimerEx("@_PlayerRobberyGarbage", TIME_ROBBERTY_GARBAGE * 1000, false, "ii", playerid, i);

			ApplyAnimation(playerid, "OTB", "BETSLP_LOOP", 10.1, 1, 1, 1, 1, 0);

			new 
				Float: pos_x,
				Float: pos_y,
				Float: pos_z;

			GetPlayerPos(playerid, pos_x, pos_y, pos_z);

			PlayerPlaySound(playerid, 20802, pos_x, pos_y, pos_z);
			return Y_HOOKS_BREAK_RETURN_1;
		}
	}
	return Y_HOOKS_CONTINUE_RETURN_1;
}

@_UpdateGarbage();
@_UpdateGarbage() {
	for(new i = 0; i < sizeof(LocationGarbage); i++) {
		if(LocationGarbage[i][E_LAST_TIME] > 0) {
			// Обновим текст, что мусорку нельзя ограбить
			if(LocationGarbage[i][E_LAST_TIME] == INRERVAL_ROBBERTY_GARBAGE * 60) {
				UpdateDynamic3DTextLabelText(LocationGarbage[i][E_LABEL], -1, ""COLOR_BLUE"Мусорный бак\n"COLOR_ORANGE"(нельзя осмотреть)");
			}

			// Отнимем одну секунду
			LocationGarbage[i][E_LAST_TIME] = LocationGarbage[i][E_LAST_TIME] - 1;
			
			// Обновим текст, что мусорку можно ограбить
			if(LocationGarbage[i][E_LAST_TIME] == 0) {	
				UpdateDynamic3DTextLabelText(LocationGarbage[i][E_LABEL], -1, ""COLOR_BLUE"Мусорный бак\n"COLOR_GREEN"(можно осмотреть)");
			}
		}
	}
}

@_PlayerRobberyGarbage(playerid, garbage_array_id);
@_PlayerRobberyGarbage(playerid, garbage_array_id) {

	new Type_Award = RandomEx(1,3);

	if(Type_Award == 1) {	
		new 
			random_award = random(MAX_ROBBERY_GARBAGE_AWARD - MIN_ROBBERY_GARBAGE_AWARD) + MIN_ROBBERY_GARBAGE_AWARD;

		format(small_string, sizeof(small_string), ""COLOR_GREEN"При осмотре мусорного бака вы обнаружили %i EXP", random_award);
		SendClientMessage(playerid, -1, small_string);

		AddPlayerEXP(playerid, random_award, "Копание в мусорном баке");
	}
	if(Type_Award == 2) {
		SendClientMessage(playerid, -1, ""COLOR_RED"При осмотре мусорного бака вы не нашли ничего полезного");
	}
	if(Type_Award == 3) {

		new food_trashy[24];

		switch(RandomEx(0,15)) {
			case 0: strins(food_trashy, "засохшую котлетку", 0);
			case 1: strins(food_trashy, "протухшую криветку", 0);
			case 2: strins(food_trashy, "испорченное яблоко", 0);
			case 3: strins(food_trashy, "затвердевший бургер", 0);
			case 4: strins(food_trashy, "банку содовой", 0);
			case 5: strins(food_trashy, "испорченный апельсин ", 0);
			case 6: strins(food_trashy, "картофель фри под плесенью", 0);
			case 7: strins(food_trashy, "окровавленное сердце читера", 0);
			case 8: strins(food_trashy, "куринное яичко", 0);
			case 9: strins(food_trashy, "тухлый томат", 0);
			case 10: strins(food_trashy, "остатки пирога", 0);
			case 11: strins(food_trashy, "почерневший банан", 0);
			case 12: strins(food_trashy, "очистки от мандарина", 0);
			case 13: strins(food_trashy, "банановую кожуру", 0);
			case 14: strins(food_trashy, "небольшую коробку сока", 0);
			case 15: strins(food_trashy, "мясо неизвестного происхождения", 0);
		}		

		format(small_string, sizeof(small_string), ""COLOR_GREEN"При осмотре мусорного бака вы нашли %s", food_trashy);
		SendClientMessage(playerid, -1, small_string);

		ApplyAnimation(playerid,"FOOD","EAT_BURGER",4.1,0,1,1,1,1,1);
		format(small_string, sizeof(small_string), "съел(а) %s", PlayerInfo[playerid][pName], food_trashy);
		SetPlayerChatBubble(playerid, small_string, C_PURPLE, 30.0, 5000);
		format(small_string, sizeof(small_string), "%s съел(а) %s", PlayerInfo[playerid][pName], food_trashy);
		ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_PURPLE, small_string);		

		new feed = RandomEx(1,3);

		if(feed == 1) {
			SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы слегка утолили свой голод");

			PlayerInfo[playerid][pHunger] += 6;
			if(PlayerInfo[playerid][pHunger] > 100) PlayerInfo[playerid][pHunger] = 100;	
			SetPlayerInt(playerid, "Hunger", PlayerInfo[playerid][pHunger]);

			GameTextForPlayer(playerid, "~n~~n~~n~~n~~n~~n~~n~~n~~w~+6 Satiety", 2000, 6);

		}
		if(feed == 2) {
			SendClientMessage(playerid, -1, ""COLOR_ORANGE"Вы поели, но этого явно мало");

			PlayerInfo[playerid][pHunger] += 3;
			if(PlayerInfo[playerid][pHunger] > 100) PlayerInfo[playerid][pHunger] = 100;	
			SetPlayerInt(playerid, "Hunger", PlayerInfo[playerid][pHunger]);

			GameTextForPlayer(playerid, "~n~~n~~n~~n~~n~~n~~n~~n~~w~+3 Satiety", 2000, 6);

		}
		if(feed == 3) {
			SendClientMessage(playerid, -1, ""COLOR_RED"Съеденная пища не пошла на пользу");

			PlayerInfo[playerid][pHunger] -= 10;
			if(PlayerInfo[playerid][pHunger] > 100) PlayerInfo[playerid][pHunger] = 100;	
			SetPlayerInt(playerid, "Hunger", PlayerInfo[playerid][pHunger]);

			GameTextForPlayer(playerid, "~n~~n~~n~~n~~n~~n~~n~~n~~r~-10 Satiety", 2000, 6);

		}				
	}

	ClearAnimations(playerid);
	TogglePlayerControllable(playerid, true);

	PlayerTimerRobbertyGarbage[playerid] = INVALID_TIMER_ID;

	mysql_format(database, small_string, sizeof(small_string), "INSERT INTO `robbery_garbage`(`PlayerID`, `GarbageID`, `Type`, `Time`) VALUES (%i, %i, %i,  CURRENT_TIMESTAMP())", PlayerInfo[playerid][pID], LocationGarbage[garbage_array_id][E_ID], Type_Award);
	mysql_pquery(database, small_string);

	UpdatePlayerProgressQuest(playerid, E_GARBAGE_CAN);
	return 1;
}