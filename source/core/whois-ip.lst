stock endofline(const line[], pos)
{
	
	if ((((pos)-(( 0)+cellmin))>=(( strlen(line))-(( 0)+cellmin)))) return 0;

	while (line[pos]) if (line[pos++] > ' ') return 0;
	return 1;
