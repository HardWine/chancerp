public bool:Player__Kick(const playerid, const reason[(32 + 1)], const adminid) {
	mysql_format(database, 
		small_string, sizeof(small_string), 
		"CALL `Player.Kick` (@p0 , @p1 , @p2);", 
			PlayerInfo[playerid][pID], 
			PlayerInfo[adminid][pID], 
			reason
	);
	mysql_pquery(database, small_string);

	if(Player__KickTimer[playerid] == (-1)) {
		Player__KickTimer[playerid] = SetTimerEx("@__KickPlayer", GetPlayerPing(playerid) + 100, false, "i", playerid);
	}
	return true;
}

