		return Dialog_Open(playerid, #DIALOG_SELL_AVIA, 0,
			"""{4eb9e6}""Ďđîäŕćŕ ëč÷íîăî âĺđňîëĺňŕ",
			big_string, 
			small_string, "Íĺň"
		);
	} else {
