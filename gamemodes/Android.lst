forward pc_cmd_re(playerid,params[]); public pc_cmd_re(playerid,params[])
{
	if(Player__AdminLevel{playerid} < 1) return true;

	if(sscanf(params,"d",params[0])) return SendClientMessage(playerid, -1, !"Čńďîëüçóéňĺ: /re [ID]");

	if(GetPVarInt(playerid, "mobile") != 1 && GetPVarInt(playerid, "recon_alt") != 1) {
		SetPVarInt(playerid, "recon_alt", 1);
		SendClientMessage(playerid, -1, """{FFAF00}""×ňîáű âęëţ÷čňü ęóđńîđ íŕćěčňĺ {FFFFFF}Ëĺâűé Alt");
	}

	if(PlayerLogged{playerid} == false || !IsPlayerConnected(playerid)) return SendClientMessage(playerid, -1, "Čăđîę íĺ ŕâňîđčçîâŕí");

	if(params[0] == (0xFFFF)) return SendClientMessage(playerid, -1, """{ff353c}""Čăđîę íĺ íŕéäĺí");
	if(params[0] == playerid) return SendClientMessage(playerid, -1, """{ff353c}""Íĺëüç˙ íŕáëţäŕňü çŕ ńŕěčě ńîáîé");

	if(Player__AdminLevel{playerid} < Player__AdminLevel{params[0]}) return SendClientMessage(playerid, -1, """{ff353c}""Íĺëüç˙ íŕáëţäŕňü çŕ ŕäěčíčńňđŕöčĺé ńňŕđřĺ ďî óđîâíţ");


	if(GetPlayerState(params[0]) == (9)) return 1; 

	spectating[playerid] = params[0];

	spec_show(playerid);
	if(spectating[playerid] != -1 && GetPlayerState(playerid) == (9))  spec_update(playerid);

	if(GetPVarInt(playerid, !"spec") != 1)
	{

		new
			Float: player_pos_x,
			Float: player_pos_y,
			Float: player_pos_z,
			Float: player_angle;

		GetPlayerPos(playerid, player_pos_x, player_pos_y, player_pos_z);
		GetPlayerFacingAngle(playerid, player_angle);
		SetPVarFloat(playerid, !"pos_x", player_pos_x);
		SetPVarFloat(playerid, !"pos_y", player_pos_y);
		SetPVarFloat(playerid, !"pos_z", player_pos_z);
		SetPVarFloat(playerid, !"pos_angle", player_angle);

		SetPVarInt(playerid, !"pos_int", GetPlayerInterior(playerid));
		SetPVarInt(playerid, !"pos_vw", GetPlayerVirtualWorld(playerid));
		SetPVarInt(playerid, !"spec", 1);


	}

	if(IsPlayerInAnyVehicle(params[0]))
	{

		SetPlayerVirtualWorld(playerid,GetPlayerVirtualWorld(params[0]));
		SetPlayerInterior(playerid, GetPlayerInterior(params[0]));
		TogglePlayerSpectating(playerid, true);
		PlayerSpectateVehicle(playerid, GetPlayerVehicleID(params[0]));
	}
	else
	{
		SetPlayerVirtualWorld(playerid,GetPlayerVirtualWorld(params[0]));
		SetPlayerInterior(playerid, GetPlayerInterior(params[0]));
		TogglePlayerSpectating(playerid, true);
		PlayerSpectatePlayer(playerid, params[0]);
	}

	SetPVarInt(playerid, "cur_spec", 1);

	return 1;
}
forward pc_cmd_msg(playerid, params[]); public pc_cmd_msg(playerid, params[])
{
	if(Player__AdminLevel{playerid} < 4) return true;
	if(!params[0]) return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ: /msg [ňĺęńň]");
	if(MDialog_strlen(params) > 80) {
		return SendClientMessage(playerid, -1, "Ńëčřęîě äëčííîĺ ńîîáůĺíčĺ");
	}
	if(GetPVarInt(playerid,"AntiFloodAdm") > gettime()){ SendClientMessage(playerid, -1, """{ff353c}""Ďîćŕëóéńňŕ íĺ ôëóäčňĺ"); return false; }
	SetPVarInt(playerid,"AntiFloodAdm",gettime() + 3);

	format(small_string, sizeof(small_string), """{FFAF00}""Ŕäěčíčńňđŕňîđ %s: %s", PlayerInfo[playerid][pName], params[0]);
	SendClientMessageToAll(-1, small_string);
	return 1;
}

forward pc_cmd_car(playerid, params[]); public pc_cmd_car(playerid, params[])
{
	if(Player__AdminLevel{playerid} < 5) return true;
	if(sscanf(params,"ddd",params[0],params[1],params[2])) return 1;
	for(new i = 0; i < 40; i++) {
		if(AdminCar[i] == (0xFFFF)) {
			new Float:X,Float:Y,Float:Z;
			GetPlayerPos(playerid, X,Y,Z);
			AdminCar[i] = FUEL_CreateVehicle(params[0], X+2,Y,Z, 0.0, params[1], params[2], 9000);
			SetVehicleVirtualWorld(AdminCar[i], GetPlayerVirtualWorld(playerid));
			LinkVehicleToInterior(AdminCar[i], GetPlayerInterior(playerid));
			SendClientMessage(playerid, -1, """{ff353c}""Íĺ çëîóďîňđĺáë˙éňĺ äŕííîé ôóíęöčĺé č óáčđŕéňĺ çŕ ńîáîé {FFFFFF}(/delcar)");

			return 1;
		}
	}
	SendClientMessage(playerid, -1, "Ďđĺâűřĺí ëčěčň ńîçäŕííűő ŕâňîěîáčëĺé");
	return 1;
}


forward pc_cmd_delcar(playerid, params[]); public pc_cmd_delcar(playerid, params[])
{
	if(Player__AdminLevel{playerid} < 5) return true;
	if(IsPlayerInAnyVehicle(playerid) == 0) {
		new
			arg[32];

		if(sscanf(params, "s", arg)) {
			return 0;
		}

		if(strcmp(arg, "all", false) == 0) {
			for(new i = 0; i < 40; i++) {
				if(AdminCar[i] != (0xFFFF)) {
					FUEL_DestroyVehicle(AdminCar[i]);
					AdminCar[i] = (0xFFFF);
				}
			}
			SendClientMessage(playerid, -1, """{FFAF00}""Âńĺ ŕâňîěîáčëč ńîçäŕííűĺ ŕäěčíčńňđŕöčĺé áűëč óäŕëĺíű");
			return 1;
		}
	} else {
		new vehicleid = GetPlayerVehicleID(playerid);

		for(new i = 0; i < 40; i++) {
			if(AdminCar[i] == vehicleid) {
				AdminCar[i] = (0xFFFF);
				FUEL_DestroyVehicle(vehicleid);
				return SendClientMessage(playerid, -1, """{6de64e}""Ŕâňîěîáčëü óäŕëĺí");
			}
		}
		SendClientMessage(playerid, -1, """{FFAF00}""Äŕííűé ŕâňîěîáčëü íĺ áűë ńîçäŕí ŕäěčíčńňđŕňîđîě");
		return 1;
	}
	return 1;
}
