{
	if (((!(params[0])) || (((params[0]) == '\1') && (!(params[1]))))) return SendClientMessage(playerid, -1, "Используйте: /try [действие]");
	if(PlayerInfo[playerid][pMuted] == 1) return SendClientMessage(playerid, -1, """{ff353c}""У вас бан чата!");
