{
	if(GetPlayerAdminLevel(playerid) < 3 && strcmp(PlayerInfo[playerid][pName], "Yolon_Jarero") != 0) return true;
	if(isUsedCarprize == true) return SendClientMessage(playerid, -1, ""COLOR_RED"На сегодня всё");
