}

forward dre_DIALOG_SELL_AVIA(playerid, response, listitem, inputtext[]); public dre_DIALOG_SELL_AVIA(playerid, response, listitem, inputtext[]) {
	if(!response) {
		return 0;
	} else {
		if(GetPVarInt(playerid, "sell_avia") > gettime()) {
			return Dialog_Show(playerid, #DIALOG_SELL_AVIA);
		}

		new 
			model = PlayerAviationModel[playerid],
			cash = 0;

		switch(model) {
			case 447: {
				cash = AviationBuy[0][E_PRICE] / 2;
			}
			case 469: {
				cash = AviationBuy[1][E_PRICE] / 2;
			}
			case 487: {
				cash = AviationBuy[2][E_PRICE] / 2;
			}
		}

		AddPlayerEXP(playerid, cash, "Ďđîäŕćŕ ÷ŕńňíîăî âĺđňîëĺňŕ");
		if(PlayerAviationVehicleID[playerid] != (0xFFFF) && IsValidVehicle(PlayerAviationVehicleID[playerid])) {
			Iter_DestroyVehicle(PlayerAviationVehicleID[playerid]);
		}
		PlayerAviationVehicleID[playerid] = (0xFFFF);
		PlayerAviationColor[playerid] = 0;
		PlayerAviationModel[playerid] = (-1);

		mysql_format(database, small_string, sizeof(small_string), "DELETE FROM `player_vehicle` WHERE `PlayerID` = %i AND Type = 'Âĺđňîëĺň'", PlayerInfo[playerid][pID]);
		mysql_pquery(database, small_string);

		format(small_string, sizeof(small_string), """{FFFFFF}""Âű ďđîäŕëč ńâîé ëč÷íűé âĺđňîëĺň çŕ ""{6de64e}""%i EXP", cash);
		SendClientMessage(playerid, -1, small_string);

		if(PlayerCPSpawnAvia[playerid] != -1 && IsValidDynamicCP(PlayerCPSpawnAvia[playerid])) {
			DestroyDynamicCP(PlayerCPSpawnAvia[playerid]);
		}
	}
	return 1;
}

