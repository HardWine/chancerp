	if(sscanf(params,"s", params[0])) return 1;
	PlayerInfo[playerid][pName] = EOS;
	format(PlayerInfo[playerid][pName], MAX_PLAYER_NAME+1, "%s", params[0]);
	SetPlayerName(playerid, params[0]);
	return 1;
}

CMD:homelock(playerid) 
{
	new i = GetPVarInt(playerid, "PlayerHouse");

	if(HouseInfo[i][hDoor] == 0) {
		HouseInfo[i][hDoor] = 1;
		SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы открыли дверь в ваш дом");
	} else {
		HouseInfo[i][hDoor] = 0;
		SendClientMessage(playerid, -1, ""COLOR_RED"Вы закрыли дверь в ваш дом");
	}

	new MySQL[128];
	mysql_format(database,
		MySQL, sizeof(MySQL),
		"UPDATE `apartment` SET Door = %i WHERE ID = '%i' LIMIT 1",
			HouseInfo[i][hDoor],
			HouseInfo[i][hID]
	);
	mysql_pquery(database, MySQL);
	return 1;
}

