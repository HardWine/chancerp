forward pc_cmd_ban(playerid, params[]); public pc_cmd_ban(playerid, params[])
{
	if(Player__AdminLevel{playerid} < 4) return true;
	new giveplayerid, result[(48)];
	new days;
	if(sscanf(params, "rI(2038)S(Íŕđóřĺíčĺ ďđŕâčë ńĺđâĺđŕ)[47]", giveplayerid, days, result)) return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ: /ban [id čăđîęŕ] [ęîë-âî äíĺé] [ďđč÷číŕ]");


	if(days < 2 && days != 2038) {
		return SendClientMessage(playerid, -1, """{FFAF00}""Ęîëč÷ĺńňâî äíĺé äîëćíî áűňü â äčŕďîçîíĺ îň 2 äî 30");
	}
	if(days > 30 && days != 2038) {
		return SendClientMessage(playerid, -1, """{FFAF00}""Ęîëč÷ĺńňâî äíĺé äîëćíî áűňü â äčŕďîçîíĺ îň 2 äî 30");
	}
	if(days == 2038) {

		static string[144];
		mysql_format(database,
			string, sizeof(string),
			"INSERT INTO ""banned_ip"" (`IP`) VALUES ('%s')",
				ipsget[giveplayerid]
		);
		mysql_pquery(database, string);

		days = 365*19;
		format(small_string, sizeof(small_string), """{ff353c}""Ŕäěčíčńňđŕňîđ %s çŕáëîęčđîâŕë čăđîęŕ %s. Ďđč÷číŕ: %s", PlayerInfo[playerid][pName], PlayerInfo[giveplayerid][pName], result);
	} else {
		format(small_string, sizeof(small_string), """{ff353c}""Ŕäěčíčńňđŕňîđ %s çŕáëîęčđîâŕë čăđîęŕ %s íŕ %i äíĺé. Ďđč÷číŕ: %s", PlayerInfo[playerid][pName], PlayerInfo[giveplayerid][pName], days, result);
	}

	SendJudgeMessageToAll(small_string, giveplayerid);

 	RemovePlayerFraction(giveplayerid, true);

 	PlayerInfo[giveplayerid][pStatus] = 0;
 	SetPlayerInt(giveplayerid, "Status", PlayerInfo[giveplayerid][pStatus]);
 	PlayerInfo[giveplayerid][pRank] = 0;
 	SetPlayerInt(giveplayerid, "Rank", PlayerInfo[giveplayerid][pRank]);	

	Ban__BanPlayer(PlayerInfo[giveplayerid][pID], PlayerInfo[playerid][pID], result, days);
	Admin__UpCountBan(PlayerInfo[playerid][pID]);

	admstat[2]++;
	upd_admstat();

	return true;
}

