public Army_OnPlayerConnect(playerid) {
	PlayerArmyJonPlant[playerid] = (-1);
}

public Army_OnPlayerDisconnect(playerid, reason) {
	for(new i = 0; i < sizeof(ArmyPlant); i++) {
		if(ArmyPlant[i][AP_Table_PlayerID] == playerid) {
			ArmyPlant[i][AP_Table_PlayerID] = (0xFFFF);

			if(IsValidDynamicObject(ArmyPlant[i][AP_Gun_ObjectID])) {
				Streamer_SetFloatData((0), ArmyPlant[i][AP_Gun_ObjectID], E_STREAMER_Z, 1034.1250);
			}
			break;
		}
	}
	PlayerArmyJonPlant[playerid] = ALS_KillTimer(PlayerArmyJonPlant[playerid]);
}

public Army_OP_PickUpDynamicPickup(playerid, pickupid) {
































	if(pickupid == army_pickup[0]) {
		SetPlayerPos(playerid, 2533.0698, -1284.5824, 1048.2891);
		SetPlayerFacingAngle(playerid, 180.000);
		SetPlayerInterior(playerid, 2);
		SetCameraBehindPlayer(playerid);
		return 1;
	} else if(pickupid == army_pickup[1]) {
		SetPlayerPos(playerid, 338.3293, 1949.1570, 22.0173);
		SetPlayerFacingAngle(playerid, 90.000);
		SetPlayerInterior(playerid, 0);
		SetCameraBehindPlayer(playerid);
		return 1;
	} else if(pickupid == army_pickup[2]) {
		if(Platform[playerid] == 1) {
			Dialog_Show(playerid, #DIALOG_ARMY_PLANT_INFO);
			return 1;
		} else {
			SendClientMessage(playerid, -1, """{FFFFFF}""На данной работе вам предстоит собирать оружие для военных сил армии штата San Andreas.");
			SendClientMessage(playerid, -1, """{FFFFFF}""Вы будете повышать свою законопослушность за каждые 25 перенесенных ящиков");
			return 1;
		}

	} else if(pickupid == army_pickup[3]) {
		if(GetPlayerFraction(playerid) != FRACTION_ARMY) {
			SendClientMessage(playerid, -1, "Подработка доступна только для военных.");
			return 1;
		}

		if(GetPVarInt(playerid, "job_army_plant") == 1) {
			if(IsPlayerAttachedObjectSlotUsed(playerid, 3)) {
				RemovePlayerAttachedObject(playerid, 3);
			}
			ClearPlayerAnimation(playerid);
			SendClientMessage(playerid, -1, """{6de64e}""Рабочий день завершен");
			SetPlayerChatBubble(playerid, 
				(PlayerInfo[playerid][pSex] == 0) ? ("закончил работу") : ("закончила работу"), 
				0x000000AA, (20.00), 2000
			);
			DeletePVar(playerid, "fix_plant");
			DeletePVar(playerid, "job_army_plant");
			CBackSkin(playerid);
			return 1;
		}
		if(PlayerInfo[playerid][pSex] == 0) {
			switch(random(2)) {
				case 0: SetPlayerSkin(playerid, 73);
				default: SetPlayerSkin(playerid, 179);
			}
		} else {
			SetPlayerSkin(playerid, 191);
		}
		SetPVarInt(playerid, "job_army_plant", 1);
		SendClientMessage(playerid, -1, """{6de64e}""Вы начали подработку на военном заводе. Для начала работы, отправляетесь к свободному столу.");
		SetPlayerChatBubble(playerid, 
			(PlayerInfo[playerid][pSex] == 0) ? ("начал работу") : ("начала работу"), 
			0x000000AA, (20.00), 2000
		);
		return 1;
	} else {
		if(GetPVarInt(playerid, "job_army_plant") == 1 && GetPVarInt(playerid, "fix_plant") == 0) {
			for(new i = 0; i < sizeof(ArmyPlant); i++) {
				if(pickupid == ArmyPlant[i][AP_Table_Checkpoint]) {
					new 
						arrayid = i;

					if(ArmyPlant[arrayid][AP_Table_PlayerID] != (0xFFFF)) {
						return SendClientMessage(playerid, -1, """{ff353c}""Этот столик занят другим игроком.");
					}

					Streamer_SetFloatData((0), ArmyPlant[arrayid][AP_Gun_ObjectID], E_STREAMER_Z, 1044.1250);

					ArmyPlant[arrayid][AP_Table_PlayerID] = playerid;

					SetPlayerPos(playerid, ArmyPlant[arrayid][AP_Table_X], ArmyPlant[arrayid][AP_Table_Y], ArmyPlant[arrayid][AP_Table_Z]);
					SetPlayerFacingAngle(playerid, ArmyPlant[arrayid][AP_Table_Angle]);
					SetCameraBehindPlayer(playerid);

					TogglePlayerControllable(playerid, false);
					ApplyAnimation(playerid, "OTB", "BETSLP_LOOP", 10.1, 1, 1, 1, 1, 0);
					SetPVarInt(playerid, "fix_plant", 1);
					PlayerArmyJonPlant[playerid] = SetTimerEx("JobPlant", 10_000, false, "ii", playerid, arrayid);
					GameTextForPlayer(playerid, "~g~~h~WAITING", 10_250, 4);
					return 1;
				}
			}
		}
		if(GetPVarInt(playerid, "fix_plant") == 1) {
			if(pickupid == army_warehouse) {
				SendClientMessage(playerid, -1, """{6de64e}""Вы отнесли готовый продукт на склад.");

				if(IsPlayerAttachedObjectSlotUsed(playerid, 3)) {
					RemovePlayerAttachedObject(playerid, 3);
				}
				ClearPlayerAnimation(playerid);

				new sum = random(3) + 2;
				new active_box = GetPVarInt(playerid, "box_army_plant");

				active_box = active_box + 1;

				if(active_box == 25) {
					IncreaseKarma(playerid);
					active_box = 0;
				}
				SetPVarInt(playerid, "box_army_plant", active_box);

				format(small_string, sizeof(small_string), "~g~~h~+%d EXP~n~TO KARMA UP %i BOX", sum, 25 - active_box);
				GameTextForPlayer(playerid, small_string, 1_250, 4);
				DeletePVar(playerid, "fix_plant");
				Player__AddEXP(PlayerInfo[playerid][pID], sum, E_JOB_ARMY_PLANT, playerid);
				mysql_format(database, 
					small_string, sizeof(small_string), 
					"UPDATE players SET `ArmyBox`= `ArmyBox` + 1 WHERE ID=%i LIMIT 1", 
						PlayerInfo[playerid][pID]
				);
				mysql_pquery(database, small_string);
				return 1;
			}
		}
	}
	return 0;
}

public Army_OnPlayerLeaveDynArea(playerid,  areaid) {
	if(areaid == army_zone) {
		if(GetPVarInt(playerid, "job_army_plant") == 1) {
			if(IsPlayerAttachedObjectSlotUsed(playerid, 3)) {
				RemovePlayerAttachedObject(playerid, 3);
			}
			SendClientMessage(playerid, -1, """{6de64e}""Рабочий день завершен");
			SetPlayerChatBubble(playerid, 
				(PlayerInfo[playerid][pSex] == 0) ? ("закончил работу") : ("закончила работу"), 
				0x000000AA, (20.00), 2000
			);
			DeletePVar(playerid, "job_army_plant");
			DeletePVar(playerid, "fix_plant");
			ClearPlayerAnimation(playerid);
			CBackSkin(playerid);
			return 1;
		}
	}
	return 0;
}

forward dcr_DIALOG_ARMY_PLANT_INFO(playerid); public dcr_DIALOG_ARMY_PLANT_INFO(playerid) {
	return Dialog_Open(playerid, #DIALOG_ARMY_PLANT_INFO, 0,
		!"""{4eb9e6}""Подработка для солдат",
		!"""{FFFFFF}""На данной работе вам предстоит собирать\nоружие для военных сил армии штата San Andreas.\nВы будете повышать свою законопослушность за каждые 25 перенесенных ящиков",
		!"Закрыть", ""
	);
}

public JobPlant(playerid, tableid) {
	if(GetPVarInt(playerid, "job_army_plant") == 0) {
		return 0;
	}

	if(IsValidDynamicObject(ArmyPlant[tableid][AP_Gun_ObjectID])) {
		Streamer_SetFloatData((0), ArmyPlant[tableid][AP_Gun_ObjectID], E_STREAMER_Z, 1034.1250);
	}

	if(ArmyPlant[tableid][AP_Table_PlayerID] != playerid) {
		return 0;
	}

	ArmyPlant[tableid][AP_Table_PlayerID] = (0xFFFF);

	ClearPlayerAnimation(playerid);
	TogglePlayerControllable(playerid, true);

	SendClientMessage(playerid, -1, """{6de64e}""Отнесите готовый продукт на склад.");

	if(!IsPlayerAttachedObjectSlotUsed(playerid, 3)) {
		SetPlayerAttachedObject(playerid, 3, 2969, 1, 0.075578, 0.407083, 0.000000, 1.248928, 97.393852, 359.645050, 1.000000, 1.000000, 1.000000);
	}
	ApplyAnimation(playerid, !"CARRY", !"crry_prtial", 4.0, 1, 0, 0, 1, 1, 1);
	SetPlayerSpecialAction(playerid, 25); 
	return 1;
}

forward pc_cmd_getpickup(playerid, params[]); public pc_cmd_getpickup(playerid, params[]) {
	if(PlayerInfo[playerid][pAdmin] < 5) {
		return 1;
	}

	for(new i = 0; i < sizeof(ArmyPlant); i++) {
		format(small_string, sizeof(small_string), "ID пикапа AP_Table_Checkpoint - %i", ArmyPlant[i][AP_Table_Checkpoint]);
		SendClientMessage(playerid, -1, small_string);
	}

	format(small_string, sizeof(small_string), "ID пикапа army_warehouse - %i", army_warehouse);
	SendClientMessage(playerid, -1, small_string);
	format(small_string, sizeof(small_string), "ID пикапа army_pickup[0] - %i", army_pickup[0]);
	SendClientMessage(playerid, -1, small_string);
	format(small_string, sizeof(small_string), "ID пикапа army_pickup[1] - %i", army_pickup[1]);
	SendClientMessage(playerid, -1, small_string);
	format(small_string, sizeof(small_string), "ID пикапа army_pickup[2] - %i", army_pickup[2]);
	SendClientMessage(playerid, -1, small_string);
	format(small_string, sizeof(small_string), "ID пикапа army_pickup[3] - %i", army_pickup[3]);
	return SendClientMessage(playerid, -1, small_string);
}

forward pc_cmd_streamer_setint(playerid, params[]); public pc_cmd_streamer_setint(playerid, params[]) {
	if(PlayerInfo[playerid][pAdmin] < 5) {
		return 1;
	}

	new 
		type, id, data, value;

	if(sscanf(params, "iiii", type, id, data, value)) {
		return SendClientMessage(playerid, -1, "Используйте: /streamer_setint [Тип] [ID] [Данные] [Значение]");
	}

	Streamer_SetIntData(type, id, data, value);
	return SendClientMessage(playerid, -1, "Готово");
}

forward pc_cmd_streamer_setfloat(playerid, params[]); public pc_cmd_streamer_setfloat(playerid, params[]) {
	if(PlayerInfo[playerid][pAdmin] < 5) {
		return 1;
	}

	new 
		type, id, data, Float: value;

	if(sscanf(params, "iiif", type, id, data, value)) {
		return SendClientMessage(playerid, -1, "Используйте: /streamer_setfloat [Тип] [ID] [Данные] [Значение]");
	}

	Streamer_SetFloatData(type, id, data, value);
	return SendClientMessage(playerid, -1, "Готово");
}
