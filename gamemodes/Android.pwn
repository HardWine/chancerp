				}
				*/
////////////////////////

				new temp[MAX_PLAYER_NAME+1];
				GetPlayerName(playerid, temp, MAX_PLAYER_NAME+1);
				if(strcmp(temp, nick, true) == 0) return LoadAccounts(playerid);

///////////////////////


				if(SetPlayerName(playerid, nick) != 1) {
					SendClientMessage(playerid, -1, ""COLOR_RED"Ошибка. Повторите ввод или перезайдите");
					return ShowPlayerDialog(playerid, dName, DIALOG_STYLE_INPUT, "Добро пожаловать!", "Введите ваш ник (Используйте формат: Имя_Фамилия)", "Далее", "");
				}
				LoadAccounts(playerid);
			}
			return 1;
		}
