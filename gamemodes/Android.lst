	}
	return (1);
}

forward @yH_OnPlayerPickUpDynPickup@026(playerid, pickupid);@yH_OnPlayerPickUpDynPickup@026(playerid, pickupid) {
	if(Dialog_IsOpen(playerid)) {
		return 0;
	}

	if(pickupid == PC_AviationBuy) {
		return (~1);
	} else if(pickupid == PC_AviationSpawn) {
		return (~1);
	} else if(pickupid == PC_AviationManager) {
		return (1);
	} else if(pickupid == PC_CenterLS[0]) {
		RM_SetPlayerPos(playerid, 1547.3691, -1366.4625, 326.2109);
		SetPlayerFacingAngle(playerid, 90.00);
		SetCameraBehindPlayer(playerid);
	} else if(pickupid == PC_CenterLS[1]) {
		RM_SetPlayerPos(playerid, 1576.1881, -1333.6328, 16.4844);
		SetPlayerFacingAngle(playerid, 325.00);
		SetCameraBehindPlayer(playerid);
	} else if(pickupid == PC_CenterLS[2]) {

		if(GetPVarInt(playerid,"CalledSpawnPickup") > gettime()) return 1;
		SetPVarInt(playerid,"CalledSpawnPickup",gettime() + 25);

		new 
			model = PlayerAviationModel[playerid];

		if(model == (-1)) {
			return SendClientMessage(playerid, -1, """{FFAF00}""Ó âŕń íĺň ëč÷íîăî âĺđňîëĺňŕ");
		}
		if(PlayerAviationVehicleID[playerid] != (0xFFFF)) {
			return SendClientMessage(playerid, -1, """{FFAF00}""Âĺđňîëĺň óćĺ çŕńďŕâíĺí");
		}

		PlayerAviationVehicleID[playerid] = Iter_CreateVehicle(model, 1544.9669, -1353.2726, 329.7122, 90.00, 1, 1, 86400);

