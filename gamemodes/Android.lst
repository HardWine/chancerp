forward pc_cmd_id(playerid, params[]); public pc_cmd_id(playerid, params[])
{
	if(!(1 <= MDialog_strlen(params) <= 24-4))
	{
		return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ: /id [÷ŕńňü čěĺíč čăđîęŕ]");
	}

	SendClientMessage(playerid, -1, "Đĺçóëüňŕňű ďîčńęŕ:");

	new message[12+11+24],
		bool:isfound = false;
	for(new i; i < 126; i++)
	{
		if(GetPlayerName(i, message, 24))
		{
			if(strfind(message, params, true) != -1)
			{
				isfound = true;
				format(small_string, sizeof(small_string), "ID: %d | Čě˙: %s", i, message);
				SendClientMessage(playerid, -1, small_string);
			}
		}
	}
	if(isfound == false)
	{
		SendClientMessage(playerid, -1, "Ďîčńę íĺ äŕë đĺçóëüňŕňîâ!");
	}
	return 1;
}  

