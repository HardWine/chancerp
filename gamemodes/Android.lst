public OnPlayerWeaponShot(playerid, weaponid, hittype, hitid, Float:fX, Float:fY, Float:fZ) {
	new bool: isShot = false;

	for(new i = 0; i < sizeof(allowed_weapons); i++) {
		if(weaponid == allowed_weapons[i]) {
			isShot = true;
		}
	}

	if(isShot == false) 
	{

		return 0;
	} 
	else 
	{
		return 1;
	}
}



































stock DelGuns(playerid) {
		PlayerInfo[playerid][slot_2_gun] = 0;
		PlayerInfo[playerid][slot_2_ammo] = 0;
		PlayerInfo[playerid][slot_3_gun] = 0;
		PlayerInfo[playerid][slot_3_ammo] = 0;
		PlayerInfo[playerid][slot_4_gun] = 0;
		PlayerInfo[playerid][slot_4_ammo] = 0;
		PlayerInfo[playerid][slot_5_gun] = 0;
		PlayerInfo[playerid][slot_5_ammo] = 0;
		PlayerInfo[playerid][slot_8_gun] = 0;
		PlayerInfo[playerid][slot_8_ammo] = 0;

		SetPlayerInt(playerid, "slot_2_gun", 0);
		SetPlayerInt(playerid, "slot_3_gun", 0);
		SetPlayerInt(playerid, "slot_4_gun", 0);
		SetPlayerInt(playerid, "slot_5_gun", 0);
		SetPlayerInt(playerid, "slot_8_gun", 0);

		SetPlayerInt(playerid, "slot_2_ammo", 0);
		SetPlayerInt(playerid, "slot_3_ammo", 0);
		SetPlayerInt(playerid, "slot_4_ammo", 0);
		SetPlayerInt(playerid, "slot_5_ammo", 0);
		SetPlayerInt(playerid, "slot_8_ammo", 0);
		return 1;
}

stock GetGun(playerid) {

	RM_ResetPlayerWeapons(playerid);

	new Fraction:fractionid = GetPlayerFraction(playerid);

	if(GetPlayerJobDayStatus(playerid) == true)
	{
		if(IsAGang(playerid)) {
			RM_GivePlayerWeapon(playerid, 41, 250);
			RM_GivePlayerWeapon(playerid, 5, 1);
		}
		if(IsACop(playerid)) {
			RM_GivePlayerWeapon(playerid, 3, 1);
		}	
		if(fractionid == FRACTION_GOVERMENT) {
				new rank = PlayerInfo[playerid][pRank];
				if(rank == 1 || rank == 3 || rank == 5) {
					SetPlayerArmour(playerid, 100);
					RM_ResetPlayerWeapons(playerid);
					RM_GivePlayerWeapon(playerid, 3, 1);
					RM_GivePlayerWeapon(playerid, 24, 60);
				}
		}	
		if(fractionid == FRACTION_NEWS) {
			RM_GivePlayerWeapon(playerid, 43, 50);
		}
	}

	if(PlayerInfo[playerid][slot_2_gun] != 0) RM_GivePlayerWeapon(playerid, PlayerInfo[playerid][slot_2_gun], PlayerInfo[playerid][slot_2_ammo]);
	if(PlayerInfo[playerid][slot_3_gun] != 0) RM_GivePlayerWeapon(playerid, PlayerInfo[playerid][slot_3_gun], PlayerInfo[playerid][slot_3_ammo]);
	if(PlayerInfo[playerid][slot_4_gun] != 0) RM_GivePlayerWeapon(playerid, PlayerInfo[playerid][slot_4_gun], PlayerInfo[playerid][slot_4_ammo]);
	if(PlayerInfo[playerid][slot_5_gun] != 0) RM_GivePlayerWeapon(playerid, PlayerInfo[playerid][slot_5_gun], PlayerInfo[playerid][slot_5_ammo]);
	if(PlayerInfo[playerid][slot_8_gun] != 0) RM_GivePlayerWeapon(playerid, PlayerInfo[playerid][slot_8_gun], PlayerInfo[playerid][slot_8_ammo]);		
	return 1;
}


forward pc_cmd_makegun(playerid, params[]); public pc_cmd_makegun(playerid, params[]) {

	if(PlayerArea[playerid] == true) return 1;


