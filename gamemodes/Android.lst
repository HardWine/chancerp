public OnRuntimeError(code, &bool:suppress)
{
	if (code == 0x00495359)
	{
		YSI_g_sCrashdetect = true;
		suppress = true;
		return 1;
	}
	return ScriptInit_OnRuntimeError(code, suppress);
}














