forward pc_cmd_changehouse(playerid, params[]); public pc_cmd_changehouse(playerid, params[]) {

	if(GetPVarInt(playerid,"deal_created") > gettime()) return SendClientMessage(playerid, -1, """{FFAF00}""Ďîäîćäčňĺ íĺěíîăî");
	SetPVarInt(playerid,"deal_created",gettime()+30);	
	new
		player_house = GetPlayerHouseID(playerid);
	if(Player__Hotel[playerid] != (-1)) return 1;
	if(player_house == 0) return 1;
	if(sscanf(params, "ii", params[0], params[1])) return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ: /changehouse [id čăđîęŕ] [äîďëŕňŕ ďîęóďŕňĺë˙]");
	if(PlayerLogged{params[0]} == false || !IsPlayerConnected(params[0])) return 0;
	if(Player__Hotel[params[0]] != (-1)) return 1;
	new
		seller_house = GetPlayerHouseID(params[0]);

	if(GetDistanceBetweenPlayerz(playerid, params[0], 10.00) != 1) return SendClientMessage(playerid, -1, """{ff353c}""Âű ńëčřęîě äŕëĺęî îň óęŕçŕííîăî čăđîęŕ");

	if(PlayerInfo[playerid][pTransferControl] >= 2)
		return SendClientMessage(playerid, -1, """{ff353c}""Äîńňčăíóň ëčěčň ńäĺëîę ďî íĺäâčćčěîńňč íŕ ńĺăîäí˙");
	if(PlayerInfo[params[0]][pTransferControl] >= 2)
		return SendClientMessage(playerid, -1, """{ff353c}""Čăđîęîě äîńňčăíóň ëčěčň ńäĺëîę ďî íĺäâčćčěîńňč íŕ ńĺăîäí˙");

	if(PlayerInfo[playerid][pDebt] > 1000) return SendClientMessage(playerid, -1, """{ff353c}""Âŕřč řňđŕôű ďđĺâűřŕţň ""{FFFFFF}""1000 EXP""{ff353c}"", âű íĺ ěîćĺňĺ ńîâĺđřŕňü ńäĺëęč");
	if(PlayerInfo[params[0]][pDebt] > 1000) return SendClientMessage(playerid, -1, """{ff353c}""Řňđŕôű óęŕçŕííîăî čăđîęŕ ďđĺâűřŕţň ""{FFFFFF}""1000 EXP""{ff353c}"", âű íĺ ěîćĺňĺ çŕęëţ÷čňü ń íčě ńäĺëęó");


	new fourth = HouseInfo[player_house][hPrice]/4;
	new maxplus = HouseInfo[player_house][hPrice]+fourth;
	if(params[1] > maxplus) return SendClientMessage(playerid, -1, """{ff353c}""Ěŕęńčěŕëüíŕ˙ äîďëŕňŕ đŕâíŕ 125 ďđîöĺíňîâ îň ăîń. ńňîčěîńňč");
	if(params[1] < 0) return SendClientMessage(playerid, -1, """{ff353c}""Íĺęîđđĺęňíŕ˙ öĺíŕ");
	if(params[0] == playerid || params[0] == (0xFFFF)) return SendClientMessage(playerid, -1, """{ff353c}""Íĺâĺđíűé ID!");


	SetPVarInt(playerid, "buyer_house", params[0]);
	SetPVarInt(playerid, "price_house", params[1]);

	if(seller_house > 0) {
		format(big_string, sizeof(big_string), "{FFFFFF}Âű ďđĺäëîćčëč îáěĺí íĺäâčćčěîńňč %s\n""{ff353c}""Âű îňäŕĺňĺ: {FFFFFF}Äîě ą%d \n""{6de64e}""Âű ďîëó÷ŕĺňĺ: {FFFFFF}Äîě ą%d, %d EXP\n\n""{FFAF00}""×ňîáű ďîäňâĺđäčňü ńäĺëęó íŕćěčňĺ - Äŕëĺĺ", PlayerInfo[params[0]][pName], player_house, seller_house, params[1]);
		SPD(playerid, dChangeHouse, 0, "Îáěĺí íĺäâčćčěîńňüţ", big_string, "Äŕëĺĺ", "Îňěĺíŕ");
	} else {

		format(big_string, sizeof(big_string), "{FFFFFF}Âű ďđĺäëîćčëč îáěĺí íĺäâčćčěîńňč %s\n""{ff353c}""Âű îňäŕĺňĺ: {FFFFFF}Äîě ą%d \n""{6de64e}""Âű ďîëó÷ŕĺňĺ: {FFFFFF}%d EXP\n\n""{FFAF00}""×ňîáű ďîäňâĺđäčňü ńäĺëęó íŕćěčňĺ - Äŕëĺĺ", PlayerInfo[params[0]][pName], player_house, params[1]);
		SPD(playerid, dChangeHouse, 0, "Îáěĺí íĺäâčćčěîńňüţ", big_string, "Äŕëĺĺ", "Îňěĺíŕ");
	}
	return 1;
}
stock AcceptHouseChange(playerid) {
	new buyerid = GetPVarInt(playerid, "buyer_house");
	new price = GetPVarInt(playerid, "price_house");
	new
		seller_house = GetPlayerHouseID(buyerid);
	new
		player_house = GetPlayerHouseID(playerid);

	if(player_house == 0) return 1;
	if(GetDistanceBetweenPlayerz(playerid, buyerid, 10.00) != 1) return SendClientMessage(playerid, -1, """{FFAF00}""Âű ńëčřęîě äŕëĺęî îň óęŕçŕííîăî čăđîęŕ");

	if(GetPVarInt(playerid, "SellingCar") != -1) return SendClientMessage(playerid, -1, """{FFAF00}""Ó âŕń ĺńňü ŕęňčâíîĺ ďđĺäëîćĺíčĺ");

	SetPVarInt(playerid, "SellingCar", buyerid);

	if(GetPVarInt(buyerid, "CarOffer") == -1) { SetPVarInt(buyerid, "CarOffer", playerid); }
	else return SendClientMessage(playerid, -1, """{FFAF00}""Äŕííűé čăđîę ńĺé÷ŕń đŕńńěŕňđčâŕĺň äđóăîĺ ďđĺäëîćĺíčĺ");

	SetPVarInt(buyerid, "OfferPrice", price);


	if(seller_house > 0) {
		format(big_string, sizeof(big_string), "{FFFFFF}%s ďđĺäëŕăŕĺň îáěĺí íĺäâčćčěîńňč\n""{ff353c}""Âű îňäŕĺňĺ: {FFFFFF}Äîě ą%d, %d EXP\n""{6de64e}""Âű ďîëó÷ŕĺňĺ: {FFFFFF}Äîě ą%d\n\nÂű ńîăëŕńíű?", PlayerInfo[playerid][pName], seller_house, price, player_house);
		SPD(buyerid, dChangeHouseOperation, 0, "Îáěĺí íĺäâčćčěîńňüţ", big_string, "Ďđčí˙ňü", "Îňęŕç");
	} else {

		format(big_string, sizeof(big_string), "{FFFFFF}%s ďđĺäëŕăŕĺň îáěĺí íĺäâčćčěîńňč\n""{ff353c}""Âű îňäŕĺňĺ: {FFFFFF}%d EXP\n""{6de64e}""Âű ďîëó÷ŕĺňĺ: {FFFFFF}Äîě ą%d\n\nÂű ńîăëŕńíű?", PlayerInfo[playerid][pName], price, player_house);
		SPD(buyerid, dChangeHouseOperation, 0, "Îáěĺí íĺäâčćčěîńňüţ", big_string, "Ďđčí˙ňü", "Îňęŕç");

	}
	SendClientMessage(playerid, -1, """{FFAF00}""Îćčäŕéňĺ ďîäňâĺđćäĺíč˙ ńäĺëęč");
	return 1;
}
stock AcceptCarChange(playerid) {
	new buyerid = GetPVarInt(playerid, "buyer_house");
	new price = GetPVarInt(playerid, "price_house");

	if(caridhouse[playerid] == (0xFFFF)) return 1;
	if(GetDistanceBetweenPlayerz(playerid, buyerid, 10.00) != 1) return SendClientMessage(playerid, -1, """{FFAF00}""Âű ńëčřęîě äŕëĺęî îň ďîęóďŕňĺë˙");

	if(GetPVarInt(playerid, "SellingCar") != -1) return SendClientMessage(playerid, -1, """{FFAF00}""Ó âŕń ĺńňü ŕęňčâíîĺ ďđĺäëîćĺíčĺ");

	SetPVarInt(playerid, "SellingCar", buyerid);

	if(GetPVarInt(buyerid, "CarOffer") == -1) { SetPVarInt(buyerid, "CarOffer", playerid); }
	else return SendClientMessage(playerid, -1, """{FFAF00}""Äŕííűé čăđîę ńĺé÷ŕń đŕńńěŕňđčâŕĺň äđóăîĺ ďđĺäëîćĺíčĺ");

