		case dMenu: {
			if(!response) {
				return 1;
			}
			if(response) {
				switch(listitem) {
					case 0: callcmd::quest(playerid, "\0");
					case 1: callcmd::achievement(playerid, "\0");
					case 2: {
						ShowPlayerDialog(playerid, dMenuLicense, DIALOG_STYLE_LIST,"Документы персонажа","{FFFFFF}1. Паспорт\n2. Лицензии","Выбрать","Закрыть");
					}
					case 3: ShowSkill(playerid);
					case 4: callcmd::gps(playerid,"\0");
					case 5: {
						ShowPlayerDialog(playerid, dSupport, DIALOG_STYLE_LIST,"Помощь","{FFFFFF}1. Список команд\n2. Фракции\n3. Правила сервера\n4. Справка","Выбрать","Закрыть");
					}
					case 6: {
						return ShowPlayerDialog(playerid, dMenuFeedback, DIALOG_STYLE_LIST, "Связь с администрацией","{FFFFFF}1. Сообщить о нарушение\n2. Задать вопрос\n3. Оставить сообщение о баге\n4. Предложить улучшение", "Выбрать","Закрыть");
					}
					case 7: ShowPlayerDialog(playerid, dDonate, DIALOG_STYLE_INPUT, "Донат", "{FFFFFF}1. Пополнить счет\n2. Premium "COLOR_RED"(Скидка)"COLOR_WHITE"\n2. Конвертировать в EXP\n3. Cмена RP ника", "Выбрать","Закрыть");
					case 8: ShowPlayerDialog(playerid, dMenuSettings, DIALOG_STYLE_LIST, "Настройки","{FFFFFF}1. Цвет оформления\n2. Отображение наказаний\n3. Защита аккаунта", "Выбрать","Закрыть");
					case 9: {
							new
								player_house = GetPlayerHouseID(playerid);
							if(Player.Hotel[playerid] != INVALID_HOTEL_ID) return SendClientMessage(playerid, -1, "Чтобы сменить ник нужно не иметь недвижимость");
							if(player_house != 0) return SendClientMessage(playerid, -1, "Чтобы сменить ник нужно не иметь недвижимость");
									
							ShowPlayerDialog(playerid, dMenuChangeNick, DIALOG_STYLE_INPUT, "Смена NonRP ника","{FFFFFF}Введите новый ник", "Выбрать","Закрыть");
						
					}
				}
			}
			return 1;
		}
		case dSelectCar: {
			if(!response) {
				if(GetPVarInt(playerid, "carselected") == 1)
					return SendClientMessage(playerid, -1, ""COLOR_RED"Вы уже выбирали автомоибль в этой сессии");
				if(PlayerInfo[playerid][pSelectedSlot] == 2) return SendClientMessage(playerid, -1, ""COLOR_GREEN"Данный автомобиль уже выбран");
				if(IsValidVehicle(caridhouse[playerid]))
				{
					
				    if(vehicleInfo[caridhouse[playerid]][useAttach])
				    {
				        if(IsValidObject(vehicleInfo[caridhouse[playerid]][attachObject])) DestroyObject(vehicleInfo[caridhouse[playerid]][attachObject]);
				    }
				    

					DestroyVehicle(caridhouse[playerid]);
					caridhouse[playerid] = INVALID_VEHICLE_ID;
				}				
				PlayerInfo[playerid][pSelectedSlot] = 2;
				SetPlayerInt(playerid, "SelectedSlot", PlayerInfo[playerid][pSelectedSlot]);
				SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы выбрали второй автомобиль");
				LoadCarPlayerId(playerid);
				SetPVarInt(playerid, "carselected", 1);
			}
			if(response) {
				if(GetPVarInt(playerid, "carselected") == 1)
					return SendClientMessage(playerid,-1,  ""COLOR_RED"Вы уже выбирали автомоибль в этой сессии");
				if(PlayerInfo[playerid][pSelectedSlot] == 1) return SendClientMessage(playerid, -1, ""COLOR_GREEN"Данный автомобиль уже выбран");
				if(IsValidVehicle(caridhouse[playerid]))
				{
					
				    if(vehicleInfo[caridhouse[playerid]][useAttach])
				    {
				        if(IsValidObject(vehicleInfo[caridhouse[playerid]][attachObject])) DestroyObject(vehicleInfo[caridhouse[playerid]][attachObject]);
				    }
					
					DestroyVehicle(caridhouse[playerid]);
					caridhouse[playerid] = INVALID_VEHICLE_ID;
				}				
				PlayerInfo[playerid][pSelectedSlot] = 1;
				SetPlayerInt(playerid, "SelectedSlot", PlayerInfo[playerid][pSelectedSlot]);
				SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы выбрали первый автомобиль");
				LoadCarPlayerId(playerid);
				SetPVarInt(playerid, "carselected", 1);

			}
		}
		case dMenuChangeNick: {
			if(!response) {
				return 1;
			}
			if(response) {

				if(PlayerInfo[playerid][pMarried] == 1) 
					return SendClientMessage(playerid, -1, "Вы не можете сменить ник находясь в браке");

				if(IsRpNickname(inputtext) == 0) {
					return SendClientMessage(playerid, -1, "Указанный Вами никнейм не сооветсвует RP требованиям");
				}
				if(Player.IsChangeNick(playerid) != -1) {
					return SendClientMessage(playerid, -1, "Вы уже отправили заявку на смену ника. Дождитесь результата.");
				}
				if(Player.IsUsedName(inputtext) != 0) {
					format(small_string, sizeof(small_string), "Указанное Вами имя (%s) уже кем-то используется", inputtext);
					return SendClientMessage(playerid, -1, small_string);
				}
				Player.AddChangeNick(playerid, inputtext);
				return 1;
			}
		}
		case dDonateNick: {
			if(!response) {
				return 1;
			}
			if(response) {

				if(PlayerInfo[playerid][pMarried] == 1) 
					return SendClientMessage(playerid, -1, "Вы не можете сменить ник находясь в браке");

				if(PlayerInfo[playerid][pDonate] < 49) {
					return SendClientMessage(playerid, -1, "Цена услуги составляет 49 рублей. Для продолжения пополните счет (chancerp.ru/donate)");
				}
				if(Player.IsChangeNick(playerid) != -1) {
					return SendClientMessage(playerid, -1, "Вы уже отправили заявку на смену ника. Дождитесь результата.");
				}
				if(Player.IsUsedName(inputtext) != 0) {
					format(small_string, sizeof(small_string), "Указанное Вами имя (%s) уже кем-то используется", inputtext);
					return SendClientMessage(playerid, -1, small_string);
				}
				if(Player.ChangeNick(playerid, inputtext, E_SELL) == true) {
					PlayerInfo[playerid][pDonate] -= 49;
					SetPlayerInt(playerid, "Donate", PlayerInfo[playerid][pDonate]);

					format(small_string, sizeof(small_string), "Ваш никнейм был успешно изменен на %s", PlayerInfo[playerid][pName]);
					return SendClientMessage(playerid, -1, small_string);
				}
				return 1;
			}
		}
		case dChangeHouse: {
			if(!response) return 1;
			return AcceptHouseChange(playerid);
		}
		case dChangeHouseOperation: {
			if(!response) {
				new sellerid = GetPVarInt(playerid, "CarOffer");
				SendClientMessage(sellerid, -1, ""COLOR_RED"Сделка отменена");
				SendClientMessage(playerid, -1, ""COLOR_RED"Сделка отменена");
				return CancelOffer(playerid);
			}
			if(GetPVarInt(playerid, "CarOffer") != -1) {
				new sellerid = GetPVarInt(playerid, "CarOffer");
				new price = GetPVarInt(playerid, "OfferPrice");

				if(GetDistanceBetweenPlayerz(playerid, sellerid, 10.00) != 1) return SendClientMessage(playerid, -1, ""COLOR_RED"Продавец слишком далеко"), CancelOffer(playerid);
				if(PlayerLogged{sellerid} == false || !IsPlayerConnected(sellerid)) return SendClientMessage(playerid, -1, ""COLOR_RED"Продавец не в сети"), CancelOffer(playerid);

				if(price > 0) {
					if(CheckCash(playerid, price) == false) return SendClientMessage(playerid, -1, ""COLOR_RED"Недостаточно средств"), CancelOffer(playerid), SendClientMessage(sellerid, -1, ""COLOR_RED"Сделка отменена");
					RemovePlayerEXP(playerid, price, "Доплата при обмене домами для игрока %s", PlayerInfo[sellerid][pName]);
					AddPlayerEXP(sellerid, price, "Доплата при обмене домами от игрока %s", PlayerInfo[playerid][pName]);
				}
				SendClientMessage(playerid, -1, ""COLOR_GREEN"Сделка подтверждена");
				SendClientMessage(sellerid, -1, ""COLOR_GREEN"Сделка подтверждена");

				new player_house = GetPlayerHouseID(playerid);
				new seller_house = GetPlayerHouseID(sellerid);
				if(IsValidVehicle(caridhouse[playerid]))
				{
					DestroyVehicle(caridhouse[playerid]);
					caridhouse[playerid] = INVALID_VEHICLE_ID;
				}
				if(IsValidVehicle(caridhouse[sellerid]))
				{
					DestroyVehicle(caridhouse[sellerid]);
					caridhouse[sellerid] = INVALID_VEHICLE_ID;
				}
				if(player_house > 0) {
					//
					HouseInfo[player_house][hOwned] = 1;
					HouseInfo[player_house][hTakings] = 1;
					strmid(HouseInfo[player_house][hOwner], PlayerInfo[sellerid][pName], 0, strlen(PlayerInfo[sellerid][pName]), 255);
					//if(PlayerInfo[sellerid][pCar] == 0) PlayerInfo[sellerid][pCar] = 509, SetPlayerInt(sellerid, "Car", PlayerInfo[sellerid][pCar]);
					new MySQL[110];
					mysql_format(database, MySQL, sizeof(MySQL), "UPDATE `apartment` SET Owner = '%e', Owned = 1, Takings = 1 WHERE ID = '%d' LIMIT 1",PlayerInfo[sellerid][pName],player_house);
					mysql_pquery(database, MySQL, "", "");

					Streamer_SetIntData(STREAMER_TYPE_PICKUP, HouseInfo[player_house][hPickup], 23, 1272);
					BuyHouse(player_house);
					SetPVarInt(sellerid, "PlayerHouse", player_house);

					SendClientMessage(sellerid, -1, ""COLOR_RED"Оплатите дом в банке, во избежание дальнейшей продажи дома государству");
					SendClientMessage(sellerid, -1, "(( Открыть или закрыть двери дома можно командой: /homelock ))");
				}

				HouseInfo[seller_house][hOwned] = 1;
				HouseInfo[seller_house][hTakings] = 1;
				strmid(HouseInfo[seller_house][hOwner], PlayerInfo[playerid][pName], 0, strlen(PlayerInfo[playerid][pName]), 255);
				//if(PlayerInfo[playerid][pCar] == 0) PlayerInfo[playerid][pCar] = 509, SetPlayerInt(playerid, "Car", PlayerInfo[playerid][pCar]);
				new MySQL[110];
				mysql_format(database, MySQL, sizeof(MySQL), "UPDATE `apartment` SET Owner = '%e', Owned = 1, Takings = 1 WHERE ID = '%d' LIMIT 1",PlayerInfo[playerid][pName],seller_house);
				mysql_pquery(database, MySQL, "", "");

				Streamer_SetIntData(STREAMER_TYPE_PICKUP, HouseInfo[seller_house][hPickup], 23, 1272);
				BuyHouse(seller_house);
				SetPVarInt(playerid, "PlayerHouse", seller_house);


				SendClientMessage(playerid, -1, ""COLOR_RED"Оплатите дом в банке, во избежание дальнейшей продажи дома государству");
				SendClientMessage(playerid, -1, "(( Открыть или закрыть двери дома можно командой: /homelock ))");

				CancelOffer(playerid);

				PlayerInfo[playerid][pTransferControl] = PlayerInfo[playerid][pTransferControl]+1;
				SetPlayerInt(playerid, "TransferControl", PlayerInfo[playerid][pTransferControl]);

				PlayerInfo[sellerid][pTransferControl] = PlayerInfo[sellerid][pTransferControl]+1;
				SetPlayerInt(sellerid, "TransferControl", PlayerInfo[sellerid][pTransferControl]);

				LoadCarPlayerId(playerid);
				LoadCarPlayerId(sellerid);

				static string[512];

				mysql_format(database,
					string, sizeof(string),
					"INSERT INTO `changehouse_log` (`Seller`, `Buyer`, `Addition`, `Shouse`, `Bhouse`) VALUES (%i, %i, %i, %i, %i)",
						GetPlayerAccountID(sellerid),
						GetPlayerAccountID(playerid),
						price,
						seller_house,
						player_house
				);
				return mysql_pquery(database, string);
			}
		}
		case dChangeCar: {
			if(!response) return 1;
			return AcceptCarChange(playerid);
		}
		case dSellCar: {
			if(!response) return 1;
			return SellCar_Gov(playerid);
		}
