	SendClientMessage(params[0], -1, ""COLOR_GREEN"Поздравляем! Вы получили 500 EXP за победу в мероприятии!");
	SendClientMessage(playerid, -1, ""COLOR_GREEN"Награда в размере 500 EXP выдана");
