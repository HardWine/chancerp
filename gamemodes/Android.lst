forward TD_OnDialogResponse(playerid, dialogid, response, listitem, inputtext[]);
public TD_OnDialogResponse(playerid, dialogid, response, listitem, inputtext[])
{
	switch(dialogid)
	{
    case dSelectColor: {
	if(!response) return 1;
	if(response) {
		if(GetPVarInt(playerid,"AntiFloodTD") > gettime())	{ SendClientMessage(playerid, -1, !"""{ff353c}""Повторите через несколько секунд"); return false; }
		switch(listitem) {
			case 0: {
				if(PlayerInfo[playerid][pColor] == 0) pc_cmd_selectcolor(playerid,"\0"); SendClientMessage(playerid, -1, !"""{F3FF02}""Цвет установлен");
				PlayerInfo[playerid][pColor] = 0;
				SetPlayerInt(playerid, "Color", PlayerInfo[playerid][pColor]);
				update_logo_textdraw_color(playerid);
				SetPVarInt(playerid,"AntiFloodTD",gettime() + 10);
			}
			case 1: {
				if(PlayerInfo[playerid][pColor] == 1) pc_cmd_selectcolor(playerid,"\0"); SendClientMessage(playerid, -1, !"""{F3FF02}""Цвет установлен");
				PlayerInfo[playerid][pColor] = 1;
				SetPlayerInt(playerid, "Color", PlayerInfo[playerid][pColor]);
				update_logo_textdraw_color(playerid);
				SetPVarInt(playerid,"AntiFloodTD",gettime() + 10);
			}
			case 2: {
				if(PlayerInfo[playerid][pColor] == 2) pc_cmd_selectcolor(playerid,"\0"); SendClientMessage(playerid, -1, !"""{F3FF02}""Цвет установлен");
				PlayerInfo[playerid][pColor] = 2;
				SetPlayerInt(playerid, "Color", PlayerInfo[playerid][pColor]);
				update_logo_textdraw_color(playerid);
				SetPVarInt(playerid,"AntiFloodTD",gettime() + 10);
			}
			case 3: {
				if(PlayerInfo[playerid][pColor] == 3) pc_cmd_selectcolor(playerid,"\0"); SendClientMessage(playerid, -1, !"""{F3FF02}""Цвет установлен");
				PlayerInfo[playerid][pColor] = 3;
				SetPlayerInt(playerid, "Color", PlayerInfo[playerid][pColor]);
				update_logo_textdraw_color(playerid);
				SetPVarInt(playerid,"AntiFloodTD",gettime() + 10);
			}
    	}
	}
	return 1;
	}
	}
	return 1;
}

