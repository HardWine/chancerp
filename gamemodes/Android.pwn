                	new senderstring[20];
					if(senderid != INVALID_PLAYER_ID) {
					format(senderstring, 20, "[%d]", senderid);
					} else {
					format(senderstring, 20, "[?]");
					}


                	format(small_string, sizeof(small_string), "{FF4500}Жалоба от репортера:{ffd700} %s[%d]", PlayerInfo[playerid][pName],playerid);
					SendAdminMessage(-1, small_string);
                	format(small_string, sizeof(small_string), "{FF4500}Прислал: {ffd700}%s%s{ffd700} {FF4500}Текст:{ffd700} '%s'", AllAd[counter][0], senderstring, AllAd[counter][1]);
					SendAdminMessage(-1, small_string);


            		format(AllAd[counter][0], 20, "-");
		            format(AllAd[counter][1], 144, "Пусто");
		            format(AllAd[counter][2], 144, "0");        
		                 
        		}
        		default: {
        			AllAd[GetPVarInt(playerid,"ListAD")][2] = "0"; 
					return callcmd::edit(playerid);
        		}
            }  			
		}
		case dEditAdvertOption:
		{
			if(!response) 
            { 
                AllAd[GetPVarInt(playerid,"ListAD")][2] = "0"; 
				return callcmd::edit(playerid);
            } 
            switch(listitem) 
            { 
                case 0: 
                { 
                	format(big_string, sizeof(big_string), "{ffffff}%s\n\nВведите текст отредактированого объявления\n"COLOR_RED"Соблюдайте правила редактирования!",
                		AllAd[GetPVarInt(playerid,"ListAD")][1]
                	);
                    return ShowPlayerDialog(playerid,dEditAdvertCompleted,DIALOG_STYLE_INPUT,"Объявление",big_string,"Изменить","Закрыть"); 
                } 
                case 1: 
                { 
                	format(big_string, sizeof(big_string), "{ffffff}Вы хотите отправить это объявление в очередь:\n"COLOR_ORANGE"%s",
                		AllAd[GetPVarInt(playerid,"ListAD")][1]
                	);
                    return ShowPlayerDialog(playerid,dEditAdvertSend,DIALOG_STYLE_MSGBOX,"Объявление",big_string,"Изменить","Закрыть");
                }
                case 2: 
                {
                	new counter = GetPVarInt(playerid,"ListAD");

                	new senderid = _ReturnPlayerID(AllAd[counter][0]);
                	new senderstring[20];
					if(senderid != INVALID_PLAYER_ID) {
					format(senderstring, 20, "[%d]", senderid);
					} else {
					format(senderstring, 20, "[?]");
					}

                	format(small_string, sizeof(small_string), "{FF4500}Жалоба от репортера:{ffd700} %s[%d]", PlayerInfo[playerid][pName],playerid);
					SendAdminMessage(-1, small_string);
                	format(small_string, sizeof(small_string), "{FF4500}Прислал: {ffd700}%s%s{ffd700} {FF4500}Текст:{ffd700} '%s'", AllAd[counter][0], senderstring, AllAd[counter][1]);
					SendAdminMessage(-1, small_string);

            		format(AllAd[counter][0], 20, "-");
		            format(AllAd[counter][1], 144, "Пусто");
		            format(AllAd[counter][2], 144, "0");        
		            callcmd::edit(playerid);       
        		} 
            }  			
		}
		case dEditAdvertCompleted:
		{
			if(!response) return ShowEditOptions(playerid); 
 			new symbols = strlen(inputtext);
            if(inputtext[0] == '\0') {
            	format(big_string, sizeof(big_string), "{ffffff}%s\n\nВведите текст отредактированого объявления\n"COLOR_RED"Соблюдайте правила редактирования!",
            		AllAd[GetPVarInt(playerid,"ListAD")][1]
            	);
            	return ShowPlayerDialog(playerid,dEditAdvertCompleted,DIALOG_STYLE_INPUT,"Объявление",big_string,"Изменить","Закрыть"); 
            }
            if(symbols < 1 || symbols > 64)
            {
            	format(big_string, sizeof(big_string), "{ffffff}%s\n\nВведите текст отредактированого объявления\n"COLOR_RED"Соблюдайте правила редактирования!",
            		AllAd[GetPVarInt(playerid,"ListAD")][1]
            	);
            	SendClientMessage(playerid, -1, ""COLOR_RED"Объявление должно содержать от 1 до 64 символов"); 
				return ShowPlayerDialog(playerid,dEditAdvertCompleted,DIALOG_STYLE_INPUT,"Объявление",big_string,"Изменить","Закрыть"); 
            }

            new counter = GetPVarInt(playerid,"ListAD");

            format(AllAd[counter][1], 144, "%s", inputtext);

            SendClientMessage(playerid, -1, ""COLOR_GREEN"Данное объявление успешно отредактиравано"); 
            return ShowEditOptions(playerid); 
  		}
		case dEditAdvertSend: {
			if(!response) return ShowEditOptions(playerid); 
            for(new i = 0; i < 10; i++) 
            { 
                if(strlen(adlist[i][0]) <= 1) 
                { 
                	new counter = GetPVarInt(playerid,"ListAD");
                    adlist[i][0] = AllAd[counter][1]; // добавляем в очередь 
                    adlist[i][1] = AllAd[counter][0]; // добавляем в очередь 

                    format(adlist[i][2], 144, "%s", PlayerInfo[playerid][pName]);

                    AllAd[GetPVarInt(playerid,"ListAD")][0] = "-"; // очищаем место для объявлений 
                    AllAd[GetPVarInt(playerid,"ListAD")][1] = "нет"; // очищаем место для объявлений 
                    AllAd[GetPVarInt(playerid,"ListAD")][2] = "0"; // очищаем место для объявлений 
                    AddPlayerEXP(playerid, 50, "Редактирование объявления");
                    AddPlayerAchievement(playerid, E_REAL_EDITOR);
                    GameTextForPlayer(playerid, "~n~~n~~n~~n~EDIT COMPLETED~n~~g~~h~+50 EXP", 2500, 6);
                   	format(small_string, sizeof(small_string), ""COLOR_BLUE"Объявление отправлено. Его номер в очереди: {FFFFFF}%d", i+1);
					return SendClientMessage(playerid, -1, small_string);
                } 
            }  
		}
		case dInvArea:
		{
			if(response) {
				InviteArmy(playerid);
			}
			return 1;
		}
		case dDrugHouse:
		{
			if(response) {
				get_drugs_accepted(playerid);
			}
			return 1;
		}
		case dLeave:
		{
			if(response) {

				Leave(playerid);
			}
			return 1;
		}
		case dBuyApartment:
		{
			if(response) {
				BuyApartment(playerid);
			}
			return 1;
		}
		case dSellApartment:
		{
			if(response) {
				SellApartment(playerid);
			}
			return 1;
		}
		case dNullKarma:
		{
			if(response) {
				CNull(playerid);
			}
			return 1;
		}
		/*case dInviting: {
			if(response) {
			CInvite(playerid);
			}
			return 1;
		}*/
		case dLogin:  {
			if(!response)
			{
				ShowPlayerDialog(playerid, dKickMessage, DIALOG_STYLE_MSGBOX, "Оповещение", "{FFFFFF}Вы были кикнуты с сервера.\n{FF0000}Причина: Отказ от авторизации.\n{FFFFFF}Для выхода с сервера введите \"/q\" в чат", "Выход", "");
				return Kick(playerid);
			}
			if(!strlen(inputtext)) return ShowPlayerDialog(playerid, dLogin, DIALOG_STYLE_INPUT, "Вход в аккаунт", "{FF0000}Ошибка: {FFFFFF}Вы не можете продолжить авторизацию не введя пароль!\nВведите пароль от аккаунта для входа на сервер:", "Вход", "");
			if(!strcmp(PlayerInfo[playerid][pPassword], inputtext))
			{
				new query_string[49+MAX_PLAYER_NAME];

				mysql_format(database, query_string, sizeof(query_string), "SELECT * FROM "TABLE_ACCOUNTS" WHERE `Name` = '%e'", PlayerInfo[playerid][pName]);
				mysql_tquery(database, query_string, "SecureVerification","i", playerid);
			}
			else
			{
				switch(GetPVarInt(playerid, "WrongPassword"))
				{
					case 0: ShowPlayerDialog(playerid, dLogin, DIALOG_STYLE_INPUT, "Вход в аккаунт", "{FF0000}Ошибка: {FFFFFF}Вы ввели неверный пароль! У Вас осталось 3 попытки.\nВведите пароль от аккаунта для входа на сервер:", "Вход", "");
					case 1: ShowPlayerDialog(playerid, dLogin, DIALOG_STYLE_INPUT, "Вход в аккаунт", "{FF0000}Ошибка: {FFFFFF}Вы ввели неверный пароль! У Вас осталось 2 попытки.\nВведите пароль от аккаунта для входа на сервер:", "Вход", "");
					case 2: ShowPlayerDialog(playerid, dLogin, DIALOG_STYLE_INPUT, "Вход в аккаунт", "{FF0000}Ошибка: {FFFFFF}Вы ввели неверный пароль! У Вас осталась последняя попытка, после чего Вас кикнет.\nВведите пароль от аккаунта для входа на сервер:", "Вход", "");
					default:
					{
						ShowPlayerDialog(playerid, dKickMessage, DIALOG_STYLE_MSGBOX, "", "{FFFFFF}Вы были кикнуты с сервера.\n{FF0000}Причина: Превышен лимит попыток на ввод ", "Выход", "");
						return Kick(playerid);
					}
				}
				SetPVarInt(playerid, "WrongPassword", GetPVarInt(playerid, "WrongPassword")+1);
			}
			return 1;
		}
