			else if(strlen(inputtext) < 1) return ShowPlayerDialog(playerid, dBuyDrug, DIALOG_STYLE_INPUT, "Покупка наркотиков", "{FFFFFF}Введите количество грамм для покупки:\n"COLOR_BLUE"Цена за грамм: {FFFFFF}50 EXP", "Далее", "Закрыть");
			else if(strlen(inputtext) > 3) return ShowPlayerDialog(playerid, dBuyDrug, DIALOG_STYLE_INPUT, "Покупка наркотиков", "{FFFFFF}Введите количество грамм для покупки:\n"COLOR_BLUE"Цена за грамм: {FFFFFF}50 EXP", "Далее", "Закрыть");
			for(new i = strlen(inputtext)-1; i != -1; i--)
			{
