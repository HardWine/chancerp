forward UpdateSpeed(playerid);
public UpdateSpeed(playerid)
{
	Timer_Speed[playerid] = KillTimer(Timer_Speed[playerid]);

	if(!IsPlayerInAnyVehicle(playerid) || GetPlayerState(playerid) != (2)) {
		stop_detector(playerid);
		if(GetPVarInt(playerid, "taxijob")) {

			if(PlayerInfo[playerid][pLicense] == 0) {
				hide_speedo(playerid);
				show_logo(playerid);
				return 1;
			}
			if(GetPVarInt(playerid, "tempjob") > 0) {
				hide_speedo(playerid);
				show_logo(playerid);
				return 1;
			}
			new
			Fraction: fractionid = GetPlayerFraction(playerid);
			if(fractionid != FRACTION_NONE) return hide_speedo(playerid);
			DeletePVar(playerid, "taxijob");
			cabAvailible[playerid] = 1; 
			if(cabClient[playerid] != (0xFFFF)) {
				SendClientMessage(cabClient[playerid], -1, """{ff353c}""Âîäčňĺëü ďîęčíóë ňŕęńč. Çŕęŕç îňěĺíĺí");
				cabClient[playerid] = (0xFFFF);
			}
			if(destinationMark[playerid] != (-1)) {
				DestroyDynamicCP(destinationMark[playerid]);
				destinationMark[playerid] = (-1);
			}
			SendClientMessage(playerid, -1, """{ff353c}""Âű ďîęčíóëč ňŕęńč č áîëüřĺ íĺ ěîćĺňĺ ďđčíčěŕňü çŕęŕçű");
		}
		show_logo(playerid);
		return hide_speedo(playerid);

	}
	new v = GetPlayerVehicleID(playerid);
	new modelid = GetVehicleModel(v);
	new speed_vehicle = floatround(GetVehicleSpeed(v));
	new Float:chp;
	GetVehicleHealth(v, chp);
	if(floatround(chp) < 350) {
		SetVehicleHealth(v, 350);
		new engine, lights, alarm, doors, bonnet, boot, objective;
		GetVehicleParamsEx(v, engine, lights, alarm, doors, bonnet, boot, objective);
		if(engine == 1) SendClientMessage(playerid, -1, """{ff353c}""Ňđŕíńďîđň çŕăëîő");
		SetVehicleParamsEx(v, 0, 0, alarm, 0, bonnet, boot, objective);
	}

	if(Platform[playerid] == 1) {
	if(PlayerInfo[playerid][pSelectedSlot] == 1) {
	format(small_string,sizeof(small_string),"%09d",PlayerInfo[playerid][pMileage]/1000);
	}		
	if(PlayerInfo[playerid][pSelectedSlot] == 2) {
	format(small_string,sizeof(small_string),"%09d",PlayerInfo[playerid][pMileage2]/1000);
	}
	PlayerTextDrawSetString(playerid,speedo_TD[playerid][2], small_string);
	if(speed_vehicle == 0) {
		format(big_string, sizeof(big_string),"%s",GetVehicleText(modelid));
		PlayerTextDrawSetString(playerid,speedo_TD[playerid][3], big_string);
	} else {
		format(big_string, sizeof(big_string),"%dkm/h",speed_vehicle);
		PlayerTextDrawSetString(playerid,speedo_TD[playerid][3], big_string);
	}
	}

	for(new i = 0; i < sizeof(YachtBuy); i++) {
		if(YachtBuy[i][E_VEHICLE_ID] == v) {
			new 
				Float: pos_x,
				Float: pos_y,
				Float: pos_z;

			GetPlayerPos(playerid, pos_x, pos_y, pos_z);
			RemovePlayerFromVehicle(playerid);
			SetVehicleToRespawn(v);
			RM_SetPlayerPos(playerid, pos_x, 510.00, pos_z);
			break;
		}
	}

	for(new i = 0; i < sizeof(AviationBuy); i++) {
		if(AviationBuy[i][E_VEHICLE_ID] == v) {
			new 
				Float: pos_x,
				Float: pos_y,
				Float: pos_z;

			GetPlayerPos(playerid, pos_x, pos_y, pos_z);
			RemovePlayerFromVehicle(playerid);
			SetVehicleToRespawn(v);
			RM_SetPlayerPos(playerid, pos_x, -2620.00, pos_z);
			break;
		}
	}


	if(IsPlayerInVehicle(playerid, caridhouse[playerid])) {
	if(PlayerInfo[playerid][pSelectedSlot] == 1) {
	if(speed_vehicle > 2 && speed_vehicle < 30) PlayerInfo[playerid][pMileage] += 19;
	if(speed_vehicle > 30 && speed_vehicle < 90) PlayerInfo[playerid][pMileage] += 49;
	if(speed_vehicle > 90 && speed_vehicle < 1200) PlayerInfo[playerid][pMileage] += 79;
	if(speed_vehicle > 120) PlayerInfo[playerid][pMileage] += 99;

	if(GetPVarInt(playerid,"mileageflood") < gettime()) {
		SetPlayerInt(playerid, "Mileage", PlayerInfo[playerid][pMileage]);
		SetPVarInt(playerid,"mileageflood", gettime() + 30);
	}

	}
	else {
	if(speed_vehicle > 2 && speed_vehicle < 30) PlayerInfo[playerid][pMileage2] += 19;
	if(speed_vehicle > 30 && speed_vehicle < 90) PlayerInfo[playerid][pMileage2] += 49;
	if(speed_vehicle > 90 && speed_vehicle < 1200) PlayerInfo[playerid][pMileage2] += 79;
	if(speed_vehicle > 120) PlayerInfo[playerid][pMileage2] += 99;

	if(GetPVarInt(playerid,"mileageflood") < gettime()) {
		SetPlayerInt(playerid, "Mileage2", PlayerInfo[playerid][pMileage2]);
		SetPVarInt(playerid,"mileageflood", gettime() + 30);
	}

	}
	}
	if(!v) return Timer_Speed[playerid] = SetTimerEx("UpdateSpeed",500,false,"d",playerid); 
	if(Platform[playerid] == 1) {
		update_speedo(playerid, speed_vehicle);
	}


	return Timer_Speed[playerid] = SetTimerEx("UpdateSpeed",500,false,"d",playerid); 
}

forward  DrugsEffect(playerid); public  DrugsEffect(playerid)
{
	DrugTimer[playerid] = KillTimer(DrugTimer[playerid]);
	new time[3];
	gettime(time[0], time[1], time[2]);
	SetPlayerTime(playerid, time[0], time[1]);
	SetPlayerWeather(playerid, 1);
	SetPlayerDrunkLevel(playerid, 0);
	SetPVarInt(playerid,"DrugsEffect",0);
	return 1;
}
stock IsVehicleOccupied(vehicleid)
{
	for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i=Iterator@Player [_: i])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);)
	{
		if(IsPlayerInVehicle(i, vehicleid)) return i;
	}
	return -1;
}

