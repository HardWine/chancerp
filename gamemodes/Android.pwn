							Fraction[fractionid][E_FRACTION_LEADER_NAME], (Fraction[fractionid][E_FRACTION_AUTO_INVITE] == 1) ? (""COLOR_GREEN"Доступно") : (""COLOR_RED"Недоступно"), (Fraction[fractionid][E_FRACTION_AUTO_RANG] == 1) ? (""COLOR_GREEN"Доступно") : (""COLOR_RED"Недоступно")
						);
