		format(small_string, sizeof(small_string), "×ŕńîâ îňűăđŕíî\t""{FFAF00}""%d\n\t\n",PlayerInfo[targetid][pHours]);strcat(pass_string,small_string);

		if(PlayerSIMCardNumber[playerid] != (-1)) {
			format(small_string,sizeof(small_string),"""{FFFFFF}""Ňĺëĺôîí\t""{FFAF00}""%d\n\t\n",PlayerSIMCardNumber[targetid]); strcat(pass_string,small_string);
		} else {
			format(small_string,sizeof(small_string),"""{FFFFFF}""Ňĺëĺôîí\t""{FFAF00}""%s\n\t\n","Îňńóňńâóĺň"); strcat(pass_string,small_string);
		}

		format(small_string,sizeof(small_string),"""{FFFFFF}""Çŕęîíîďîńëóříîńňü\t""{FFAF00}""%d\n",PlayerInfo[targetid][pKarma]); strcat(pass_string,small_string);
		format(small_string,sizeof(small_string),"""{FFFFFF}""Âîĺííűé áčëĺň\t""{FFAF00}""%s\n\t\n", (PlayerInfo[playerid][pArmyDoc] == 0) ? ("Îňńóňńňâóĺň") : ("Ďîëó÷ĺí") ); strcat(pass_string,small_string);

		format(small_string,sizeof(small_string),"""{FFFFFF}""Ôđŕęöč˙\t""{FFAF00}""%s\n", (fractionid == FRACTION_NONE) ? ("Ăđŕćäŕíńęčé") : FractionTitle[_:fractionid-1]); strcat(pass_string,small_string);
		format(small_string,sizeof(small_string),"""{FFFFFF}""Đŕíă\t""{FFAF00}""%s\n\t\n", (fractionid == FRACTION_NONE) ? ("Îňńóňńňâóĺň") : gFractionRankName_RU[_:fractionid-1][PlayerInfo[targetid][pRank]]); strcat(pass_string,small_string);

		format(small_string,sizeof(small_string),"""{FFFFFF}""Ňđŕíńďîđň #1\t""{FFAF00}""%s\n",GetVehicleText(PlayerInfo[targetid][pCar])); strcat(pass_string,small_string);
		format(small_string,sizeof(small_string),"""{FFFFFF}""Ňđŕíńďîđň #2\t""{FFAF00}""%s\n",GetVehicleText(PlayerInfo[targetid][pCar2])); strcat(pass_string,small_string);
		format(small_string,sizeof(small_string),"""{FFFFFF}""×ŕńňíűé âĺđňîëĺň\t""{FFAF00}""%s\n", (PlayerAviationModel[targetid] == (-1)) ? ("""{FFAF00}""Îňńóňńňâóĺň") : (GetVehicleText(PlayerAviationModel[targetid]))); strcat(pass_string,small_string);
		format(small_string,sizeof(small_string),"""{FFFFFF}""×ŕńňíŕ˙ ˙őňŕ\t""{FFAF00}""%s\n\t\n", (PlayerYachtModel[targetid] == (-1)) ? ("""{FFAF00}""Îňńóňńňâóĺň") : (GetVehicleText(PlayerYachtModel[targetid]))); strcat(pass_string,small_string);

		format(small_string,sizeof(small_string),"""{FFFFFF}""Íĺäâčćčěîńňü\t""{FFAF00}""%s",(GetPlayerHouse(targetid)) ? ("Äîě") : ("Îňńóňńňâóĺň")); strcat(pass_string,small_string);

		if(Player__Hotel[targetid] != (-1)) {
			format(small_string,sizeof(small_string),"\n\t\n""{FFFFFF}""Íîěĺđ â îňĺëĺ\t""{FFAF00}""%s\n",(Player__Hotel[targetid] == (-1)) ? ("Îňńóňńňâóĺň") : ("Ĺńňü")), strcat(pass_string,small_string);
		}

		SPD(playerid,
			DIALOG_INFO, 4,
			"""{4eb9e6}""Ńňŕňčńňčęŕ",
			pass_string,
			"Íŕçŕä", "Çŕęđűňü"
		);

	}
	return 1;
}

stock ShowPass(playerid, targetid) {
	if(PlayerInfo[targetid][pBirth] == 0) return SendClientMessage(targetid, -1, "Ó Âŕń íĺň ďŕńďîđňŕ! Ďîëó÷čňü ĺăî ěîćíî ó ńîňđóäíčęîâ ěýđčč");
	if(IsPlayerConnected(playerid) && IsPlayerConnected(targetid)) {

		new FirstName[16],LastName[16];
		sscanf(PlayerInfo[targetid][pName],"p<_>s[16]s[16]",FirstName,LastName);

		new pass_string[768];

		format(small_string, sizeof(small_string), """{FFFFFF}""Ăđŕćäŕíńňâî: SA\t");strcat(pass_string,small_string);
		format(small_string, sizeof(small_string), """{FFFFFF}""Íîěĺđ ďŕńďîđňŕ: %d\n\n",PlayerInfo[targetid][pID]);strcat(pass_string,small_string);
		format(small_string, sizeof(small_string), """{FFFFFF}""Äŕňŕ đîćäĺíč˙: %d\t\t",PlayerInfo[targetid][pBirth]);strcat(pass_string,small_string);
		format(small_string,sizeof(small_string),"""{FFFFFF}""Ďîë: %s\n\n", (PlayerInfo[targetid][pSex] == 0) ? ("Ě") : ("Ć")); strcat(pass_string,small_string);
		format(small_string,sizeof(small_string),"""{FFFFFF}""Čě˙: %s\n", FirstName); strcat(pass_string,small_string);
		format(small_string,sizeof(small_string),"""{FFFFFF}""Ôŕěčëč˙: %s\n", LastName); strcat(pass_string,small_string);

		if(PlayerInfo[targetid][pMarried] == 1 && PlayerInfo[targetid][pSex] == 0) {
			format(small_string,sizeof(small_string),"""{FFFFFF}""\nĆĺíŕ: %s\n\n",PlayerInfo[targetid][pPartner]); strcat(pass_string,small_string); }
		if(PlayerInfo[targetid][pMarried] == 1 && PlayerInfo[targetid][pSex] == 1) {
			format(small_string,sizeof(small_string),"""{FFFFFF}""Ěóć: %s\n\n",PlayerInfo[targetid][pPartner]); strcat(pass_string,small_string); }

		SPD(playerid,
			dStats, 0,
			"USA Passport",
			pass_string,
			"Íŕçŕä", "Çŕęđűňü"
		);

	}
	return 1;
}
