forward pc_cmd_bug(playerid, params[]); public pc_cmd_bug(playerid, params[])
{
	if(PlayerInfo[playerid][pMuted] == 1) return SendClientMessage(playerid, -1, !"""{ff353c}""У вас бан чата");
	if(GetPVarInt(playerid,"ReportedBug") > gettime()){ return SendClientMessage(playerid, -1, !"""{ff353c}""Вы уже недавно сообщали о баге"); }
	SetPVarInt(playerid,"ReportedBug",gettime() + 90);
    if (sscanf(params, "s[129]", params))
        return SendClientMessage(playerid, -1, !"Использование: /bug [описание бага]");
    static const bug_str[] = " сообщил о баге: ";
    new string[sizeof(bug_str)+24+128];
    GetPlayerName(playerid, string, sizeof(string));
    strcat(string, bug_str), strcat(string, params);
    new File:f = fopen(!"BugLog.txt", io_append);
    if (f == File:0)
        return SendClientMessage(playerid, -1,
            !"""{ff353c}""Ошибка. Попробуйте позже");
    for (new i = -1; string[++i] != '\0';)
        fputchar(f, string[i], false);
    fputchar(f, '\n', false);
    fclose(f);
    SendClientMessage(playerid, -1, !"""{6de64e}""Вы успешно сообщили о баге. Спасибо!");
    new chat[144];
    format(chat, sizeof(chat), "{FF4500}%s[%d] оставил баг-репорт:{ffd700} %s", PlayerInfo[playerid][pName],playerid, params[0]);
	SendAdminMessage(-1, chat);
	return 1;

}

