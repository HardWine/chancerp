			total_iterator = total_iterator + 1;

			distance = GetPlayerDistanceFromPoint(playerid, GPSInfo[i][GI_X], GPSInfo[i][GI_Y], GPSInfo[i][GI_Z]);

			format(gps_string, sizeof(gps_string), "%i\t%s\t""{6de64e}""%0.2f m.""{FFFFFF}""\n", total_iterator, GPSInfo[i][GI_Title], distance);
			strcat(gps_string_all, gps_string);
		}
	}

	return Dialog_Open(playerid, #DIALOG_GPS_SHOW_POINT, 5,
		"""{4eb9e6}""GPS Навигация",
		gps_string_all,
		"Выбрать", "Назад"
	);
}

forward dre_DIALOG_GPS_SHOW_POINT(playerid, response, listitem, inputtext[]); public dre_DIALOG_GPS_SHOW_POINT(playerid, response, listitem, inputtext[]) {
	if(!response) {
		DeletePVar(playerid, "GPS_Category");
		return Dialog_Show(playerid, #DIALOG_GPS_SHOW_CATEGORY);
	} else {
		new 
			gps_id = strval(inputtext),
			gps_categoryid = GetPVarInt(playerid, "GPS_Category"),
			total_iterator;

		for(new i = 0; i < sizeof(GPSInfo); i++) {
			if(GPSInfo[i][GI_CategoryID] == gps_categoryid) {
				total_iterator = total_iterator + 1;

				if(total_iterator == gps_id) {
					if(PlayerInfo[playerid][pAdmin] > 3) {
						SetPlayerPos(playerid, GPSInfo[i][GI_X], GPSInfo[i][GI_Y], GPSInfo[i][GI_Z]);
						SetPlayerInterior(playerid, 0);
						SetPlayerVirtualWorld(playerid, 0);
						return SetCameraBehindPlayer(playerid);
					}
					TogglePlayerDynamicCP(playerid, GPSInfo[i][GI_CheckpointID], true);
					Streamer_Update(playerid, (2));

					SetPVarInt(playerid, "Gps_Active", 1);

					static string[37 + (32) + 1];
					format(string, sizeof(string), "GPS Навигатор автивен: ""{6de64e}""%s", GPSInfo[i][GI_Title]);
					return SendClientMessage(playerid, -1, string);
				}
			}
		}
	}
	return 1;
}

public HideGpsForPlayer(playerid) {
	for(new i = 0; i < sizeof(GPSInfo); i++) {
		TogglePlayerDynamicCP(playerid, GPSInfo[i][GI_CheckpointID], false);
	}
	return Streamer_Update(playerid, (2));
}

public Gps_OnPlayerEnterDynamicCP(playerid,  checkpointid) {
	for(new i = 0; i < sizeof(GPSInfo); i++) {
		if(GPSInfo[i][GI_CheckpointID] == checkpointid) {
			static string[42 + (32) + 1];
			TogglePlayerDynamicCP(playerid, GPSInfo[i][GI_CheckpointID], false);
			Streamer_Update(playerid, (2));

			DeletePVar(playerid, "Gps_Active");

			format(string, sizeof(string), "Местоположение достигнуто: ""{6de64e}""%s", GPSInfo[i][GI_Title]);
			SendClientMessage(playerid, -1, string);
			return 1;
		}
	}
	return 0;
}

public GPS_OnPlayerDeath(playerid) {
	if(GetPVarInt(playerid, "Gps_Active") == 1) {
		SendClientMessage(playerid, -1, """{ff353c}""GPS Навигация отключена.");
		HideGpsForPlayer(playerid);
		DeletePVar(playerid, "Gps_Active");
	}
}
