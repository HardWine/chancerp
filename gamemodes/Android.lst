forward pc_cmd_force(playerid); public pc_cmd_force(playerid) {
	if(Player__AdminLevel{playerid} < 5) return true;

	for(new c = 0; c <= GetVehiclePoolSize(); c++) {
		if(IsVehicleOccupied(c) == -1 && IsVehicleStreamedIn(c, playerid)) {

			SetVehicleToRespawn(c);
		}
	}
	veh_update = 0;
	SendClientMessage(playerid, -1, "Âű îáíîâčëč âĺńü íĺçŕí˙ňűé ňđŕíńďîđň â đŕäčóńĺ ďđîđčńîâęč");
	return 1;	
}
forward pc_cmd_spawncars(playerid, params[]); public pc_cmd_spawncars(playerid, params[])
{
	if(Player__AdminLevel{playerid} < 5) return true;
	if(veh_update == 1) {
		return SendClientMessage(playerid, -1, "Óćĺ çŕďóůĺííî îáíîâëĺíčĺ ńâîáîäíîăî ňđŕíńďîđňŕ. Ďîďđîáóéňĺ ďîçćĺ");
	}
	format(small_string, sizeof(small_string), """{FFAF00}""Ŕäěčíčńňđŕňîđ %s îáíîâčň âĺńü íĺçŕí˙ňűé ňđŕíńďîđň ÷ĺđĺç 30 ńĺęóíä", PlayerInfo[playerid][pName]);
	SendClientMessageToAll(-1, small_string);
	veh_update = 1;
	return SetTimer(!"@_RespawnVehicle", 30_000, false);
}
@_RespawnVehicle();
@_RespawnVehicle() {
	for(new c = 0; c <= GetVehiclePoolSize(); c++) {
		if(IsVehicleOccupied(c) == -1) {
			SetVehicleToRespawn(c);
		}
	}
	veh_update = 0;
	return SendClientMessageToAll(-1, """{FFAF00}""Íĺçŕí˙ňűĺ ňđŕíńďîđňűĺ ńđĺäńňâŕ áűëč îáíîâëĺíű");
}

stock HowMuchAdmins() {
	new null = 0;
	for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Admin ))-1);_:( i=Iterator@Admin [_: i])!=((_:F@f:F@e:sizeof (Iterator@Admin ))-1);) {
       if(pl_afk_time[i] >= 6) continue;
       null++; 
	}	
	return null;
}

stock AttackModeAuto(text[]) {
	if(HowMuchAdmins() == 0) {
       if(!strcmp(text, "đóň")) COMPARES++;
       if(!strcmp(text, "đŕçíîń")) COMPARES++;
       if(!strcmp(text, "ńëčâ")) COMPARES++;
       if(!strcmp(text, "÷čň")) COMPARES++;
       if(!strcmp(text, "ěčíčăŕí")) COMPARES++;
       if(!strcmp(text, "áŕí")) COMPARES++;
	}
}

forward pc_cmd_report(playerid, params[]); public pc_cmd_report(playerid, params[])
{
	new chat[144];
	if(PlayerInfo[playerid][pMuted] == 1) return SendClientMessage(playerid, -1, """{ff353c}""Ó âŕń áŕí ÷ŕňŕ");

	if(!params[0])return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ: /report [ňĺęńň]");

	AttackModeAuto(params[0]);
	format(chat, sizeof(chat), "{FF4500}%s[%d]:{ffd700} %s", PlayerInfo[playerid][pName],playerid, params[0]);
	SendAdminMessage(-1, chat);
	SendClientMessage(playerid, -1, """{FFAF00}""Âŕřĺ ńîîáůĺíčĺ áűëî îňďđŕâëĺíî ŕäěčíčńňđŕňîđŕě ńĺđâĺđŕ. Îćčäŕéňĺ îňâĺňŕ");
	format(small_string, sizeof(small_string), "{FF4500}Îňďđŕâëĺííűé ňĺęńň: {ffd700}%s", params[0]);
	SendClientMessage(playerid, -1, small_string);
	admstat[0]++;
	upd_admstat();
	return 1;
}
forward pc_cmd_ask(playerid, params[]); public pc_cmd_ask(playerid, params[])
{
	new chat[144];

	if(PlayerInfo[playerid][pMuted] == 1) return SendClientMessage(playerid, -1, """{ff353c}""Ó âŕń áŕí ÷ŕňŕ");
	if(GetPVarInt(playerid,!"AntiFloodHelper") > gettime()){ SendClientMessage(playerid, -1, "Ďčńŕňü â đĺďîđň ěîćíî đŕç â ěčíóňó"); return false; }
	if(!params[0])return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ: /ask [ňĺęńň]");
	SetPVarInt(playerid,!"AntiFloodHelper",gettime() + 60);
	AttackModeAuto(params[0]);
	format(chat, sizeof(chat), "[ASK] ""{FFAF00}""%s[%d]: %s", PlayerInfo[playerid][pName],playerid, params[0]);
	SendHelperMessage(-1, chat);
	if((_:F@i:(Iter_Single@Helper )) == 0)
	{
		SendAdminMessage(-1, chat);
	}
	SendClientMessage(playerid, -1, """{FFAF00}""Âŕřĺ ńîîáůĺíčĺ áűëî îňďđŕâëĺíî. Îćčäŕéňĺ îňâĺňŕ");
	format(small_string, sizeof(small_string), "{FF4500}Îňďđŕâëĺííűé ňĺęńň: {ffd700}%s", params[0]);
	SendClientMessage(playerid, -1, small_string);
	admstat[0]++;
	upd_admstat();	
	return 1;
}
forward pc_cmd_pm(playerid, params[]); public pc_cmd_pm(playerid, params[])
{
	if(Player__AdminLevel{playerid} > 0) {
		if(sscanf(params, "d s[128]",params[0],params[1])) return	SendClientMessage(playerid, -1, !"Čńďîëüçóéňĺ: /pm [id čăđîęŕ] [ňĺęńň]");

		if(!IsPlayerConnected(params[0])) return  1;
		if(params[0] == (0xFFFF)) return 1;
		if(GetPVarInt(params[0],!"GotReport") > gettime()) return 1;
		format(small_string, sizeof(small_string), "%s îňâĺňčë %s: %s",PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName], params[1]);
		SendAdminMessage(0xFF9945FF, small_string);
		format(small_string, sizeof(small_string), "Ŕäěčíčńňđŕňîđ %s îňâĺňčë: %s",PlayerInfo[playerid][pName], params[1]);
		SendClientMessage(params[0], 0xFF9945FF, small_string);
		PlayerPlaySound(params[0], 1085, 0.0, 0.0, 0.0);
		SetPVarInt(params[0],!"GotReport",gettime() + 5);
		Admin__UpCountPM(PlayerInfo[playerid][pID]);
		admstat[1]++;
		upd_admstat();
	} else if(Player__HelperLevel{playerid} != 0) {
		if(sscanf(params, "d s[128]",params[0],params[1])) return	SendClientMessage(playerid, -1, !"Čńďîëüçóéňĺ: /pm [id čăđîęŕ] [ňĺęńň]");

		if(!IsPlayerConnected(params[0])) return  1;
		if(params[0] == (0xFFFF)) return 1;
		if(GetPVarInt(params[0],!"GotReport") > gettime()) return 1;
		format(small_string, sizeof(small_string), "%s îňâĺňčë %s: %s",PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName], params[1]);
		SendAdminMessage(0xFF9945FF, small_string);
		SendHelperMessage(0xFF9945FF, small_string);
		format(small_string, sizeof(small_string), "Support %s îňâĺňčë: %s",PlayerInfo[playerid][pName], params[1]);
		SendClientMessage(params[0], 0xFF9945FF, small_string);
		PlayerPlaySound(params[0], 1085, 0.0, 0.0, 0.0);
		SetPVarInt(params[0],!"GotReport",gettime() + 5);
		Helper__UpCountPM(PlayerInfo[playerid][pID]);
		admstat[1]++;
		upd_admstat();		
	} else {
		return 0;
	}
	return 1;
}
