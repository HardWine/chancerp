		PlayerPlaySound(playerid, 4203, 0, 0, 0);
		format(small_string, sizeof(small_string), ""COLOR_GREEN"Добро пожаловать! Ваш банковский баланс: {FFFFFF} %d EXP", PlayerInfo[playerid][pBank]);
		SendClientMessage(playerid, -1, small_string);
		return 1;
	}
	if(areaid == bank_zone[3])
	{
		return Dialog_Bank_Property(playerid);
	}
	if(areaid == bank_zone[4])
	{
		if(GetPlayerHouse(playerid) > 0) {
			ShowPlayerDialog(playerid, dSellApartment, DIALOG_STYLE_MSGBOX, "Продажа недвижимости", ""COLOR_RED"Вы действительно хотите продать дом за треть стоимости?", "Продать", "Закрыть");
		}
		else {
			SendClientMessage(playerid, -1, ""COLOR_ORANGE"В данном окне можно продать свой дом государству");
		}
		return 1;
	}
	if(areaid == bank_zone[5])
	{
		new
			arrayID = Player.Hotel[playerid];

		if(arrayID != INVALID_HOTEL_ID) {
			if(Hotel.Room[arrayID][E_HOTEL_ROOM_RENT_DAY] >= 7) {
				format(small_string, sizeof(small_string), "~b~DAYS: ~w~%d~n~~r~MAXIMUM", Hotel.Room[arrayID][E_HOTEL_ROOM_RENT_DAY]);
				GameTextForPlayer(playerid, small_string, 2500, 4);
				return 1;
			}
			new
				tax = 180;

			if(CheckCash(playerid, tax) == false) return 1;
			RemovePlayerEXP(playerid, tax, "Оплата проживания в отеле");

			Hotel.UpRentDay(arrayID);
			SendClientMessage(playerid, -1, ""COLOR_ORANGE"Вы оплатили проживание в отеле на одни сутки");
			format(small_string, sizeof(small_string), "~r~-%d EXP~n~~b~DAYS: ~w~%d", tax, Hotel.Room[arrayID][E_HOTEL_ROOM_RENT_DAY]);
			GameTextForPlayer(playerid, small_string, 2500, 4);
		}
		else {
			SendClientMessage(playerid, -1, ""COLOR_ORANGE"В данном окне можно продлить дни проживания в отеле");
		}
		return 1;
	}
	if(areaid == GetLicense_zone)
	{
		if(Platform[playerid] == 0) return ShowPlayerDialog(playerid, dLicenseAdaptive, DIALOG_STYLE_INPUT, "Сдача экзамена", "{FFFFFF}1. Водительские права - 50 EXP\n2. Удостоверение пилота - 250 EXP\n\n"COLOR_BLUE"Введите цифру выбранного пункта", "Далее", "Закрыть");
		ShowPlayerDialog(playerid, dLicense, DIALOG_STYLE_LIST, "Сдача экзамена", "{FFFFFF}1. Водительские права - 50 EXP\n2. Удостоверение пилота - 250 EXP", "Далее", "Закрыть");
		return 1;
	}
	CallLocalFunction("Casino_OnPlayerEnterDynArea", "ii", playerid, areaid);
	CallLocalFunction("AT_OnPlayerEnterDynArea", "ii", playerid, areaid);
	return 1;
}

public OnPlayerLeaveDynamicArea(playerid, STREAMER_TAG_AREA areaid) {

	if(GetPlayerState(playerid) == PLAYER_STATE_SPECTATING) return 0;
	CallLocalFunction("Casino_OnPlayerLeaveDynArea", "ii", playerid, areaid);
	CallLocalFunction("Patrol_OnPlayerLeaveDynArea", "ii", playerid, areaid);
	CallLocalFunction("Army_OnPlayerLeaveDynArea", "ii", playerid, areaid);

	if(areaid == Main_Beach) {
		if(GetPVarInt(playerid, "Ecologyst")) {
			RemovePlayerAttachedObject(playerid, 8);
			DeletePVar(playerid, "Ecologyst");
			GameTextForPlayer(playerid, "Clean Finished", 2000, 3);
			SendClientMessage(playerid, -1, ""COLOR_RED"Вы покинули пляж, работа завершена!");
			SetPVarInt(playerid, "trash_collected", 0);
		}
	}


	return 1;
}

public OnPlayerEnterRaceCheckpoint(playerid)
{
	//race_Checkpoint(playerid);
	if(IsPlayerInAnyVehicle(playerid) == 0) {
		return 1;
	}

	if(GetPVarInt(playerid, "gb")) {
		DeletePVar(playerid, "gb");
		return DisablePlayerRaceCheckpoint(playerid);
	}

	if(cabAvailible[playerid] == 1 && GetPVarInt(playerid, "taxijob")) {
		cabAvailible[playerid] = 2;
		return DisablePlayerRaceCheckpoint(playerid);
	}

	switch(UnloadFarm[playerid]) {
		case 1: {
			new vehicle;
			vehicle = GetPlayerVehicleID(playerid);
			if(GetPlayerVehicleSeat(playerid) != 0) return 1;
			if(vehicle == HARVEST_CAR[0]) SetPlayerRaceCheckpoint(playerid, 1,-294.1775,-1412.4579,12.8644,-294.1775,-1412.4579,12.8644,5);
			if(vehicle == HARVEST_CAR[1]) SetPlayerRaceCheckpoint(playerid, 1,-306.8991,-1344.1766,8.3550,-306.8991,-1344.1766,8.3550,5);
			if(vehicle == HARVEST_CAR[2]) SetPlayerRaceCheckpoint(playerid, 1,-249.8366,-1376.5028,10.2615,-249.8366,-1376.5028,10.2615,5);
			UnloadFarm[playerid]++;
			SetPlayerChatBubble(playerid, "доставил(а) сырье на обработку", C_PURPLE, 30.0, 5000);
			format(small_string, sizeof(small_string), "%s доставил(а) сырье на обработку", PlayerInfo[playerid][pName]);
			ProxDetector(playerid, MAX_DISTANCE_VISIBLE, C_PURPLE, small_string);
			SendClientMessage(playerid, -1, ""COLOR_ORANGE"Возвращайтесь и разделите прибыль с работниками");
		}
		case 2: {
			new Float:X,Float:Y,Float:Z;
			GetPlayerPos(playerid, X,Y,Z);
			new vehicle;
			vehicle = GetPlayerVehicleID(playerid);
			if(GetPlayerVehicleSeat(playerid) != 0) return 1;
			TOTAL_DRUGS += 60;
			update_drug_text();

			if(vehicle == HARVEST_CAR[0])	Harvest[0] = 0;
			if(vehicle == HARVEST_CAR[1])	Harvest[1] = 0;
			if(vehicle == HARVEST_CAR[2])	Harvest[2] = 0;

			ReloadFarmText();


			UnloadFarm[playerid] = -1;
			SetVehicleToRespawn(vehicle);
			DisablePlayerRaceCheckpoint(playerid);
			new pay = RandomEx(25, 75);

			foreach(new i: Player) {
				if(GetPVarInt(i, "tempjob") == 1) {
					if(IsPlayerInRangeOfPoint(i, 15, X, Y, Z)) {
						if(IsPlayerPremiumAccount(i) == true) {
							AddPlayerEXP(i, pay * 2, "Премия за разгрузку фургона на ферме");
						} else {
							AddPlayerEXP(i, pay, "Премия за разгрузку фургона на ферме");
						}
						format(small_string, sizeof(small_string), ""COLOR_BLUE"Фургон разгружен. Ваша премия: {FFFFFF}+%d EXP", pay);
						SendClientMessage(playerid, -1, small_string);
					}
				}
			}
		}
	}
	switch(RouteFarm[playerid]) {
		case 1: SetPlayerRaceCheckpoint(playerid, 0,-275.9756,-1416.3439,10.9044,-213.5012,-1405.0016,5.9683,10), RouteFarm[playerid] += 1; // combine
		case 2: SetPlayerRaceCheckpoint(playerid, 0,-213.5012,-1405.0016,5.9683,-193.6143,-1382.0881,4.7299,10), RouteFarm[playerid] += 1; // combine
		case 3: SetPlayerRaceCheckpoint(playerid, 0,-193.6143,-1382.0881,4.7299,-246.4743,-1362.7891,9.0994,10), RouteFarm[playerid] += 1; // combine
		case 4: SetPlayerRaceCheckpoint(playerid, 0,-246.4743,-1362.7891,9.0994,-282.0067,-1368.1895,9.1771,10), RouteFarm[playerid] += 1; // combine
		case 5: SetPlayerRaceCheckpoint(playerid, 0,-282.0067,-1368.1895,9.1771,-315.0952,-1332.1112,8.4617,10), RouteFarm[playerid] += 1; // combine
		case 6: SetPlayerRaceCheckpoint(playerid, 0,-315.0952,-1332.1112,8.4617,-289.3944,-1326.7306,7.9310,10), RouteFarm[playerid] += 1; // combine
		case 7: SetPlayerRaceCheckpoint(playerid, 0,-289.3944,-1326.7306,7.9310,-244.2876,-1321.6423,9.3308,10), RouteFarm[playerid] += 1; // combine
		case 8: SetPlayerRaceCheckpoint(playerid, 0,-244.2876,-1321.6423,9.3308,-200.8287,-1340.5165,8.6160,10), RouteFarm[playerid] += 1; // combine
		case 9: SetPlayerRaceCheckpoint(playerid, 0,-200.8287,-1340.5165,8.6160,-189.9037,-1372.4922,4.3427,10), RouteFarm[playerid] += 1; // combine
		case 10: SetPlayerRaceCheckpoint(playerid, 0,-189.9037,-1372.4922,4.3427,-187.2960,-1404.8115,3.3137,10), RouteFarm[playerid] += 1; // combine
		case 11: SetPlayerRaceCheckpoint(playerid, 0,-187.2960,-1404.8115,3.3137,-217.4142,-1402.9197,6.6611,10), RouteFarm[playerid] += 1; // combine
		case 12: SetPlayerRaceCheckpoint(playerid, 0,-217.4142,-1402.9197,6.6611,-283.1469,-1393.8297,10.4023,10), RouteFarm[playerid] += 1; // combine
		case 13: SetPlayerRaceCheckpoint(playerid, 0,-283.1469,-1393.8297,10.4023,-376.5204,-1446.3860,25.2918,10), RouteFarm[playerid] += 1; // combine
		case 14: SetPlayerRaceCheckpoint(playerid, 1,-376.5204,-1446.3860,25.2918,-376.5204,-1446.3860,25.2918,10), RouteFarm[playerid] += 1; // combine
		case 15: {
			new vehicle;
			vehicle = GetPlayerVehicleID(playerid);
			SetVehicleToRespawn(vehicle);
			DisablePlayerRaceCheckpoint(playerid);
			new pay = RandomEx(45, 105);

			if(IsPlayerPremiumAccount(playerid) == true || X2_STATUS == 1) {
				pay = pay * 2;
			}

			AddPlayerEXP(playerid, pay, "Работа на комбаине");
			format(small_string, sizeof(small_string), ""COLOR_BLUE"Поле засеяно. Ваша премия: {FFFFFF}+%d EXP", pay);
			SendClientMessage(playerid, -1, small_string);
			HarvestAmount += 600;
			RouteFarm[playerid] = -1;
		}
	}
	if(RouteTrash[playerid]  == 6) {
		new vehicle;
		vehicle = GetPlayerVehicleID(playerid);
		DisablePlayerRaceCheckpoint(playerid);
		new pay = RandomEx(115, 225);

		if(IsPlayerPremiumAccount(playerid) == true || X2_STATUS == 1) {
			pay = pay * 2;
		}	
		AddPlayerAchievement(playerid, E_CLEAN_CITY);

		AddPlayerEXP(playerid, pay, "Работа на мусоровозе");	
		UpdatePlayerProgressQuest(playerid, E_TRASH_DRIVER);
		format(small_string, sizeof(small_string), ""COLOR_BLUE"Мусоровоз разгружен. Ваша зарплата: {FFFFFF}+%d EXP", pay);
		SendClientMessage(playerid, -1, small_string);
		SetVehicleToRespawn(vehicle);
		RouteTrash[playerid] = -1;
		return 1;
	}
	if(RouteTrash[playerid] > 0) {
		TogglePlayerControllable(playerid, 0);
		DisablePlayerRaceCheckpoint(playerid);
		SendClientMessage(playerid, -1, "Подождите 10 секунд...");
		SetPVarInt(playerid, "MinusTime", 10);
		BinTimer[playerid] = KillTimer(BinTimer[playerid]);
		return BinTimer[playerid] = SetTimerEx("SelectBin", 10000, false, "i", playerid);
	}
	if(RouteLSPD[playerid] != -1) {
		if(RouteLSPD[playerid]  == 6) {
		new vehicle;
		vehicle = GetPlayerVehicleID(playerid);
		DisablePlayerRaceCheckpoint(playerid);
		new 
			value = RandomEx(5, 12);

		AddPlayerAchievement(playerid, E_TURN_FLASHERS);
		IncreaseStatus(playerid, value);
		SetVehicleToRespawn(vehicle);
		RouteLSPD[playerid] = -1;
		DeletePVar(playerid, "turnout_num");
		SendClientMessage(playerid, -1, ""COLOR_GREEN"Задание завершено");
		return 1;
		}
		DisablePlayerRaceCheckpoint(playerid);
		SendClientMessage(playerid, -1, ""COLOR_GREEN"Следите за порядком в данной зоне до истечения времени");
		SetPVarInt(playerid, "MinusTime", 120);
		LSPDTimer[playerid] = KillTimer(LSPDTimer[playerid]);
		return LSPDTimer[playerid] = SetTimerEx("Turnout", 120000, false, "i", playerid);
	}
	switch(ArmyMission[playerid])
	{
		case 0: SetPlayerRaceCheckpoint(playerid, 1, 328.5100,1963.1115,17.6406, 328.5100,1963.1115,17.6406, 5);
		case 1: {
			SendClientMessage(playerid, -1, ""COLOR_BLUE"Началась загрузка боеприпасов. Подождите немного...");
			DisablePlayerRaceCheckpoint(playerid);
			SetPVarInt(playerid, "MinusTime", 10);
			routetimer[playerid] = KillTimer(routetimer[playerid]);
			routetimer[playerid] = SetTimerEx("WareStop", 10000, 0, "i", playerid);
		}
		case 2: {

			IncreaseStatus(playerid, 10);

			AddPlayerAchievement(playerid, E_DANGEROUS);
			ArmyMission[playerid] = 0;
			SendClientMessage(playerid, -1, ""COLOR_BLUE"Вы доставили военный груз");
			DisablePlayerRaceCheckpoint(playerid);

			new price = 100;
			if(IsPlayerPremiumAccount(playerid) == true || X2_STATUS == 1) {
				price = price * 2;
			}

			AddPlayerEXP(playerid, price, "Доставка военного груза");

			IncreaseKarma(playerid);
		}
	}
	switch(RouteAir2[playerid])
