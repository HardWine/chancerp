forward CheckMaxIpConnections(playerid);
public CheckMaxIpConnections(playerid)
{
   	new plrIP[16];
	new remplrIP[16];
    new i;
    new iMaxCons = 0;

    GetPlayerIp(playerid, plrIP, sizeof(plrIP));

    for(i = 0; i < 126; i++)
    {
        GetPlayerIp(i, remplrIP, sizeof(remplrIP));

        if(strcmp(remplrIP, plrIP))
            iMaxCons++;
    }

    if(iMaxCons >= 5)
	{
        for(i = 0; i < 126; i++)
    	{
  	 		GetPlayerIp(i, remplrIP, sizeof(remplrIP));

        	if(strcmp(remplrIP, plrIP))
        	    dc_kickfix__Kick(i);
    	}

    	KickPlayer(playerid, 8);
    }
}


