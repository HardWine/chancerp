forward pc_cmd_cars(playerid); public pc_cmd_cars(playerid) {
	new house = GetPVarInt(playerid, "PlayerHouse");
	switch(HouseInfo[house][hClass]) {
		case 2..5: {
			if(GetPVarInt(playerid, "CarOffer") == -1 || GetPVarInt(playerid, "OfferPrice") == -1) {
				format(big_string, sizeof(big_string), "{ffffff}1.""{4eb9e6}"" %s {ffffff}(%d ęě.)\n2.""{4eb9e6}"" %s {ffffff}(%d ęě.)",
					GetVehicleText(PlayerInfo[playerid][pCar]), PlayerInfo[playerid][pMileage]/1000, GetVehicleText(PlayerInfo[playerid][pCar2]), PlayerInfo[playerid][pMileage2]/1000
				);
				return RM_ShowPlayerDialog(playerid, dSelectCar, 0, "Âűáîđ ňđŕíńďîđňŕ", big_string, ">> 1 <<", ">> 2 <<");
			} else return 1;
		}
		default: {
			SendClientMessage(playerid, -1, "Čńďîëüçîâŕňü äâŕ ŕâňîěîáčë˙ ěîćíî ňîëüęî ń äîěîě íĺ íčćĺ ńđĺäíĺăî ęëŕńńŕ!");
		}
	}
	return 1;
}
