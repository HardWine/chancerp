CMD:check(playerid, params[]) {
	if(GetPlayerAdminLevel(playerid) < 0) {
		if(sscanf(params,"d", params[0])) return 1;
		format(small_string, sizeof(small_string), "auth state: %d", PlayerLogged{params[0]});
		SendClientMessage(playerid, -1, small_string);		
	}
	return 1;
}


forward int_op();
public int_op() {

	foreach(new i: Player) {
		if(GetPlayerState(i) == PLAYER_STATE_ONFOOT && PlayerLogged{i} == false) return ImmediateKick(i);
		if(PlayerLogged{i} == false) {
			continue;
		}	
		gettime(hour, minute, seconds);
		if(GetPlayerVirtualWorld(i) != 0 || GetPlayerInterior(i) != 0) {
			SetPlayerWeather(i, 1);
			SetPlayerTime(i, 12, 0);
		} else {
			SetPlayerWeather(i, weather);
			if(hour == 20) hour = 19;
			if(hour == 21) hour = 20;
			if(hour == 22) hour = 20;
			if(hour == 23) hour = 21;
			if(hour == 0) hour = 22;
			if(hour == 1) hour = 23;
			if(hour == 2) hour = 0;
			if(hour == 3) hour = 1;
			if(hour == 4) hour = 2;
			SetPlayerTime(i, hour, minute);
		}
	}
	return SetTimer("int_op", 250, false);
}

stock startplane(playerid) {	
	SetPlayerInterior(playerid, 0);
	GameTextForPlayer(playerid, "~w~Welcome to San Andreas!", 4000, 1);
	if(IsValidDynamicObject(plane[playerid])) DestroyDynamicObject(plane[playerid]);
	plane[playerid] = CreateDynamicObject(1683, 1702.597412, -2591.397460, 42.363739, 0.000000, 3.499993, 0.000000, playerid+333, 0, playerid, 300.0, 300.0);
	new finish = MoveDynamicObject(plane[playerid], 1947.561889, -2591.318115, 18.415964, 60.0, -1.499999, 0.599993, 0.299999);
	InterpolateCameraPos(playerid, 1940.245117, -2531.656005, 17.888648, 1987.642700, -2558.958251, 17.013938, finish);
	InterpolateCameraLookAt(playerid, 1936.698608, -2535.175537, 18.076105, 1983.598022, -2561.897705, 17.010032, finish);	

	PlaneTimer[playerid] = KillTimer(PlaneTimer[playerid]);
	PlaneTimer[playerid] = SetTimerEx("finishplane", finish, 0, "i", playerid);
	SendClientMessage(playerid, -1, "- Пилот [Громкоговоритель]: Уважаемые пассажиры, пожалуйста займите свои места");
	SendClientMessage(playerid, -1, "- Пилот [Громкоговоритель]: Мы начинаем посадку в Inernational Los Santos Airport");
}

forward finishplane(playerid);
public finishplane(playerid) {
	gettime(hour, minute);
	SendClientMessage(playerid, -1, "- Пилот [Громкоговоритель]: Мы успешно приземлились в штате San Andreas");
	switch(weather) {
		case 0..7: format(small_string, sizeof(small_string), "- Пилот [Громкоговоритель]: За боротом солнечно, +21. Местное время: %d:%02d", hour, minute);
		case 8: format(small_string, sizeof(small_string), "- Пилот [Громкоговоритель]: За боротом облачно, +15. Местное время: %d:%02d", hour, minute);
		case 9: format(small_string, sizeof(small_string), "- Пилот [Громкоговоритель]: За боротом туман, +19. Местное время: %d:%02d", hour, minute);
		case 10: format(small_string, sizeof(small_string), "- Пилот [Громкоговоритель]: За боротом ясно, +19. Местное время: %d:%02d", hour, minute);
		case 11: format(small_string, sizeof(small_string), "- Пилот [Громкоговоритель]: За боротом жарко, +26. Местное время: %d:%02d", hour, minute);
		case 12..15: format(small_string, sizeof(small_string), "- Пилот [Громкоговоритель]: За боротом обычная погода, +16. Местное время: %d:%02d", hour, minute);
		case 16..20: format(small_string, sizeof(small_string), "- Пилот [Громкоговоритель]: За боротом пасмурно, +14. Местное время: %d:%02d", hour, minute);
	}
	SendClientMessage(playerid, -1, small_string);
	SendClientMessage(playerid, -1, "- Пилот [Громкоговоритель]: Спасибо что воспользовались нашими услугами!");

	PlaneTimer[playerid] = KillTimer(PlaneTimer[playerid]);

	finishRegister(playerid);

}

stock finishRegister(playerid) {
	new query_string[512];
	mysql_format(database, query_string, sizeof(query_string), "SELECT players.*, CONVERT(players.State, SIGNED) AS NormState, TIME_TO_SEC(TIMEDIFF(NOW(), `LastTime`)) AS NormTime FROM players WHERE `Name` = '%e' LIMIT 1", PlayerInfo[playerid][pName]);
	mysql_pquery(database, query_string, "UploadPlayerAccount","i", playerid);
	return 1;
}

DialogCreate:pay_debt(playerid) {

		if(PlayerInfo[playerid][pDebt] == 0) return SendClientMessage(playerid, -1, ""COLOR_RED"У вас нет неоплаченных штрафов");
		format(small_string, sizeof(small_string), ""COLOR_BLUE"Штрафы: "COLOR_WHITE"%d EXP", PlayerInfo[playerid][pDebt]);

		return Dialog_Open(playerid, Dialog:pay_debt, DIALOG_STYLE_LIST,
		small_string,
		"Оплатить все штрафы\nОплатить частично",
		"Выбор", "Закрыть"
	);
}

DialogResponse:pay_debt(playerid, response, listitem, inputtext[]) {

	if(!response) {
		return ShowPlayerDialog(playerid, dBank, DIALOG_STYLE_LIST, ""COLOR_BLUE"Банкомат", ""COLOR_WHITE"1. Снять средства\n2. Положить средства\n3. Пополнить счет мобильного\n4. Оплатить штрафы", "Выбрать", "Закрыть");
			
	}
	if(listitem == 0) pay_debt_all(playerid);
	if(listitem == 1) Dialog_Show(playerid, Dialog:pay_debt_part);
	return 1;
}

stock pay_debt_all(playerid) {
	if(CheckCash(playerid, PlayerInfo[playerid][pDebt]) == false) return 1;
	RemovePlayerEXP(playerid, PlayerInfo[playerid][pDebt], "Оплата штрафов за скорость");
	PlayerInfo[playerid][pDebt] = 0;
	SetPlayerInt(playerid, "Debt", PlayerInfo[playerid][pDebt]);
	SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы оплатили все штрафы! Теперь можете спать спокойно!");
	return 1;
}

DialogCreate:pay_debt_part(playerid) {
		if(PlayerInfo[playerid][pDebt] == 0) return SendClientMessage(playerid, -1, ""COLOR_RED"У вас нет неоплаченных штрафов");
		format(small_string, sizeof(small_string), ""COLOR_BLUE"Штрафы: "COLOR_WHITE"%d EXP", PlayerInfo[playerid][pDebt]);
		return Dialog_Open(playerid, Dialog:pay_debt_part, DIALOG_STYLE_INPUT,
		small_string,
		""COLOR_WHITE"Введите сумму которую вы хотите оплатить",
		"Оплата", "Назад"
	);
}

DialogResponse:pay_debt_part(playerid, response, listitem, inputtext[]) {

	if(!response) {
		return Dialog_Show(playerid, Dialog:pay_debt);	
	}

	new debt = strval(inputtext);
	if(debt > PlayerInfo[playerid][pDebt] || debt < 1) return 1;
	if(CheckCash(playerid, debt) == false) return 1;
	RemovePlayerEXP(playerid, debt, "Оплата части штрафов за скорость");
	PlayerInfo[playerid][pDebt] -= debt;
	SetPlayerInt(playerid, "Debt", PlayerInfo[playerid][pDebt]);
	SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы оплатили часть своих штрафов");
	Dialog_Show(playerid, Dialog:pay_debt);
	return 1;
}

