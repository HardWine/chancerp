stock ClearPlayerAnimation(playerid) {
	ClearAnimations(playerid, 1);
	ApplyAnimation(playerid, !"ped", !"facsurp", 4.0, 1, 0, 0, 1, 1, 1);
	ApplyAnimation(playerid, !"ped", !"facsurp", 4.0, 1, 0, 0, 1, 1, 1);
	SetPlayerSpecialAction(playerid, SPECIAL_ACTION_NONE);
	return true;
}
stock PlayerInGangZone(playerid,Float:min_x_coord,Float:min_y_coord,Float:max_x_coord,Float:max_y_coord)
{
	new Float:xxp,Float:yyp,Float:zzp;
	GetPlayerPos(playerid, xxp, yyp, zzp);
	if((xxp <= max_x_coord && xxp >= min_x_coord) && (yyp <= max_y_coord && yyp >= min_y_coord)) return true;
	return false;
}
