public OnQueryError(errorid, error[], callback[], query[], connectionHandle)
{
	printf("OnQueryError errorid %i,  error[] = %s, callback[] = %s, query[] = %s, connectionHandle = %i", errorid, error, callback, query, connectionHandle);
	switch(errorid)
	{
		case 2006:
		{
			printf("Lost connection to server");
		}
		case 1149:
		{
			printf("Something is wrong in your syntax, query: %s",query);
		}
	}
	return 1;
}

stock GetPlayerDaysWithoutActivity(const account_id) {
	mysql_format(database,
	small_string, sizeof(small_string),
	"SELECT TIMESTAMPDIFF(DAY, `LastDate`, NOW()) AS Day FROM `players` WHERE ID = %i LIMIT 1",
	account_id
	);
	mysql_query(database, small_string, true);

	new
	rows = cache_get_row_count();

	if(rows == 0) {
	return 0;
	} else {
		return cache_get_field_content_int(0, "Day");
	}
}


stock LoadAccounts(playerid) {
	GetPlayerName(playerid, PlayerInfo[playerid][pName], 24+1);

	new name[24 + 1];
	GetPlayerName(playerid, name, 24);
	new string[144];
	mysql_format(database, string, sizeof(string), "SELECT `Password` FROM ""players"" WHERE `Name` = '%e' LIMIT 1", name);
	printf(string);
	mysql_tquery(database, string, "FindPlayerInTable","i", playerid);
	return 1;
}
