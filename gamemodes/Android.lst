		format(house_string[0], sizeof(house_string[]), """{6de64e}""%i äí.", HouseInfo[house_array][hTakings]);
		format(house_string[1], sizeof(house_string[]), """{6de64e}""%i EXP", HouseInfo[house_array][hPrice] / 3);
