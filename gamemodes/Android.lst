stock Leave(playerid) {
	SetPlayerColor(playerid, 0xFFFFFFFF);
	SetPlayerArmour(playerid, 0);
	RM_ResetPlayerWeapons(playerid);
	RemovePlayerFraction(playerid, true);
 	PlayerInfo[playerid][pStatus] = 0;
 	SetPlayerInt(playerid, "Status", PlayerInfo[playerid][pStatus]);
 	PlayerInfo[playerid][pRank] = 0;
 	SetPlayerInt(playerid, "Rank", PlayerInfo[playerid][pRank]);
	CBackSkin(playerid);
	CopTimerID[playerid] = KillTimer(CopTimerID[playerid]);
	return 1;
}
forward Turnout(playerid);
public Turnout(playerid) {
	new vehicleid = GetPlayerVehicleID(playerid);
	new vehicle_owner;
	for(new i = 0; i < sizeof(VehicleInfo); i++) {
	if(VehicleInfo[i][VI_VehicleID] == vehicleid) {
	vehicle_owner = VehicleInfo[i][VI_Owner];
	}
	}
	if(vehicle_owner != VO_FRACTION_LSPD) {
		LSPDTimer[playerid] = KillTimer(LSPDTimer[playerid]);
		RouteLSPD[playerid] = -1;
		return SendClientMessage(playerid, -1, "Íĺîáőîäčěî íŕőîäčňüń˙ â ńëóćĺáíîě ŕâňîěîáčëĺ");
	}
	LSPDTimer[playerid] = KillTimer(LSPDTimer[playerid]);
	RM_TogglePlayerControllable(playerid, 1);
	if(RouteLSPD[playerid] != -1) {
		RouteLSPD[playerid] ++;
	}
	else RouteLSPD[playerid] = 1, SetPVarInt(playerid, "turnout_num", 1);
	if(RouteLSPD[playerid] > 5) {
		SendClientMessage(playerid, -1, """{4eb9e6}""Îňďđŕâë˙éňĺńü ę äĺďŕđňŕěĺíňó äë˙ ńäŕ÷č îň÷ĺňŕ");
		return SetPlayerRaceCheckpoint(playerid, 1, 1560.7728,-1694.9004,5.8970, 1560.7728,-1694.9004,5.8970, 5); 
	}
	switch(random(10)) {
		case 0: SetPlayerRaceCheckpoint(playerid, 0, 1062.3949,-1740.1267,13.1927,1062.3949,-1740.1267,13.1927, 5),
		SendClientMessage(playerid, -1, """{4eb9e6}""Âŕřŕ ňî÷ęŕ ďŕňđóëčđîâŕíč˙: {FFFFFF}'Ŕâňîâîęçŕë'");
		case 1: SetPlayerRaceCheckpoint(playerid, 0, 1421.5691,-1692.4011,13.2670,1421.5691,-1692.4011,13.2670, 5),
		SendClientMessage(playerid, -1, """{4eb9e6}""Âŕřŕ ňî÷ęŕ ďŕňđóëčđîâŕíč˙: {FFFFFF}'Áŕíę'");
		case 2: SetPlayerRaceCheckpoint(playerid, 0, 1476.6667,-1723.7067,13.2680,1476.6667,-1723.7067,13.2680, 5),
		SendClientMessage(playerid, -1, """{4eb9e6}""Âŕřŕ ňî÷ęŕ ďŕňđóëčđîâŕíč˙: {FFFFFF}'Ěýđč˙'");
