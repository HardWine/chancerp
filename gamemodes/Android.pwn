		case dSetLeader: {
			if(!response) {
				return 1;
			}
			if(response) {
				switch(listitem) {
					case 0..MAX_FRACTION+1: {
					new fractionid = listitem;
					new ff = fractionid+1;
					if(GetFractionLeader(fractionid) != -1) {
						format(small_string, sizeof(small_string), ""COLOR_ORANGE"Фракция %s уже имеет назначенного лидера", GetFractionTitle(fractionid));
						return SendClientMessage(playerid, -1, small_string);
					} 

					new chosen_leader = GetPVarInt(playerid, "selected_leader");

					new pfraction = GetPlayerFractionInt(chosen_leader);

					if(pfraction-1 != fractionid && pfraction != 0) return SendClientMessage(playerid, -1, ""COLOR_RED"Игрок должен быть гражданским или в выбранной фракции");

					Fraction.SetLeader(fractionid, chosen_leader);
					SetPlayerFraction(chosen_leader, Fraction:ff, true);
					


					for(new i; i < MAX_PLAYERS; i++) {
						if(GetPlayerFraction(i) == Fraction:ff && PlayerInfo[i][pRank] > 8) {
						if(i != chosen_leader) {
							PlayerInfo[i][pRank] = 8; 
							SetPlayerInt(i, "Rank", PlayerInfo[i][pRank]); 
							CBackSkin(i);
							SendClientMessage(i, -1, ""COLOR_RED"Вы были понижены до 8 ранга в связи с назначением лидера");		
						}
						}
					}

					new LeaderAccountID = GetPlayerAccountID(chosen_leader);
					mysql_format(database, big_string, sizeof(big_string),
					"UPDATE `players` SET `Rank` = '8' WHERE `Rank` > '8' AND `Job` = '%i' AND `ID` != '%i'", ff, LeaderAccountID);
					mysql_pquery(database, big_string);

					PlayerInfo[chosen_leader][pStatus] = 0; SetPlayerInt(chosen_leader, "Status", PlayerInfo[chosen_leader][pStatus]); 
					PlayerInfo[chosen_leader][pRank] = 10; SetPlayerInt(chosen_leader, "Rank", PlayerInfo[chosen_leader][pRank]); 

					UpdateSpawnInfo(chosen_leader);
					CBackSkin(chosen_leader);
					for(new i = 0; i < MAX_FRACTION; i++) {
					if(Fraction[i][E_FRACTION_ID] == INVALID_FRACTION_ID) {
						continue;
					}

					if(Fraction[i][E_FRACTION_LEADER_ID] == GetPlayerAccountID(playerid)) {
						Player.Leader[playerid] = i;
						break;
					}
					}
					
					format(small_string, sizeof small_string, ""COLOR_BLUE"%s был назначен руководителем фракции %s", PlayerInfo[chosen_leader][pName], GetFractionTitle(fractionid));
					SendClientMessageToAll(-1, small_string);
					}
				}
			}
			return 1;
		}
