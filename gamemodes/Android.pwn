	mysql_pquery(database, Query, "", "");
	return true;
}

stock IsRpNickname(nickname[]) {

	if(strval(nickname) != 0) return 0;
	if(strfind(nickname, ".", true) != -1) return 0;
	if(strfind(nickname, "@", true) != -1) return 0;
	if(strfind(nickname, "(", true) != -1) return 0;
	if(strfind(nickname, ")", true) != -1) return 0;
	if(strfind(nickname, "=", true) != -1) return 0;
	if(strfind(nickname, "$", true) != -1) return 0;
	if(strfind(nickname, "[", true) != -1) return 0;
	if(strfind(nickname, "]", true) != -1) return 0;
	return regex_match(nickname, "[A-Z][a-z]+_[A-Z][a-z]+");
}

stock IsValidEmail(mail[]) {
	return regex_match(mail, "[a-zA-Z0-9_\\.]+@([a-zA-Z0-9\\-]+\\.)+[a-zA-Z]{2,4}");
}


stock RandomEx(one, two) {
	return (random(two - one) + one);
}
forward count_return(playerid);
public count_return(playerid) {
	if(gone[playerid] != -1) {
		new g[12];
		format(g, sizeof(g), "~r~%d", gone[playerid]);
		GameTextForPlayer(playerid, g, 1250, 4);
		gone[playerid]--;
		if(gone[playerid] == 0) {
			goneaway(playerid);
			gone[playerid] = -1;
			ReturnTimerID[playerid] = KillTimer(ReturnTimerID[playerid]);
			return 1;
		}
	}
	ReturnTimerID[playerid] = KillTimer(ReturnTimerID[playerid]);
	return ReturnTimerID[playerid] = SetTimerEx("count_return", 1000, false, "d", playerid);
}
public OnPlayerClickPlayer(playerid, clickedplayerid, source)
{
	if(GetPlayerAdminLevel(playerid) >= 1) {
		format(small_string, sizeof(small_string), "%i", clickedplayerid);
		callcmd::g(playerid, small_string);
	}
	return 1;
}
public OnPlayerClickPlayerTextDraw(playerid, PlayerText:playertextid) {
	if(playertextid == spec_PTD[playerid][2]) { // Update
		if(GetPlayerAdminLevel(playerid) < 1) return true;
		spec_update(playerid);
	}
	if(playertextid == spec_PTD[playerid][3]) { // Get Stats
		if(GetPlayerAdminLevel(playerid) < 1) return true;
		ShowStats(playerid,spectating[playerid]);
	}
	if(playertextid == spec_PTD[playerid][4]) { // Close
		if(GetPlayerAdminLevel(playerid) < 1) return true;
		StopSpectate(playerid);
	}			
	//
	if(playertextid == tuning_ui[playerid][0]) { // Update
		new dialog_tuning = GetPVarInt(playerid, "dialog_tuning");
		new dialog_status = GetPVarInt(playerid, "dialog_status");

		if(dialog_status == 555) {
			DeletePVar(playerid, "dialog_status");
			if(dialog_tuning == 1) return Dialog_Show(playerid, Dialog:tuning_menu);
			if(dialog_tuning == 2) return Dialog_Show(playerid, Dialog:elements);
			if(dialog_tuning == 3) return Dialog_Show(playerid, Dialog:elements_cat);
			if(dialog_tuning == 4) return Dialog_Show(playerid, Dialog:element_buy);
			if(dialog_tuning == 5) return Dialog_Show(playerid, Dialog:vynil);
			if(dialog_tuning == 6) return Dialog_Show(playerid, Dialog:vynil_buy);
			if(dialog_tuning == 7) return Dialog_Show(playerid, Dialog:paintjob);
			if(dialog_tuning == 8) return Dialog_Show(playerid, Dialog:paintjob_list);
			if(dialog_tuning == 8) return Dialog_Show(playerid, Dialog:paintjob_buy);
		} else {
			SetPVarInt(playerid, "dialog_status", 555);
			Dialog_Close(playerid);
			return ShowPlayerDialog(playerid, dKickMessage, DIALOG_STYLE_MSGBOX, ""COLOR_BLUE"Информация", ""COLOR_ORANGE"Чтобы вернуться к главному меню нажмите кнопку "COLOR_WHITE"MENU", "ОК", "");
		}
	}	
	if(playertextid == tuning_ui[playerid][1]) { // Update
		new view = GetPVarInt(playerid, "view");
		if(view == 3) view_customs(playerid, 0);
		if(view == 2) view_customs(playerid, 2);
		if(view == 1) view_customs(playerid, 1);
	}
	if(playertextid == tuning_ui[playerid][2]) { // Update
		printf("(id: %d) Нажатие Exit в тюнинге получено (part 1)", playerid);
		SetVehicleToRespawn(caridhouse[playerid]);
		printf("(id: %d) Нажатие Exit в тюнинге получено (part 2)", playerid);
		// SetPlayerScreenColour(playerid, 0x000000FF);
		printf("(id: %d) Нажатие Exit в тюнинге получено (part 3)", playerid);
		// FadePlayerScreenColour(playerid, 0x00000000, 5000, 25);
		printf("(id: %d) Нажатие Exit в тюнинге получено (part 4)", playerid);
		SetPlayerPos(playerid, 1034.0261,-1460.2059,13.3655);
		printf("(id: %d) Нажатие Exit в тюнинге получено (part 5)", playerid);
		SetPlayerVirtualWorld(playerid, 0);
		printf("(id: %d) Нажатие Exit в тюнинге получено (part 6)", playerid);
		SetPlayerInterior(playerid, 0);
		printf("(id: %d) Нажатие Exit в тюнинге получено (part 7)", playerid);
		SetVehiclePos(caridhouse[playerid], 1034.0261,-1460.2059,13.3655);
		printf("(id: %d) Нажатие Exit в тюнинге получено (part 8)", playerid);
		LinkVehicleToInterior(caridhouse[playerid], 0);
		SetVehicleVirtualWorld(caridhouse[playerid], 0);
		printf("(id: %d) Нажатие Exit в тюнинге получено (part 9)", playerid);
		TogglePlayerSpectating(playerid, 0);
		printf("(id: %d) Нажатие Exit в тюнинге получено (part 10)", playerid);
		PutPlayerInVehicle(playerid, caridhouse[playerid], 0);
		printf("(id: %d) Нажатие Exit в тюнинге получено (part 11)", playerid);
		SetCameraBehindPlayer(playerid);
		printf("(id: %d) Нажатие Exit в тюнинге получено (part 12)", playerid);
		DeletePVar(playerid, "dialog_tuning");
		printf("(id: %d) Нажатие Exit в тюнинге получено (part 13)", playerid);
		SendClientMessage(playerid, -1, ""COLOR_YELLOW"Вы покинули тюнинг-ателье");
		printf("(id: %d) Нажатие Exit в тюнинге получено (part 14)", playerid);
		hide_tuning(playerid);
		Dialog_Close(playerid);



		if(PlayerInfo[playerid][pSelectedSlot] == 1) {
			ChangeVehicleColor(caridhouse[playerid], PlayerInfo[playerid][pCarCol], PlayerInfo[playerid][pCarCol2]);
		} else {
			ChangeVehicleColor(caridhouse[playerid], PlayerInfo[playerid][pCar2Col], PlayerInfo[playerid][pCar2Col2]);	
		}

		
		ShowPlayerDialog(playerid, dKickMessage, DIALOG_STYLE_MSGBOX, ""COLOR_BLUE"Механик мастерской", ""COLOR_WHITE"Хорошей дороги, заезжайте еще!", "Спасибо", "");
		SetVehicleZAngle(GetPlayerVehicleID(playerid), 85.0);
	}		
	return 1;
}
forward PlayerUpdate(playerid);
public PlayerUpdate(playerid) {
	if(PlayerLogged{playerid} == false) {
		if(GetPlayerVirtualWorld(playerid) != 333+playerid && GetPlayerState(playerid) != PLAYER_STATE_SPECTATING) ImmediateKick(playerid);
	}	

	if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT && PlayerInfo[playerid][pScore] >= 100000 && GetPlayerWeapon(playerid) == 0) {
		if(GetPVarInt(playerid, "casehere") == 0) {
			SetPVarInt(playerid, "casehere", 1);
			SetPlayerAttachedObject(playerid,3,1210,5,0.299999,0.099999,0.000000,0.000000,-83.000000,0.000000,1.000000,1.000000,1.000000); 
		}
	} else {
		if(GetPVarInt(playerid, "casehere")) {
			RemovePlayerAttachedObject(playerid, 3);
			DeletePVar(playerid, "casehere");
		}
	}
	// Streamer_Update(playerid, STREAMER_TYPE_3D_TEXT_LABEL);
	// Streamer_Update(playerid, STREAMER_TYPE_MAP_ICON);
	// Streamer_Update(playerid, STREAMER_TYPE_OBJECT);

	new taxi = GetPVarInt(playerid, "taxi_called");
	if(taxi < 91 && taxi >= 2) {
		SetPVarInt(playerid, "taxi_called", taxi-1);
		if(taxi == 1) {

			DeletePVar(playerid, "taxi_called");
			SendClientMessage(playerid, -1, ""COLOR_ORANGE"Ни один таксист не откликнулся на ваш заказ");
		}
	}
	new animation_index = GetPlayerAnimationIndex(playerid);
	if((animation_index == 159 || animation_index == 157 || animation_index == 161) && IsABMX(GetPlayerVehicleID(playerid)) == 0)
	{
		SendClientMessage(playerid, -1, "Вы были кикнуты по подозрению в читерстве");
		return Kick(playerid);
	}
	if(GetPVarInt(playerid, "oncapture") > 0) {
		new ccounter = GetPVarInt(playerid, "oncapture");
		ccounter -= 1;
		SetPVarInt(playerid, "oncapture", ccounter);
		if(ccounter <= 0) {
			DeletePVar(playerid, "oncapture");
			DeletePVar(playerid, "opponent");
		}
	}
	if(PlayerLogged{playerid} == false || !IsPlayerConnected(playerid)) {
		if(GetPlayerVirtualWorld(playerid) != playerid+333) SetPlayerVirtualWorld(playerid, playerid+333);
		goto skip_all;
	}
	pl_afk_time[playerid] ++;


	if(GetPVarInt(playerid, "Fix_Spawn_Register") == 1) {
		new 
			Float: pos_x,
			Float: pos_y,
			Float: pos_z;

		GetPlayerPos(playerid, pos_x, pos_y, pos_z);

		if(pos_z < 1900) {
			SetPlayerPos(playerid, 1685.8025,-2332.4546,-2.6797);
			SetPlayerInterior(playerid, 0);
			SetPlayerVirtualWorld(playerid, 0);
			SetPlayerFacingAngle(playerid, 0);
			SetCameraBehindPlayer(playerid);
			DeletePVar(playerid, "Fix_Spawn_Register");
		}

	}

	if(pl_afk_time[playerid] < 4) {
		PlayerInfo[playerid][pOnline]++;
		if(PlayerInfo[playerid][pOnline] >= 3600) { Salary(playerid); }
		// HUNGER
		if(PlayerInfo[playerid][pHours] > 2) {
			if(PlayerInfo[playerid][pHunger] > 95) {
					new Float:hunger_health;

					GetPlayerHealth(playerid, hunger_health);

					if(hunger_health > 98) {
						SetPlayerHealth(playerid, 100.0); 
					} else {
					SetPlayerHealth(playerid, hunger_health+3);	
					}	
			}
			new hunger_definition = GetPVarInt(playerid, "player_hunger");
			SetPVarInt(playerid, "player_hunger", hunger_definition+1);
			if(hunger_definition >= 60) {

				SetPVarInt(playerid, "player_hunger", 0);

				if(PlayerInfo[playerid][pHunger] > 0) {
					if(GetPlayerAdminLevel(playerid) < 6) PlayerInfo[playerid][pHunger] -= 1;
					SetPlayerInt(playerid, "Hunger", PlayerInfo[playerid][pHunger]);
				} else {
					new Float:hunger_health;
					GetPlayerHealth(playerid, hunger_health);
					SetPlayerHealth(playerid, hunger_health-3);
					new random_text = Random(0,6);
					if(random_text == 0) SendClientMessage(playerid, -1, ""COLOR_RED"Вы проголодались, вам необходимо перекусить");
					//GameTextForPlayer(playerid, "~n~~n~~n~~n~~n~~n~~n~~n~~r~HUNGER!", 3500, 6);
				}
			}
		}
		// HUNGER
	}
	else {
		if(GetPVarInt(playerid,!"OffFrisk") > gettime()) {
		if(GetPVarInt(playerid, "punishf") != 1) {
			DeletePVar(playerid, "OffFrisk"); SetPVarInt(playerid, "punishf", 1);
			if(PlayerInfo[playerid][pJailed] == 0) {
				PlayerInfo[playerid][pJailTime] = 3600;
				PlayerInfo[playerid][pJailed] = 1;
				SetPlayerInt(playerid, "Jailed", PlayerInfo[playerid][pJailed]);
				SetPlayerInt(playerid, "JailTime", PlayerInfo[playerid][pJailTime]);
				PlayerInfo[playerid][pWanted] = 0;
				SetPlayerWanted(playerid, 0);
				SetPlayerInt(playerid, "Wanted", 0);
				PlayerInfo[playerid][pPetard] = 0;
				PlayerInfo[playerid][pGrenade] = 0;
				PlayerInfo[playerid][pDynamite] = 0;
				SetPlayerInt(playerid, "Petard", PlayerInfo[playerid][pPetard]);
				SetPlayerInt(playerid, "Grenade", PlayerInfo[playerid][pGrenade]);
				SetPlayerInt(playerid, "Dynamite", PlayerInfo[playerid][pDynamite]);
				PlayerInfo[playerid][pDrugs] = 0;
				PlayerInfo[playerid][pDrugsSell] = 0;
				PlayerInfo[playerid][pStuff] = 0;
				SetPlayerInt(playerid, "Drugs", PlayerInfo[playerid][pDrugs]);
				SetPlayerInt(playerid, "DrugsSell", PlayerInfo[playerid][pDrugsSell]);
				SetPlayerInt(playerid, "Stuff", PlayerInfo[playerid][pStuff]);
				new chat[144];
				format(chat, sizeof(chat), ""COLOR_RED"Игрок %s вышел при обыске и был отправлен в тюрьму", PlayerInfo[playerid][pName]);
				SendClientMessageToAll(-1, chat);
			}
		}
		}
		if(GetPVarInt(playerid,!"OffArrest") > gettime() || GetPVarType(playerid, !"cuffed") == PLAYER_VARTYPE_INT) {
		if(GetPVarInt(playerid, "punish") != 1) {
			DeletePVar(playerid, "OffArrest"); SetPVarInt(playerid, "punish", 1);
			if(PlayerInfo[playerid][pJailed] == 0) {
				PlayerInfo[playerid][pJailTime] = PlayerInfo[playerid][pWanted];
				PlayerInfo[playerid][pJailed] = 1;
				SetPlayerInt(playerid, "Jailed", PlayerInfo[playerid][pJailed]);
				SetPlayerInt(playerid, "JailTime", PlayerInfo[playerid][pJailTime]);
				PlayerInfo[playerid][pWanted] = 0;
				SetPlayerWanted(playerid, 0);
				SetPlayerInt(playerid, "Wanted", 0);
				new chat[144];
				format(chat, sizeof(chat), ""COLOR_RED"Игрок %s вышел в AFK при задержании и был отправлен в тюрьму", PlayerInfo[playerid][pName]);
				SendClientMessageToAll(-1, chat);
			}
		}
	}
	}


	if(player_Patrol[playerid] != -1) {
	new inactive_patrol = GetPVarInt(playerid, "inactive_patrol");
	inactive_patrol --;
	SetPVarInt(playerid, "inactive_patrol", inactive_patrol);
	if(inactive_patrol <= 0) {
		OnLeavePatrol(playerid, 2);
	}
	}

	new MinusTime = GetPVarInt(playerid, "MinusTime");
	MinusTime --;
	if(MinusTime >= 0) {
		format(small_string, sizeof(small_string), "~g~~h~ TIME %s", Convert(MinusTime));
		GameTextForPlayer(playerid, small_string, 1500, 4);
		SetPVarInt(playerid, "MinusTime", MinusTime);
	}


	new DDTime = GetPVarInt(playerid, "DDTime");
	DDTime --;
	if(DDTime >= 0) {
		SetPlayerColor(playerid, RainBow[random(sizeof(RainBow))]);
		if(DDTime == 0) CBackSkin(playerid);
		format(small_string, sizeof(small_string), "~r~~h~ Double Damage %s", Convert(DDTime));
		GameTextForPlayer(playerid, small_string, 1500, 4);
		SetPVarInt(playerid, "DDTime", DDTime);
	}

	if(RouteAir[playerid] > 4) {
	new small_c[90];
	new Float: fDistance = GetPlayerDistanceFromPoint(playerid, 1922.8334,-2249.4912,13.1084);
	format(small_c, sizeof(small_c), "~b~TO DESTINATION: ~w~%.0f M.", fDistance);
	GameTextForPlayer(playerid, small_c, 5000, 4);
	}
	if(RouteAir2[playerid] > 3) {
	new small_c[90];
	new Float: fDistance = GetPlayerDistanceFromPoint(playerid, 1609.3046,1634.0345,10.3938);
	format(small_c, sizeof(small_c), "~b~TO DESTINATION: ~w~%.0f M.", fDistance);
	GameTextForPlayer(playerid, small_c, 5000, 4);
	}

	if(GetPlayerAdminLevel(playerid) > 0) {
		if(spectating[playerid] != -1 && GetPlayerState(playerid) == PLAYER_STATE_SPECTATING) spec_update(playerid);
	}

	if(PlayerInfo[playerid][pJailed] == 2)
	{
		ResetPlayerWeapons(playerid);
		if(PlayerInfo[playerid][pWanted] > 0) {
			PlayerInfo[playerid][pWanted] = 0;
			SetPlayerWanted(playerid, PlayerInfo[playerid][pWanted]);
		}

		if(!IsPlayerInRangeOfPoint(playerid, 55.0, -8718.3047,1702.0928,10.2857)) {
			RemovePlayerFromVehicle(playerid);
			new zpizdok = RandomEx(15,20);
			SetPlayerPos(playerid, -8718.3047,1702.0928,zpizdok);
			SetPlayerVirtualWorld(playerid, 50);
			SetPlayerInterior(playerid, 5);
		}
		PlayerInfo[playerid][pJailTime] = PlayerInfo[playerid][pJailTime]-1;
		new small_update_string[144];
		format(small_update_string, sizeof(small_update_string), "~y~JAIL TIME: ~w~%s", Convert(PlayerInfo[playerid][pJailTime]));
		GameTextForPlayer(playerid, small_update_string, 1100, 5);
		if(PlayerInfo[playerid][pJailTime] < 1)
		{
			SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы заплатили свой долг обществу, теперь вы свободны");
			PlayerInfo[playerid][pJailTime] = 0;
			PlayerInfo[playerid][pJailed] = 0;
			SetPlayerInt(playerid, "Jailed", PlayerInfo[playerid][pJailed]);
			SetPlayerInt(playerid, "JailTime", PlayerInfo[playerid][pJailTime]);
			UpdateSpawnInfo(playerid);
			SetPlayerInterior(playerid, 0);
			SetPlayerVirtualWorld(playerid, 0);
			SetPlayerFacingAngle(playerid, 260.0);
			SpawnPlayer(playerid);
		}
		if(PlayerInfo[playerid][pJailTime] % 60 == 0) {
			SetPlayerInt(playerid, "JailTime", PlayerInfo[playerid][pJailTime]);
		}
	}


	if(PlayerInfo[playerid][pJailed] == 1)
	{
		ResetPlayerWeapons(playerid);
		if(PlayerInfo[playerid][pWanted] > 0) {
			PlayerInfo[playerid][pWanted] = 0;
			SetPlayerWanted(playerid, PlayerInfo[playerid][pWanted]);
		}
		/*if(PlayerInfo[playerid][pWanted] % 60 == 0 || PlayerInfo[playerid][pWanted] == 0) {
			SetPlayerInt(playerid, "Wanted", PlayerInfo[playerid][pWanted]);
		}*/
		if(!GetPVarInt(playerid, "jailgot")) randomed_jail(playerid);
		if(!IsPlayerInRangeOfPoint(playerid, 10.0, GetPVarFloat(playerid, "jail_x"),GetPVarFloat(playerid, "jail_y"),GetPVarFloat(playerid, "jail_z"))) {
			RemovePlayerFromVehicle(playerid);
			SetPlayerPos(playerid, GetPVarFloat(playerid, "jail_x"),GetPVarFloat(playerid, "jail_y"),GetPVarFloat(playerid, "jail_z"));
			SetPlayerVirtualWorld(playerid, 50);
			SetPlayerInterior(playerid, 5);
		}
		PlayerInfo[playerid][pJailTime] = PlayerInfo[playerid][pJailTime]-1;
		new small_update_string[144];
		format(small_update_string, sizeof(small_update_string), "~y~JAIL TIME: ~w~%s", Convert(PlayerInfo[playerid][pJailTime]));
		GameTextForPlayer(playerid, small_update_string, 1100, 5);
		if(PlayerInfo[playerid][pJailTime] < 1)
		{
			if(PlayerInfo[playerid][pJailed] == 1) SetPlayerPos(playerid, 1801.3871,-1578.9026,14.0698);
			SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы заплатили свой долг обществу, теперь вы свободны");
			PlayerInfo[playerid][pJailTime] = 0;
			PlayerInfo[playerid][pJailed] = 0;
			SetPlayerInt(playerid, "Jailed", PlayerInfo[playerid][pJailed]);
			SetPlayerInt(playerid, "JailTime", PlayerInfo[playerid][pJailTime]);
			UpdateSpawnInfo(playerid);
			SetPlayerInterior(playerid, 0);
			SetPlayerVirtualWorld(playerid, 0);
		}
		if(PlayerInfo[playerid][pJailTime] % 60 == 0) {
			SetPlayerInt(playerid, "JailTime", PlayerInfo[playerid][pJailTime]);
		}
	}


	if(LawTimer[playerid] > 0) {
		LawTimer[playerid]--;
		if(LawTimer[playerid] == 0) {
			Law(playerid);
		}
	}
	if(PlayerInfo[playerid][pWanted] > 0) {
		PlayerInfo[playerid][pWanted]--;
		//SetPlayerInt(playerid, "Wanted", PlayerInfo[playerid][pWanted]);
	}
	if(ThefStatus[playerid] > 0) {
		if(TimeTCar[playerid] < 1) {
			if(PlayerInfo[playerid][pTheftSkill] != 0) {
			PlayerInfo[playerid][pTheftSkill] -= 1;
			SetPlayerInt(playerid, "TheftSkill", PlayerInfo[playerid][pTheftSkill]);
			}
			ThefStatus[playerid] = 0;
			TCar[playerid] = 0;
			GangZoneDestroy(TheftZone[playerid]);
			if(Player.SteelCar[playerid] != INVALID_DYNAMIC_CP) {
				DestroyDynamicCP(Player.SteelCar[playerid]);
				Player.SteelCar[playerid] = INVALID_DYNAMIC_CP;
			}
			goto skip_all;
		}
		TimeTCar[playerid]--;
		new small_update_string[144];
		format(small_update_string, sizeof(small_update_string), "~w~THEFT AUTO: ~y~%s", Convert(TimeTCar[playerid]));
		GameTextForPlayer(playerid, small_update_string, 1300, 4);
	}


	if(PlayerInfo[playerid][pMuted] > 0 )
	{
		PlayerInfo[playerid][pMuteTime]--;
		if(PlayerInfo[playerid][pMuteTime] < 1)
		{
			SendClientMessage(playerid, -1, ""COLOR_GREEN"Чат разблокирован. Просим вас не нарушать правила!");
			PlayerInfo[playerid][pMuteTime] = 0;
			PlayerInfo[playerid][pMuted] = 0;
			SetPlayerInt(playerid, "Muted", PlayerInfo[playerid][pMuted]);
			SetPlayerInt(playerid, "MuteTime", PlayerInfo[playerid][pMuteTime]);
		}
		if(PlayerInfo[playerid][pMuteTime] % 60 == 0) {
			SetPlayerInt(playerid, "MuteTime", PlayerInfo[playerid][pMuteTime]);
		}
	}
	if(porter_state[playerid] == 2) {
		ApplyAnimation(playerid, !"CARRY", !"crry_prtial", 4.0, 1, 0, 0, 1, 1, 1);
	}
	skip_all:
	PlayerTimerID[playerid] = KillTimer(PlayerTimerID[playerid]);
	return PlayerTimerID[playerid] = SetTimerEx("PlayerUpdate", 1000, false, "d", playerid);
}

Convert(number)
{
	new hours = 0, mins = 0, secs = 0, string[100];
	hours = floatround(number / 3600);
	mins = floatround((number / 60) - (hours * 60));
	secs = floatround(number - ((hours * 3600) + (mins * 60)));
	if(hours > 0)
	{
		format(string, 100, "%i:%02d:%02d", hours, mins, secs);
	}
	else
	{
		format(string, 100, "%i:%02d", mins, secs);
	}
	return string;
}

CMD:gmap(playerid) {
	if(!IsACrime(playerid)) return 1;
	new ownlands;
	new gangid = GetPlayerFractionInt(playerid);
	for(new i = 0; i <= total_gangzones; i++) {
		if(gz_info[i][gz_owner] == gangid) ownlands++;
	}
	format(small_string, sizeof(small_string), "Всего #%d территорий под контролем %s", ownlands, GetGangName(gangid));
	SendClientMessage(playerid, -1, small_string);	
	return 1;
}

CMD:gzn(playerid) {
	if(PlayerInGangZone(playerid, 1460, -2788, 3000, -872)) {
		for(new x = 0; x <= 99; x++) {
			if(PlayerInGangZone(playerid, gz_ls[x][min_x], gz_ls[x][min_y], gz_ls[x][max_x], gz_ls[x][max_y])) {
				format(small_string, sizeof(small_string), "Территория #%d под контролем %s", x, GetGangName(gz_info[x][gz_owner]));
				SendClientMessage(playerid, -1, small_string);
			}
		}
	}
	if(PlayerInGangZone(playerid, -3000, -727.5, -1228, 1588.5)) {
		for(new i = 0; i <= 119; i++) {
			if(PlayerInGangZone(playerid, gz_sf[i][min_x], gz_sf[i][min_y], gz_sf[i][max_x], gz_sf[i][max_y])) {
				format(small_string, sizeof(small_string), "Территория #%d  %f %f %f %f под контролем %s", i+100, gz_sf[i][min_x], gz_sf[i][min_y], gz_sf[i][max_x], gz_sf[i][max_y], GetGangName(gz_info[i+100][gz_owner]));
				SendClientMessage(playerid, -1, small_string);
			}
		}
	}
	return 1;
}

CMD:gzcolor(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) < 5) return 1;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, -1, "Введите: /gzcolor [id фракции]");
	if(params[0] < 2 || params[0] > 9) return SendClientMessage(playerid, -1, "(( ID: 2: Grove, 3: Ballas, 4: Bagos, 5: Rifa, 6: Aztec, 7-9: Мафии ))");
	if(params[0] >= 2 && params[0] <= 6) {
		for(new i = 0; i <= 99; i++)
		{
			if(PlayerInGangZone(playerid, gz_ls[i][min_x], gz_ls[i][min_y], gz_ls[i][max_x], gz_ls[i][max_y]))
			{
				gz_info[i][gz_owner] = params[0];
				GangZoneStopFlashForAll(gz_info[i][zone]);
				GangZoneHideForAll(gz_info[i][zone]);
				GangZoneShowForAll(gz_info[i][zone], GangZoneColor(gz_info[i][gz_owner]));
				SaveGZ(i);
				UpdateGangEmblem(params[0]);

				static const
					fmt_str0[] = ""COLOR_ORANGE"[A] Администратор %s покрасил территорию %d в цвет %s";
				new
					str[sizeof(fmt_str0) - 2 + MAX_PLAYER_NAME - 2 + 4 - 2 + MAX_PLAYER_NAME - 2 + 4 - 2 + 11];
				format(str, sizeof(str), fmt_str0, PlayerInfo[playerid][pName], i, GetGangName(params[0]));
				SendAdminMessage(-1, str);
				return true;
			}
		}
	}
	if(params[0] >= 7 && params[0] <= 9) {
		for(new i = 0; i <= 119; i++)
		{
			if(PlayerInGangZone(playerid, gz_sf[i][min_x], gz_sf[i][min_y], gz_sf[i][max_x], gz_sf[i][max_y]))
			{
				gz_info[i+100][gz_owner] = params[0];
				GangZoneStopFlashForAll(gz_info[i+100][zone]);
				GangZoneHideForAll(gz_info[i+100][zone]);
				GangZoneShowForAll(gz_info[i+100][zone], GangZoneColor(gz_info[i+100][gz_owner]));
				SaveGZ(i+100);
				UpdateGangEmblem(params[0]);

				static const
					fmt_str0[] = ""COLOR_ORANGE"[A] Администратор %s покрасил территорию %d в цвет %s";
				new
					str[sizeof(fmt_str0) - 2 + MAX_PLAYER_NAME - 2 + 4 - 2 + MAX_PLAYER_NAME - 2 + 4 - 2 + 11];
				format(str, sizeof(str), fmt_str0, PlayerInfo[playerid][pName], i+100, GetGangName(params[0]));
				SendAdminMessage(-1, str);
				return true;
			}
		}	
	}
	return true;
}
stock ReloadFarmText() {
	format(h00, sizeof(h00), ""COLOR_BLUE"Загружено:\n {FFFFFF}%d/200", Harvest[0]);
	Update3DTextLabelText(farmtext, 0xFFFFFFFF, h00);
	format(h01, sizeof(h01), ""COLOR_BLUE"Загружено:\n {FFFFFF}%d/200", Harvest[1]);
	Update3DTextLabelText(farmtext1, 0xFFFFFFFF, h01);
	format(h02, sizeof(h02), ""COLOR_BLUE"Загружено:\n {FFFFFF}%d/200", Harvest[2]);
	Update3DTextLabelText(farmtext2, 0xFFFFFFFF, h02);
	return 1;
}

new message_type = 0;
forward InfoMessage();
public InfoMessage() {
	if(message_type == 0) {
		SendClientMessageToAll(-1, "(i) "COLOR_RED"Не передавай данные от своего аккаунта третьим лицам.");
		SendClientMessageToAll(-1, "(i) "COLOR_RED"В противном случае, ты можешь потерять свой аккаунт навсегда!");
		message_type = 1;
	} else if(message_type == 1) {
		SendClientMessageToAll(-1, "(i) "COLOR_ORANGE"Появились вопросы по игровому процессу? Не знаешь где находится нужное место? ...");
		SendClientMessageToAll(-1, "(i) "COLOR_ORANGE"или как можно заработать игровую валюту? Задай вопрос помощникам и они ...");
		SendClientMessageToAll(-1, "(i) "COLOR_ORANGE"с радостью придут к тебе на помощь! (/ask [ваш вопрос])");
		message_type = 2;
	} else if(message_type == 2) {
		foreach(new i: Player)
		{	
			SendClientMessage(i, -1, "(i) "COLOR_BLUE"Хочешь стать частью нашей команды? Узнай как это сделать на нашем форуме");
			if(GetPVarInt(i, "mobile")) {
				SendClientMessage(i, -1, "(i) "COLOR_BLUE"/forum => Поддержка => Команда Chance RolePlay => Оставить анкету на собеседование");
			} else {
				SendClientMessage(i, -1, "(i) "COLOR_BLUE"talk.chancerp.ru => Поддержка => Команда Chance RolePlay => Оставить анкету на собеседование");
			}	
		}
		message_type = 3;
	} else if(message_type == 3) {
		foreach(new i: Player)
		{	
			if(GetPVarInt(i, "mobile")) {
				SendClientMessage(i, -1, "(i) "COLOR_BLUE"Не хватает EXP? Воспользуйся {FFFFFF}/donate!");
			} else {
				SendClientMessage(i, -1, "(i) "COLOR_BLUE"Не хватает EXP? Пополни свой счет на {FFFFFF}ChanceRp.Ru/donate");
			}	
			SendClientMessage(i,-1, "(i) "COLOR_BLUE"В личном кабинете на сайте можно испытать свою удачу в рулетке!");
			SendClientMessage(i,-1, "(i) "COLOR_BLUE"Ты можешь выйграть EXP, различный транспорт и скины");
			SendClientMessage(i,-1, "(i) "COLOR_BLUE"Каждая 10 прокрутка рулетки совершенно бесплатна!");			
		}
		message_type = 4;
	} else if(message_type == 4) {
		foreach(new i: Player)
		{	
			SendClientMessage(i,-1, "(i) "COLOR_BLUE"Присоединяйтесь к нашему Discord каналу для общения!");			
			if(GetPVarInt(i, "mobile")) {
				SendClientMessage(i, -1, "(i) "COLOR_BLUE"Получить приглашение в Discord канал: {FFFFFF}/discord");
			} else {
				SendClientMessage(i, -1, "(i) "COLOR_BLUE"Приглашение доступно по адресу: {FFFFFF}ChanceRp.Ru/discord");
			}	
		}
		message_type = 5;
	} else if(message_type == 5) {
		foreach(new i: Player)
		{	
			SendClientMessage(i,-1, "(i) "COLOR_BLUE"Если вы увидели нарушителя сообщите на форум в раздел {FFFFFF}'Жалобы'");	
			SendClientMessage(i,-1, "(i) "COLOR_BLUE"Администрация проверит жалобу и нарушитель будет наказан!");			
			if(GetPVarInt(i, "mobile")) {
				SendClientMessage(i, -1, "(i) "COLOR_BLUE"Перейти на форум проекта: {FFFFFF}/forum");
			} else {
				SendClientMessage(i, -1, "(i) "COLOR_BLUE"Форум доступен по адресу: {FFFFFF}talk.chancerp.ru");
			}

		}
		message_type = 6;
	} else if(message_type == 6) {
		SendClientMessageToAll(-1, "(i) "COLOR_BLUE"Вы играете на сервере {FFFFFF}Chance RolePlay");
		format(small_string, sizeof(small_string), "(i) "COLOR_BLUE"Текущий онлайн: {FFFFFF}%d игроков", Iter_Count(Player));
		SendClientMessageToAll(-1, small_string);
		message_type = 7;
	} else if(message_type == 7) {
		SendClientMessageToAll(-1, "(i) "COLOR_BLUE"Нужно что-то продать или купить? Используйте: {FFFFFF}/adv");
		SendClientMessageToAll(-1, "(i) "COLOR_BLUE"Сотрудники San News опубликуют объявление и его увидят все");
		message_type = 8;
	} else if(message_type == 8) {
		SendClientMessageToAll(-1, "(i) "COLOR_BLUE"Нужна помощь? Есть вопросы по серверу?");
		SendClientMessageToAll(-1, "(i) "COLOR_BLUE"Техническая поддержка: {FFFFFF}vk.com/chance_help");
		message_type = 0;
	}
}

forward bad_weather();
public bad_weather() {
	weather = RandomEx(0,8);
	if(weather == 8) {
		weather = RandomEx(10,12);
	}
}

stock PayDay() {

	if(gangwar_delay_gang != 0) gangwar_delay_gang = 0;
	if(gangwar_delay_mafia != 0) gangwar_delay_mafia = 0;	

	PayDDoS = false;

	printf("New_Day");

	BusinessIncome();
	if(newweather == -1) {
		weather = RandomEx(0,20);
	} else {
		weather = newweather;
		newweather = -1;
	}
	switch(weather) {
		case 8..9: SetTimer("bad_weather", 1000*60*5, false);
		case 12..20: SetTimer("bad_weather", 1000*60*5, false);
	}

	newweather = RandomEx(0,20);

	format(small_string, sizeof(small_string), "%d:00", hour);

	GameTextForAll(small_string, 5000, 0);

	foreach(new i: Player)
	{

	if(hour == 12) {
		if(PlayerInfo[i][pDebt] < 1000 && PlayerInfo[i][pHours] > 12) {
			if(PlayerInfo[i][pBank] < 150000) {
				new percent = PlayerInfo[i][pBank]/100;
				AddPlayerBankEXP(i, percent, "Начисление процента на банковский счет");
			}
		}
	}

	format(small_string, sizeof(small_string), ""COLOR_ORANGE"Вам осталось до зарплаты: "COLOR_WHITE"%s\n",Convert(3600-PlayerInfo[i][pOnline]));
	SendClientMessage(i, -1, small_string);
	}

	SetWorldTime(hour);
	orders = RandomEx(10,30);
	forecast = -1;
}

forward UpdateTimers();
public UpdateTimers() {

	if((minute % 15) == 0 && seconds == 0) {

		new factor_spawn;
		foreach(new i: Player) {
			if(IsPlayerInDynamicArea(i, Main_Beach)) {
				SendClientMessage(i, -1, ""COLOR_ORANGE"(Работа - Уборщик пляжа) "COLOR_WHITE"Мусор обновлен");
			}
		}
		for(new i = 0; i < MAX_ECO; i++) {

			factor_spawn = random(1);

			if(TrashObjects[i][spawned] == 0 && factor_spawn == 0) {
				TrashObjects[i][spawned] = 1;

				if(IsValidDynamicObject(TrashObjects[i][trash_obj])) DestroyDynamicObject(TrashObjects[i][trash_obj]);
				TrashObjects[i][trash_obj] = CreateDynamicObject(TrashObjects[i][trash_obj_id],
					TrashObjects[i][trash_x],  
			        TrashObjects[i][trash_y],
			        TrashObjects[i][trash_z], 
					TrashObjects[i][trash_x2],  
			        TrashObjects[i][trash_y2],
			        TrashObjects[i][trash_z2], 0, 0, -1, 75.0, 75.0);

			}
		}

	}
	
	gettime(hour, minute, seconds);

	if(minute == 58 && PayDDoS == false) {
		PayDDoS = true;
	}

	if(!minute && PayDDoS == true && test_server == false && AutoHouseSell == true)
	{
		PayDay();
	}

	if(army_door_timeout > 0) army_door_timeout--;
	if(test_server == false) {
		if(minute == 50 && hour == 4 && ralert == true)
		{

			SendRconCommand("hostname "SERVER_HOSTNAME_A1"");	

			ralert = false;
			SendClientMessageToAll(-1, ""COLOR_RED"Запланированный рестарт сервера через {FFFFFF}5 минут");
			SendClientMessageToAll(-1, ""COLOR_RED"Завершите ваши дела/работу на время обслуживания сервера!");

			foreach(new i: Player) {
				GameTextForPlayer(i, "~b~Server restart in ~w~5 minutes!", 3000, 0);
			}

		}
		if(minute == 55 && hour == 4 && AutoHouseSell == true)
		{
			AutoHouseSell = false;
			print("autohousesell = false");

			SendClientMessageToAll(-1, ""COLOR_RED"Запланированный рестарт запущен и займет примерно {FFFFFF}5 минут");
			SendClientMessageToAll(-1, "(i) "COLOR_BLUE"Рестарты нужны чтобы поддерживать стабильную работу сервера");
			SendClientMessageToAll(-1, "(i) "COLOR_BLUE"Обслуживание производится ежедневно c 4:55 по 5:00 (MSK)");			

			foreach(new i: Player) {
				GameTextForPlayer(i, "~b~Server under maintenance~n~~w~Just wait...", 15000, 0);
				Kick(i);
			}

			CallLocalFunction("OnServerRestart", "");
			SendRconCommand("hostname "SERVER_HOSTNAME_A2"");
			SendRconCommand("password ServerRestartWait");

			mysql_pquery(database, "UPDATE players SET TransferControl = 0");
			mysql_pquery(database, "UPDATE players SET TransferControl2 = 0");
			mysql_pquery(database, "UPDATE players SET PayDayBonus = 0");
			mysql_pquery(database, "UPDATE `players` SET `RankGot` = '5' WHERE `Rank` = '10'");
			mysql_pquery(database, "UPDATE `players` SET `UpRank` = '0'");
			mysql_pquery(database, "UPDATE `players` SET `GotBonus` = '0'");
			mysql_pquery(database, "TRUNCATE banned_ip");

			for(new i = 1; i <= TOTALHOUSE; i++)
			{
				if(HouseInfo[i][hOwned] == 1 && strcmp("The State", HouseInfo[i][hOwner], true))
				{
					HouseInfo[i][hTakings] -= 1;
					SetHouseInt(i, "Takings", HouseInfo[i][hTakings]);
					if(HouseInfo[i][hTakings] <= 0)
					{
						HouseInfo[i][hOwned] = 0;
						//BuyHouse(i);
						new MySQL[256];
						mysql_format(database,
							MySQL, sizeof(MySQL),
							"UPDATE `apartment` SET Owner = 'The State', Owned = 0, Takings = 0 WHERE ID = '%i' LIMIT 1",
								HouseInfo[i][hID]
						);
						mysql_pquery(database, MySQL);
					}
				}
			}
			for(new i = 0; i < MAX_HOTEL_ROOM; i++) {
				if(Hotel.Room[i][E_HOTEL_ROOM_OWNER_ID] != INVALID_ACCOUNT_ID) {
					Hotel.DownRentDay(i);
				}
			}
			for(new i = 0; i < MAX_BUSINESS; i++) {
				BusinessInfo[i][Taxes] -= 1;
				SetBusinessInt( "Taxes", BusinessInfo[i][Taxes], i);
				
				if(BusinessInfo[i][Taxes] < 1) {

					BusinessInfo[i][OwnerID] = INVALID_ACCOUNT_ID;
					SetBusinessInt("OwnerID", BusinessInfo[i][OwnerID], i);

					BusinessInfo[i][Income] = 0;
					SetBusinessInt( "Income", BusinessInfo[i][Income], i);		

					BusinessInfo[i][Taxes] = 0;
					SetBusinessInt( "Taxes", BusinessInfo[i][Taxes], i);	

				}
			}
		}

		if(minute == 58 && hour == 4 && KDReset == true) {
			KDReset = false;
			print("kdreset = false");

			mysql_query(database, "SELECT DAYNAME(CURRENT_TIMESTAMP()) as Day", true);

			new
				day_name[30];

			cache_get_field_content(0, "Day", day_name, database, 30);

			if(strcmp(day_name, "Saturday") == 0) {
				mysql_pquery(database, "UPDATE `player_admin` SET `KD_Week` = 0");
				mysql_pquery(database, "UPDATE `player_helper` SET `KD_Week` = 0");
			}

			getdate(_, month, day);

			if(day == 1) {
				mysql_pquery(database, "UPDATE `player_admin` SET `KD_Month` = 0");
				mysql_pquery(database, "UPDATE `player_helper` SET `KD_Month` = 0");
			}

		}
		if(minute == 0 && hour == 5 && KDReset == false && AutoHouseSell == false)
		{
			SendRconCommand("gmx");
		}
	}

	for(new i = 0; i < MAX_BUSINESS; i++) {
		if(BusinessInfo[i][Rob] == 0) continue;
		if(BusinessInfo[i][Rob] > 0) BusinessInfo[i][Rob] = BusinessInfo[i][Rob]-1;
		if(BusinessInfo[i][Rob] < 0) BusinessInfo[i][Rob] = 0;
	}
	
	return SetTimer("UpdateTimers", 1000, false);
}

stock Salary(playerid) {
	if(GetPVarInt(playerid, "parrot")) {
		if(PlayerInfo[playerid][pParrot] >= 3) {
			PlayerInfo[playerid][pParrot] = PlayerInfo[playerid][pParrot]-1;
			SetPlayerInt(playerid, "Parrot", PlayerInfo[playerid][pParrot]);
			SendClientMessage(playerid, -1, ""COLOR_GREEN"Попугай растет, теперь он будет повторять за вами еще чаще!");	
		}
	}
	SendClientMessage(playerid, -1, ""COLOR_ORANGE"Вы отыграли час. Зарплата поступила на ваш банковский счет");
	PlayerInfo[playerid][pHours] += 1;
	UpdatePlayerProgressQuest(playerid, E_TIME);
	SetPlayerScore(playerid, PlayerInfo[playerid][pHours]);
	SetPlayerInt(playerid, "Hours", PlayerInfo[playerid][pHours]);
	if(PlayerInfo[playerid][pHours] == 24) {
		new partner = _ReturnPlayerID(PlayerInfo[playerid][pReferral]);
		if(partner == INVALID_PLAYER_ID) {
			new Query[128];
			mysql_format(database, Query, sizeof(Query), "UPDATE `players` SET Score=Score+5000 WHERE Name = '%e' LIMIT 1", PlayerInfo[playerid][pReferral]);
			mysql_pquery(database, Query, "", "");
			SendClientMessage(playerid, -1, ""COLOR_GREEN"Друг пригласивший вас получил 5000 EXP");	
		}
		else {

			AddPlayerEXP(partner, 5000, "За пришлашение игрока %s", PlayerInfo[playerid][pName]);

			SendClientMessage(playerid, -1, ""COLOR_GREEN"Пригласивший вас друг получил 5000 EXP");	
			SendClientMessage(partner, -1, ""COLOR_GREEN"Вы получили 5000 EXP за приглашенного игрока!");		
		}		
	}
	GameTextForPlayer(playerid, "~g~SALARY", 5000, 0);
	PlayerInfo[playerid][pShowed] = 0;
	SetPlayerInt(playerid, "Showed", PlayerInfo[playerid][pShowed]);
	PlayerInfo[playerid][pOnline] = 0;
	SetPlayerInt(playerid, "Online", PlayerInfo[playerid][pOnline]);

	new house_array = GetPlayerHouse(playerid);
	if(house_array != 0 ) {
		house_array = GetPVarInt(playerid, "PlayerHouse");
		if(HouseInfo[house_array][hTakings] <= 3) {
			format(small_string, sizeof(small_string), ""COLOR_RED"У вашего дома, осталось мало оплаченных дней (%i дн.)", HouseInfo[house_array][hTakings]);
			SendClientMessage(playerid, -1, small_string);
			SendClientMessage(playerid, -1, ""COLOR_RED"Оплатите дом в банке, во избежание дальнейшей продажи дома государству.");
		} else {
			format(small_string, sizeof(small_string), ""COLOR_ORANGE"У вашего дома, осталось оплаченных дней (%i дн.)", HouseInfo[house_array][hTakings]);
			SendClientMessage(playerid, -1, small_string);
			SendClientMessage(playerid, -1, ""COLOR_ORANGE"Не забывайте про оплату дома. Для этого, Вам нужно посетить банк.");
		}
	}
	new
		arrayID = Player.Hotel[playerid];

	if(arrayID != INVALID_HOTEL_ID) {
		if(Hotel.Room[arrayID][E_HOTEL_ROOM_RENT_DAY] <= 3) {
			format(small_string, sizeof(small_string), ""COLOR_RED"У вашего номера в отеле, осталось мало оплаченных дней (%i дн.)", Hotel.Room[arrayID][E_HOTEL_ROOM_RENT_DAY]);
			SendClientMessage(playerid, -1, small_string);
			SendClientMessage(playerid, -1, ""COLOR_RED"Оплатите аренду комнаты в банке (/gps - Общественные места - Банк), во избежание выселения .");
		}
	}
	new exp;
	if(PlayerInfo[playerid][pTaxiTotal] > 0) {
		if(IsPlayerPremiumAccount(playerid) == true || X2_STATUS == 1) {
			AddPlayerBankEXP(playerid, PlayerInfo[playerid][pTaxiTotal]*2, "Зарплата таксиста");
		} else {
			AddPlayerBankEXP(playerid, PlayerInfo[playerid][pTaxiTotal], "Зарплата таксиста");
		}
		format(small_string, sizeof(small_string), ""COLOR_ORANGE"Зарплата таксиста: {FFFFFF}+ %d EXP", PlayerInfo[playerid][pTaxiTotal]);
		SendClientMessage(playerid, -1, small_string);
		PlayerInfo[playerid][pTaxiTotal] = 0;
		SetPlayerInt(playerid, "TaxiTotal", PlayerInfo[playerid][pTaxiTotal]);
	}
	new
		Fraction: fractionid = GetPlayerFraction(playerid),
		player_rank = PlayerInfo[playerid][pRank];


	if(fractionid == FRACTION_ARMY) {
		if(player_rank > 0 && player_rank < 3) {
			exp = 200;
		} else if(player_rank > 2 && player_rank < 6) {
			exp = 250;
		} else if(player_rank > 5 && player_rank < 8) {
			exp = 300;
		} else {
			exp = 450;
		}
		if(GetPlayerLeader(playerid) != -1) exp += 250;
		if(IsPlayerPremiumAccount(playerid) == true || X2_STATUS == 1) {
			AddPlayerBankEXP(playerid, exp*2, "Зарплата в Армии");
		} else {
			AddPlayerBankEXP(playerid, exp, "Зарплата в Армии");
		}

		format(small_string, sizeof(small_string), ""COLOR_ORANGE"Зарплата: {FFFFFF}+ %d EXP", exp);
		SendClientMessage(playerid, -1, small_string);
	}

	if(fractionid == FRACTION_LSPD) {
		if(player_rank > 0 && player_rank < 3) {
			exp = 200;
		} else if(player_rank > 2 && player_rank < 6) {
			exp = 250;
		} else if(player_rank > 5 && player_rank < 8) {
			exp = 300;
		} else {
			exp = 450;
		}
		if(GetPlayerLeader(playerid) != -1) exp += 250;
		if(IsPlayerPremiumAccount(playerid) == true || X2_STATUS == 1) {
			AddPlayerBankEXP(playerid, exp*2, "Зарплата в LSPD");
		} else {
			AddPlayerBankEXP(playerid, exp, "Зарплата в LSPD");
		}
		format(small_string, sizeof(small_string), ""COLOR_ORANGE"Зарплата: {FFFFFF}+ %d EXP", exp);
		SendClientMessage(playerid, -1, small_string);
	}

	if(fractionid == FRACTION_FBI) {
		if(player_rank > 0 && player_rank < 3) {
			exp = 250;
		} else if(player_rank > 2 && player_rank < 6) {
			exp = 300;
		} else if(player_rank > 5 && player_rank < 8) {
			exp = 350;
		} else {
			exp = 450;
		}
		if(GetPlayerLeader(playerid) != -1) exp += 250;
		if(IsPlayerPremiumAccount(playerid) == true || X2_STATUS == 1) {
			AddPlayerBankEXP(playerid, exp*2, "Зарплата в FBI");
		} else {
			AddPlayerBankEXP(playerid, exp, "Зарплата в FBI");
		}
		format(small_string, sizeof(small_string), ""COLOR_ORANGE"Зарплата: {FFFFFF}+ %d EXP", exp);
		SendClientMessage(playerid, -1, small_string);
	}

	if(fractionid == FRACTION_GOVERMENT) {
		if(player_rank > 0 && player_rank < 3) {
			exp = 250;
		} else if(player_rank > 2 && player_rank < 6) {
			exp = 350;
		} else if(player_rank > 5 && player_rank < 8) {
			exp = 450;
		} else {
			exp = 550;
		}
		if(GetPlayerLeader(playerid) != -1) exp += 250;
		if(IsPlayerPremiumAccount(playerid) == true || X2_STATUS == 1) {
			AddPlayerBankEXP(playerid, exp*2, "Зарплата в правительстве");
		} else {
			AddPlayerBankEXP(playerid, exp, "Зарплата в правительстве");
		}
		format(small_string, sizeof(small_string), ""COLOR_ORANGE"Зарплата: {FFFFFF}+ %d EXP", exp);
		SendClientMessage(playerid, -1, small_string);
	}

	if(fractionid == FRACTION_NEWS) {
		if(player_rank > 0 && player_rank < 3) {
			exp = 150;
		} else if(player_rank > 2 && player_rank < 6) {
			exp = 250;
		} else if(player_rank > 5 && player_rank < 8) {
			exp = 350;
		} else {
			exp = 450;
		}
		if(GetPlayerLeader(playerid) != -1) exp += 250;
		if(IsPlayerPremiumAccount(playerid) == true || X2_STATUS == 1) {
			AddPlayerBankEXP(playerid, exp*2, "Зарплата в San News");
		} else {
			AddPlayerBankEXP(playerid, exp, "Зарплата в San News");
		}
		format(small_string, sizeof(small_string), ""COLOR_ORANGE"Зарплата: {FFFFFF}+ %d EXP", exp);
		SendClientMessage(playerid, -1, small_string);
	}



	if(fractionid > FRACTION_LSPD && fractionid <= FRACTION_DN_BOYS) {
		exp = gang_profit[_:fractionid];
		if(GetPlayerLeader(playerid) != -1) exp += 250;
		if(IsPlayerPremiumAccount(playerid) == true || X2_STATUS == 1) {
			AddPlayerBankEXP(playerid, exp*2, "Зарплата в банде");
		} else {
