	            format(small_string, sizeof(small_string), "[A] %s(%i) áűë ęčęíóň. (code #4 > OnFoot: Teleport in car)", PlayerInfo[playerid][pName], playerid);
	        }

	        if(kickcode == 5)
	        {
	            SendClientMessage(playerid, 0xEB4949FF, "[AC] " "Âű áűëč ęčęíóňű ďî ďîäîçđĺíčţ â ÷čňĺđńňâĺ! (code #5 > OnFoot: Weapon Hack)");
	            format(small_string, sizeof(small_string), "[A] %s(%i) áűë ęčęíóň. (code #5 > OnFoot: Weapon Hack)", PlayerInfo[playerid][pName], playerid);
	        }

			if(kickcode == 10)
			{
	            SendClientMessage(playerid, 0xEB4949FF, "[AC] " "Âű áűëč ęčęíóňű ďî ďîäîçđĺíčţ â ÷čňĺđńňâĺ! (code #10 > AntiFreeze)");
	            format(small_string, sizeof(small_string), "[A] %s(%i) áűë ęčęíóň. (code #10 > AntiFreeze)", PlayerInfo[playerid][pName], playerid);
			}

	        if(kickcode == 11)
	        {
	            SendClientMessage(playerid, 0xEB4949FF, "[AC] " "Âű áűëč ęčęíóňű ďî ďîäîçđĺíčţ â ÷čňĺđńňâĺ! (code #11 > Damager)");
	            format(small_string, sizeof(small_string), "[A] %s(%i) áűë ęčęíóň. (code #11 > Damager)", PlayerInfo[playerid][pName], playerid);
	        }

	        if(kickcode == 12)
	        {
	            SendClientMessage(playerid, 0xEB4949FF, "[AC] " "Âű áűëč ęčęíóňű ďî ďîäîçđĺíčţ â ÷čňĺđńňâĺ! (code #12 > OnFoot: Health Hack)");
	            format(small_string, sizeof(small_string), "[A] %s(%i) áűë ęčęíóň. (code #12 > OnFoot: Health Hack)", PlayerInfo[playerid][pName], playerid);
	        }

	        if(kickcode == 13)
