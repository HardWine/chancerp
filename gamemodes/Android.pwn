			SendClientMessage(playerid, -1, ""COLOR_ORANGE"Вы сняли одежду");
			new skin_nude = RandomEx(0,3);
			SetPVarInt(playerid, "nude", 1);
			if(PlayerInfo[playerid][pSex] == 0) {
				
				switch(skin_nude) {
					case 0: SetPlayerSkin(playerid, 18);
					case 1: SetPlayerSkin(playerid, 45);
					case 2: SetPlayerSkin(playerid, 97);
					case 3: SetPlayerSkin(playerid, 154);
