forward bool:Player__GetPlayerCar(const playerid, const slot);
public bool:Player__GetPlayerCar(const playerid, const slot) {
	format(small_string, sizeof(small_string), "CALL `Player.GetPlayerCar` (%i , %i);", PlayerInfo[playerid][pID], slot);
	printf(small_string);
	mysql_pquery(database, small_string, "@_LoadPlayerCar", "ii", playerid, slot);
	return true;
}

forward bool:Player__DeletePlayerCar(const playerid, const slot);
public bool:Player__DeletePlayerCar(const playerid, const slot) {
	if(Player__CarVehicleID[playerid][slot] != (0xFFFF)) {
		Iter_DestroyVehicle(Player__CarVehicleID[playerid][slot]);
		Player__CarVehicleID[playerid][slot] = (0xFFFF);
		return true;
	}
	return false;
}

@_LoadPlayerCar(const playerid, const slot);
@_LoadPlayerCar(const playerid, const slot) {
	new 
		rows = cache_get_row_count();

	if(rows == 0) {
		Player__CarID[playerid][slot] = (-1);
		Player__CarModelID[playerid][slot] = (0xFFFF);
		Player__CarVehicleID[playerid][slot] = (0xFFFF);
		Player__CarColor_1[playerid][slot] = 0;
		Player__CarColor_2[playerid][slot] = 0;
