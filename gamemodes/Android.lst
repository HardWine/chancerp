@_LoadPlayerDailyQuest(const playerid);
@_LoadPlayerDailyQuest(const playerid) {
	new 
		rows = cache_get_row_count();

	if(rows) {
		for(new i = 0; i < rows; i++) {
			PlayerDailyQuest[playerid][i][E_QUEST] = cache_get_field_content_int(i, "Quest");
