forward dre_DIALOG_SELECT_SH(playerid, response, listitem, inputtext[]); public dre_DIALOG_SELECT_SH(playerid, response, listitem, inputtext[]) {
	if(!response) {
		DeletePVar(playerid, "cmd_sh");
		return 1;
	} else {
		new
			targetid = GetPVarInt(playerid, "cmd_sh");

		if(IsPlayerConnected(targetid) == 0) {
			return 1;
		}

		if(Player__AdminLevel{playerid} != 0) {
			switch(listitem) {
				case 0: {
					format(small_string, sizeof(small_string), "{FF9945}[A] %s(%i) čńďîëüçîâŕë řŕáëîí ą%i ďđč îňâĺňĺ čăđîęó %s(%i)", PlayerInfo[playerid][pName], playerid, listitem, PlayerInfo[targetid][pName], targetid);
					SendAdminMessage(-1, small_string);
					format(small_string, sizeof(small_string), "Ŕäěčíčńňđŕňîđ %s îňâĺňčë: Ŕäěčíčńňđŕöč˙ Chance RP, ćĺëŕĺň Âŕě ďđč˙ňíîé čăđű č őîđîřĺăî íŕńňđîĺíč˙ :)", PlayerInfo[playerid][pName]);
					SendClientMessage(targetid, 0xFF9945FF, small_string);
				}
				case 1: {
					format(small_string, sizeof(small_string), "{FF9945}[A] %s(%i) čńďîëüçîâŕë řŕáëîí ą%i ďđč îňâĺňĺ čăđîęó %s(%i)", PlayerInfo[playerid][pName], playerid, listitem, PlayerInfo[targetid][pName], targetid);
					SendAdminMessage(-1, small_string);					
					format(small_string, sizeof(small_string), "Ŕäěčíčńňđŕňîđ %s îňâĺňčë: Âű ěîćĺňĺ îńňŕâčňü çŕ˙âęó â Support Team íŕ ôîđóěĺ talk.chancerp.ru-'Ďîääĺđćęŕ'", PlayerInfo[playerid][pName]);
					SendClientMessage(targetid, 0xFF9945FF, small_string);
				}
				case 2: {
					format(small_string, sizeof(small_string), "{FF9945}[A] %s(%i) čńďîëüçîâŕë řŕáëîí ą%i ďđč îňâĺňĺ čăđîęó %s(%i)", PlayerInfo[playerid][pName], playerid, listitem, PlayerInfo[targetid][pName], targetid);
					SendAdminMessage(-1, small_string);
					format(small_string, sizeof(small_string), "Ŕäěčíčńňđŕňîđ %s îňâĺňčë: Ó âŕń nonRP íčę, âű ěîćĺňĺ îńňŕâčňü çŕ˙âęó íŕ ńěĺíó (/mn 8. Ńěĺíŕ NonRP íčęŕ)", PlayerInfo[playerid][pName]);
					SendClientMessage(targetid, 0xFF9945FF, small_string);
				}
				case 3: {
					format(small_string, sizeof(small_string), "{FF9945}[A] %s(%i) čńďîëüçîâŕë řŕáëîí ą%i ďđč îňâĺňĺ čăđîęó %s(%i)", PlayerInfo[playerid][pName], playerid, listitem, PlayerInfo[targetid][pName], targetid);
					SendAdminMessage(-1, small_string);
