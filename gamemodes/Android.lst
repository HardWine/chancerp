forward bool:Hotel__BuyHolelPlayer(const arrayID, const accID, const name[]); 
public bool:Hotel__BuyHolelPlayer(const arrayID, const accID, const name[]) {
	Hotel__Room[arrayID][E_HOTEL_ROOM_OWNER_ID] = accID;
	strmid(Hotel__Room[arrayID][E_HOTEL_ROOM_OWNER_NAME], name, 0, MDialog_strlen(name), 24);
	Hotel__Room[arrayID][E_HOTEL_ROOM_RENT_DAY] = (1);



	new 
		targetid = GetPlayerIDFromAccID(accID);

	if(targetid != (0xFFFF)) {
		Player__Hotel[targetid] = arrayID;
	}

	format(small_string, sizeof(small_string), "CALL `Hotel.BuyHolelPlayer` (%i , %i);", accID, Hotel__Room[arrayID][E_HOTEL_ROOM_ID]);
	mysql_pquery(database, small_string);
	return true;
}

forward bool:Hotel__SetNullOwner(const arrayID); 
public bool:Hotel__SetNullOwner(const arrayID) {

	new 
		targetid = GetPlayerIDFromAccID(Hotel__Room[arrayID][E_HOTEL_ROOM_OWNER_ID]);

	if(targetid != (0xFFFF)) {
		Player__Hotel[targetid] = (-1);
		if(caridhouse[targetid] != (0xFFFF))
		{
			Iter_DestroyVehicle(caridhouse[targetid]);
			caridhouse[targetid] = (0xFFFF);
		}
	}


	Hotel__Room[arrayID][E_HOTEL_ROOM_OWNER_ID] = (-1);
	strmid(Hotel__Room[arrayID][E_HOTEL_ROOM_OWNER_NAME], "Îňńóňńňâóĺň", 0, MDialog_strlen("Îňńóňńňâóĺň"), 24);



	format(small_string, sizeof(small_string), "CALL `Hotel.SetNullOwner` (%i);", Hotel__Room[arrayID][E_HOTEL_ROOM_ID]);
	mysql_pquery(database, small_string);
	return true;
}

forward Hotel__UpRentDay(const arrayID);
public Hotel__UpRentDay(const arrayID) {
	Hotel__Room[arrayID][E_HOTEL_ROOM_RENT_DAY] ++;



	format(small_string, sizeof(small_string), "CALL `Hotel.UpRentDay` (%i);", Hotel__Room[arrayID][E_HOTEL_ROOM_ID]);
	mysql_pquery(database, small_string);
	return true;
}


forward Hotel__DownRentDay(const arrayID);
public Hotel__DownRentDay(const arrayID) {
	Hotel__Room[arrayID][E_HOTEL_ROOM_RENT_DAY] --;
	if(Hotel__Room[arrayID][E_HOTEL_ROOM_RENT_DAY] <= 0) {
		Hotel__SetNullOwner(arrayID);
	} else {


		format(small_string, sizeof(small_string), "CALL `Hotel.DownRentDay` (%i);", Hotel__Room[arrayID][E_HOTEL_ROOM_ID]);
		mysql_pquery(database, small_string);
	}
	return true;
}

forward Hotel__SetRentDay(const arrayID, const dayss);
public Hotel__SetRentDay(const arrayID, const dayss) { 
	Hotel__Room[arrayID][E_HOTEL_ROOM_RENT_DAY] = dayss; 

	format(small_string, sizeof(small_string), "CALL `Hotel.SetRentDay` (%i, %i);", Hotel__Room[arrayID][E_HOTEL_ROOM_ID], dayss); 
	mysql_pquery(database, small_string); 
	return true; 
}

forward bool:Hotel__Show(const arrayID);
public bool:Hotel__Show(const arrayID) {
	printf("ID = %i OwnerID = %i Name = %s Day = %i Inter = %i World = %i", 
		Hotel__Room[arrayID][E_HOTEL_ROOM_ID],
		Hotel__Room[arrayID][E_HOTEL_ROOM_OWNER_ID],
		Hotel__Room[arrayID][E_HOTEL_ROOM_OWNER_NAME],
		Hotel__Room[arrayID][E_HOTEL_ROOM_RENT_DAY],
		Hotel__Room[arrayID][E_HOTEL_ROOM_INTER],
		Hotel__Room[arrayID][E_HOTEL_ROOM_WOLRD]
	);
	return true;
}




