	SetPVarInt(playerid, "arrest_on", 60);
	return 1;
}


forward UnTaserPlayer(playerid);
public UnTaserPlayer(playerid)
{
	if(GetPVarType(playerid, !"cuffed") == 1) return 1;
	if(playerid == (0xFFFF))
		return 0;

	RM_TogglePlayerControllable(playerid, 1);
	DeletePVar(playerid, !"tasered");
	return 1;
}
forward pc_cmd_hi(playerid, params[]); public pc_cmd_hi(playerid, params[])
{
	if(IsPlayerConnected(playerid))
	{

		if(IsPlayerInAnyVehicle(playerid)) return SendClientMessage(playerid, -1, "Íĺëüç˙ čńďîëüçîâŕňü â ňđŕíńďîđňĺ");
		new id;
		if(sscanf(params,"r",id)) return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ: /hi [id čăđîęŕ]");

		if(!IsPlayerConnected(id)) return SendClientMessage(playerid, -1, """{ff353c}""Čăđîę íĺ íŕéäĺí");
		if(id == (0xFFFF)) return SendClientMessage(playerid, -1, """{ff353c}""Čăđîę íĺ íŕéäĺí");
		if(id == playerid) return 1;
		new Float:X, Float:Y, Float:Z;
		GetPlayerPos(id, X, Y, Z);
		new Float:distance = GetPlayerDistanceFromPoint(playerid, X, Y, Z);
		if(GetPVarInt(id, !"spec") == 1) distance = 50;
		if(distance < 1.5 && distance > 0.5)
		{
			new Float:angle;
			GetPlayerFacingAngle(playerid, angle);
			SetPlayerFacingAngle(id, angle + 180);
			format(small_string, sizeof(small_string), "%s ďîćŕë(ŕ) đóęó %s", PlayerInfo[playerid][pName], PlayerInfo[id][pName]);
			ProxDetector(playerid, 20, 0xDD90FFFF, small_string);
			ApplyAnimation(playerid,"GANGS","hndshkfa",4.1, 0, 1, 1, 0, 0, 1);
			ApplyAnimation(id,"GANGS","hndshkfa",4.1, 0, 1, 1, 0, 0, 1);
			UpdatePlayerProgressQuest(playerid, E_HI);
			return true;
		}
		else if (distance < 20.0)
		{
			format(small_string, sizeof(small_string), "%s ěŕřĺň đóęîé %s", PlayerInfo[playerid][pName], PlayerInfo[id][pName]);
			ProxDetector(playerid, 20, 0xDD90FFFF, small_string);
			ApplyAnimation(playerid, "PED", "endchat_03", 4.1, 0, 1, 1, 0, 0, 1);
		}
		else SendClientMessage(playerid, -1, """{FFAF00}""Âű ńëčřęîě äŕëĺęî îň óęŕçŕííîăî čăđîęŕ");
	}
	return true;
}
forward pc_cmd_kiss(playerid, params[]); public pc_cmd_kiss(playerid, params[])
{
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ: /kiss [id čăđîęŕ]");
	if(GetPVarInt(playerid,"LOLIKATime") > gettime()) return SendClientMessage(playerid, -1, """{FFAF00}""Ďîäîćäčňĺ íĺěíîăî");
	if(playerid == params[0]) return true;
	if(GetDistanceBetweenPlayerz(playerid, params[0], 2.00) != 1) return SendClientMessage(playerid, -1, """{FFAF00}""Âű ńëčřęîě äŕëĺęî îň óęŕçŕííîăî čăđîęŕ");
	new Float:angle;
	GetPlayerFacingAngle(playerid, angle);
	SetPlayerFacingAngle(params[0], angle + 180);

	format(small_string, sizeof(small_string), "%s ďîöĺëîâŕë(ŕ) %s", PlayerInfo[playerid][pName], PlayerInfo[params[0]][pName]);
	ProxDetector(playerid, 20, 0xDD90FFFF, small_string);

	ApplyAnimation(playerid, "KISSING", "Playa_Kiss_02", 3.0, 0, 0, 0, 0, 0); 
	ApplyAnimation(params[0], "KISSING", "Playa_Kiss_02", 3.0, 0, 0, 0, 0, 0); 
	SetPVarInt(playerid,"LOLIKATime",gettime()+10);
	return true;
}
forward pc_cmd_offjail(playerid,params[]); public pc_cmd_offjail(playerid,params[])
{
		if(Player__AdminLevel{playerid} < 4) return 1; 
		new query[128],param_name[24],param_reason[32],param_day; 
		if(sscanf(params, "s[24]ds[32]", param_name,param_day,param_reason)) return SendClientMessage(playerid, -1, "Čńďîëüçóéňĺ: /offjail [íčę] [ěčíóňű] [ďđč÷číŕ]"); 
		if(!strcmp(param_name, "Boulevard_Picard", true) || !strcmp(param_name, "Yolon_Jarero", true) || !strcmp(param_name, "Ricky_Lawrence", true)) return 1;
		if(param_day > 360 || param_day < 1) return SendClientMessage(playerid, -1, """{ff353c}""Ěŕęńčěŕëüíîĺ íŕęŕçŕíčĺ - 180 ěčíóň"); 
		SetPVarString(playerid,"OffJailReason",param_reason); 
		SetPVarInt(playerid,"OffJailDay",param_day); 
		mysql_format(database, query,sizeof(query), "SELECT * FROM ""players"" WHERE `Name` = '%e'", param_name); 
		mysql_tquery(database, query, "OffJails", "is", playerid, param_name); 
		return 1;
}
