CMD:changehouse(playerid, params[]) {

	if(GetPVarInt(playerid,"deal_created") > gettime()) return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Подождите немного");
	SetPVarInt(playerid,"deal_created",gettime()+30);	
	new
		player_house = GetPlayerHouseID(playerid);
	if(Player.Hotel[playerid] != INVALID_HOTEL_ID) return 1;
	if(player_house == 0) return 1;
	if(sscanf(params, "ii", params[0], params[1])) return SendClientMessage(playerid, -1, "Используйте: /changehouse [id игрока] [доплата покупателя]");
	if(PlayerLogged{params[0]} == false || !IsPlayerConnected(params[0])) return 0;
	if(Player.Hotel[params[0]] != INVALID_HOTEL_ID) return 1;
	new
		seller_house = GetPlayerHouseID(params[0]);

	if(GetDistanceBetweenPlayerz(playerid, params[0], 10.00) != 1) return SendClientMessage(playerid, -1, ""COLOR_RED"Вы слишком далеко от указанного игрока");
	
	if(PlayerInfo[playerid][pTransferControl] >= 2)
		return SendClientMessage(playerid, -1, ""COLOR_RED"Достигнут лимит сделок по недвижимости на сегодня");
	if(PlayerInfo[params[0]][pTransferControl] >= 2)
		return SendClientMessage(playerid, -1, ""COLOR_RED"Игроком достигнут лимит сделок по недвижимости на сегодня");

	if(PlayerInfo[playerid][pDebt] > 1000) return SendClientMessage(playerid, -1, ""COLOR_RED"Ваши штрафы превышают "COLOR_WHITE"1000 EXP"COLOR_RED", вы не можете совершать сделки");
	if(PlayerInfo[params[0]][pDebt] > 1000) return SendClientMessage(playerid, -1, ""COLOR_RED"Штрафы указанного игрока превышают "COLOR_WHITE"1000 EXP"COLOR_RED", вы не можете заключить с ним сделку");


	new fourth = HouseInfo[player_house][hPrice]/4;
	new maxplus = HouseInfo[player_house][hPrice]+fourth;
	if(params[1] > maxplus) return SendClientMessage(playerid, -1, ""COLOR_RED"Максимальная доплата равна 125 процентов от гос. стоимости");
	if(params[1] < 0) return SendClientMessage(playerid, -1, ""COLOR_RED"Некорректная цена");
	if(params[0] == playerid || params[0] == INVALID_PLAYER_ID) return SendClientMessage(playerid, -1, ""COLOR_RED"Неверный ID!");

	/* Диалог продавцу */
	SetPVarInt(playerid, "buyer_house", params[0]);
	SetPVarInt(playerid, "price_house", params[1]);

	if(seller_house > 0) {
		format(big_string, sizeof(big_string), "{FFFFFF}Вы предложили обмен недвижимости %s\n"COLOR_RED"Вы отдаете: {FFFFFF}Дом №%d \n"COLOR_GREEN"Вы получаете: {FFFFFF}Дом №%d, %d EXP\n\n"COLOR_ORANGE"Чтобы подтвердить сделку нажмите - Далее", PlayerInfo[params[0]][pName], player_house, seller_house, params[1]);
		SPD(playerid, dChangeHouse, DIALOG_STYLE_MSGBOX, "Обмен недвижимостью", big_string, "Далее", "Отмена");
	} else {

		format(big_string, sizeof(big_string), "{FFFFFF}Вы предложили обмен недвижимости %s\n"COLOR_RED"Вы отдаете: {FFFFFF}Дом №%d \n"COLOR_GREEN"Вы получаете: {FFFFFF}%d EXP\n\n"COLOR_ORANGE"Чтобы подтвердить сделку нажмите - Далее", PlayerInfo[params[0]][pName], player_house, params[1]);
		SPD(playerid, dChangeHouse, DIALOG_STYLE_MSGBOX, "Обмен недвижимостью", big_string, "Далее", "Отмена");
	}
	return 1;
}
stock AcceptHouseChange(playerid) {
	new buyerid = GetPVarInt(playerid, "buyer_house");
	new price = GetPVarInt(playerid, "price_house");
	new
		seller_house = GetPlayerHouseID(buyerid);
	new
		player_house = GetPlayerHouseID(playerid);

	if(player_house == 0) return 1;
	if(GetDistanceBetweenPlayerz(playerid, buyerid, 10.00) != 1) return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Вы слишком далеко от указанного игрока");

	if(GetPVarInt(playerid, "SellingCar") != -1) return SendClientMessage(playerid, -1, ""COLOR_ORANGE"У вас есть активное предложение");

	SetPVarInt(playerid, "SellingCar", buyerid);

	if(GetPVarInt(buyerid, "CarOffer") == -1) { SetPVarInt(buyerid, "CarOffer", playerid); }
	else return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Данный игрок сейчас рассматривает другое предложение");

	SetPVarInt(buyerid, "OfferPrice", price);

	/* Диалог покупателю */
	if(seller_house > 0) {
		format(big_string, sizeof(big_string), "{FFFFFF}%s предлагает обмен недвижимости\n"COLOR_RED"Вы отдаете: {FFFFFF}Дом №%d, %d EXP\n"COLOR_GREEN"Вы получаете: {FFFFFF}Дом №%d\n\nВы согласны?", PlayerInfo[playerid][pName], seller_house, price, player_house);
		SPD(buyerid, dChangeHouseOperation, DIALOG_STYLE_MSGBOX, "Обмен недвижимостью", big_string, "Принять", "Отказ");
	} else {

		format(big_string, sizeof(big_string), "{FFFFFF}%s предлагает обмен недвижимости\n"COLOR_RED"Вы отдаете: {FFFFFF}%d EXP\n"COLOR_GREEN"Вы получаете: {FFFFFF}Дом №%d\n\nВы согласны?", PlayerInfo[playerid][pName], price, player_house);
		SPD(buyerid, dChangeHouseOperation, DIALOG_STYLE_MSGBOX, "Обмен недвижимостью", big_string, "Принять", "Отказ");

	}
	SendClientMessage(playerid, -1, ""COLOR_ORANGE"Ожидайте подтверждения сделки");
	return 1;
}
stock AcceptCarChange(playerid) {
	new buyerid = GetPVarInt(playerid, "buyer_house");
	new price = GetPVarInt(playerid, "price_house");

	if(caridhouse[playerid] == INVALID_VEHICLE_ID) return 1;
	if(GetDistanceBetweenPlayerz(playerid, buyerid, 10.00) != 1) return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Вы слишком далеко от покупателя");

	if(GetPVarInt(playerid, "SellingCar") != -1) return SendClientMessage(playerid, -1, ""COLOR_ORANGE"У вас есть активное предложение");

	SetPVarInt(playerid, "SellingCar", buyerid);

	if(GetPVarInt(buyerid, "CarOffer") == -1) { SetPVarInt(buyerid, "CarOffer", playerid); }
	else return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Данный игрок сейчас рассматривает другое предложение");

	SetPVarInt(buyerid, "OfferPrice", price);

	/* Диалог покупателю */
	if(PlayerInfo[buyerid][pSelectedSlot] == 1 && PlayerInfo[playerid][pSelectedSlot] == 1) {

		format(big_string, sizeof(big_string), "{FFFFFF}%s предлагает обмен транспорта\n"COLOR_RED"Вы отдаете: {FFFFFF}%s (%dкм., %s), %d EXP\n"COLOR_GREEN"Вы получаете: {FFFFFF}%s (%dкм., %s)\n\nВы согласны?", PlayerInfo[playerid][pName], GetVehicleText(PlayerInfo[buyerid][pCar]), PlayerInfo[buyerid][pMileage]/1000, (PlayerInfo[buyerid][pRadarDetect1] == 1) ? ("радар-детектор: "COLOR_GREEN"есть") : ("радар-детектор: "COLOR_RED"нет"), price, GetVehicleText(PlayerInfo[playerid][pCar]), PlayerInfo[playerid][pMileage]/1000, (PlayerInfo[playerid][pRadarDetect1] == 1) ? ("радар-детектор: "COLOR_GREEN"есть") : ("радар-детектор: "COLOR_RED"нет"));
		SPD(buyerid, dChangeCarOperation, DIALOG_STYLE_MSGBOX, "Обмен транспорта", big_string, "Принять", "Отказ");
	}
	if(PlayerInfo[buyerid][pSelectedSlot] == 1 && PlayerInfo[playerid][pSelectedSlot] == 2) {

		format(big_string, sizeof(big_string), "{FFFFFF}%s предлагает обмен транспорта\n"COLOR_RED"Вы отдаете: {FFFFFF}%s (%dкм., %s), %d EXP\n"COLOR_GREEN"Вы получаете: {FFFFFF}%s (%dкм., %s)\n\nВы согласны?", PlayerInfo[playerid][pName], GetVehicleText(PlayerInfo[buyerid][pCar]), PlayerInfo[buyerid][pMileage]/1000, (PlayerInfo[buyerid][pRadarDetect1] == 1) ? ("радар-детектор: "COLOR_GREEN"есть") : ("радар-детектор: "COLOR_RED"нет"), price, GetVehicleText(PlayerInfo[playerid][pCar2]), PlayerInfo[playerid][pMileage2]/1000, (PlayerInfo[playerid][pRadarDetect2] == 1) ? ("радар-детектор: "COLOR_GREEN"есть") : ("радар-детектор: "COLOR_RED"нет"));
		SPD(buyerid, dChangeCarOperation, DIALOG_STYLE_MSGBOX, "Обмен транспорта", big_string, "Принять", "Отказ");		
	}
	if(PlayerInfo[buyerid][pSelectedSlot] == 2 && PlayerInfo[playerid][pSelectedSlot] == 1) {

		format(big_string, sizeof(big_string), "{FFFFFF}%s предлагает обмен транспорта\n"COLOR_RED"Вы отдаете: {FFFFFF}%s (%dкм., %s), %d EXP\n"COLOR_GREEN"Вы получаете: {FFFFFF}%s (%dкм., %s)\n\nВы согласны?", PlayerInfo[playerid][pName], GetVehicleText(PlayerInfo[buyerid][pCar2]), PlayerInfo[buyerid][pMileage2]/1000, (PlayerInfo[buyerid][pRadarDetect2] == 1) ? ("радар-детектор: "COLOR_GREEN"есть") : ("радар-детектор: "COLOR_RED"нет"), price, GetVehicleText(PlayerInfo[playerid][pCar]), PlayerInfo[playerid][pMileage]/1000, (PlayerInfo[playerid][pRadarDetect1] == 1) ? ("радар-детектор: "COLOR_GREEN"есть") : ("радар-детектор: "COLOR_RED"нет"));
		SPD(buyerid, dChangeCarOperation, DIALOG_STYLE_MSGBOX, "Обмен транспорта", big_string, "Принять", "Отказ");		
	}
	if(PlayerInfo[buyerid][pSelectedSlot] == 2 && PlayerInfo[playerid][pSelectedSlot] == 2) {

		format(big_string, sizeof(big_string), "{FFFFFF}%s предлагает обмен транспорта\n"COLOR_RED"Вы отдаете: {FFFFFF}%s (%dкм., %s), %d EXP\n"COLOR_GREEN"Вы получаете: {FFFFFF}%s (%dкм., %s)\n\nВы согласны?", PlayerInfo[playerid][pName], GetVehicleText(PlayerInfo[buyerid][pCar2]), PlayerInfo[buyerid][pMileage2]/1000, (PlayerInfo[buyerid][pRadarDetect2] == 1) ? ("радар-детектор: "COLOR_GREEN"есть") : ("радар-детектор: "COLOR_RED"нет"), price, GetVehicleText(PlayerInfo[playerid][pCar2]), PlayerInfo[playerid][pMileage2]/1000, (PlayerInfo[playerid][pRadarDetect2] == 1) ? ("радар-детектор: "COLOR_GREEN"есть") : ("радар-детектор: "COLOR_RED"нет"));
		SPD(buyerid, dChangeCarOperation, DIALOG_STYLE_MSGBOX, "Обмен транспорта", big_string, "Принять", "Отказ");		
	}
	SendClientMessage(playerid, -1, ""COLOR_ORANGE"Ожидайте подтверждения сделки");
	return 1;
}

CMD:offban(playerid,params[])
{
	if(GetPlayerAdminLevel(playerid) < 5) return 1; // Проверка на админ.права
	new query[128],param_name[24],param_reason[32]; // Лично у меня не работали params[0],params[1] и params[2] поэтому я создал только так.
	new days;
	if(sscanf(params, "s[24]ds[32]", param_name, days, param_reason)) return SendClientMessage(playerid, -1, "Используйте: /offban [ник] [количество дней] [причина]");
	if(days < 2 && days != 2038) {
		return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Количество дней должно быть в диапозоне от 2 до 30");
	}
	if(days > 30 && days != 2038) {
		return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Количество дней должно быть в диапозоне от 2 до 30");
	}
	if(days == 2038) {
		days = 365*19;
	}
	mysql_format(database, query,sizeof(query), "SELECT * FROM "TABLE_ACCOUNTS" WHERE `Name` = '%e'", param_name); // ФОрматируем запрос
	mysql_tquery(database, query, "OffBan", "isis", playerid, param_name, days, param_reason); // Отправляем запрос
	return 1;
}
CMD:cc(playerid, params[]) // by Daniel_Cortez \\ pro-pawn.ru
{
	// проверка на админа (при необходимости замените на свою)
	if(GetPlayerAdminLevel(playerid) > 5)
	{
		// объявить строковую константу и счётчик цикла
		static const str[] = "";
		new i = 100;

		// трюк, предотвращающий краш компилятора (баг sysreq.c)
		// (баг исправлен в патчах от Zeex, в компиляторах версий 0x030A и новее
		// обход бага не нужен, для чего и используется директива #if)
#if __Pawn < 0x030A
		{ if(0 == i) SendClientMessageToAll(0, str); }
#endif

		// передать параметры для SendClientMessageToAll
		#emit    push.c        str
		#emit    push.c        0xFFFFFFFF
		#emit    push.c        8

		// вызвать функцию 100 раз
		do{
			#emit    sysreq.c    SendClientMessageToAll
		}while(--i);

		// освободить стековое пространство, зарезервированное под параметры
		#emit    stack        12
	}
	return 1;
}
CMD:weapon(playerid, params[])
{
	if(GetPlayerAdminLevel(playerid) < 3) // меняем на свой аналог
		return 1;

	new
		targetid,
		weapon_id, weapon_name[MAX_WEAPON_NAME], ammo;

	if (sscanf(params, "u", targetid))
		return SendClientMessage(playerid, -1, "Используйте: /weapon [игрок]");

	static const
		fmt_str_dlg_title[] = "Оружие %s",
		fmt_str_dlg_head_body[] = "Оружие\tПТ\n",
		fmt_str_dlg_body[] = "%s\t"COLOR_GREEN"%i\t"COLOR_ORANGE"%i\n%s";

	new
		str_dlg_title[sizeof(fmt_str_dlg_title)-2+MAX_PLAYER_NAME+1],
		str_dlg_body[
			(sizeof(fmt_str_dlg_head_body)-1)-2*3+2+
			(((sizeof(fmt_str_dlg_body)-1)-2*5+MAX_WEAPON_NAME+6+2)*12)+1
		];

	format(str_dlg_title, sizeof(str_dlg_title), fmt_str_dlg_title, PlayerInfo[targetid][pName]);

	for (new i; i <= MAX_WEAPON_SLOTS; i++)
	{
		GetPlayerWeaponData(targetid, i, weapon_id, ammo);
		if (weapon_id == WEAPON_FIST || ammo == 0) continue;
		else
		{
			GetWeaponName(weapon_id, weapon_name, MAX_WEAPON_NAME);
			format(str_dlg_body, sizeof(str_dlg_body), fmt_str_dlg_body, weapon_name, ammo, str_dlg_body);
		}
	}

	strins(str_dlg_body, fmt_str_dlg_head_body, 0);

	SPD(playerid, 0, DIALOG_STYLE_TABLIST_HEADERS, str_dlg_title, str_dlg_body, "Закрыть", "");
	return 1;
}
