public OnPlayerStreamOut(playerid, forplayerid)
{

	if(IsPlayerConnected(forplayerid))
	{
		if(spectating[forplayerid] == playerid)
		{

			UpdateSpectatingStatus(forplayerid, playerid);
		}
	}
	return 1;
}

stock UpdateSpectatingStatus(spectatorid, spectedid)
{
	if(Player__AdminLevel{spectatorid} == 0) {
		return true;
	}

	if(spectating[spectatorid] == spectedid)
	{

		if(GetPlayerState(spectedid) == (7)) return pc_cmd_reoff(spectatorid,"\0"); 
		if(GetPlayerState(spectedid) == (9)) return pc_cmd_reoff(spectatorid,"\0"); 
		if(!IsPlayerConnected(spectedid)) pc_cmd_reoff(spectatorid,"\0"); 

		if(IsPlayerInAnyVehicle(spectedid))
		{

			SetPlayerVirtualWorld(spectatorid,GetPlayerVirtualWorld(spectedid));
			SetPlayerInterior(spectatorid, GetPlayerInterior(spectedid));
			TogglePlayerSpectating(spectatorid, true);
			PlayerSpectateVehicle(spectatorid, GetPlayerVehicleID(spectedid));
		}
		else
		{
			SetPlayerVirtualWorld(spectatorid,GetPlayerVirtualWorld(spectedid));
			SetPlayerInterior(spectatorid, GetPlayerInterior(spectedid));
			TogglePlayerSpectating(spectatorid, true);
			PlayerSpectatePlayer(spectatorid, spectedid);
		}

		if(spectating[spectatorid] != -1 && GetPlayerState(spectatorid) == (9))  spec_update(spectatorid);
	}
	return 1;
}

stock StopSpectate(playerid)
{
    for(new i=0; i<10; i++)
    {
        if(IsPlayerAttachedObjectSlotUsed(playerid, i)) RemovePlayerAttachedObject(playerid, i);
    }
	hide_spec(playerid);
	TogglePlayerSpectating(playerid, false);
	CancelSelectTextDraw(playerid);
	spectating[playerid] = -1;








	return spectating[playerid] = (0xFFFF);
}

