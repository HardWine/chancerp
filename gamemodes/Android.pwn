	SendClientMessage(playerid, -1, small_string);
	format(small_string, sizeof(small_string), ""COLOR_ORANGE"Ваш банковский баланс: {FFFFFF} %d EXP", PlayerInfo[playerid][pBank]);
	SendClientMessage(playerid, -1, small_string);


