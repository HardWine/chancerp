	}
	if(GetPVarInt(playerid, "arrest_on") != 0) return SendClientMessage(playerid, -1, """{ff353c}""Ýëĺęňđîřîęĺđ óćĺ âęëţ÷ĺí");
	SendClientMessage(playerid, -1,  """{ff353c}""Âű âęëţ÷čëč ýëĺęňđîřîęĺđ íŕ {FFFFFF}60 ńĺęóíä");
	ShowAction(playerid, "âęëţ÷čë(ŕ) ýëĺęňđîřîęĺđ");
	if(PlayerInfo[playerid][pRank] < 3 && GetPlayerFraction(playerid) == FRACTION_LSPD) return SendClientMessage(playerid, -1, """{ff353c}""Äîńňóď ę ýëĺęňđîřîęĺđó îňęđűâŕĺňń˙ ń 3 đŕíăŕ");
	CopTimerID[playerid] = KillTimer(CopTimerID[playerid]);
