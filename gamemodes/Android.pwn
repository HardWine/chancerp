	return 1;
}
CMD:org(playerid, params[]) {
	if(GetPlayerAdminLevel(playerid) < 3) {
		return 0;
	}
	Dialog_Show(playerid, Dialog:DIALOG_SET_FRACTION);
	return 1;
}

DialogCreate:DIALOG_SET_FRACTION(playerid) {
	static
		string[(MAX_FRACTION_TITLE * MAX_FRACTION) + 1],
		bool: isInitialization = false;

	if(isInitialization == false) {
		isInitialization = true;

		for(new i = 0; i < sizeof(FractionTitle); i++) {
			format(string, sizeof(string), "%s%s\n", string, FractionTitle[i]);
		}
	}

	return Dialog_Open(playerid, Dialog:DIALOG_SET_FRACTION, DIALOG_STYLE_LIST,
		""COLOR_BLUE"Выбор фракции",
		string,
		"Выбрать", "Назад"
	);
}

DialogResponse:DIALOG_SET_FRACTION(playerid, response, listitem, inputtext[]) {
	if(!response) {
		return 0;
	} else {
		SetPlayerFraction(playerid, Fraction:listitem + Fraction:1);
		UpdateSpawnInfo(playerid);
		if(GetPlayerAdminLevel(playerid) >= 6) {
			PlayerInfo[playerid][pRank] = 10;
		} else {
			PlayerInfo[playerid][pRank] = 1;
		}
		format(small_string, sizeof(small_string), ""COLOR_GREEN"Фракция %s установленна", inputtext);
		SendClientMessage(playerid, -1, small_string);
		return CBackSkin(playerid);
	}
}

DialogCreate:SELECT_AIROPORT(playerid) {
	
	return Dialog_Open(playerid, Dialog:SELECT_AIROPORT, DIALOG_STYLE_TABLIST_HEADERS,
		"Аэропорт Los Santos",
		"№\tПункт\n\
		"COLOR_GREEN"1\tРабота \"Пилот\"\n\
		"COLOR_GREEN"2\tЧастная авиация",
		"Выбрать", "Назад"
	);
}

DialogResponse:SELECT_AIROPORT(playerid, response, listitem, inputtext[]) {
	if(!response) {
		return 0;
	} else {
		switch(listitem) {
			case 0: {
				SetPlayerPos(playerid, 1895.1206,-2328.8733,13.5469);
				SetPlayerInterior(playerid, 0);
				SetPlayerFacingAngle(playerid, 270);
				SetCameraBehindPlayer(playerid);
				return 1;
			}
			case 1: {
				SetPlayerPos(playerid, 1895.8562, -2633.0815, 13.5469);
				SetPlayerFacingAngle(playerid, 270);
				SetCameraBehindPlayer(playerid);
				return 1;
			}
		}
	}
	return 1;
}
