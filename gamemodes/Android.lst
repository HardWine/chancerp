	        if(strval(AllAd[i][2]) == 0 && strcmp(AllAd[i][0], "-", true, 10 )) { format(str, 144,"{ffffff}%d. Îňďđŕâčňĺëü: %s""{6de64e}"" [Îćčäŕĺň]\n",i+1,AllAd[i][0]); strcat(sctring,str); } 
	        else if(strval(AllAd[i][2]) == 1 && strcmp(AllAd[i][0], "-", true, 10 )) { format(str, 144,"{ffffff}%d. Îňďđŕâčňĺëü: %s""{ff353c}"" [Íŕ ďđîâĺđęĺ]\n",i+1,AllAd[i][0]); strcat(sctring,str); }  
	        if(!strcmp(AllAd[i][0], "-", true, 10 )) { format(str, 144,"%d. Îňńóňńňâóĺň\n",i+1); strcat(sctring,str); } 
	    }
    	return SPD(playerid,dEditAdvert,2,"Ďđîâĺđęŕ îáú˙âëĺíčé",sctring,"Ďđîâĺđęŕ","Îňěĺíŕ"); 
    }
    else {
		for(new i; i < 19; i++) 
	    {
	    	SendClientMessage(playerid, -1, """{ff353c}""");
	        if(strval(AllAd[i][2]) == 0 && strcmp(AllAd[i][0], "-", true, 10 )) { format(str, 144,"{ffffff}%d. Îňďđŕâčňĺëü: %s""{6de64e}"" [Îćčäŕĺň]\n",i+1,AllAd[i][0]); strcat(sctring,str); } 
	        else if(strval(AllAd[i][2]) == 1 && strcmp(AllAd[i][0], "-", true, 10 )) { format(str, 144,"{ffffff}%d. Îňďđŕâčňĺëü: %s""{ff353c}"" [Íŕ ďđîâĺđęĺ]\n",i+1,AllAd[i][0]); strcat(sctring,str); }  
	        if(!strcmp(AllAd[i][0], "-", true, 10 )) { format(str, 144,"{ffffff}%d. Îňńóňńňâóĺň\n",i+1); strcat(sctring,str); } 
	    }    	
    }
    return SPD(playerid,dEditAdvertAdaptive,1,"Ďđîâĺđęŕ îáú˙âëĺíčé",sctring,"Ďđîâĺđęŕ","Îňěĺíŕ"); 
}

forward SendADList();
public SendADList() 
{ 
    if(MDialog_strlen(adlist[0][0]) < 2) return SetTimer("SendADList",15*1000,0); 
    format(small_string, sizeof small_string, "[Îáú˙âëĺíčĺ]{55B94E} %s", adlist[0][0]); 
    for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i=Iterator@Player [_: i])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);) {
		if(GetPVarInt(i, "fm")) continue;
		SendClientMessage(i, -1, small_string);
	}
    new senderid = _ReturnPlayerID(adlist[0][1]);
    new senderstring[24];
    new editorid = _ReturnPlayerID(adlist[0][2]);
    new editorstring[24];

	if(senderid != (0xFFFF)) {
	format(senderstring, 24, "[%d] (ňĺë. %i)", senderid, PlayerSIMCardNumber[senderid]);
	} else {
	format(senderstring, 24, "[?]");
	}

	if(editorid != (0xFFFF)) {
	format(editorstring, 24, "[%d]", editorid);
	} else {
	format(editorstring, 24, "[?]");
	}

    format(small_string, sizeof small_string, "{55B94E}Îňďđŕâčňĺëü: {FFFFFF}%s%s {55B94E}Đĺäŕęňîđ: {FFFFFF}%s%s", adlist[0][1], senderstring, adlist[0][2], editorstring); 
    for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Player ))-1);_:( i=Iterator@Player [_: i])!=((_:F@f:F@e:sizeof (Iterator@Player ))-1);) {
		if(GetPVarInt(i, "fm")) continue;
		SendClientMessage(i, -1, small_string);
	}
    adlist[0][0] = adlist[1][0], adlist[0][1] = adlist[1][1], adlist[0][2] = adlist[1][2];
    adlist[1][0] = adlist[2][0], adlist[1][1] = adlist[2][1], adlist[1][2] = adlist[2][2]; 
    adlist[2][0] = adlist[3][0], adlist[2][1] = adlist[3][1], adlist[2][2] = adlist[3][2]; 
    adlist[3][0] = adlist[4][0], adlist[3][1] = adlist[4][1], adlist[3][2] = adlist[4][2]; 
    adlist[4][0] = adlist[5][0], adlist[4][1] = adlist[5][1], adlist[4][2] = adlist[5][2]; 
    adlist[5][0] = adlist[6][0], adlist[5][1] = adlist[6][1], adlist[5][2] = adlist[6][2]; 
    adlist[6][0] = adlist[7][0], adlist[6][1] = adlist[7][1], adlist[6][2] = adlist[7][2]; 
    adlist[7][0] = adlist[8][0], adlist[7][1] = adlist[8][1], adlist[7][2] = adlist[8][2]; 
    adlist[8][0] = adlist[9][0], adlist[8][1] = adlist[9][1], adlist[8][2] = adlist[9][2]; 
    adlist[9][0] = "0"; 
    return SetTimer("SendADList",15*1000,0); 
}
