stock ShuffleDeepArray_Entry(...) {
	assert(numargs() == 3);
	new
		i,
		base,
		size = getarg(1),
		target;
	#emit LOAD.S.alt 12
	#emit STOR.S.alt base
	#emit LOAD.S.pri size
	#emit SHL.C.pri  2
	#emit ADD
	#emit STOR.S.pri i
	while (i != base) {
		i -= 4;
		target = (random(size) << 2) + base;

		#emit LREF.S.pri i
		#emit LOAD.S.alt i
		#emit ADD
		#emit PUSH.pri

		#emit LREF.S.pri target
		#emit LOAD.S.alt target
		#emit ADD

		#emit LOAD.S.alt i
		#emit SUB
		#emit SREF.S.pri i

		#emit POP.pri
		#emit LOAD.S.alt target
		#emit SUB
		#emit SREF.S.pri target
	}
}

