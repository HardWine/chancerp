stock get_drugs(playerid) {
	new 
	Fraction:fractionid = GetPlayerFraction(playerid);
	if(fractionid > FRACTION_LSPD && fractionid < FRACTION_RUSSIAN_MAFIA) 
	{
		if(TOTAL_DRUGS <= 0) TOTAL_DRUGS = 0;
		if(TOTAL_DRUGS < 15) return SendClientMessage(playerid, -1, """{ff353c}""В притоне недостаточно наркотиков");
		if(drug_amount[playerid] > 0) return SendClientMessage(playerid, -1, """{ff353c}""У Вас максимальное кол-во наркотиков");
		format(drug_string, sizeof(drug_string), """{4eb9e6}""Склад притона: {FFFFFF}%dгр.",TOTAL_DRUGS);
		SendClientMessage(playerid, -1, drug_string);
		drug_amount[playerid] = 0;
		format(drug_string, sizeof(drug_string), "Цена за 1 гр. наркотиков составляет %d EXP", 33);
		SendClientMessage(playerid, -1, drug_string);

		if(CheckCash(playerid, 33*15) == false) return 1;

		SendClientMessage(playerid, -1, """{FFAF00}""Через 10 секунд вы закупите партию из 15 гр. наркотиков");
		SendClientMessage(playerid, -1, """{FFAF00}""Чтобы отменить это действие - покиньте пикап");
		buydrugs_Timer[playerid] = SetTimerEx("get_drugs_accepted", 10000, false, "d", playerid);
	}
	return 1;
}

stock update_drug_text() {

 	format(drug_string, sizeof(drug_string), """{4eb9e6}""Склад: {FFFFFF}%dгр.", TOTAL_DRUGS);
	Update3DTextLabelText(totaldrug, 0xFFFFFFFF, drug_string);
}

stock get_drugs_delivred(playerid)	{
	PlayerInfo[playerid][pWanted] += 90;
	SetPlayerInt(playerid, "Wanted", PlayerInfo[playerid][pWanted]);
	Player__AddEXP(PlayerInfo[playerid][pID], 50, E_JOB_DRUGS, playerid);
	drug_amount[playerid]--;
    if(drug_amount[playerid] <= 0) {
    drug_amount[playerid] = 0;

	DecreaseKarma(playerid);

	switch(random(10)) {
		case 0: SendClientMessage(playerid, 0xE6E6E6E6, "- Покупатель: Отличный стафф, чувак. Удачи тебе");
		case 1: SendClientMessage(playerid, 0xE6E6E6E6, "- Покупатель: Заезжай еще, ниггер");
		case 2: SendClientMessage(playerid, 0xE6E6E6E6, "- Покупатель: Мог бы и побыстрей, барыга");
		case 3: SendClientMessage(playerid, 0xE6E6E6E6, "- Покупатель: Классная петрушка, а теперь вали отсюда!");
		case 4: SendClientMessage(playerid, 0xE6E6E6E6, "- Покупатель: Пахнет волшебством, спасибо мэн");
		case 5: SendClientMessage(playerid, 0xE6E6E6E6, "- Покупатель: Нигга, мы тебя уже заждались");
		case 6: SendClientMessage(playerid, 0xE6E6E6E6, "- Покупатель: Надеюсь не будет как в прошлый раз...");
		case 7: SendClientMessage(playerid, 0xE6E6E6E6, "- Покупатель: Ради этого я продал мамино обручальное кольцо");
		case 8: SendClientMessage(playerid, 0xE6E6E6E6, "- Покупатель: Ух, щас полетаем");
		case 9: SendClientMessage(playerid, 0xE6E6E6E6, "- Покупатель: Надеюсь это не мука!");
	}

    SendClientMessage(playerid, -1, """{6de64e}""Ты доставил все наркотики");
	for(new i = 0; i < 41; i++)
	{
		if(IsValidDynamicCP(point_sell[i])) {
			TogglePlayerDynamicCP(playerid, point_sell[i], false);
		}
	}

	format(drug_string, sizeof(drug_string), """{4eb9e6}""Получено с продаж: ""{FFFFFF}""%d EXP", 50*15);
	SendClientMessage(playerid, -1, drug_string);
	return 1;
    }

	format(drug_string, sizeof(drug_string), """{4eb9e6}""Получено: ""{FFFFFF}""%d EXP", 50);
	SendClientMessage(playerid, -1, drug_string);
	format(drug_string, sizeof(drug_string), """{4eb9e6}""Осталось доставить: {FFFFFF}%d грамм", drug_amount[playerid]);
	SendClientMessage(playerid, -1, drug_string);
	return 1;
}

	forward get_drugs_accepted(playerid);
	public get_drugs_accepted(playerid) {
	if(IsValidTimer(buydrugs_Timer[playerid]))
	{
		ALS_KillTimer(buydrugs_Timer[playerid]);
		buydrugs_Timer[playerid] = 0;
	}
	if(TOTAL_DRUGS < 15) return SendClientMessage(playerid, -1, """{ff353c}""В притоне недостаточно наркотиков");
 	if(!IsPlayerInRangeOfPoint(playerid, 2.2, 2178.9387,-1660.8270,14.9413)) return 1;
	if(drug_amount[playerid] >= 15) return SendClientMessage(playerid, -1, """{ff353c}""У Вас максимальное кол-во наркотиков");

	if(CheckCash(playerid, 33*15) == false) return 1;
	Player__DownEXP(PlayerInfo[playerid][pID], 33*15, E_BUY_DRUGS_JOB, playerid);
	TOTAL_DRUGS -= 15;

	update_drug_text();

	drug_amount[playerid] += 15;

	format(drug_string, sizeof(drug_string), """{4eb9e6}""Вы закупили 15 гр. наркотиков за %d EXP", 33*15);
	SendClientMessage(playerid, -1, drug_string);
	SendClientMessage(playerid, -1, """{4eb9e6}""Ваша задача: ""{FFFFFF}""Развозить наркотики по гетто");

	for(new i = 0; i < 41; i++) {
		if(IsValidDynamicCP(point_sell[i])) {
			TogglePlayerDynamicCP(playerid, point_sell[i], true);
		}
	}
	return 1;
}

stock Dealer_OnGameModeInit() {
	totaldrug = Create3DTextLabel("_", 0xFFFFFFFF, 2178.9387,-1660.8270,14.9413+1, 40, 0);
	TOTAL_DRUGS = 45;
	update_drug_text();
	drughouse = CreateDynamicPickup(1279, 2, 2178.9387,-1660.8270,14.9413);

	for(new i = 0; i < 41; i++) {
		point_sell[i] = CreateDynamicCP(DrugSale[i][cor_X], DrugSale[i][cor_Y], DrugSale[i][cor_Z], 1.5, -1, -1, -1, 60);
	}
	return 1;
}

stock Dealer_OnPlayerEnterDynamicCP(playerid, checkpointid) {
	for(new i = 0; i < 41; i++)
	{
		if(checkpointid == point_sell[i] && IsValidDynamicCP(checkpointid))
		{
		    get_drugs_delivred(playerid);
			TogglePlayerDynamicCP(playerid, point_sell[i], false);
			return 1;
		}
	}
	return 0;
}
stock Dealer_OP_PickUpDynamicPickup(playerid, pickupid) {
	if(pickupid == drughouse) {
		get_drugs(playerid);
		return 1;
	}
	return 0;
}

stock Dealer_OnPlayerConnect(playerid) {
	drug_amount[playerid] = 0;

	for(new i = 0; i < 41; i++) {
		if(IsValidDynamicCP(point_sell[i])) {
			TogglePlayerDynamicCP(playerid, point_sell[i], false);
		}
	}

	return 1;
}

stock Dealer_OnPlayerDisconnect(playerid, reason) {
	#pragma unused reason
    drug_amount[playerid] = 0;
	if(IsValidTimer(buydrugs_Timer[playerid]))
	{
		ALS_KillTimer(buydrugs_Timer[playerid]);
		buydrugs_Timer[playerid] = -1;
	}

	for(new i = 0; i < 41; i++) {
		if(IsValidDynamicCP(point_sell[i])) {
			TogglePlayerDynamicCP(playerid, point_sell[i], false);
		}
	}
	return 1;
}


