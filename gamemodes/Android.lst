	for(new  i=_:_Y_ITER_C1:_Y_ITER_C2:sizeof  Player@YSII_Ag-1;_:( i=_:_Y_ITER_C0: Player@YSII_Ag[ i])!=_:_Y_ITER_C1:_Y_ITER_C2:sizeof  Player@YSII_Ag-1;)
	{
