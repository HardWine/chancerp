	format(small_string, sizeof(small_string), "Âű ńîáčđŕĺňĺńü ďĺđĺäŕňü ""{4eb9e6}""%s""{FFFFFF}"" %s, óęŕćčňĺ ęîëč÷ĺńňâî ďň.",
		weapon_names[current_weapon],
		PlayerInfo[recipient][pName]
	);

	return Dialog_Open(playerid, #DIALOG_GIVEGUN, 1,
		"Ďĺđĺäŕňü îđóćčĺ", small_string, "Ăîňîâî", "Îňěĺíŕ"
	);	
}

stock RemovePlayerWeapon(const playerid, const weaponid, const value) {
    new 
    	saveweapon[13], 
    	saveammo[13],
    	current_slot = -1;

    for(new slot = 0; slot < 13; slot++) {
 		GetPlayerWeaponData(playerid, slot, saveweapon[slot], saveammo[slot]);
 	}
 	RM_ResetPlayerWeapons(playerid);

    for(new slot; slot < 13; slot++) {
    	if(saveammo[slot] == 0) {
    		continue;
    	}

        if(saveweapon[slot] == weaponid) {
        	current_slot = slot;
            continue;
        }
 		RM_GivePlayerWeapon(playerid, saveweapon[slot], saveammo[slot]);
    }

    if(current_slot != -1) {
	    new 
	    	last_patr_slot = saveammo[current_slot];

	    last_patr_slot = last_patr_slot - value;

	    if(last_patr_slot > 0) {
	    	RM_GivePlayerWeapon(playerid, saveweapon[current_slot], last_patr_slot);
	    }
	}
}

forward dre_DIALOG_GIVEGUN(playerid, response, listitem, inputtext[]); public dre_DIALOG_GIVEGUN(playerid, response, listitem, inputtext[]) {
	if(!response) return 1;

	new weapon_verify = GetPVarInt(playerid, "weapon_selected");
	new ammo_verify = GetPVarInt(playerid, "ammo_selected");

	new current_weapon = GetPlayerWeapon(playerid);
	new recipient = GetPVarInt(playerid, "givegun");
	new slot_weapon = GetWeaponIDSlot(current_weapon);

	if(GetDistanceBetweenPlayerz(playerid, recipient, 5.00) != 1) return SendClientMessage(playerid, -1, """{FFAF00}""Âű ńëčřęîě äŕëĺęî îň óęŕçŕííîăî čăđîęŕ");

	if(slot_weapon == 0) return SendClientMessage(playerid, -1, """{FFAF00}""Íĺîáőîäčěî äĺđćŕňü â đóęŕő îđóćčĺ, đŕçđĺřĺííîĺ äë˙ ďĺđĺäŕ÷č");

	new get_weapons, get_ammo;

	GetPlayerWeaponData(playerid, slot_weapon, get_weapons, get_ammo);

	if(weapon_verify != current_weapon) SendClientMessage(playerid, -1, "(1) Îřčáęŕ!");
	if(ammo_verify	 != get_ammo)  SendClientMessage(playerid, -1, "(2) Îřčáęŕ!");

	new value = strval(inputtext);

	if(get_ammo < value) return SendClientMessage(playerid, -1, """{ff353c}""Ó Âŕń íĺň ńňîëüęî ďň.");
	if(value < 1 || value > 150) return SendClientMessage(playerid, -1, """{ff353c}""Óęŕćčňĺ ęîë-âî îň 1 äî 150");

	new pt = get_ammo-value;

	format(small_string, sizeof(small_string), "%d %d | %d %d | %d %d", weapon_verify, current_weapon, ammo_verify, get_ammo, pt, value);
	SendClientMessage(playerid, -1, small_string);	

	SetPlayerChatBubble(playerid, "ďĺđĺäŕë(ŕ) îđóćčĺ", 0xDD90FFFF, 30.0, 5000);
	format(small_string, sizeof(small_string), "%s ďĺđĺäŕë(ŕ) îđóćčĺ", PlayerInfo[playerid][pName]);
	ProxDetector(playerid, (20.00), 0xDD90FFFF, small_string);

	SetPlayerChatBubble(recipient, "âç˙ë(ŕ) îđóćčĺ", 0xDD90FFFF, 30.0, 5000);
	format(small_string, sizeof(small_string), "%s âç˙ë(ŕ) îđóćčĺ", PlayerInfo[recipient][pName]);
	ProxDetector(recipient, (20.00), 0xDD90FFFF, small_string);	

	RM_GivePlayerWeapon(recipient, current_weapon, value);

	RemovePlayerWeapon(playerid, current_weapon, value);


















	GetPlayerWeaponData(playerid, 2, PlayerInfo[playerid][slot_2_gun], PlayerInfo[playerid][slot_2_ammo]);
	GetPlayerWeaponData(playerid, 3, PlayerInfo[playerid][slot_3_gun], PlayerInfo[playerid][slot_3_ammo]);
	GetPlayerWeaponData(playerid, 4, PlayerInfo[playerid][slot_4_gun], PlayerInfo[playerid][slot_4_ammo]);
