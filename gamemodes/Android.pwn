				new QUERY[128];
				mysql_format(database,QUERY,sizeof(QUERY),"UPDATE "TABLE_ACCOUNTS" SET AuthPass = '0', Secured = '0' WHERE ID = '%d' LIMIT 1", GetPlayerAccountID(playerid));
				mysql_tquery(database, QUERY);
				PlayerInfo[playerid][pSecured] = 0;
			}
			return 1;
		}
		case dRegister:
