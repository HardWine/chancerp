};

stock AddPlayerLog(const playerid, const log_type, const format_string[], va_args<>)
{
	va_format(small_string, sizeof(small_string), format_string, va_start<3>);

	mysql_format(database, 
		big_string, sizeof(big_string), 
		"INSERT INTO `player_log` (`PlayerID`, `Action`, `Text`) VALUES (%i, %i, '%e');", 
		PlayerInfo[playerid][pID],
		log_type,
		small_string
	);
	printf(big_string);
	mysql_pquery(database, big_string);
}

