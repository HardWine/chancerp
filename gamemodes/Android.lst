	for(new i = 0; i < 99; i++) {

		if(total_b == 0) SetPVarInt(playerid, "business_n_1", i);
		if(total_b == 1) SetPVarInt(playerid, "business_n_2", i);
		if(total_b == 2) SetPVarInt(playerid, "business_n_3", i);

		if(BusinessInfo[i][OwnerID] != PlayerInfo[playerid][pID]) continue;
		total_b += 1;
