forward @yH_OnPlayerDisconnect@026(playerid, reason);@yH_OnPlayerDisconnect@026(playerid, reason) {
	#pragma unused reason

	PlayerAviationModel[playerid] = (-1);
	if(PlayerAviationVehicleID[playerid] != (0xFFFF) && IsValidVehicle(PlayerAviationVehicleID[playerid])) {
		Iter_DestroyVehicle(PlayerAviationVehicleID[playerid]);
	}
	PlayerAviationVehicleID[playerid] = (0xFFFF);
	PlayerAviationColor[playerid] = 1;
	PlayerSellAviaTime[playerid] = -1;
	if(PlayerCPSpawnAvia[playerid] != -1) {
		DestroyDynamicCP(PlayerCPSpawnAvia[playerid]);
		Streamer_Update(playerid, (2));
	}
	PlayerCPSpawnAvia[playerid] = -1;
	return (1);
}

