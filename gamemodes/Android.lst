	return 1;
}
public OnPlayerRequestClass(playerid, classid) {
	if(IsPlayerNPC(playerid)) return 1;
	ac_1{playerid} = true; 
	UpdateSpawnInfo(playerid);
	if(!GetPVarInt(playerid, "OnPlayerRequestClassFix"))
	{
		if(GetPVarInt(playerid, "OnPlayerRequestClass_F4_Bug")) return SpawnPlayer(playerid);
		TogglePlayerSpectating(playerid, true);
		SetTimerEx("TogglePlayerSpectatingOff", 500, 0, "i", playerid);
	}
	else {
	DeletePVar(playerid, "OnPlayerRequestClassFix");
	SpawnPlayer(playerid);   
	}
	return 1;
}
public OnPlayerDeath(playerid, killerid, reason)
{
	for(new  i=(_:F@n:F@A:(_:F@f:F@e:sizeof (Iterator@Admin ))-1);_:( i=Iterator@Admin [_: i])!=((_:F@f:F@e:sizeof (Iterator@Admin ))-1);)
	{
		SendDeathMessageToPlayer(i, killerid, playerid, reason);
	}

	if(PlayerArea[playerid] == true && PlayerInfo[killerid][pHours] > 3) {


		new 
			convert_platform_to_enum_value = 2;

		if(GetPVarInt(playerid, "mobile") == 1) {
			convert_platform_to_enum_value = 1;
		}

		if(killerid == (0xFFFF)) { 
			small_string[0] = EOS;
			format(small_string, sizeof(small_string), "INSERT INTO `dm_area`(`PlayerID`, `Type`, `Platform`, `Time`) VALUES (%i, 'Ńěĺđňü', %i, CURRENT_TIMESTAMP())", PlayerInfo[playerid][pID], convert_platform_to_enum_value);
			printf(small_string);
			mysql_pquery(database, small_string);
		} else if(PlayerArea[killerid] == true) { 


			format(small_string, sizeof(small_string), "~b~KILLED BY ~y~%s", PlayerInfo[killerid][pName]);
			GameTextForPlayer(playerid, small_string, 5000, 5);

			format(small_string, sizeof(small_string), "+1 ~b~KILL~w~~n~R.I.P. ~y~%s", PlayerInfo[playerid][pName]);
			GameTextForPlayer(killerid, small_string, 5000, 5);


			small_string[0] = EOS;
			format(small_string, sizeof(small_string), "INSERT INTO `dm_area`(`PlayerID`, `Type`, `Platform`, `Time`) VALUES (%i, 'Ńěĺđňü', %i, CURRENT_TIMESTAMP())", PlayerInfo[playerid][pID], convert_platform_to_enum_value);
			printf(small_string);
			mysql_pquery(database, small_string);

			format(small_string, sizeof(small_string), "INSERT INTO `dm_area`(`PlayerID`, `Type`, `Platform`, `Time`) VALUES (%i, 'Óáčéńňâî äđóăîăî čăđîęŕ', %i, CURRENT_TIMESTAMP())", PlayerInfo[killerid][pID], convert_platform_to_enum_value);
			printf(small_string);
			mysql_pquery(database, small_string);

			UpdatePlayerProgressQuest(killerid, E_ARENAS);
		}
		return 1;
	}


	if(GetPVarInt(playerid, "dialog_tuning")) {
		hide_tuning(playerid);
		DeletePVar(playerid, "dialog_tuning");
	}	
	RM_ResetPlayerWeapons(playerid);

	DelGuns(playerid);

	UpdateSpawnInfo(playerid);
	if(IsPlayerInRangeOfPoint(playerid, 10, 325.2081,2544.4429,17.1558)) {
		SetPVarInt(playerid, "deadbattle", 1);
	}
	CallLocalFunction("GPS_OnPlayerDeath", "i", playerid);
	if(GetPVarInt(playerid, "tempjob") != 0) {
		DeletePVar(playerid, "tempjob");
	}

	if(GetPVarInt(playerid, "oncapture") > 0) {
		new c_op = GetPVarInt(playerid, "opponent");

		printf("opponrnt: %d", c_op);

		capture_info[c_op][score] += 1;

		DeletePVar(playerid, "opponent");
		DeletePVar(playerid, "oncapture");

		if(killerid != (0xFFFF)) {
		AddPlayerAchievement(killerid, E_BATTLE_SQUARES);	
		}
	}
	SetTimerEx("fix_spawn", 250+GetPlayerPing(playerid), false, "i", playerid);
	return 1;
}
