forward pc_cmd_arena_exit(playerid, params[]); public pc_cmd_arena_exit(playerid, params[]) {
	if(PlayerArea[playerid] == true) {
		PlayerArea[playerid] = false;
		RM_SetPlayerPos(playerid, 960.5510, -48.5531, 1001.1172);
		SetPlayerFacingAngle(playerid, 180.00);
		SetPlayerVirtualWorld(playerid, 10);
		SetPlayerInterior(playerid, 3);
		RM_ResetPlayerWeapons(playerid);
		for (new i = 0; i < sizeof(SavePlayerWeapon[]); i++) {
		    RM_GivePlayerWeapon(playerid, SavePlayerWeapon[playerid][i][0], SavePlayerWeapon[playerid][i][1]);
		}

		for(new i = 0; i < sizeof(SavePlayerWeapon[]); i++) {
			SavePlayerWeapon[playerid][i][0] = 0;
			SavePlayerWeapon[playerid][i][1] = 0;
		}

		SetPlayerHealth(playerid, SavePlayerHealth[playerid]);
		SetPlayerArmour(playerid, SavePlayerArmour[playerid]);

		return SendClientMessage(playerid, -1, """{6de64e}""Âű ďîęčíóëč ŕđĺíó");
	}
	return SendClientMessage(playerid, -1, """{FFAF00}""Âű äîëćíű íŕőîäčňüń˙ íŕ ŕđĺíĺ");
}

forward dcr_DIALOG_SELECT_SPAWN(playerid); public dcr_DIALOG_SELECT_SPAWN(playerid) {
	return Dialog_Open(playerid, #DIALOG_SELECT_SPAWN, 0,
		"""{4eb9e6}""Äîáđî ďîćŕëîâŕňü!", 
		"""{4eb9e6}""Ěčđ""{FFFFFF}"" - Ďî˙âčňüń˙ â îáű÷íîě ěčđĺ, äë˙ đîëĺâîé čăđű\n""{FFAF00}""Ŕđĺíŕ""{FFFFFF}"" - Ďĺđĺěĺńňčňüń˙ â ëîááč ŕđĺíű äë˙ ńđŕćĺíčé",
		"Ěčđ", "Ŕđĺíŕ"
	);
}

forward dre_DIALOG_SELECT_SPAWN(playerid, response, listitem, inputtext[]); public dre_DIALOG_SELECT_SPAWN(playerid, response, listitem, inputtext[]) {
	if(!response) {
		TogglePlayerSpectating(playerid, false);
		SetPVarInt(playerid, "first_spawn", 1);
	} else {

		TogglePlayerSpectating(playerid, false);	
	}

	new DaysAgo = GetPlayerDaysWithoutActivity(PlayerInfo[playerid][pID]);

	format(small_string, sizeof(small_string), """{4eb9e6}""Ďîńëĺäíčé âőîä: ""{FFFFFF}""%d ""{4eb9e6}""äí. íŕçŕä", DaysAgo);

	if(DaysAgo == 0) format(small_string, sizeof(small_string), """{4eb9e6}""Ďîńëĺäíčé âőîä: ""{FFFFFF}""ńĺăîäí˙", DaysAgo);
	if(DaysAgo == 1) format(small_string, sizeof(small_string), """{4eb9e6}""Ďîńëĺäíčé âőîä: ""{FFFFFF}""â÷ĺđŕ", DaysAgo);
	if(DaysAgo == 2) format(small_string, sizeof(small_string), """{4eb9e6}""Ďîńëĺäíčé âőîä: ""{FFFFFF}""ďîçŕâ÷ĺđŕ", DaysAgo);


	SendClientMessage(playerid, -1, small_string);

	if(DaysAgo >= 30 && PlayerInfo[playerid][pHours] > 5) {
		GivePlayerPremiumAccount(playerid, 7, 0);
		Dialog_Show(playerid, #DIALOG_FREE_PREMIUM);
	} else {
		ActivatePremium(playerid);
	}

	CallLocalFunction("UpdateLastDay", "i", playerid);

	return 1;
}
