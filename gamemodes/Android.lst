	if(total_b == 0) return SendClientMessage(playerid, -1, "Âű íĺ âëŕäĺĺňĺ áčçíĺńŕěč"); 

	Dialog_Open(playerid, #BusinessManage, 5,
        "Áčçíĺńű",
        business_string,
        "OK", "Çŕęđűňü");
	return 1;
}

