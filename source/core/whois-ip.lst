static stock Hooks_Ordinal(n)
{
	new str[8];
	valstr(str, n);
	switch (n % 100)
	{
	case 11, 12, 13:
		strcat(str, "th");
	default:
		switch (n % 10)
		{
		case 1:
			strcat(str, "st");
		case 2:
			strcat(str, "nd");
		case 3:
			strcat(str, "rd");
		default:
			strcat(str, "th");
		}
	}
	return str;
}

