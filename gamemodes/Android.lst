forward @yH_OnPlayerDialogShowed@015(const playerid, const e_DIALOG_IDs:dialogid, const response, const listitem, const inputtext[]);@yH_OnPlayerDialogShowed@015(const playerid, const e_DIALOG_IDs:dialogid, const response, const listitem, const inputtext[]) {
    if(dialogid == dBuyCar) 
    {
    	if(response) {
    		BuyCar(playerid);
    	}
    	return 1;
    }
    return 1;
}
stock BuyCar(playerid) {
	new selectedcar = GetPVarInt(playerid, "VehToBuy");
	if(!selectedcar) return SendClientMessage(playerid, -1, """{FFAF00}""Ńíŕ÷ŕëŕ íĺîáőîäčěî ńĺńňü çŕ đóëü ďîíđŕâčâřĺăîń˙ ŕâňîěîáčë˙");
	new vehprice = GetPVarInt(playerid, "PriceToBuy");
	DeletePVar(playerid, "VehToBuy");
	DeletePVar(playerid, "PriceToBuy");
	if(CheckCash(playerid, vehprice) == false) return 1;
	RemovePlayerEXP(playerid, vehprice, "Ďđčîáđĺňĺíčĺ ŕâňîěîáčë˙ (modelid %i)", selectedcar);
	format(small_string, sizeof(small_string), "~r~-%d ~w~EXP", vehprice);
	GameTextForPlayer(playerid, small_string, 3000, 5);


	SendClientMessage(playerid, -1, """{6de64e}""Ďîçäđŕâë˙ĺě! Âű ďđčîáđĺëč íîâűé ňđŕíńďîđň");
	SendClientMessage(playerid, -1, """{6de64e}""Ňđŕíńďîđň ďŕđęóĺňń˙ ó íĺäâčćčěîńňč, äë˙ ĺăî čńďîëüçîâŕíč˙ âŕě íóćĺí äîě");
	SendClientMessage(playerid, -1, """{4eb9e6}""Äîěŕ îň ńđĺäíĺăî ęëŕńńŕ ďîçâîë˙ţň čěĺňü äâŕ ŕâňî {FFFFFF}(/cars)");

	if(PlayerInfo[playerid][pSelectedSlot] == 1) {
		PlayerInfo[playerid][pCar] = selectedcar;
		SetPlayerInt(playerid, "Car", PlayerInfo[playerid][pCar]);
		PlayerInfo[playerid][pMileage] = 0;
		SetPlayerInt(playerid, "Mileage", PlayerInfo[playerid][pMileage]);
