DialogCreate:AutoPassport(playerid) {

	Dialog_Open(playerid, Dialog:AutoPassport, DIALOG_STYLE_INPUT,
        "Оформление паспорта",
        ""COLOR_WHITE"Введите ваш год рождения (диапазон: 1920-1974)",
        "Далее", "Отмена");	

}

DialogResponse:AutoPassport(playerid, response, listitem, inputtext[]) {
	if(!response) {
		return 1;
	} else {
		new strval_inputtext = strval(inputtext);

		if(strval_inputtext >= 1920 && strval_inputtext <= 1974) {
			PlayerInfo[playerid][pBirth] = strval_inputtext; 
			SetPlayerInt(playerid, "Birth", PlayerInfo[playerid][pBirth]);
			DeletePVar(playerid, "gov_payment");
			callcmd::me(playerid, "получил(а) паспорт гражданина штата San Andreas");
			callcmd::pass(playerid, "");
			return 1;
		} else {
			return Dialog_Show(playerid, Dialog:AutoPassport);
		}	
	}
}


DialogCreate:PassPayment(playerid) {

	Dialog_Open(playerid, Dialog:PassPayment, DIALOG_STYLE_MSGBOX,
        "Государственная пошлина",
        ""COLOR_WHITE"Оплатить пошлину на получение паспорта размером "COLOR_GREEN"500 EXP?",
        "Да", "Нет");	

}

DialogResponse:PassPayment(playerid, response, listitem, inputtext[]) {
	if(!response) {
		DeletePVar(playerid, "payment_check");
		DeletePVar(playerid, "gov_payment");
		return 1;
	} else {
		if(CheckCash(playerid, 500) == false) return 1;
		RemovePlayerEXP(playerid, 500, "Оплата пошлины за утерю паспорта");		
		SetPVarInt(playerid, "gov_payment", 1);	
		DeletePVar(playerid, "payment_check");
		SendClientMessage(playerid, -1, ""COLOR_GREEN"Вы оплатили пошлину, возвращайтесь в мэрию для получения паспорта");
		SendClientMessage(playerid, -1, "(( Оплаченная пошлина будет действительна до конца текущей игровой сессии! ))");
		callcmd::me(playerid, "оплатил(а) государственную пошлину");
	}
	return 1;
}

CMD:spy(playerid, params[]) {
	if(GetPVarInt(playerid,"keek_status") == 1) return SendClientMessage(playerid, -1, "(( Чтобы прекратить слежку введите: /stopspy ))");

	if(GetPVarInt(playerid,"SpyActive") > gettime()) return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Нельзя использовать слежку так часто");

	if(GetPlayerFraction(playerid) != FRACTION_FBI) return 1;
	if(GetPlayerJobDayStatus(playerid) == false)
	{
		return SendClientMessage(playerid, -1, MSG_START_JOB_DAY);
	}
	if(PlayerInfo[playerid][pRank] < 7) return SendClientMessage(playerid, -1, ""COLOR_RED"Шпионаж доступен с 7 ранга");

	if(sscanf(params,"d", params[0])) return SendClientMessage(playerid, -1, ""COLOR_RED"Введите ID игрока для принятия его внешнего вида");
	if(PlayerLogged{params[0]} == false || !IsPlayerConnected(params[0])) {
		return SendClientMessage(playerid, -1, ""COLOR_RED"Данного игрока нет в сети");
	}		
	if(GetPlayerAdminLevel(params[0]) > 0) return 1;
	if(GetPlayerFraction(params[0]) == FRACTION_FBI) return 1;

	SetPVarInt(playerid,"SpyActive",gettime()+300);

	SetPlayerSkin(playerid, GetPlayerSkin(params[0]));
	SetPlayerColor(playerid, GetPlayerColor(params[0]));

	SPD(playerid, dKickMessage, DIALOG_STYLE_MSGBOX, "Шпионаж", ""COLOR_WHITE"Вы успешно приняли вид выбранного человека", "Окей", "");
	SendClientMessage(playerid, -1, "(( Маскировка завершится при выходе из игры или смерти персонажа ))");
	
	new Fraction:fractionid = GetPlayerFraction(playerid),
		Fraction:target_fractionid = GetPlayerFraction(params[0]);

	format(small_string, sizeof(small_string), ""COLOR_BLUE"%s начал шпионаж. Образ: "COLOR_WHITE"'%s'", PlayerInfo[playerid][pName], (target_fractionid == FRACTION_NONE) ? ("Гражданский") : FractionTitle[_:target_fractionid-1]);
	SendFamilyMessage(fractionid, -1, small_string);

	SetPVarInt(playerid, "keek_status", 1);
	return 1;
}
CMD:stopspy(playerid, params[]) {

	if(GetPlayerFraction(playerid) != FRACTION_FBI) return 1;
	if(PlayerInfo[playerid][pRank] < 7) return 1;	

	CBackSkin(playerid);
	DeletePVar(playerid, "keek_status");

	SPD(playerid, dKickMessage, DIALOG_STYLE_MSGBOX, "Шпионаж", ""COLOR_WHITE"Вы успеншно завершили шпионаж", "Окей", "");
	return 1;
}
