	format(small_string, sizeof(small_string), "VIEW INTERIOR HOUSE ~g~~h~%i", time);
	GameTextForPlayer(playerid, small_string, 1200, 5);

	Player__ViemTime{playerid}--;
	if(time > 0) {
		(J@=0,I@=-1,Timer: ViewInteriourHouse_yT@(playerid));
		return 1;
	} else {
		House_UnLinkPlayer(playerid);
		return 0;
	}
}

@yH_OnPlayerAuthorization@005(playerid);@yH_OnPlayerAuthorization@005(playerid) {
	new 
		player_id = PlayerInfo[playerid][pID];

	for(new i = 0; i < (690); i++) {
		if(HouseInfo[i][E_HOUSE_OWNER] == player_id) {
			Player__House[playerid] = i;
			CheckHouseRentDay(playerid);
			break;
		}
	}
}

stock CheckHouseRentDay(playerid) {
	new 
		player_house = Player__House[playerid];

	if(player_house == (-1)) {
		return false;
	}

	new 
		rent_day = HouseInfo[player_house][E_HOUSE_RENT_DAY];

	if(rent_day <= 3) {
		format(small_string, sizeof(small_string), 
			"""{ff353c}""У вашего дома, осталось мало оплаченных дней (%i дн.)", 
				rent_day
		);
	} else {
		format(small_string, sizeof(small_string), 
			"""{FFAF00}""У вашего дома, осталось %i оплаченных дней.", 
					rent_day
		);
	}
	SendClientMessage(playerid, -1, small_string);
	SendClientMessage(playerid, -1, """{ff353c}""Оплатите дом в банке, во избежание дальнейшей продажи дома государству.");
	return true;
}

stock bool:IsPlayerInHouse(const playerid) {
	return (Player__House[playerid] == (-1)) ? false : true;
}

stock GetPlayerHouse(const playerid) {
	return Player__House[playerid];
}

forward Dialog_BuyHouse(const playerid, const arrayID);
public Dialog_BuyHouse(const playerid, const arrayID) {
	format(big_string, sizeof(big_string), 
#line 406
		"""{FFFFFF}""Номер дома: ""{6de64e}""%i""{FFFFFF}""\nВладелец: %s%s""{FFFFFF}""\nЦена: ""{6de64e}""%i$""{FFFFFF}""\nКласс: ""{6de64e}""%s""{FFFFFF}""\n\n""{FFAF00}""1. Для покупки дома, введите цифру 1\n2. Для просмотра интерьера дома, введите цифру 2", 
		HouseInfo[arrayID][E_HOUSE_ID],
		(HouseInfo[arrayID][E_HOUSE_OWNER] == (-1)) ? ("""{6de64e}""") : ("""{FFAF00}"""),
		HouseInfo[arrayID][E_HOUSE_OWNER_NAME],
		HouseInfo[arrayID][E_HOUSE_PRICE],
		House_Class[HouseInfo[arrayID][E_HOUSE_CLASS] - 1]
	);
	return MDialog_ShowPlayerDialog(playerid, 
		DIALOG_BUY_HOUSE, 1, 
		!"""{4eb9e6}""Информация о доме",
		big_string,
		!"Далее", !"Закрыть"
	);
}

@yH_OnPlayerDialogShowed@005(const playerid, const dialogid, const response, const listitem, const inputtext[]);@yH_OnPlayerDialogShowed@005(const playerid, const dialogid, const response, const listitem, const inputtext[]) {
	if(dialogid == DIALOG_BUY_HOUSE) {
		if(!response) {
			return (-2);
		} else {
			new
				strval_value = strval(inputtext),
				arrayID = Player__EnterHouse[playerid];

			if(arrayID == (-1)) {
				return (-2);
			}

			if(strval_value == 1) {
				if(Player__House[playerid] != (-1)) {
					SendClientMessage(playerid, -1, "У вас уже есть дом.");
					return (-2);
				}
				if(HouseInfo[arrayID][E_HOUSE_OWNER] != (-1)) {
					SendClientMessage(playerid, -1, "Дом уже куплен другим игроком.");
					return (-2);
				}
				if(CheckCash(playerid, HouseInfo[arrayID][E_HOUSE_PRICE]) == false) return (-2);

				Player__DownEXP(PlayerInfo[playerid][pID], HouseInfo[arrayID][E_HOUSE_PRICE], E_BUY_HOUSE, playerid);
				House_SetOwner(arrayID, PlayerInfo[playerid][pID], PlayerInfo[playerid][pName]);
				House_LinkPlayer(playerid, arrayID);
				return (-2);
			} else if(strval_value == 2) {
				Player__ViemTime{playerid} = (10);
				ViewInteriourHouse(playerid);
				House_LinkPlayer(playerid, arrayID);
				return (-2);
			} else {
				Dialog_BuyHouse(playerid, arrayID);
				return (-2);
			}
		}
	} else if(dialogid == DIALOG_CMD_HOUSE) {
		if(!response) {
			return (1);
		}

		new 
			strval_value = strval(inputtext),
			arrayID = Player__House[playerid];

		if(strval_value == 1) {
			House_SwitchClossed(arrayID);
			Dialog_CMD_House(playerid);
			return (-2);
		}
	}
	return (1);
}

forward pc_cmd_home(playerid, params[]); public pc_cmd_home(playerid, params[]) {
	if(IsPlayerInHouse(playerid) == false) {
		return SendClientMessage(playerid, -1, """{ff353c}""У вас нет дома");
	}

	new 
		houseID = GetPlayerHouse(playerid);

	Dialog_CMD_House(houseID);
	return 1;
}

forward Dialog_CMD_House(playerid);
public Dialog_CMD_House(playerid) {
	new 
		arrayID = Player__House[playerid];

	if(arrayID == (-1)) {
		return SendClientMessage(playerid, -1, """{ff353c}""У вас нет дома.");
	}

	format(small_string, sizeof(small_string), 
#line 500
		"""{FFFFFF}""1. %s\n""{FFFFFF}""2. Использовать аптечку (%i шт.)", 
		(HouseInfo[arrayID][E_HOUSE_CLOSSED] == 0) ? ("""{ff353c}"" Закрыть двери") : ("""{6de64e}""Открыть двери"),
		HouseInfo[arrayID][E_HOUSE_MED_CHEST]
	);
	return SPD(playerid, 
		DIALOG_CMD_HOUSE, 1, 
		"""{4eb9e6}""Информация о доме", 
		small_string, 
		"Выбрать", "Закрыть"
	);
}
