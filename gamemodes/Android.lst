stock GetNearestVehicle(playerid)
{
	for(new i=1,Float:x,Float:y,Float:z; i<1200; ++i)
	{
		if(IsVehicleStreamedIn(i, playerid))
		{
			GetVehiclePos(i, x, y, z);
			if(IsPlayerInRangeOfPoint(playerid, 3.0, x, y, z)) return i;
		}
	}
	return 0;
}
