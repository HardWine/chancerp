			new
				distance = min(
					matrix[j + 1] + 1     ,                          min(
					matrix[j] + 1         ,                         
					prev + _:(b[i] != a[j])                          )
				);
			prev = matrix[j + 1];
			matrix[j + 1] = distance;
		}
	}
	return matrix[lenA];
}









stock LevenshteinDistance(const a[], const b[])
{
