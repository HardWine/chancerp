stock GetAmxAddress() {
	static address = 0;
	if (address == 0) {
		static const code[] = {
			0x90909090, 0x90909090, 0x90909090, 0x90909090, 
			0x0424448b, 0xC3C3C3C3


		};
		address = RunShellcode(refabs(code));
	}
	return address;
}


