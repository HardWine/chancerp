static stock YHNPS_Find(heap, end, value)
{
	new
		start = 0,
		mid;
	--end;
	while (start <= end)
	{
		mid = (start + end) / 2;
		new
			diff = value - AMX_Read(heap + mid * 8);
		if (diff < 0)
		{
