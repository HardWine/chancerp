stock chrfind(needle, haystack[], start = 0)
{
	
	if (start < 0)
	{
		start = 0;
	}
	else if (start > MDialog_strlen(haystack)) return -1;
	while (haystack[start]) if (haystack[start++] == needle) return start - 1;
	return -1;
}

