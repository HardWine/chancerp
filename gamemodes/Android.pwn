DialogCreate:GetCarTriad(playerid) {

		if(Platform[playerid] == 0) {
		Dialog_Open(playerid, Dialog:GetCarTriad, DIALOG_STYLE_INPUT,
	        "Гараж",
	        "Elegy\nSentinel\nStretch"INPUT_NUMBER"",
	        "Вызов", "Отмена");
		} else {
			Dialog_Open(playerid, Dialog:GetCarTriad, DIALOG_STYLE_LIST,
	        "Гараж",
	        ""COLOR_WHITE"Elegy\nSentinel\nStretch",
	        "Вызов", "Отмена");
		}
