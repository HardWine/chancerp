static stock Opcode:ReadOpcodeNearThis(offset = 0) {
	new ret_addr;


	#emit load.s.alt 4
	#emit lctrl 0
	#emit add
	#emit move.alt
	#emit lctrl 1
	#emit xchg
	#emit sub
	#emit load.s.alt offset
	#emit add

	#emit stor.s.pri ret_addr
	#emit lref.s.pri ret_addr

	#emit stack 4
	#emit retn

	return OP_NONE; 
}

static stock bool:HaveToRelocateOpcodes() {
