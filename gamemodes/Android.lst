				        if(PlayerInfo[playerid][pSex] != 0) {
				        	SetPlayerSkin(playerid, 172);
				        } else {
				        	SetPlayerSkin(playerid, 171);
				        }

						SetCasinoCroupier(CasinoInfo[i][CI_Table_ID], playerid);
						return 1;
					} else {
						SendClientMessage(playerid, -1, """{FFAF00}""У этого столика уже есть крупье.");
						return 1;
					}
				}
			}
		}
	}
	return 0;
