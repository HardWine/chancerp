public OnQueryError(errorid, error[], callback[], query[], connectionHandle)
{
	printf("OnQueryError errorid %i,  error[] = %s, callback[] = %s, query[] = %s, connectionHandle = %i", errorid, error, callback, query, connectionHandle);
	switch(errorid)
	{
		case CR_SERVER_GONE_ERROR:
		{
			printf("Lost connection to server");
		}
		case ER_SYNTAX_ERROR:
		{
			printf("Something is wrong in your syntax, query: %s",query);
		}
	}
	return 1;
}

stock GetPlayerDaysWithoutActivity(const account_id) {
	mysql_format(database,
	small_string, sizeof(small_string),
	"SELECT TIMESTAMPDIFF(DAY, `LastDate`, NOW()) AS Day FROM `players` WHERE ID = %i LIMIT 1",
	account_id
	);
	mysql_query(database, small_string, true);

	new
	rows = cache_get_row_count();

	if(rows == 0) {
	return 0;
	} else {
		return cache_get_field_content_int(0, "Day");
	}
}


stock LoadAccounts(playerid) {
	GetPlayerName(playerid, PlayerInfo[playerid][pName], MAX_PLAYER_NAME+1);

	new name[MAX_PLAYER_NAME + 1];
	GetPlayerName(playerid, name, MAX_PLAYER_NAME);
	new string[144];
	mysql_format(database, string, sizeof(string), "SELECT `Password` FROM "TABLE_ACCOUNTS" WHERE `Name` = '%e' LIMIT 1", name);
	printf(string);
	mysql_tquery(database, string, "FindPlayerInTable","i", playerid);
	return 1;
}
forward FindPlayerInTable(playerid);
public FindPlayerInTable(playerid)
{
	new rows = cache_get_row_count();
	if(!rows)
	{
		if(IsRpNickname(PlayerInfo[playerid][pName]) == 0)
		{
			SendClientMessage(playerid, -1, ""COLOR_RED"Используйте ник формата: {FFFFFF}Имя_Фамилия");
			return ShowPlayerDialog(playerid, dName, DIALOG_STYLE_INPUT, "Добро пожаловать!", "Введите ваш ник (Используйте формат: Имя_Фамилия)", "Далее", "");
		}		
		InterpolateCameraPos(playerid, -1837.003540, 13.019827, 1061.618530, -1820.481445, 14.647293, 1061.661132, 600000);
		InterpolateCameraLookAt(playerid, -1837.070190, 18.019355, 1061.601684, -1823.374633, 18.696737, 1061.180175, 600000);
		SetPlayerInterior(playerid, 1);
		PlayerPlaySound(playerid, 1185,0,0,0);
		ShowPlayerDialog(playerid, dRegister, DIALOG_STYLE_INPUT, "Регистрация на Chance RolePlay", "{FFFFFF}Добро пожаловать на первый кроссплатформенный сервер "COLOR_RED"Chance RolePlay\n{FFFFFF}На нашем сервере можно играть с Android устройств! Подробнее на ChanceRp.Ru\n\nВведите пароль для регистрации нового аккаунта", "Далее", "Выход");
	}
	else
	{
		/*
		InterpolateCameraPos(playerid, 81.122398, -1932.470092, 27.765895, 322.160278, -1831.970214, 28.446659, 30000);
		InterpolateCameraLookAt(playerid, 86.105430, -1932.268920, 27.406829, 322.265502, -1826.974853, 28.634115, 30000);
		*/
		SetPlayerInterior(playerid, 1);
		InterpolateCameraPos(playerid, -729.544677, 516.456726, 1395.859130, -974.603881, 421.461975, 1365.758666, 180000);
		InterpolateCameraLookAt(playerid, -733.823913, 513.959167, 1395.188110, -970.295471, 423.991180, 1365.556762, 180000);

		//SetPlayerVirtualWorld(playerid, playerid+1);
		/*InterpolateCameraPos(playerid, 1521.565307, -49.093311, 1003.626708, 1526.929931, -48.205944, 1003.581115, 600000);
		InterpolateCameraLookAt(playerid, 1524.309448, -44.954540, 1003.043334, 1524.135375, -44.179340, 1002.592773, 600000);
		*/
		//SetPlayerInterior(playerid, 2);
		//if(Platform[playerid] != 0) PlayerPlaySound(playerid, 1097,0,0,0);
		ShowPlayerDialog(playerid, dLogin, DIALOG_STYLE_INPUT, "Вход в аккаунт", "{FFFFFF}Добро пожаловать на первый кроссплатформенный сервер "COLOR_RED"Chance RolePlay\n{FFFFFF}Введите пароль от аккаунта для того, чтобы продолжить игру:", "Вход", "Закрыть");
		cache_get_field_content(0, "Password", PlayerInfo[playerid][pPassword]);
	}
	return 1;
}
ReturnUser(text[])
{
	new pos = 0;
	while (text[pos] < 0x21) // Strip out leading spaces
	{
		if (text[pos] == 0) return INVALID_PLAYER_ID; // No passed text
		pos++;
	}
	new userid = INVALID_PLAYER_ID;
	if (IsNumeric(text[pos])) // Check whole passed string
	{
		// If they have a numeric name you have a problem (although names are checked on id failure)
		userid = strval(text[pos]);
		if (userid >=0 && userid < MAX_PLAYERS)
		{
			if(!IsPlayerConnected(userid))
			{
				userid = INVALID_PLAYER_ID;
			}
			else
			{
				return userid; // A player was found
			}
		}
	}
	// They entered [part of] a name or the id search failed (check names just incase)
	new len = strlen(text[pos]);
	new count = 0;
	new name[MAX_PLAYER_NAME];
	for (new i = 0; i < MAX_PLAYERS; i++)
	{
		if (IsPlayerConnected(i))
		{
			GetPlayerName(i, name, sizeof (name));
			if (strcmp(name, text[pos], true, len) == 0) // Check segment of name
			{
				if (len == strlen(name)) // Exact match
				{
					return i; // Return the exact player on an exact match
					// Otherwise if there are two players:
					// Me and MeYou any time you entered Me it would find both
					// And never be able to return just Me's id
				}
				else // Partial match
				{
					count++;
					userid = i;
				}
			}
		}
	}
	if (count != 1)
	{
		userid = INVALID_PLAYER_ID;
	}
	return userid; // INVALID_USER_ID for bad return
}
IsNumeric(const string[])
{
	for (new i = 0, j = strlen(string); i < j; i++)
	{
		if (string[i] > '9' || string[i] < '0') return 0;
	}
	return 1;
}/*
SaveGZ(frac, he)
{
	new query[90];
	mysql_format(database, query, sizeof(query), "UPDATE gz SET fraction = %i WHERE id = %i LIMIT 1",frac, he);
	mysql_pquery(database, query, "", "");
	return true;
}*/
GetGangName(fnumbwer)
{
	new string[40];
	switch(fnumbwer)
	{
		case 3: format(string,sizeof(string), "Ballas Gang");
		case 4: format(string,sizeof(string), "Vagos Gang");
		case 2: format(string,sizeof(string), "Grove Street");
		case 6: format(string,sizeof(string), "Aztecas");
		case 5: format(string,sizeof(string), "Rifa Gang");
		case 7: format(string,sizeof(string), "Russian Mafia");
		case 8: format(string,sizeof(string), "Triads Mafia");
		case 9: format(string,sizeof(string), "Da Nang Boys");

	}
	return string;
}

public OnGameModeExit()
{
	foreach(new i: Player) {
		OnPlayerDisconnect(i, 255);
	}
	DestroyAllDynamicPickups();
	DestroyAllDynamicCPs();
	DestroyAllDynamicObjects();
	DestroyAllDynamicMapIcons();
	DestroyAllDynamic3DTextLabels();
	DestroyAllDynamicAreas();
	mysql_close(database);
	return 1;
}

forward CheckBannedIp(playerid);
public CheckBannedIp(playerid) {
	new rows = cache_get_row_count();
	if(rows)
	{
		SendClientMessage(playerid, -1, ""COLOR_RED"Ваш IP Адрес заблокирован. Попробуйте зайти в игру позже");
		//SendClientMessage(playerid, -1, ""COLOR_RED"Попробуйте зайти в игру позже");
		Kick(playerid);
	} else {
		
		SetPVarInt(playerid, "OnPlayerRequestClassFix", 1);
		requestt[playerid] = KillTimer(requestt[playerid]);
		requestt[playerid] = SetTimerEx("SetPlayerCameraPosForReqClass", GetPlayerPing(playerid) + 500, 0, "i", playerid);
	}
}


public OnPlayerConnect(playerid)
{
	AD_OnPlayerConnect(playerid);

	PlayerInfo[playerid] = NULL_PlayerInfo;
	PlayerLogged{playerid} = false;
	RemObject(playerid);
	GetPlayerIp(playerid, ipsget[playerid], MAX_LENGTH_IP);

	Client[playerid] = 0;
	gpci(playerid, Client[playerid], 45);

	new sendername[MAX_PLAYER_NAME+1];
	GetPlayerName(playerid, sendername, sizeof(sendername));

	if(!strcmp(Client[playerid], ""updated_client"") || strcmp(Client[playerid], "44355A5834564C393054584655524D4F52584B41") == false) {	
		SetPVarInt(playerid, "mobile", 1);

		if(IsRpNickname(sendername) == 0) {
			SetPVarInt(playerid, "mobile_client", 1);
			SendClientMessage(playerid, -1, ""COLOR_ORANGE"Чтобы каждый раз не вводить ник, укажите его в "COLOR_WHITE"settings.ini");
			SendClientMessage(playerid, -1, ""COLOR_ORANGE"В папке "COLOR_WHITE"'andoid/data/com.rockstargames.gtasa/files/SAMP'");
			ShowPlayerDialog(playerid, dName, DIALOG_STYLE_INPUT, "Добро пожаловать!", "Введите ваш ник (Используйте формат: Имя_Фамилия)", "Далее", "");
		} 
		else 
		{
			LoadAccounts(playerid);
		}
	} 
	else 
	{
		LoadAccounts(playerid);
	}
	OnPlayerConnect_textdraw(playerid);

	TogglePlayerSpectating(playerid, true);//Собстно, начало обхода

	new query_string[144];
	mysql_format(database, query_string, sizeof(query_string), "SELECT * FROM "TABLE_BANIP" WHERE `IP` = '%s'", ipsget[playerid]);
	mysql_tquery(database, query_string, "CheckBannedIp","i", playerid);	

	ac_1{playerid} = false; 

	SetPlayerVirtualWorld(playerid, playerid+333);
	
	gettime(hour, minute, seconds);
	
	PlayerTimerID[playerid] = KillTimer(PlayerTimerID[playerid]);
	PlayerTimerID[playerid] = SetTimerEx("PlayerUpdate", 1000, false, "d", playerid);
	
	secure[playerid] = 0;
	SetPVarInt(playerid, "mate", -1);

	cabClient[playerid] = INVALID_PLAYER_ID;
	gonecar[playerid] = INVALID_VEHICLE_ID;
	Dealer_OnPlayerConnect(playerid);
	Porter_OnPlayerConnect(playerid);
	CallLocalFunction("Fraction_OnPlayerConnect", "i", playerid);
	CallLocalFunction("Gps_OnPlayerConnect", "i", playerid);
	CallLocalFunction("Army_OnPlayerConnect", "i", playerid);

	SetPVarInt(playerid, "SellingCar", -1);
	SetPVarInt(playerid, "CarOffer", -1);

	pPickup_Status{playerid} = false;  

	DamageTaken[playerid] = 0;

	PlayerInfo[playerid][slot_2_gun] = 0;
	PlayerInfo[playerid][slot_2_ammo] = 0;
	PlayerInfo[playerid][slot_3_gun] = 0;
	PlayerInfo[playerid][slot_3_ammo] = 0;
	PlayerInfo[playerid][slot_4_gun] = 0;
	PlayerInfo[playerid][slot_4_ammo] = 0;
	PlayerInfo[playerid][slot_5_gun] = 0;
	PlayerInfo[playerid][slot_5_ammo] = 0;
	PlayerInfo[playerid][slot_8_gun] = 0;
	PlayerInfo[playerid][slot_8_ammo] = 0;	

	Player.MafiaCP[playerid] = INVALID_DYNAMIC_CP;
	Player.SteelCar[playerid] = INVALID_DYNAMIC_CP;
	Player.FarmCP[playerid] = INVALID_DYNAMIC_CP;
	Player.PatrolCP[playerid] = INVALID_DYNAMIC_CP;
	Streamer_Update(playerid, STREAMER_TYPE_CP);
	GangZoneShowForPlayer(playerid,gangzone,0xFF7F0066); // 51

	carry[playerid] = -1;
	gone[playerid] = -1;
	PlayerCar[playerid] = -1;
	CarColor[playerid] = -1;
	CarColor2[playerid] = -1;
	player_Patrol[playerid] = -1;
	ReturnTimerID[playerid] = KillTimer(ReturnTimerID[playerid]); 
	caridhouse[playerid] = INVALID_VEHICLE_ID;
	spectating[playerid] = INVALID_PLAYER_ID;
	Platform[playerid] = -1;
	for(new i = 0; i < 20; i++) {
		SendClientMessage(playerid, -1, ""COLOR_RED"");
	}
	SendClientMessage(playerid, -1, ""COLOR_BLUE"Добро пожаловать на первый кроссплатформенный проект в "COLOR_WHITE"San Andreas Multiplayer");
	SendClientMessage(playerid, -1, ""COLOR_BLUE"Посетите наше сообщество Вконтакте: "COLOR_WHITE"vk.com/ChanceRp");
	format(small_string,
		sizeof(small_string),
		""COLOR_BLUE"Текущий онлайн на Chance RolePlay: "COLOR_WHITE"%d игроков",
		Iter_Count(Player));
	SendClientMessage(playerid, -1, small_string);
	
	printf("%s", Client[playerid]);
	
	for(new i = 0; i < sizeof(update_gpci); i++)
	{
		if(strcmp(Client[playerid], update_gpci[i], false) == 0)
		{
			ShowPlayerDialog(playerid, DIALOG_INFO, DIALOG_STYLE_MSGBOX, 
				""COLOR_BLUE"Обновление клиента",
				""COLOR_WHITE"Вышло обновление! Мы работаем чтобы ваша игра была приятнее\n\
					Необходимо обновить клиент. Узнайте как, в нашей группе:\n\
					"COLOR_GREEN"vk.com/chancerp", 
				"Закрыть", ""
			);	
			return Kick(playerid);
		}
	}
					
	if(Platform[playerid] == -1) {
		Platform[playerid] = 1;
	}

	printf("Name: %s | Platform: %d | IP: %s", sendername, Platform[playerid], ipsget[playerid]);	

	AuthTimeFix[playerid] = KillTimer(AuthTimeFix[playerid]);
	AuthTimeFix[playerid] = SetTimerEx("FixAuth", FIX_AUTH_TIME, 0, "i", playerid);	
	return 1;
}

public OnPlayerDisconnect(playerid, reason)
{
	AD_OnPlayerDisconnect(playerid, reason);
	// удаляем игрока из чит-панели
	DeletePlayerCheaterPanel(playerid);
	// прячем чит-панельку
	HidePlayerCheaterPanel(playerid);

	SetPlayerInt(playerid, "isOnline", 0);
	if(IsPlayerNPC(playerid)) {
		Iter_Remove(NPC, playerid);
		return 1;
	}

	if(GetPVarInt(playerid, "weapon_hack") == 1)
	{
		DelGuns(playerid);
	}
	if(PlayerArea[playerid] == false) {

	GetPlayerWeaponData(playerid, 2, PlayerInfo[playerid][slot_2_gun], PlayerInfo[playerid][slot_2_ammo]);
	GetPlayerWeaponData(playerid, 3, PlayerInfo[playerid][slot_3_gun], PlayerInfo[playerid][slot_3_ammo]);
	GetPlayerWeaponData(playerid, 4, PlayerInfo[playerid][slot_4_gun], PlayerInfo[playerid][slot_4_ammo]);
	GetPlayerWeaponData(playerid, 5, PlayerInfo[playerid][slot_5_gun], PlayerInfo[playerid][slot_5_ammo]);
	GetPlayerWeaponData(playerid, 8, PlayerInfo[playerid][slot_8_gun], PlayerInfo[playerid][slot_8_ammo]);

	SetPlayerInt(playerid, "slot_2_gun", PlayerInfo[playerid][slot_2_gun]);
	SetPlayerInt(playerid, "slot_3_gun", PlayerInfo[playerid][slot_3_gun]);
	SetPlayerInt(playerid, "slot_4_gun", PlayerInfo[playerid][slot_4_gun]);
	SetPlayerInt(playerid, "slot_5_gun", PlayerInfo[playerid][slot_5_gun]);
	SetPlayerInt(playerid, "slot_8_gun", PlayerInfo[playerid][slot_8_gun]);

	SetPlayerInt(playerid, "slot_2_ammo", PlayerInfo[playerid][slot_2_ammo]);
	SetPlayerInt(playerid, "slot_3_ammo", PlayerInfo[playerid][slot_3_ammo]);
	SetPlayerInt(playerid, "slot_4_ammo", PlayerInfo[playerid][slot_4_ammo]);
	SetPlayerInt(playerid, "slot_5_ammo", PlayerInfo[playerid][slot_5_ammo]);
	SetPlayerInt(playerid, "slot_8_ammo", PlayerInfo[playerid][slot_8_ammo]);
	
	}

	OnArenaDisconnect(playerid);

	//trucker_offline(playerid);
	//race_Disconnect(playerid, reason);

	if(GetPlayerLoging(playerid) == true)
	{
		CallLocalFunction("OnPlayerGameQuit", "i", playerid);

		// kick/ban
		if(reason != 2)
		{
			new 
				Float: pos_x,
				Float: pos_y,
				Float: pos_z,
				Float: angle;

			new 
				interior,
				world;

			if(IsPlayerInAnyVehicle(playerid) && GetPlayerVehicleID(playerid) == caridhouse[playerid])
			{
				// Cохраняем машину
				GetVehiclePos(caridhouse[playerid], pos_x, pos_y, pos_z);
				GetVehicleZAngle(caridhouse[playerid], angle);
				interior = GetPlayerInterior(playerid);
				world = GetPlayerVirtualWorld(playerid);

				mysql_format(database, 
					big_string, sizeof(big_string), 
					"UPDATE `players` SET `Pos_X` = '%f', `Pos_Y` = '%f', `Pos_Z` = '%f', `Angle` = '%f', `Int` = '%f', `World` = '%f', `State` = 'На машине', `LastTime` = CURRENT_TIMESTAMP() WHERE ID = %i LIMIT 1", 
					pos_x, pos_y, pos_z, angle, interior, world, GetPlayerAccountID(playerid)
				);
				mysql_pquery(database, big_string);
			}
			else
			{
				// Сохраняем пешком

				GetPlayerPos(playerid, pos_x, pos_y, pos_z);
				GetPlayerFacingAngle(playerid, angle);
				interior = GetPlayerInterior(playerid);
				world = GetPlayerVirtualWorld(playerid);

				mysql_format(database, 
					big_string, sizeof(big_string), 
					"UPDATE `players` SET `Pos_X` = '%f', `Pos_Y` = '%f', `Pos_Z` = '%f', `Angle` = '%f', `Int` = '%f', `World` = '%f', `State` = 'Пешком', `LastTime` = CURRENT_TIMESTAMP() WHERE ID = %i LIMIT 1", 
					pos_x, pos_y, pos_z, angle, interior, world, GetPlayerAccountID(playerid)
				);
				mysql_pquery(database, big_string);
			}
			printf(big_string);
		}
	}

	if(PlayerInfo[playerid][pSelectedSlot] == 1) {
		if(caridhouse[playerid] != INVALID_VEHICLE_ID) {
			SetPlayerInt(playerid, "Fuel1", GetVehicleFuel(caridhouse[playerid]));
		}	
	} else if(PlayerInfo[playerid][pSelectedSlot] == 2) {
		if(caridhouse[playerid] != INVALID_VEHICLE_ID) {
			SetPlayerInt(playerid, "Fuel2", GetVehicleFuel(caridhouse[playerid]));
		}	
	}
	if(IsValidVehicle(caridhouse[playerid]))
	{
		DestroyVehicle(caridhouse[playerid]);
		caridhouse[playerid] = INVALID_VEHICLE_ID;
	}
	
	SetPlayerInt(playerid, "Online", PlayerInfo[playerid][pOnline]);
	onair_offline(playerid);
	stop_detector(playerid);
	OnPlayerDisconnect_textdraw(playerid);

	if(IsValidDynamicObject(plane[playerid])) DestroyDynamicObject(plane[playerid]);
	new mate = GetPVarInt(playerid, "mate");

	if(mate != -1 && mate != playerid) {
		if(GetPVarInt(mate, "mate") == playerid) {
			SetPVarInt(mate,  "mate", -1);
			SendClientMessage(mate, -1, ""COLOR_RED"Ваш партнер покинул команду");
		}
		SetPVarInt(playerid, "mate", -1);
	}	

	SetPlayerInt(playerid, "Wanted", PlayerInfo[playerid][pWanted]);

	/*
	new Fraction: fractionid = GetPlayerFraction(playerid);
	if(fractionid != FRACTION_NONE) {
		if(uninvitePlayerID[_:fractionid-1] == playerid) {
			KillTimer(uninviteTimer[_:fractionid-1]);
			uninviteFraction[_:fractionid-1] = -1;
			uninvitePlayerID[_:fractionid-1] = INVALID_PLAYER_ID;
			format(small_string, sizeof(small_string), ""COLOR_PEACH"Игрок {FFFFFF}%s[%d]"COLOR_PEACH" не был уволен. Причина: {FFFFFF}Вышел из игры", PlayerInfo[playerid][pName], playerid);
			SendLeadMessage(fractionid, -1, small_string);
		}
	}
	*/

	secure[playerid] = 0;

	gonecar[playerid] = INVALID_VEHICLE_ID;

	SetPVarInt(playerid, "SellingCar", -1);
	CancelOffer(playerid);

	if(cabAvailible[playerid] != 1) cabAvailible[playerid] = 1; // Водитель вышел из такси - удаляем переменную для получения заказа
	if(destinationMark[playerid] != INVALID_DYNAMIC_CP) {
		DestroyDynamicCP(destinationMark[playerid]);
		destinationMark[playerid] = INVALID_DYNAMIC_CP;
	}
	if(cabClient[playerid] != INVALID_PLAYER_ID) cabClient[playerid] = INVALID_PLAYER_ID;
	//CallLocalFunction("Fraction_OnPlayerDisconnect", "ii", playerid, reason);
	CallLocalFunction("Casino_OnPlayerDisconnect", "ii", playerid, reason);
	CallLocalFunction("Gps_OnPlayerDisconnect", "ii", playerid, reason);
	CallLocalFunction("Army_OnPlayerDisconnect", "ii", playerid, reason);
	if(GetPVarInt(playerid,!"OffFrisk") > gettime()) {
		if(GetPVarInt(playerid, "punishf") != 1) {
		DeletePVar(playerid, "OffFrisk"); SetPVarInt(playerid, "punishf", 1);
		if(PlayerInfo[playerid][pJailed] == 0) {
				PlayerInfo[playerid][pJailTime] = 3600;
				PlayerInfo[playerid][pJailed] = 1;
				SetPlayerInt(playerid, "Jailed", PlayerInfo[playerid][pJailed]);
				SetPlayerInt(playerid, "JailTime", PlayerInfo[playerid][pJailTime]);
				PlayerInfo[playerid][pWanted] = 0;
				SetPlayerWanted(playerid, 0);
				SetPlayerInt(playerid, "Wanted", 0);

				PlayerInfo[playerid][pPetard] = 0;
				PlayerInfo[playerid][pGrenade] = 0;
				PlayerInfo[playerid][pDynamite] = 0;
				SetPlayerInt(playerid, "Petard", PlayerInfo[playerid][pPetard]);
				SetPlayerInt(playerid, "Grenade", PlayerInfo[playerid][pGrenade]);
				SetPlayerInt(playerid, "Dynamite", PlayerInfo[playerid][pDynamite]);
				PlayerInfo[playerid][pDrugs] = 0;
				PlayerInfo[playerid][pDrugsSell] = 0;
				PlayerInfo[playerid][pStuff] = 0;
				SetPlayerInt(playerid, "Drugs", PlayerInfo[playerid][pDrugs]);
				SetPlayerInt(playerid, "DrugsSell", PlayerInfo[playerid][pDrugsSell]);
				SetPlayerInt(playerid, "Stuff", PlayerInfo[playerid][pStuff]);
				format(small_string, sizeof(small_string), ""COLOR_RED"Игрок %s вышел при обыске и был отправлен в тюрьму", PlayerInfo[playerid][pName]);
				SendClientMessageToAll(-1, small_string);
			}
		}
	}
	if(GetPVarInt(playerid,!"OffArrest") > gettime() || GetPVarType(playerid, !"cuffed") == PLAYER_VARTYPE_INT) {
		if(GetPVarInt(playerid, "punish") != 1) {
			DeletePVar(playerid, "OffArrest"); SetPVarInt(playerid, "punish", 1);
			if(PlayerInfo[playerid][pJailed] == 0) {
				PlayerInfo[playerid][pJailTime] = PlayerInfo[playerid][pWanted];
				PlayerInfo[playerid][pJailed] = 1;
				SetPlayerInt(playerid, "Jailed", PlayerInfo[playerid][pJailed]);
				SetPlayerInt(playerid, "JailTime", PlayerInfo[playerid][pJailTime]);
				PlayerInfo[playerid][pWanted] = 0;
				SetPlayerWanted(playerid, 0);
				SetPlayerInt(playerid, "Wanted", 0);
				format(small_string, sizeof(small_string), ""COLOR_RED"Игрок %s вышел при аресте и был отправлен в тюрьму", PlayerInfo[playerid][pName]);
				SendClientMessageToAll(-1, small_string);
				
			}
		}
	}
	foreach(new i: Player)
	{
		if(GetPlayerState(i) == PLAYER_STATE_SPECTATING && spectating[i] == playerid)
		{
			StopSpectate(i);
			GameTextForPlayer(i,"~r~Player Offline", 3800, 3);
		}
	}
	Dealer_OnPlayerDisconnect(playerid, reason);
	Porter_OnPlayerDisconnect(playerid, reason);
	if(Player.PatrolCP[playerid] != INVALID_DYNAMIC_CP) {
		DestroyDynamicCP(Player.PatrolCP[playerid]);
		Player.PatrolCP[playerid] = INVALID_DYNAMIC_CP;
	}
	if(Player.MafiaCP[playerid] != INVALID_DYNAMIC_CP) {
		DestroyDynamicCP(Player.MafiaCP[playerid]);
		Player.MafiaCP[playerid] = INVALID_DYNAMIC_CP;
	}
	if(Player.SteelCar[playerid] != INVALID_DYNAMIC_CP) {
		DestroyDynamicCP(Player.SteelCar[playerid]);
		Player.SteelCar[playerid] = INVALID_DYNAMIC_CP;
	}
	if(Player.FarmCP[playerid] != INVALID_DYNAMIC_CP) {
		DestroyDynamicCP(Player.FarmCP[playerid]);
		Player.FarmCP[playerid] = INVALID_DYNAMIC_CP;
	}

	//if(PlayerLogged{playerid} == false || !IsPlayerConnected(playerid)) return  1;
	PreviewElement[playerid] = KillTimer(PreviewElement[playerid]);
	WelcomeCustoms[playerid] = KillTimer(WelcomeCustoms[playerid]);
	PlaneTimer[playerid] = KillTimer(PlaneTimer[playerid]);
	AuthTimeFix[playerid] = KillTimer(AuthTimeFix[playerid]);
	requestt[playerid] = KillTimer(requestt[playerid]);
	vehfixtimer[playerid] = KillTimer(vehfixtimer[playerid]);
	RobTimer[playerid] = KillTimer(RobTimer[playerid]);
	AzinoTimer[playerid] = KillTimer(AzinoTimer[playerid]);
	DrugTimer[playerid] = KillTimer(DrugTimer[playerid]);
	Timer_Speed[playerid] = KillTimer(Timer_Speed[playerid]);
	taxiPayment[playerid] = KillTimer(taxiPayment[playerid]);
	routetimer[playerid] = KillTimer(routetimer[playerid]);
	PlayerTimerID[playerid] = KillTimer(PlayerTimerID[playerid]);
	ReturnTimerID[playerid] = KillTimer(ReturnTimerID[playerid]);
	CopTimerID[playerid] = KillTimer(CopTimerID[playerid]);
	FriskTimer[playerid] = KillTimer(FriskTimer[playerid]);
	BinTimer[playerid] = KillTimer(BinTimer[playerid]);
	LSPDTimer[playerid] = KillTimer(LSPDTimer[playerid]);
	entrance_timer[playerid] = KillTimer(entrance_timer[playerid]);
	ThefStatus[playerid] = 0;
	TheftZone[playerid] = -1;
	if(TimeTCar[playerid] != 0) {
		TimeTCar[playerid] = 0;
		if(PlayerInfo[playerid][pTheftSkill] != 0) {
		PlayerInfo[playerid][pTheftSkill] -= 1;
		SetPlayerInt(playerid, "TheftSkill", PlayerInfo[playerid][pTheftSkill]);
		}
	}
	TCar[playerid] = 0;
	if(IsValidTimer(LeaveTimer[playerid])) KillTimer(LeaveTimer[playerid]),LeaveTimer[playerid] = -1;
	if(IsValidTimer(LawTimer[playerid])) KillTimer(LawTimer[playerid]),LawTimer[playerid] = -1;
	if(Lawyer == playerid) Lawyer = INVALID_PLAYER_ID;

	if(gone[playerid] != -1) {
		gone[playerid] = -1;
		gonecar[playerid] = INVALID_VEHICLE_ID;
	}
	if(player_Patrol[playerid] != -1) {

		if(player_Patrol[playerid] == 0) {
			PATROL_TOWER[0] = 0;
		}
		else if(player_Patrol[playerid] == 1) {
			PATROL_TOWER[1] = 0;
		}
		else if(player_Patrol[playerid] == 2) {
			PATROL_TOWER[2] = 0;
		}
		else if(player_Patrol[playerid] == 3) {
			PATROL_TOWER[3] = 0;
		}
		else if(player_Patrol[playerid] == 4) {
			PATROL_TOWER[4] = 0;
		}
		else if(player_Patrol[playerid] == 5) {
			PATROL_TOWER[5] = 0;
		}
		else if(player_Patrol[playerid] == 6) {
			PATROL_TOWER[6] = 0;
		}
		else if(player_Patrol[playerid] == 7) {
			PATROL_TOWER[7] -= 1;
		}
		else if(player_Patrol[playerid] == 8) {
			PATROL_TOWER[8] -= 1;
		}

		player_Patrol[playerid] = -1;
		PatrolTimer[playerid] = KillTimer(PatrolTimer[playerid]);
		DeletePatrolCP(playerid);
	}

	PlayerInfo[playerid][slot_2_gun] = 0;
	PlayerInfo[playerid][slot_2_ammo] = 0;
	PlayerInfo[playerid][slot_3_gun] = 0;
	PlayerInfo[playerid][slot_3_ammo] = 0;
	PlayerInfo[playerid][slot_4_gun] = 0;
	PlayerInfo[playerid][slot_4_ammo] = 0;
	PlayerInfo[playerid][slot_5_gun] = 0;
	PlayerInfo[playerid][slot_5_ammo] = 0;
	PlayerInfo[playerid][slot_8_gun] = 0;
	PlayerInfo[playerid][slot_8_ammo] = 0;	

	if(carry[playerid] != -1) carry[playerid] = -1;

	SetPlayerWanted(playerid, 0);
	AllAd[GetPVarInt(playerid,"ListAD")][2] = "0";
	return PlayerInfo[playerid] = NULL_PlayerInfo;
}

forward arena_death(playerid);
public arena_death(playerid) {
	return TogglePlayerSpectating(playerid, 1);
}

