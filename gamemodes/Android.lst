		return 0;
	} 

	if(params[0] == EOS) {
		return SendClientMessage(playerid, -1, !"Используйте: /lip [IP Адрес/ID Игрока]");
	}	

	new 
		bool: isSuccess = false,
		ip_address[(16 + 1)];

	if(IsValidIP(params) == 0) {
		new 
			strval_params = strval(params);

		if(strval_params >= 0 && strval_params < 250) {
			if(PlayerLogged{strval_params} == false) {
				return SendClientMessage(playerid, -1, !"Игрок не авторизован.");
			}

			strmid(ip_address, PlayerInfo[strval_params][pIP], 0, MDialog_strlen(PlayerInfo[strval_params][pIP]), (16 + 1));
			isSuccess = true;
		}
	} else {
		strmid(ip_address, params, 0, MDialog_strlen(params), (16 + 1));
		isSuccess = true;
	}

	if(isSuccess == false) {
		return SendClientMessage(playerid, -1, !"Используйте: /lip [IP Адрес/ID Игрока]");
	}

	static 
		string[150 + ((16 + 1) * 3) + 2 + 1];

	mysql_format(database, 
		string, sizeof(string), 
		"SELECT Name, LastDate FROM players WHERE IP = '%e' OR LastIP = '%e' OR RegIP = '%e' GROUP BY Name LIMIT %i;", 
			ip_address, 
			ip_address,
			ip_address,
			(15)
	);
	return mysql_pquery(database, string, "@_ReturnCommandLIP", "is", playerid, ip_address);
}

@_ReturnCommandLIP(playerid, ip[]);
@_ReturnCommandLIP(playerid, ip[]) {
	new rows = cache_get_row_count();

	if(!rows) {
		return SendClientMessage(playerid, -1, !"Аккауны по указанному IP адресу не найдены."); 
	} else {
		static max_string[((15) * (24 + 20) + 50) / 4],
			name[24],
			last_date[20 + 1],
			format_string[24 + 20 + 1];

		max_string = !"Ник\tДата последнего входа\n""{FFFFFF}""";

		for(new i = 0; i < rows; i++) {
			cache_get_field_content(i, "Name", name);
			cache_get_field_content(i, "LastDate", last_date);

			format(format_string, sizeof(format_string), "%s\t%s\n", name, last_date);
			strcat(max_string, format_string);
		}

		static 
			dialog_header[30 + (16 + 1) + 1];

		format(dialog_header, sizeof(dialog_header), """{4eb9e6}""Поиск по IP %s (%i)", ip, rows);
		return MDialog_ShowPlayerDialog(playerid, 4785, 5, dialog_header, max_string, "Закрыть", "");
	}
}



