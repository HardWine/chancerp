CMD:promo(playerid, params[]) {
	return Dialog_Show(playerid, Dialog:DIALOG_INPUT_PROMO);
}

DialogCreate:DIALOG_INPUT_PROMO(playerid) {
	return Dialog_Open(playerid, Dialog:DIALOG_INPUT_PROMO, DIALOG_STYLE_INPUT,
		"Промокод",
		"Введите промокод для продолжения",
		"Далее", "Закрыть"
	);
}

DialogResponse:DIALOG_INPUT_PROMO(playerid, response, listitem, inputtext[]) {
	if(!response) {
	
	} else {
		mysql_format(database, big_string, sizeof(big_string),
			"SELECT `ID`, `Sum`, CONVERT(Status, SIGNED) AS Status, CONVERT(Ma, SIGNED) AS Ma FROM `promocode` WHERE `Code` = '%e' LIMIT 1;",
				inputtext
		);
		mysql_query(database, big_string, true);

		new
			rows = cache_get_row_count();

		if(rows == 0) {
			return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Введен неверный промокод");
		} else {
			new
				Status = cache_get_field_content_int(0, "Status"),
				Ma = cache_get_field_content_int(0, "Ma");

			if(Status == 2 && Ma == 2) {
				return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Промокод уже активирован");
			} 

			if(Ma == 1 && PlayerInfo[playerid][pHours] > 6)
				return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Данный промокод работает только для новичков!");

			new
				id = cache_get_field_content_int(0, "ID"),
				sum = cache_get_field_content_int(0, "Sum");
			// Проверяем, вводил ли пользователь этот промокод ранее

			mysql_format(database, big_string, sizeof(big_string),
				"SELECT `ID` FROM `player_promocode` WHERE `PlayerID` = %i AND `PromoID` = %i LIMIT 1",
					GetPlayerAccountID(playerid),
					id
			);
			mysql_query(database, big_string, true);

			rows = cache_get_row_count();

			if(rows != 0) {
				return SendClientMessage(playerid, -1, ""COLOR_ORANGE"Вы уже активировали этот промокод ранее");
			} else {
				AddPlayerEXP(playerid, sum, "Активация промокода %s", inputtext);

				format(small_string, sizeof(small_string), ""COLOR_WHITE"Вы активировали промокод на "COLOR_GREEN"%i EXP", sum);
				SendClientMessage(playerid, -1, small_string);

				if(Ma != 1) {
					format(small_string, sizeof(small_string),
						"UPDATE `promocode` SET Status=2 WHERE ID = %i LIMIT 1;",
							id
					);
					mysql_pquery(database, small_string);
				}
				format(small_string, sizeof(small_string),
					"INSERT INTO `player_promocode`(`PlayerID`, `PromoID`, `Sum`) VALUES (%i, %i, %i)",
						GetPlayerAccountID(playerid),
						id,
						sum
				);
				mysql_pquery(database, small_string);
				return 1;
			}
		}
	}
	return 1;
}

CMD:fix(playerid) {
	if(status_bin == 0 && IsPlayerInRangeOfPoint(playerid, 2, -2119.323730, 721.934997, 69.004051)) {
		callcmd::me(playerid, "убирает мусор");
		if(IsValidDynamic3DTextLabel(text_trash)) {
			DestroyDynamic3DTextLabel(text_trash);
		}
		if(IsValidDynamicObject(bin)) {
			DestroyDynamicObject(bin);
		}
		if(IsValidDynamicObject(trash)) {
			DestroyDynamicObject(trash);
		}
		bin = CreateDynamicObject(1330, -2119.323730, 721.934997, 69.004051, 0.000000, 0.000000, 0.000000, 0, 0, -1, 300.00, 300.00); 
		status_bin = 1;
		foreach(new i: Player) { 
				if(IsPlayerInRangeOfPoint(i, 100, -2119.323730, 721.934997, 69.004051)) {
				Streamer_Update(i, STREAMER_TYPE_OBJECT);
				Streamer_Update(i, STREAMER_TYPE_3D_TEXT_LABEL);			
			}
		}
	} 
	return 1;
}

