stock Iter_Random_Internal(count, const array[], start, ...)
{
	new
		numArgs,
		rewrite,
		first,
		last;





	#emit LOAD.S.pri   8
	#emit ADD.C        0xFFFFFFF4
	#emit ADDR.alt     24
	#emit STOR.S.alt   first
	#emit XCHG
	#emit ADD
	#emit STOR.S.pri   last
	#emit SHR.C.alt    2
	#emit STOR.S.alt   numArgs

	if (numArgs)
	{
		for (new value, excluded = rewrite = first; excluded != last; excluded += 4)
		{
			#emit LREF.S.pri   excluded
			#emit LOAD.I
			#emit STOR.S.pri   value
			#emit SREF.S.pri   excluded

			if (0 <= value < start && array[value] > value)
			{



				for (new i2 = first, v2; i2 != rewrite; i2 += 4)
				{
					#emit LREF.S.pri   i2
					#emit STOR.S.pri   v2
					if (value < v2)
					{

						do
						{
							#emit LOAD.S.pri   value
							#emit SREF.S.pri   i2
							value = v2;
							i2 += 4;
							#emit LREF.S.pri   i2
							#emit STOR.S.pri   v2
						}
						while (i2 != rewrite);
						#emit LOAD.S.pri   value
						#emit SREF.S.pri   i2
						break;
					}
					else if (value == v2)
					{
						--numArgs;
						rewrite -= 4;
						break;
					}

				}
				rewrite += 4;
			}
			else
			{

				--numArgs;
			}
		}
	}
	if (count <= numArgs)
