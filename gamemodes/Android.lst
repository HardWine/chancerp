			format(small_string, 100, """{4eb9e6}""Поле засеяно. Ваша премия: {FFFFFF}+%d EXP", pay);
			SendClientMessage(playerid, -1, small_string);
			HarvestAmount += 600;
		 	return RouteFarm[playerid] = -1;
		}
	}
	if(RouteTrash[playerid]  == 6) {
